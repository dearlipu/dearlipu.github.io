---
import { readdirSync } from "node:fs";
import { siteConfig } from "../config";
import "../styles/global.css";

interface Props {
  badge?: string;
  title: string;
  description: string;
  imageFolder: string;
  fallbackFolder?: string;
}

const {
  badge = "Project Gallery",
  title,
  description,
  imageFolder,
  fallbackFolder = "projects",
} = Astro.props;

const toImageUrls = (folder: string) => {
  const folderUrl = new URL(`../../public/${folder.replace(/^\/+|\/+$/g, "")}/`, import.meta.url);

  try {
    return readdirSync(folderUrl)
      .filter((file) => /\.(avif|gif|jpe?g|png|webp|svg)$/i.test(file))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
      .map((file) => `/${folder.replace(/^\/+|\/+$/g, "")}/${file}`);
  } catch {
    return [];
  }
};

let galleryImages = toImageUrls(imageFolder);

if (galleryImages.length === 0 && fallbackFolder !== imageFolder) {
  galleryImages = toImageUrls(fallbackFolder);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | {siteConfig.name}</title>
  </head>

  <body>
    <main class="min-h-screen bg-[#05080f] text-white px-6 py-10 sm:px-10 sm:py-14 lg:px-16">
      <div class="mx-auto max-w-7xl">
        <div class="relative overflow-hidden rounded-3xl border border-white/15 bg-gradient-to-br from-[#0b1220] via-[#060b14] to-[#070b12] p-6 shadow-2xl sm:p-9 md:p-12">
          <div class="pointer-events-none absolute -top-16 -left-16 h-44 w-44 rounded-full bg-blue-500/25 blur-3xl"></div>
          <div class="pointer-events-none absolute -bottom-20 -right-16 h-56 w-56 rounded-full bg-indigo-500/25 blur-3xl"></div>

          <a href="/#projects" class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/90 transition hover:bg-white/12">
            <span aria-hidden="true">←</span>
            Back to projects
          </a>

          <p class="mt-6 inline-flex rounded-full border border-blue-400/60 bg-blue-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em] text-blue-200">
            {badge}
          </p>

          <h1 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight text-white sm:text-4xl md:text-5xl">{title}</h1>

          <p class="mt-4 max-w-3xl text-sm leading-relaxed text-slate-200 sm:text-base">{description}</p>
        </div>

        {galleryImages.length > 0 ? (
          <section class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {galleryImages.map((src, index) => (
              <article class="group relative overflow-hidden rounded-2xl border border-white/20 bg-white/5 shadow-xl transition duration-300 hover:-translate-y-1 hover:border-blue-300/70">
                <img
                  src={src}
                  alt={`${title} image ${index + 1}`}
                  class="h-72 w-full object-cover transition duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/5 to-transparent opacity-90"></div>
                <div class="absolute inset-x-4 bottom-4 flex items-end justify-between gap-3">
                  <p class="text-sm font-semibold text-white">Artwork {String(index + 1).padStart(2, "0")}</p>
                  <span class="rounded-full border border-white/25 bg-black/35 px-3 py-1 text-xs text-white/90">Preview</span>
                </div>
              </article>
            ))}
          </section>
        ) : (
          <section class="mt-10 rounded-2xl border border-dashed border-white/35 bg-white/5 p-8 text-center">
            <h2 class="text-xl font-semibold text-white">No images found yet.</h2>
            <p class="mt-2 text-sm text-slate-200">Add images to <code>public/{imageFolder}</code> to show this gallery.</p>
          </section>
        )}
      </div>
    </main>
  </body>
</html>
