---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<header id="header"
  class="fixed top-0 left-0 right-0 z-[999] transition-all duration-300 bg-transparent">

  <!-- MOBILE TOP BAR -->
  <div class="flex md:hidden justify-between items-center px-6 py-4">

    <!-- BRAND (shows only when menu open) -->
    <span id="brandText"
      class="text-sm font-medium text-white opacity-0 transition duration-300">
      @dearlipu
    </span>

    <!-- MENU BUTTON -->
    <button id="menuBtn"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium 
      bg-[#0f172a] text-white shadow-lg transition-all duration-300 z-[1000]">

      Menu

      <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 transition-transform duration-300"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        
        <path id="iconPath"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 5v14M5 12h14" />
      </svg>
    </button>
  </div>


  <!-- BACKDROP (KEEP BLUR) -->
  <div id="menuBackdrop"
    class="fixed inset-0 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition duration-300 z-[998]">
  </div>


  <!-- MENU PANEL -->
  <div id="menuPanel"
    class="fixed top-20 right-4 w-[90%] max-w-sm bg-[#04060a] text-white rounded-3xl p-6 shadow-2xl border border-gray-700 z-[999]
    
    opacity-0 scale-90 translate-y-4 pointer-events-none
    transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] origin-top-right">

    <ul class="text-lg space-y-1">

      <!-- ITEM -->
      <li class="menu-item">
        <a href="#about" class="menu-link flex justify-between items-center">
          Home
          <!-- ICON -->
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#projects" class="menu-link flex justify-between items-center">
          Services
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#experience" class="menu-link flex justify-between items-center">
          Benefits
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#education" class="menu-link flex justify-between items-center">
          Work
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#pricing" class="menu-link flex justify-between items-center">
          Pricing
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#cta" class="menu-link flex justify-between items-center">
          Contact
          <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M17 7l-10 10" />
            <path d="M8 7l9 0l0 9" />
          </svg>
        </a>
      </li>

    </ul>
  </div>


  <!-- DESKTOP NAV -->
  <nav class="hidden md:block max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li><a href="#about" class="text-gray-700 hover:text-black font-medium">About</a></li>
      {hasProjects && <li><a href="#projects" class="text-gray-700 hover:text-black font-medium">Projects</a></li>}
      {hasExperience && <li><a href="#experience" class="text-gray-700 hover:text-black font-medium">Client Work</a></li>}
      {hasEducation && <li><a href="#education" class="text-gray-700 hover:text-black font-medium">Expertise</a></li>}
      <li><a href="#pricing" class="text-gray-700 hover:text-black font-medium">Pricing</a></li>
    </ul>
  </nav>

</header>


<script>
  const btn = document.getElementById("menuBtn");
  const panel = document.getElementById("menuPanel");
  const backdrop = document.getElementById("menuBackdrop");
  const icon = document.getElementById("menuIcon");
  const path = document.getElementById("iconPath");
  const items = document.querySelectorAll(".menu-item");
  const brand = document.getElementById("brandText");

  let open = false;

  function animateItems(show) {
    items.forEach((el, i) => {
      el.style.transition = "all 0.4s ease";
      el.style.transitionDelay = `${i * 60}ms`;

      el.style.opacity = show ? "1" : "0";
      el.style.transform = show ? "translateY(0)" : "translateY(10px)";
    });
  }

  function openMenu() {
    panel.classList.remove("opacity-0","scale-90","translate-y-4","pointer-events-none");
    panel.classList.add("opacity-100","scale-100","translate-y-0");

    backdrop.classList.remove("opacity-0","pointer-events-none");
    backdrop.classList.add("opacity-100");

    // BUTTON STYLE CHANGE
    btn.classList.remove("bg-[#0f172a]", "text-white");
    btn.classList.add("bg-white", "text-black");

    brand.classList.remove("opacity-0");
    brand.classList.add("opacity-100");

    icon.style.transform = "rotate(180deg)";
    path.setAttribute("d","M6 6l12 12M6 18L18 6");

    document.body.style.overflow = "hidden";

    animateItems(true);
    open = true;
  }

  function closeMenu() {
    panel.classList.add("opacity-0","scale-90","translate-y-4","pointer-events-none");
    panel.classList.remove("opacity-100","scale-100","translate-y-0");

    backdrop.classList.add("opacity-0","pointer-events-none");
    backdrop.classList.remove("opacity-100");

    btn.classList.add("bg-[#0f172a]", "text-white");
    btn.classList.remove("bg-white", "text-black");

    brand.classList.add("opacity-0");

    icon.style.transform = "rotate(0deg)";
    path.setAttribute("d","M12 5v14M5 12h14");

    document.body.style.overflow = "";

    animateItems(false);
    open = false;
  }

  btn.addEventListener("click", () => open ? closeMenu() : openMenu());
  backdrop.addEventListener("click", closeMenu);

  document.querySelectorAll(".menu-link").forEach(link => {
    link.addEventListener("click", closeMenu);
  });

  animateItems(false);
</script>


<style>
  .menu-link {
    display: flex;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    transition: all 0.25s ease;
  }

  .menu-link:hover {
    opacity: 0.7;
  }

  .menu-item {
    opacity: 0;
    transform: translateY(10px);
  }

  .arrow {
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .menu-link:hover .arrow {
    transform: translate(4px, -4px);
    opacity: 1;
  }
</style>
