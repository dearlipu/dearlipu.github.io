---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;

// group into pairs
const grouped = [];
for (let i = 0; i < siteConfig.experience.length; i += 2) {
  grouped.push(siteConfig.experience.slice(i, i + 2));
}
---

{
  hasExperience && (
    <section id="experience" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

          <!-- LEFT -->
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Our Benefits.
            </h2>

            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />

            <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
              Get unlimited design work for a simple monthly rate. No hourly billing, no surprises — pause or cancel whenever you need.
            </p>
          </div>

          <!-- RIGHT -->
          <div class="lg:col-span-8">
            <div class="relative">
          
              <!-- CENTER LINE -->
              <div class="absolute left-1/2 top-0 bottom-0 w-[2px] -translate-x-1/2 bg-gray-300"></div>
          
              {siteConfig.experience.map((exp, index) => (
          
                <div class="relative mb-12">
          
                  <!-- ICON -->
                  <div class="absolute left-1/2 -top-3 -translate-x-1/2 z-20">
          
                    <div class="w-7 h-7 flex items-center justify-center rounded-full bg-white shadow">
          
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                        viewBox="0 0 24 24" fill="currentColor"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M4.929 4.929a10 10 0 1 1 14.141 14.141a10 10 0 0 1 -14.14 -14.14m8.071 4.071a1 1 0 1 0 -2 0v2h-2a1 1 0 1 0 0 2h2v2a1 1 0 1 0 2 0v-2h2a1 1 0 1 0 0 -2h-2v-2z" />
                      </svg>
          
                    </div>
          
                  </div>
          
                  <!-- CARD -->
                  <div class="bg-white rounded-xl border border-gray-100 
                              p-5 md:p-6 shadow-sm hover:shadow-md transition-all duration-300
                              max-w-2xl mx-auto">
          
                    <div class="flex justify-between items-start mb-3">
                      <div>
                        <h3 class="text-lg font-semibold text-gray-900">
                          {exp.title}
                        </h3>
                        <p
                          class="text-sm"
                          style={`color: ${siteConfig.accentColor}`}
                        >
                          {exp.company}
                        </p>
                      </div>
          
                      <span class="text-xs text-gray-400">
                        {exp.dateRange}
                      </span>
                    </div>
          
                    <ul class="space-y-2">
                      {exp.bullets.map((bullet) => (
                        <li class="flex items-start">
                          <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3"></span>
                          <span class="text-sm text-gray-600">
                            {bullet}
                          </span>
                        </li>
                      ))}
                    </ul>
          
                  </div>
          
                </div>
          
              ))}
          
            </div>
          </div>

        </div>
      </div>
    </section>
  )
}
