---
import { siteConfig } from "../config";

const experiences = siteConfig.experience || [];
const hasExperience = experiences.length > 0;

const statCards = [
  { label: "Years of practice", value: "7+" },
  { label: "Industries supported", value: "15+" },
  { label: "Designs shipped", value: "500+" },
];
---

{
  hasExperience && (
    <section id="experience" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Experience
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Built through real client work, not theory
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              A premium creative partner should bring both aesthetics and outcomes. This timeline highlights how my work evolved across branding, motion, and content systems.
            </p>

            <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3 lg:grid-cols-1">
              {
                statCards.map((item) => (
                  <div class="rounded-xl border border-gray-200 bg-gradient-to-br from-white to-gray-50 p-3.5 shadow-sm">
                    <p class="text-xl font-bold text-gray-900">{item.value}</p>
                    <p class="text-xs uppercase tracking-[0.14em] text-gray-500">{item.label}</p>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="lg:col-span-8">
            <div class="relative space-y-6 sm:space-y-7">
              {experiences.map((exp, index) => (
                <article class="experience-card group relative overflow-hidden rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition-all duration-300 sm:p-6">
                  <div
                    class="absolute left-0 top-0 h-full w-1.5 rounded-l-2xl"
                    style={`background: linear-gradient(180deg, ${siteConfig.accentColor}, ${siteConfig.accentColor}70)`}
                  ></div>

                  <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div class="pl-3 sm:pl-4">
                      <h3 class="text-xl font-semibold text-gray-900">{exp.title}</h3>
                      <p class="mt-1 text-sm font-medium sm:text-base" style={`color: ${siteConfig.accentColor}`}>{exp.company}</p>
                    </div>

                    <div class="flex items-center gap-2 pl-3 text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 sm:pl-0">
                      <span class="inline-block h-2 w-2 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></span>
                      {exp.dateRange}
                    </div>
                  </div>

                  <ul class="space-y-2.5 pl-3 sm:pl-4">
                    {exp.bullets.map((bullet) => (
                      <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-600 sm:text-base">
                        <span class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-gray-400"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>

                  {index < experiences.length - 1 && (
                    <div class="pointer-events-none absolute -bottom-4 left-1/2 h-8 w-[1px] -translate-x-1/2 bg-gray-200"></div>
                  )}
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .experience-card {
    background-image: radial-gradient(circle at top right, rgba(59, 130, 246, 0.1), transparent 45%);
  }

  .experience-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.09);
    border-color: rgba(148, 163, 184, 0.5);
  }
</style>
