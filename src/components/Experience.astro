---
import { siteConfig } from "../config";

const experiences = siteConfig.experience || [];
const hasExperience = experiences.length > 0;

const trustSignals = ["Strategy-first execution", "Premium visual quality", "Fast and reliable delivery"];
---

{
  hasExperience && (
    <section id="experience" class="relative overflow-hidden px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-slate-50 via-white to-white"></div>
      <div class="pointer-events-none absolute -left-20 top-16 -z-10 h-52 w-52 rounded-full blur-3xl" style={`background-color: ${siteConfig.accentColor}22`}></div>
      <div class="pointer-events-none absolute -right-16 bottom-10 -z-10 h-64 w-64 rounded-full bg-indigo-100/60 blur-3xl"></div>

      <div class="mx-auto max-w-6xl">
        <div class="max-w-4xl">
          <p class="inline-flex items-center rounded-full border border-blue-100 bg-white/80 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700 shadow-sm backdrop-blur">
            Journey & Proof
          </p>

          <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
            A premium creative roadmap built on measurable outcomes
          </h2>

          <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

          <p class="mt-5 text-sm leading-relaxed text-gray-600 sm:text-base md:text-lg">
            This section replaces a typical resume-style list with a clearer service-provider narrative—showing growth, specialization, and the quality standards clients can expect at each stage.
          </p>

          <div class="mt-5 flex flex-wrap gap-2.5">
            {
              trustSignals.map((item) => (
                <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white/90 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-gray-600 shadow-sm">
                  <span class="inline-block h-1.5 w-1.5 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></span>
                  {item}
                </span>
              ))
            }
          </div>
        </div>

        <div class="timeline mt-10 sm:mt-12">
          {experiences.map((exp, index) => (
            <article class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}>
              <div class="timeline-dot" style={`background-color: ${siteConfig.accentColor}; border-color: ${siteConfig.accentColor}`}></div>

              <div class="timeline-card group">
                <div class="timeline-accent" style={`background: linear-gradient(180deg, ${siteConfig.accentColor}, ${siteConfig.accentColor}70)`}></div>

                <div class="relative z-10">
                  <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <h3 class="text-xl font-bold tracking-tight text-gray-900">{exp.title}</h3>
                      <p class="mt-1 text-sm font-medium sm:text-base" style={`color: ${siteConfig.accentColor}`}>{exp.company}</p>
                    </div>
                    <span class="inline-flex w-fit rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-gray-600">
                      {exp.dateRange}
                    </span>
                  </div>

                  <ul class="space-y-2.5">
                    {exp.bullets.map((bullet) => (
                      <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-600 sm:text-base">
                        <span class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-gray-400"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .timeline {
    position: relative;
    display: grid;
    gap: 1.25rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.5rem;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    background: linear-gradient(to bottom, rgba(148, 163, 184, 0.75), rgba(148, 163, 184, 0.15));
  }

  .timeline-item {
    position: relative;
    padding-left: 2rem;
  }

  .timeline-dot {
    position: absolute;
    left: 0;
    top: 1.25rem;
    width: 1rem;
    height: 1rem;
    border: 3px solid;
    border-radius: 9999px;
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.92);
    z-index: 10;
  }

  .timeline-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(226, 232, 240, 0.9);
    border-radius: 1rem;
    background: linear-gradient(155deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.88));
    padding: 1.2rem 1.2rem 1.25rem 1.25rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 32px rgba(15, 23, 42, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .timeline-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.14), transparent 45%);
    pointer-events: none;
  }

  .timeline-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
  }

  .timeline-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 42px rgba(15, 23, 42, 0.11);
    border-color: rgba(148, 163, 184, 0.55);
  }

  @media (min-width: 1024px) {
    .timeline {
      gap: 1.5rem;
    }

    .timeline::before {
      left: 50%;
      transform: translateX(-1px);
    }

    .timeline-item {
      width: calc(50% - 1.5rem);
      padding-left: 0;
    }

    .timeline-item.left {
      justify-self: start;
    }

    .timeline-item.right {
      justify-self: end;
    }

    .timeline-item.left .timeline-dot {
      left: calc(100% + 0.75rem);
    }

    .timeline-item.right .timeline-dot {
      left: -1.75rem;
    }
  }
</style>
