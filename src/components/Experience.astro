---
import { siteConfig } from "../config";

const experiences = siteConfig.experience || [];
const hasExperience = experiences.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="max-w-3xl">
          <p class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
            Professional Journey
          </p>

          <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
            A results-driven creative roadmap
          </h2>

          <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

          <p class="mt-5 text-sm leading-relaxed text-gray-600 sm:text-base">
            Instead of a generic experience list, this roadmap shows how my work has grown from design execution to strategy-led creative systems that improve performance.
          </p>
        </div>

        <div class="timeline mt-10 sm:mt-12">
          {experiences.map((exp, index) => (
            <article class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}>
              <div class="timeline-dot" style={`background-color: ${siteConfig.accentColor}; border-color: ${siteConfig.accentColor}`}></div>

              <div class="timeline-card group">
                <div class="timeline-accent" style={`background: linear-gradient(180deg, ${siteConfig.accentColor}, ${siteConfig.accentColor}70)`}></div>

                <div class="relative z-10">
                  <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <h3 class="text-lg font-bold text-gray-900 sm:text-xl">{exp.title}</h3>
                      <p class="text-sm font-medium sm:text-base" style={`color: ${siteConfig.accentColor}`}>{exp.company}</p>
                    </div>
                    <span class="inline-flex w-fit rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-gray-600">
                      {exp.dateRange}
                    </span>
                  </div>

                  <ul class="space-y-2.5">
                    {exp.bullets.map((bullet) => (
                      <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-600 sm:text-base">
                        <span class="mt-2 inline-block h-1.5 w-1.5 rounded-full bg-gray-400"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .timeline {
    position: relative;
    display: grid;
    gap: 1.25rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.5rem;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    background: linear-gradient(to bottom, rgba(148, 163, 184, 0.6), rgba(148, 163, 184, 0.2));
  }

  .timeline-item {
    position: relative;
    padding-left: 2rem;
  }

  .timeline-dot {
    position: absolute;
    left: 0;
    top: 1.2rem;
    width: 1rem;
    height: 1rem;
    border: 3px solid;
    border-radius: 9999px;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.9);
    z-index: 10;
  }

  .timeline-card {
    position: relative;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    background: linear-gradient(160deg, #ffffff, #f8fafc);
    padding: 1.1rem 1.2rem 1.2rem 1.2rem;
    box-shadow: 0 8px 28px rgba(15, 23, 42, 0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .timeline-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
  }

  .timeline-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
    border-color: rgba(148, 163, 184, 0.55);
  }

  @media (min-width: 1024px) {
    .timeline {
      gap: 1.5rem;
    }

    .timeline::before {
      left: 50%;
      transform: translateX(-1px);
    }

    .timeline-item {
      width: calc(50% - 1.5rem);
      padding-left: 0;
    }

    .timeline-item.left {
      justify-self: start;
    }

    .timeline-item.right {
      justify-self: end;
    }

    .timeline-item.left .timeline-dot {
      left: calc(100% + 0.75rem);
    }

    .timeline-item.right .timeline-dot {
      left: -1.75rem;
    }
  }
</style>
