---
import { siteConfig } from "../config";
---

<section id="contact" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT -->
      <div id="contactLeft" class="lg:col-span-4 flex flex-col">

        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          Let’s Work Together.
        </h2>

        <div class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`} />

        <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
          Let’s build something impactful — brand, website, or content.
        </p>

        <div class="mt-6 image-box rounded-xl overflow-hidden border border-gray-200 shadow-sm">
          <img src="/images/contact.jpg" class="w-full h-full object-cover" />
        </div>

      </div>

      <!-- RIGHT -->
      <div class="lg:col-span-8">

        <form id="contactForm" class="contact-card flex flex-col">

          <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-900">Start a Project</h3>
            <p class="text-sm text-gray-500 mt-1">Continue on WhatsApp</p>
          </div>

          <!-- GRID -->
          <div class="grid sm:grid-cols-2 gap-4">

            <input required type="text" placeholder="Your Name *" class="input" />
            <input required type="email" placeholder="Email *" class="input" />

            <!-- CUSTOM SELECT SERVICE -->
            <div class="custom-select" data-name="service">
              <div class="select-trigger">Project Type *</div>
              <div class="select-options">
                <div data-value="Social Media Design">Social Media Design</div>
                <div data-value="Video Editing">Video Editing</div>
                <div data-value="Branding">Branding</div>
                <div data-value="Print Design">Print Design</div>
              </div>
            </div>

            <!-- CUSTOM SELECT TIMELINE -->
            <div class="custom-select" data-name="timeline">
              <div class="select-trigger">Timeline</div>
              <div class="select-options">
                <div data-value="Urgent (1–3 days)">Urgent (1–3 days)</div>
                <div data-value="1 Week">1 Week</div>
                <div data-value="Flexible">Flexible</div>
              </div>
            </div>

            <!-- CUSTOM SELECT BUDGET -->
            <div class="custom-select sm:col-span-2" data-name="budget">
              <div class="select-trigger">Budget</div>
              <div class="select-options">
                <div data-value="₹1k–₹5k">₹1k–₹5k</div>
                <div data-value="₹5k–₹20k">₹5k–₹20k</div>
                <div data-value="₹20k+">₹20k+</div>
              </div>
            </div>

          </div>

          <textarea required rows="4"
            placeholder="Tell me about your project *"
            class="input textarea mt-4"></textarea>

          <div class="mt-6 flex items-center justify-between">
            <p class="text-xs text-gray-400">I usually reply within a few hours</p>

            <button type="submit" class="btn-primary px-6 py-2 rounded-md font-medium">
              Start Project
            </button>
          </div>

        </form>

      </div>

    </div>
  </div>
</section>

<style>

/* CARD */
.contact-card {
  background: linear-gradient(145deg, #f9fafb, #f3f4f6);
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.04);
}

/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

.textarea {
  border-radius: 16px;
}

/* FOCUS */
.input:focus,
.select-trigger:focus {
  outline: none;
  border: 1px solid var(--accent-color);
  background: #eff6ff;
  box-shadow: 0 0 0 3px rgba(29,78,216,0.15);
}

/* BUTTON */
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background-color: var(--accent-color);
  box-shadow: 0 6px 16px rgba(29,78,216,0.25);
  transform: translateY(-1px);
}

/* CUSTOM SELECT */
.custom-select {
  position: relative;
}

.select-trigger {
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  cursor: pointer;
}

.select-options {
  position: absolute;
  top: 110%;
  width: 100%;
  background: white;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  display: none;
  z-index: 10;
}

.select-options div {
  padding: 12px 16px;
  cursor: pointer;
}

.select-options div:hover {
  background: #eff6ff;
}

.custom-select.active .select-options {
  display: block;
}

/* IMAGE ANIMATION */
.image-box {
  height: 260px;
  animation: floatPro 8s ease-in-out infinite;
}

@keyframes floatPro {
  0% { transform: translateY(0px) scale(1); }
  50% { transform: translateY(-10px) scale(1.02); }
  100% { transform: translateY(0px) scale(1); }
}

</style>

<script>
/* CUSTOM SELECT */
document.querySelectorAll(".custom-select").forEach(select => {
  const trigger = select.querySelector(".select-trigger");
  const options = select.querySelectorAll(".select-options div");

  trigger.addEventListener("click", () => {
    document.querySelectorAll(".custom-select").forEach(s => s.classList.remove("active"));
    select.classList.toggle("active");
  });

  options.forEach(option => {
    option.addEventListener("click", () => {
      trigger.textContent = option.textContent;
      select.dataset.value = option.dataset.value;
      select.classList.remove("active");
    });
  });
});

/* HEIGHT MATCH */
function matchHeight() {
  const left = document.getElementById("contactLeft");
  const form = document.getElementById("contactForm");

  if (window.innerWidth >= 1024) {
    form.style.minHeight = left.offsetHeight + "px";
  } else {
    form.style.minHeight = "auto";
  }
}
window.addEventListener("load", matchHeight);
window.addEventListener("resize", matchHeight);

/* WHATSAPP */
const form = document.getElementById("contactForm");

form.addEventListener("submit", (e) => {
  e.preventDefault();

  const btn = form.querySelector("button");
  btn.disabled = true;
  btn.textContent = "Opening WhatsApp...";

  const name = form.querySelector('input[type="text"]').value;
  const email = form.querySelector('input[type="email"]').value;
  const message = form.querySelector("textarea").value;

  const selects = document.querySelectorAll(".custom-select");

  const service = selects[0].dataset.value || "";
  const timeline = selects[1].dataset.value || "";
  const budget = selects[2].dataset.value || "";

  if (!name || !email || !service) {
    btn.textContent = "Fill required fields";
    btn.disabled = false;
    return;
  }

  const text = `Hi Saurav,

New Project Inquiry

Name: ${name}
Email: ${email}
Project: ${service}
Timeline: ${timeline}
Budget: ${budget}

Details:
${message}`;

  window.open(`https://wa.me/918144991049?text=${encodeURIComponent(text)}`, "_blank");

  form.reset();

  btn.textContent = "Message ready ✓";

  setTimeout(() => {
    btn.textContent = "Start Project";
    btn.disabled = false;
  }, 3000);
});
</script>
