---
import { siteConfig } from "../config";
---

<section id="contact" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4 flex flex-col h-full">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Let’s Work Together.
      </h2>

      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
        Let’s build something impactful — brand, website, or content.
      </p>

      <!-- IMAGE -->
      <div class="mt-6 rounded-xl overflow-hidden border border-gray-200 shadow-sm flex-1">

        <img src="/images/contact.jpg"
          class="w-full h-full object-cover"
          alt="contact" />

      </div>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <form class="bg-gray-50 border border-gray-200 rounded-xl p-5 md:p-6 h-full flex flex-col justify-between">

        <div class="space-y-5">

          <!-- NAME + EMAIL -->
          <div class="grid sm:grid-cols-2 gap-4">

            <input type="text" placeholder="Your Name" class="input" />
            <input type="email" placeholder="Email" class="input" />

          </div>

          <!-- SERVICE -->
          <select class="input">
            <option>Select Service</option>
            <option>Graphic Design</option>
            <option>Video Editing</option>
            <option>Motion Graphics</option>
            <option>Print Design</option>
          </select>

          <!-- MESSAGE -->
          <textarea rows="4" placeholder="Tell me about your project..."
            class="input textarea"></textarea>

        </div>

        <!-- BUTTON -->
        <button type="submit" class="btn-primary mt-6 w-fit px-6 py-2 rounded-md font-medium">
          Start Project
        </button>

      </form>

    </div>

  </div>

</section>

<style>
/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

.textarea {
  border-radius: 16px;
}

.input:focus {
  outline: none;
  border-color: var(--accent-color);
  background: white;
}

/* BUTTON */
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.3s ease;
}

.btn-primary:hover {
  background-color: var(--accent-color);
}
</style>
