---
import { siteConfig } from "../config";
---

<section id="contact" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT -->
      <div class="lg:col-span-4">

        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          Let’s Work Together.
        </h2>

        <div class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`} />

        <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
          Let’s build something impactful — brand, website, or content.
        </p>

      </div>

      <!-- RIGHT -->
      <div class="lg:col-span-8">

        <div class="grid md:grid-cols-2 gap-6">

          <!-- FORM -->
          <form id="contactForm" class="contact-card flex flex-col justify-between">

            <div class="space-y-4">

              <h3 class="text-lg font-semibold text-gray-900">
                Start a Project
              </h3>

              <input required type="text" placeholder="Your Name *" class="input" />
              <input required type="email" placeholder="Email *" class="input" />

              <!-- PROJECT TYPE -->
              <div class="custom-select" data-name="service">
                <div class="select-trigger">Project Type *</div>
                <div class="select-options">
                  <div data-value="Social Media Design">Social Media Design</div>
                  <div data-value="Video Editing">Video Editing</div>
                  <div data-value="Branding">Branding</div>
                  <div data-value="Print Design">Print Design</div>
                </div>
              </div>

              <!-- TIMELINE -->
              <div class="custom-select" data-name="timeline">
                <div class="select-trigger">Timeline</div>
                <div class="select-options">
                  <div data-value="Urgent (1–3 days)">Urgent (1–3 days)</div>
                  <div data-value="1 Week">1 Week</div>
                  <div data-value="Flexible">Flexible</div>
                </div>
              </div>

              <!-- BUDGET -->
              <div class="custom-select" data-name="budget">
                <div class="select-trigger">Budget</div>
                <div class="select-options">
                  <div data-value="₹1k–₹5k">₹1k–₹5k</div>
                  <div data-value="₹5k–₹20k">₹5k–₹20k</div>
                  <div data-value="₹20k+">₹20k+</div>
                </div>
              </div>

              <textarea required rows="3"
                placeholder="Tell me about your project *"
                class="input textarea"></textarea>

            </div>

            <!-- FOOTER -->
            <div class="mt-5">

              <p class="text-xs text-gray-400 mb-3">
                I usually reply within a few hours.
              </p>

              <button type="submit"
                class="btn-primary w-full py-2 rounded-md font-medium">
                Start Project
              </button>

            </div>

          </form>

          <!-- IMAGE -->
          <div id="contactImage"
            class="image-box rounded-xl overflow-hidden border border-gray-200 shadow-sm">
            <img src="/images/contact.jpg" class="w-full h-full object-cover" />
          </div>

        </div>

      </div>

    </div>
  </div>
</section>

<style>

/* CARD */
.contact-card {
  background: linear-gradient(145deg, #f9fafb, #f3f4f6);
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 20px;
}

/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

.textarea {
  border-radius: 16px;
}

/* FOCUS */
.input:focus,
.select-trigger.active {
  outline: none;
  border: 1px solid var(--accent-color);
  background: #eff6ff;
  box-shadow: 0 0 0 3px rgba(29,78,216,0.15);
}

/* BUTTON */
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background-color: var(--accent-color);
}

/* SELECT */
.custom-select {
  position: relative;
}

.select-trigger {
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  cursor: pointer;
}

.select-options {
  position: absolute;
  top: 110%;
  width: 100%;
  background: #eff6ff;
  border-radius: 12px;
  border: 1px solid var(--accent-color);
  display: none;
  z-index: 10;
}

.select-options div {
  padding: 12px 16px;
}

.select-options div:hover {
  background: rgba(29,78,216,0.1);
}

.custom-select.active .select-options {
  display: block;
}

/* IMAGE (camera rig feel) */
.image-box {
  min-height: 100%;
  position: relative;
  overflow: hidden;
}

.image-box img {
  transition: transform 8s ease-in-out;
  transform: scale(1.05);
}

.image-box:hover img {
  transform: scale(1.12) translateY(-5px);
}

/* subtle auto movement */
@keyframes cinematic {
  0% { transform: scale(1.05) translateY(0px); }
  50% { transform: scale(1.08) translateY(-6px); }
  100% { transform: scale(1.05) translateY(0px); }
}

.image-box img {
  animation: cinematic 12s ease-in-out infinite;
}

/* MOBILE FIX */
@media (max-width: 768px) {
  #contact .grid {
    grid-template-columns: 1fr !important;
  }

  .image-box {
    height: 220px;
    order: -1; /* image on top */
  }
}

</style>

<script>
/* SELECT */
document.querySelectorAll(".custom-select").forEach(select => {
  const trigger = select.querySelector(".select-trigger");
  const options = select.querySelectorAll(".select-options div");

  trigger.addEventListener("click", () => {
    document.querySelectorAll(".custom-select").forEach(s => s.classList.remove("active"));
    select.classList.toggle("active");
    trigger.classList.add("active");
  });

  options.forEach(option => {
    option.addEventListener("click", () => {
      trigger.textContent = option.textContent;
      select.dataset.value = option.dataset.value;
      select.classList.remove("active");
      trigger.classList.remove("active");
    });
  });
});

/* HEIGHT MATCH */
function matchHeight() {
  const form = document.getElementById("contactForm");
  const image = document.getElementById("contactImage");

  if (window.innerWidth >= 768) {
    image.style.height = form.offsetHeight + "px";
  } else {
    image.style.height = "220px";
  }
}

window.addEventListener("load", matchHeight);
window.addEventListener("resize", matchHeight);

/* WHATSAPP */
const form = document.getElementById("contactForm");

form.addEventListener("submit", (e) => {
  e.preventDefault();

  const name = form.querySelector('input[type="text"]').value;
  const email = form.querySelector('input[type="email"]').value;
  const message = form.querySelector("textarea").value;

  const selects = document.querySelectorAll(".custom-select");
  const service = selects[0].dataset.value || "";
  const timeline = selects[1].dataset.value || "";
  const budget = selects[2].dataset.value || "";

  const text = `Hi Saurav,

New Project Inquiry

Name: ${name}
Email: ${email}
Project: ${service}
Timeline: ${timeline}
Budget: ${budget}

Details:
${message}`;

  window.open(`https://wa.me/918144991049?text=${encodeURIComponent(text)}`);
});
</script>
