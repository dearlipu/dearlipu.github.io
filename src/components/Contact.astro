---
import { siteConfig } from "../config";
---

<section id="contact" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT -->
      <div class="lg:col-span-4">

        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          Let’s Work Together.
        </h2>

        <div class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`} />

        <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
          Let’s build something impactful — brand, website, or content.
        </p>

        <!-- IMAGE -->
        <div class="mt-6 rounded-xl overflow-hidden border border-gray-200 shadow-sm image-box">
          <img src="/images/contact.jpg" class="w-full h-full object-cover" />
        </div>

      </div>

      <!-- RIGHT (NEW CARD GRID LIKE TESTIMONIAL) -->
      <div class="lg:col-span-8">

        <div class="grid md:grid-cols-2 gap-6">

          <!-- FORM CARD -->
          <div class="contact-card">

            <h3 class="text-lg font-semibold text-gray-900 mb-4">
              Start a Project
            </h3>

            <form id="contactForm" class="space-y-4">

              <input required type="text" placeholder="Your Name *" class="input" />
              <input required type="email" placeholder="Email *" class="input" />

              <!-- SELECT -->
              <div class="custom-select" data-name="service">
                <div class="select-trigger">Project Type *</div>
                <div class="select-options">
                  <div data-value="Social Media Design">Social Media Design</div>
                  <div data-value="Video Editing">Video Editing</div>
                  <div data-value="Branding">Branding</div>
                  <div data-value="Print Design">Print Design</div>
                </div>
              </div>

              <div class="custom-select" data-name="budget">
                <div class="select-trigger">Budget</div>
                <div class="select-options">
                  <div data-value="₹1k–₹5k">₹1k–₹5k</div>
                  <div data-value="₹5k–₹20k">₹5k–₹20k</div>
                  <div data-value="₹20k+">₹20k+</div>
                </div>
              </div>

              <textarea required rows="3"
                placeholder="Tell me about your project *"
                class="input textarea"></textarea>

              <button type="submit"
                class="btn-primary w-full py-2 rounded-md font-medium">
                Start Project
              </button>

            </form>

          </div>

          <!-- TRUST CARD (LIKE YOUR DARK TESTIMONIAL) -->
          <div class="trust-card">

            <h3 class="text-white text-lg font-semibold">
              Fast Response ⚡
            </h3>

            <p class="text-gray-300 text-sm mt-2">
              I usually reply within a few hours.  
              Clear communication. No delays.
            </p>

            <div class="mt-6">
              <p class="text-white font-semibold text-sm">4.9/5 Rating</p>
              <p class="text-gray-400 text-xs mt-1">
                Trusted by 100+ clients
              </p>
            </div>

            <!-- CTA -->
            <a href="https://wa.me/918144991049"
              target="_blank"
              class="inline-block mt-6 bg-white text-black px-4 py-2 rounded-md text-sm font-medium hover:opacity-90 transition">
              Chat Directly
            </a>

          </div>

        </div>

      </div>

    </div>
  </div>
</section>

<style>

/* FORM CARD */
.contact-card {
  background: linear-gradient(145deg, #f9fafb, #f3f4f6);
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 20px;
}

/* TRUST CARD */
.trust-card {
  background: #0f172a;
  border-radius: 16px;
  padding: 20px;
}

/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

.textarea {
  border-radius: 16px;
}

/* FOCUS */
.input:focus,
.select-trigger.active {
  outline: none;
  border: 1px solid var(--accent-color);
  background: #eff6ff;
  box-shadow: 0 0 0 3px rgba(29,78,216,0.15);
}

/* BUTTON */
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background-color: var(--accent-color);
}

/* SELECT */
.custom-select {
  position: relative;
}

.select-trigger {
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  cursor: pointer;
}

.select-options {
  position: absolute;
  top: 110%;
  width: 100%;
  background: #eff6ff;
  border-radius: 12px;
  border: 1px solid var(--accent-color);
  display: none;
  z-index: 10;
}

.select-options div {
  padding: 12px 16px;
}

.select-options div:hover {
  background: rgba(29,78,216,0.1);
}

.custom-select.active .select-options {
  display: block;
}

/* IMAGE */
.image-box {
  height: 240px;
  animation: float 8s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
  100% { transform: translateY(0); }
}

</style>

<script>
/* SELECT */
document.querySelectorAll(".custom-select").forEach(select => {
  const trigger = select.querySelector(".select-trigger");
  const options = select.querySelectorAll(".select-options div");

  trigger.addEventListener("click", () => {
    document.querySelectorAll(".custom-select").forEach(s => s.classList.remove("active"));
    select.classList.toggle("active");
    trigger.classList.add("active");
  });

  options.forEach(option => {
    option.addEventListener("click", () => {
      trigger.textContent = option.textContent;
      select.dataset.value = option.dataset.value;
      select.classList.remove("active");
      trigger.classList.remove("active");
    });
  });
});

/* WHATSAPP */
const form = document.getElementById("contactForm");

form.addEventListener("submit", (e) => {
  e.preventDefault();

  const name = form.querySelector('input[type="text"]').value;
  const email = form.querySelector('input[type="email"]').value;
  const message = form.querySelector("textarea").value;

  const selects = document.querySelectorAll(".custom-select");
  const service = selects[0].dataset.value || "";
  const budget = selects[1].dataset.value || "";

  const text = `Hi Saurav,

New Project Inquiry

Name: ${name}
Email: ${email}
Project: ${service}
Budget: ${budget}

Details:
${message}`;

  window.open(`https://wa.me/918144991049?text=${encodeURIComponent(text)}`);
});
</script>
