---
import { siteConfig } from "../config";
---

<section id="contact" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

    <!-- LEFT -->
    <div id="contactLeft" class="lg:col-span-4 flex flex-col">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900 leading-tight">
        Let’s Work Together.
      </h2>

      <div class="w-[75px] h-[5px] mt-3 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}></div>

      <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
        Let’s build something impactful — brand, website, or content.
      </p>

      <!-- IMAGE -->
      <div class="mt-6 rounded-xl overflow-hidden border border-gray-200 shadow-sm image-box">

        <img src="/images/contact.jpg"
          class="w-full h-full object-cover"
          alt="contact" />

      </div>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <form id="contactForm" class="contact-card flex flex-col">

        <!-- HEADER -->
        <div class="mb-6">
          <h3 class="text-xl font-semibold text-gray-900">
            Start a Project
          </h3>
          <p class="text-sm text-gray-500 mt-1">
            Fill details to continue on WhatsApp
          </p>
        </div>

        <!-- FIELDS -->
        <div class="grid sm:grid-cols-2 gap-4">

          <input required type="text" placeholder="Your Name *" class="input" />
          <input required type="email" placeholder="Email *" class="input" />

          <!-- PROJECT TYPE -->
          <select required class="input select">
            <option disabled selected>Project Type *</option>
            <option>Social Media Design</option>
            <option>Video Editing</option>
            <option>Branding</option>
            <option>Print Design</option>
          </select>

          <!-- TIMELINE -->
          <select class="input select">
            <option disabled selected>Timeline</option>
            <option>Urgent (1–3 days)</option>
            <option>1 Week</option>
            <option>Flexible</option>
          </select>

        </div>

        <!-- MESSAGE -->
        <textarea required rows="4"
          placeholder="Tell me about your project *"
          class="input textarea mt-4"></textarea>

        <!-- FOOTER -->
        <div class="mt-6 flex items-center justify-between">

          <p class="text-xs text-gray-400">
            I usually reply within a few hours
          </p>

          <button type="submit"
            class="btn-primary px-6 py-2 rounded-md font-medium">
            Start Project
          </button>

        </div>

      </form>

    </div>

  </div>

</section>

<style>

/* CARD */
.contact-card {
  background: linear-gradient(145deg, #f9fafb, #f3f4f6);
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.04);
}

/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

/* TEXTAREA */
.textarea {
  border-radius: 16px;
}

/* FOCUS FIX (premium) */
.input:focus {
  outline: none;
  border-color: var(--accent-color);
  background: #f1f5f9;
  box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.12);
}

/* REMOVE DEFAULT SELECT UI */
.select {
  appearance: none;
  background-image: none;
  cursor: pointer;
}

/* BUTTON (same feel as pricing) */
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background-color: var(--accent-color);
  color: white;
  box-shadow: 0 6px 16px rgba(29, 78, 216, 0.25);
  transform: translateY(-1px);
}

/* IMAGE ANIMATION */
.image-box {
  height: 280px;
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-6px); }
  100% { transform: translateY(0px); }
}

</style>

<script>
const form = document.getElementById("contactForm");

form.addEventListener("submit", (e) => {
  e.preventDefault();

  const btn = form.querySelector("button");
  btn.disabled = true;
  btn.textContent = "Opening WhatsApp...";

  const name = form.querySelector('input[type="text"]').value.trim();
  const email = form.querySelector('input[type="email"]').value.trim();
  const service = form.querySelectorAll("select")[0].value;
  const timeline = form.querySelectorAll("select")[1].value;
  const message = form.querySelector("textarea").value.trim();

  if (!name || !email || service.includes("Project")) {
    btn.textContent = "Fill required fields";
    btn.disabled = false;
    return;
  }

  const text = `Hi Saurav,

New Project Inquiry

Name: ${name}
Email: ${email}
Project: ${service}
Timeline: ${timeline || "Not specified"}

Details:
${message}

Let’s discuss further.`;

  const url = `https://wa.me/918144991049?text=${encodeURIComponent(text)}`;

  window.open(url, "_blank");

  form.reset();

  btn.textContent = "Message ready ✓";

  setTimeout(() => {
    btn.textContent = "Start Project";
    btn.disabled = false;
  }, 3000);
});
</script>
