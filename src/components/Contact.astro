---
import { siteConfig } from "../config";
---

<section id="contact" class="section-anchor bg-white py-18 sm:py-22">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-start">
      <div>
        <p class="section-eyebrow">Contact</p>
        <h2 class="section-title mt-5 max-w-xl">Tell me what you need, and I’ll send the right plan.</h2>
        <p class="mt-5 max-w-lg text-base leading-relaxed text-gray-600">
          Share your goals, timeline, and deliverables. I’ll reply with a focused approach, clear scope, and next steps.
        </p>
        <div class="mt-8 space-y-2 text-sm text-gray-700">
          <p>Email: <a class="font-semibold text-indigo-600" href={`mailto:${siteConfig.social.email}`}>{siteConfig.social.email}</a></p>
          <p>
            WhatsApp:
            <a class="font-semibold text-indigo-600" href={`https://wa.me/${siteConfig.social.whatsapp}`} target="_blank" rel="noopener noreferrer">
              +{siteConfig.social.whatsapp}
            </a>
          </p>
        </div>
      </div>

      <form class="rounded-3xl border border-gray-200 bg-gray-50 p-6 shadow-[0_12px_28px_rgba(15,23,42,0.06)]" action={`mailto:${siteConfig.social.email}`} method="post" enctype="text/plain">
        <div class="grid gap-4">
          <label class="text-sm font-medium text-gray-700" for="name">Name</label>
          <input id="name" name="name" required class="rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-indigo-500 focus:outline-none" />

          <label class="text-sm font-medium text-gray-700" for="email">Email</label>
          <input id="email" name="email" type="email" required class="rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-indigo-500 focus:outline-none" />

          <label class="text-sm font-medium text-gray-700" for="service">Service</label>
          <select id="service" name="service" class="rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-indigo-500 focus:outline-none">
            <option>Graphic Design</option>
            <option>Video Editing</option>
            <option>Motion Graphics</option>
            <option>Mixed Package</option>
          </select>

          <label class="text-sm font-medium text-gray-700" for="message">Project details</label>
          <textarea id="message" name="message" rows="4" required class="rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm focus:border-indigo-500 focus:outline-none"></textarea>
        </div>

        <button type="submit" class="mt-6 w-full rounded-full bg-gray-900 px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-indigo-600">
          Start a Project
        </button>
      </form>
    </div>
  </div>
</section>
