---
import { siteConfig } from "../config";

const whatsappNumber = siteConfig.social.whatsapp;
---

<section id="contact" class="px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-4">
        <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
          Contact
        </p>

        <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
          Let’s build your next visual project
        </h2>

        <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

        <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
          Share a few details below. I’ll respond with the best approach, timeline, and pricing options for your goal.
        </p>

        <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
          <p class="text-sm font-semibold text-gray-900">Quick response time</p>
          <p class="mt-1 text-sm text-gray-600">Usually within a few hours on business days.</p>
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <form id="contactForm" class="contact-card" novalidate data-whatsapp={whatsappNumber}>
            <h3 class="text-lg font-semibold text-gray-900">Start your project inquiry</h3>
            <p class="mt-1 text-sm text-gray-500">Fields marked with * are required.</p>

            <div class="mt-5 space-y-4">
              <div>
                <label for="name" class="field-label">Your Name *</label>
                <input id="name" name="name" required autocomplete="name" placeholder="e.g., John Smith" class="input" />
              </div>

              <div>
                <label for="email" class="field-label">Email *</label>
                <input id="email" name="email" type="email" required autocomplete="email" placeholder="e.g., john@email.com" class="input" />
              </div>

              <div>
                <label for="projectType" class="field-label">Project Type *</label>
                <select id="projectType" name="projectType" required class="input select-input">
                  <option value="">Select your project type</option>
                  <option>Social Media Design</option>
                  <option>Video Editing (YouTube / Reels)</option>
                  <option>Motion Graphics & Animation</option>
                  <option>Branding & Visual Identity</option>
                  <option>Print Design (Posters, Flyers)</option>
                  <option>Not sure (Need guidance)</option>
                  <option>Other (Custom Request)</option>
                </select>
              </div>

              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                  <label for="timeline" class="field-label">Timeline</label>
                  <select id="timeline" name="timeline" class="input select-input">
                    <option value="">Choose timeline</option>
                    <option>Urgent (1–3 days)</option>
                    <option>Standard (4–7 days)</option>
                    <option>Extended (1–2 weeks)</option>
                    <option>Flexible / No deadline</option>
                  </select>
                </div>

                <div>
                  <label for="budget" class="field-label">Budget</label>
                  <select id="budget" name="budget" class="input select-input">
                    <option value="">Choose budget range</option>
                    <option>₹1k–₹3k (Basic)</option>
                    <option>₹3k–₹10k (Standard)</option>
                    <option>₹10k–₹25k (Advanced)</option>
                    <option>₹25k+ (Premium)</option>
                    <option>Not sure yet</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="details" class="field-label">Project Details *</label>
                <textarea
                  id="details"
                  name="details"
                  required
                  rows="4"
                  placeholder="Tell me what you need, your style preference, and any reference links."
                  class="input textarea"
                ></textarea>
              </div>
            </div>

            <p id="formError" class="mt-4 hidden rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"></p>

            <button
              type="submit"
              class="btn-primary mt-5 w-full rounded-xl py-3 text-sm font-semibold sm:text-base"
              style={`--accent: ${siteConfig.accentColor}`}
            >
              Continue to WhatsApp
            </button>
          </form>

          <aside class="image-card rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="overflow-hidden rounded-xl">
              <img src="/images/contact.webp" alt="Preview of visual creative workflow" class="contact-image" />
            </div>

            <div class="mt-4 rounded-xl border border-gray-100 bg-gray-50 p-4">
              <p class="text-sm font-semibold text-gray-900">Prefer direct contact?</p>
              <div class="mt-3 flex flex-wrap gap-3">
                <a
                  href={`mailto:${siteConfig.social.email}`}
                  class="quick-link"
                  style={`--accent: ${siteConfig.accentColor}`}
                >
                  {siteConfig.social.email}
                </a>
                <a
                  href={`https://wa.me/${whatsappNumber}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="quick-link"
                  style={`--accent: ${siteConfig.accentColor}`}
                >
                  WhatsApp: +{siteConfig.social.whatsapp.slice(0, 2)} {siteConfig.social.whatsapp.slice(2)}
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(145deg, #ffffff, #f8fafc);
    padding: 1.25rem;
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.05);
  }

  .field-label {
    display: inline-block;
    margin-bottom: 0.35rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #4b5563;
  }

  .input {
    width: 100%;
    border-radius: 0.8rem;
    border: 1px solid #d1d5db;
    background: #fff;
    padding: 0.75rem 0.9rem;
    font-size: 0.95rem;
    color: #111827;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .input::placeholder {
    color: #9ca3af;
  }

  .input:focus {
    outline: none;
    border-color: var(--accent, #1d4ed8);
    box-shadow: 0 0 0 3px rgba(29, 78, 216, 0.12);
  }

  .select-input {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #6b7280 50%),
      linear-gradient(135deg, #6b7280 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px);
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 2.2rem;
  }

  .textarea {
    min-height: 120px;
    resize: vertical;
  }

  .btn-primary {
    border: none;
    background: #0f172a;
    color: #fff;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: var(--accent);
    transform: translateY(-1px);
  }

  .image-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100%;
  }

  .contact-image {
    height: 100%;
    min-height: 260px;
    width: 100%;
    object-fit: cover;
  }

  .quick-link {
    border-radius: 999px;
    border: 2px solid #d1d5db;
    background: #fff;
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #374151;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .quick-link:hover,
  .quick-link:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 768px) {
    .contact-image {
      min-height: 220px;
    }
  }
</style>

<script>
  const contactForm = document.getElementById("contactForm");
  const formError = document.getElementById("formError");

  contactForm?.addEventListener("submit", (event) => {
    event.preventDefault();

    const form = event.currentTarget;
    const formData = new FormData(form);

    const name = String(formData.get("name") || "").trim();
    const email = String(formData.get("email") || "").trim();
    const projectType = String(formData.get("projectType") || "").trim();
    const timeline = String(formData.get("timeline") || "Not specified").trim();
    const budget = String(formData.get("budget") || "Not specified").trim();
    const details = String(formData.get("details") || "").trim();

    if (!name || !email || !projectType || !details) {
      formError.textContent = "Please complete all required fields before continuing.";
      formError.classList.remove("hidden");
      return;
    }

    formError.classList.add("hidden");

    const whatsappNumber = String(form.dataset.whatsapp || "").replace(/\D/g, "");

    if (!whatsappNumber) {
      formError.textContent = "WhatsApp contact is not configured yet. Please use the Email button below.";
      formError.classList.remove("hidden");
      return;
    }

    const plainText = `Hi Saurav,

New Project Inquiry

Name: ${name}
Email: ${email}
Project: ${projectType}
Timeline: ${timeline}
Budget: ${budget}

Details:
${details}`;
    const encodedText = encodeURIComponent(plainText);
    const whatsappWebUrl = `https://api.whatsapp.com/send?phone=${whatsappNumber}&text=${encodedText}`;
    const whatsappAppUrl = `whatsapp://send?phone=${whatsappNumber}&text=${encodedText}`;
    const isMobile = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
    
    if (isMobile) {
      window.location.href = whatsappAppUrl;
    
      setTimeout(() => {
        window.location.href = whatsappWebUrl;
      }, 900);
    
      form.reset();
      return;
    }
    
    const popup = window.open(whatsappWebUrl, "_blank", "noopener,noreferrer");
    if (!popup) {
      formError.textContent = "Please allow pop-ups for this site so WhatsApp can open in a new tab.";
      formError.classList.remove("hidden");
      return;
    }
    
    form.reset();
  });
</script>
