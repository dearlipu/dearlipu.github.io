---
import { siteConfig } from "../config";
---

<section
  id="contact"
  class="p-8 sm:p-12 md:p-16 lg:p-24"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <!-- LEFT -->
      <div class="lg:col-span-4">

        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          Let’s Talk.
        </h2>

        <!-- BLUE BAR -->
        <div
          class="w-[75px] h-[5px] mt-3 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        ></div>

        <p class="mt-4 text-gray-600 text-sm sm:text-base max-w-sm">
          Got questions or ready to start your project? Let’s bring your ideas to life.
        </p>

        <!-- CONTACT CARDS -->
        <div class="mt-8 space-y-4">

          <!-- EMAIL -->
          <div class="bg-[#0b0b0b] border border-gray-800 rounded-xl p-5 shadow-md flex items-start gap-4">

            <!-- SVG -->
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#111] border border-gray-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 7l9 6l9 -6" />
                <path d="M21 7v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" />
              </svg>
            </div>

            <div>
              <p class="text-xs text-gray-400 mb-1">/CHAT TO SALES</p>
              <p class="text-white font-medium break-all">
                {siteConfig.social.email}
              </p>
            </div>

          </div>

          <!-- PHONE -->
          <div class="bg-[#0b0b0b] border border-gray-800 rounded-xl p-5 shadow-md flex items-start gap-4">

            <!-- SVG -->
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-[#111] border border-gray-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 4h4l2 5l-3 2a11 11 0 0 0 5 5l2 -3l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -16 -16a2 2 0 0 1 2 -2" />
              </svg>
            </div>

            <div>
              <p class="text-xs text-gray-400 mb-1">/CALL US</p>
              <p class="text-white font-medium">
                +91 8144991049
              </p>
            </div>

          </div>

        </div>
      </div>

      <!-- RIGHT FORM -->
      <div class="lg:col-span-8">

        <form class="bg-[#0b0b0b] text-white rounded-2xl p-6 sm:p-8 space-y-5 shadow-xl border border-gray-800">

          <!-- NAME -->
          <div>
            <label class="text-sm text-gray-400">Your name*</label>
            <input
              type="text"
              placeholder="Your name"
              class="w-full mt-2 px-4 py-3 rounded-lg bg-[#111] border border-gray-800 focus:outline-none focus:border-[var(--accent-color)] transition"
            />
          </div>

          <!-- EMAIL -->
          <div>
            <label class="text-sm text-gray-400">E-mail*</label>
            <input
              type="email"
              placeholder="Your Email"
              class="w-full mt-2 px-4 py-3 rounded-lg bg-[#111] border border-gray-800 focus:outline-none focus:border-[var(--accent-color)] transition"
            />
          </div>

          <!-- WEBSITE -->
          <div>
            <label class="text-sm text-gray-400">Website</label>
            <input
              type="text"
              placeholder="Your Website"
              class="w-full mt-2 px-4 py-3 rounded-lg bg-[#111] border border-gray-800 focus:outline-none focus:border-[var(--accent-color)] transition"
            />
          </div>

          <!-- MESSAGE -->
          <div>
            <label class="text-sm text-gray-400">Message</label>
            <textarea
              rows="4"
              placeholder="Your Message"
              class="w-full mt-2 px-4 py-3 rounded-lg bg-[#111] border border-gray-800 focus:outline-none focus:border-[var(--accent-color)] transition"
            ></textarea>
          </div>

          <!-- BUTTON -->
          <button
            type="submit"
            class="w-full py-4 rounded-full font-medium text-black transition hover:opacity-90"
            style={`background-color: ${siteConfig.accentColor}`}
          >
            Get in touch
          </button>

        </form>

      </div>

    </div>
  </div>
</section>
