---
import { siteConfig } from "../config";
---

<section id="contact" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white relative overflow-hidden">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

    <!-- LEFT IMAGE -->
    <div class="lg:col-span-5 relative group">

      <div class="relative rounded-2xl overflow-hidden shadow-lg transition-all duration-500 group-hover:scale-[1.02]">
        <img src="/images/contact.jpg" alt="contact"
          class="w-full h-full object-cover" />
      </div>

      <!-- FLOAT DOT -->
      <div 
        class="absolute -top-3 -left-3 w-4 h-4 rounded-full animate-pulse"
        style={`background:${siteConfig.accentColor}`}
      ></div>

    </div>

    <!-- RIGHT FORM -->
    <div class="lg:col-span-7">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
        Let’s Work Together.
      </h2>

      <div
        class="w-[75px] h-[5px] mt-3 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-5 text-sm max-w-md leading-relaxed">
        Let’s build something impactful — brand, website, or content.
      </p>

      <!-- FORM -->
      <form class="mt-8 space-y-5">

        <!-- NAME + EMAIL -->
        <div class="grid sm:grid-cols-2 gap-4">

          <input type="text" placeholder="Your Name"
            class="input" />

          <input type="email" placeholder="Email"
            class="input" />

        </div>

        <!-- SERVICE -->
        <select class="input">
          <option>Select Service</option>
          <option>Graphic Design</option>
          <option>Video Editing</option>
          <option>Motion Graphics</option>
          <option>Print Design</option>
        </select>

        <!-- MESSAGE -->
        <textarea rows="4" placeholder="Tell me about your project..."
          class="input resize-none"></textarea>

        <!-- BUTTON -->
        <button type="submit"
          class="submit-btn group">

          <span>Submit</span>

          <div class="dot"></div>

        </button>

      </form>

    </div>

  </div>

</section>

<style>
/* INPUT */
.input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 999px;
  background: #f3f4f6;
  border: 1px solid transparent;
  font-size: 14px;
  transition: all 0.25s ease;
}

textarea.input {
  border-radius: 16px;
}

.input:focus {
  outline: none;
  border-color: var(--accent-color);
  background: white;
  box-shadow: 0 0 0 3px rgba(0,0,0,0.03);
}

/* BUTTON */
.submit-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 26px;
  border-radius: 999px;
  border: 2px solid var(--accent-color);
  font-weight: 600;
  color: var(--accent-color);
  transition: all 0.3s ease;
  overflow: hidden;
}

.submit-btn:hover {
  background: var(--accent-color);
  color: white;
}

/* DOT ANIMATION */
.submit-btn .dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent-color);
  transition: all 0.3s ease;
}

.submit-btn:hover .dot {
  transform: translateX(6px);
  background: white;
}

/* FLOAT FADE-IN */
section {
  animation: fadeUp 0.8s ease forwards;
  opacity: 0;
}

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
  from {
    opacity: 0;
    transform: translateY(40px);
  }
}
</style>
