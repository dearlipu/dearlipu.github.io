---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-200">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center">

    <!-- LEFT TITLE (ALIGNED WITH OTHER SECTIONS) -->
    <div class="lg:col-span-4">
      <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900">
        Worked with
      </h2>
      <div class="w-[60px] h-[4px] mt-2 bg-blue-600 rounded-full"></div>
    </div>

    <!-- RIGHT LOGOS -->
    <div class="lg:col-span-8 relative overflow-hidden">

      <!-- fade edges -->
      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <!-- track -->
      <div class="marquee-track">

        {brands.map((b) => (
          <img src={b.logo} alt={b.name} class="logo" />
        ))}

        {brands.map((b) => (
          <img src={b.logo} alt={b.name} class="logo" />
        ))}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 40s linear infinite;
}

/* LOGO */
.logo {
  height: 3rem;
  margin-right: 3rem;
  flex-shrink: 0;

  opacity: 0.7;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

/* HOVER EFFECT */
.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.1);
}

/* ANIMATION */
@keyframes scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

/* FADE EDGES */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 4rem;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #f9fafb, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #f9fafb, transparent);
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }
}
</style>
