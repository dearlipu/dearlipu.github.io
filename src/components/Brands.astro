---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-10 bg-gray-50 border-t border-gray-200">

  <div class="w-full flex items-center gap-6 px-6 md:px-16">

    <!-- TEXT -->
    <div class="flex-shrink-0 min-w-[120px]">
      <p class="text-sm text-gray-700 font-semibold">
        Worked with:
      </p>
    </div>

    <!-- LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <div class="marquee-track">

        <!-- repeat MANY times to avoid gap -->
        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 16s linear infinite;
}

/* LOGO */
.logo {
  height: 2.2rem;
  margin-right: 2.5rem;
  opacity: 0.35; /* more transparent */
  flex-shrink: 0;
  transition: all 0.3s ease;
  filter: grayscale(100%);
}

.logo:hover {
  opacity: 0.9;
  filter: grayscale(0%);
  transform: scale(1.08);
}

/* SMOOTH LOOP (no reverse now = cleaner) */
@keyframes scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-25%);
  }
}

/* FADE */
.fade-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to right, #f9fafb, transparent);
  z-index: 10;
}

.fade-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to left, #f9fafb, transparent);
  z-index: 10;
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 1.8rem;
    margin-right: 1.8rem;
  }

  .fade-left,
  .fade-right {
    width: 2rem;
  }
}
</style>
