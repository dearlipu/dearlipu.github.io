---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-20 bg-gray-100 border-t border-gray-200">

  <div>
    <div class="flex items-center gap-6 lg:gap-10">

      <!-- TITLE -->
      <div class="flex-shrink-0 min-w-[140px]">
        <p class="text-base md:text-lg font-bold text-gray-900">
          Worked with:
        </p>
      </div>

      <!-- LOGOS -->
      <div class="relative flex-1 overflow-hidden">

        <div class="fade-left"></div>
        <div class="fade-right"></div>

        <div class="marquee-track">
          {brands.map((b) => <img src={b.logo} class="logo" alt={b.name} />)}
          {brands.map((b) => <img src={b.logo} class="logo" alt={b.name} />)}
        </div>

      </div>

    </div>
  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 28s linear infinite;
}

/* LOGO FIX (same size always) */
.logo {
  height: 32px;              /* FIXED HEIGHT */
  width: auto;
  object-fit: contain;

  margin-right: 40px;
  opacity: 0.5;
  flex-shrink: 0;

  filter: grayscale(100%);
  transition: all 0.3s ease;
}

/* HOVER */
.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.08);
}

/* ANIMATION */
@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* FADE (match footer bg) */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 60px;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #f3f4f6, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #f3f4f6, transparent);
}

/* MOBILE OPTIMIZATION */
@media (max-width: 640px) {

  .logo {
    height: 22px;
    margin-right: 24px;
  }

  .fade-left,
  .fade-right {
    width: 30px;
  }

}
</style>
