---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-200">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center">

    <!-- LEFT -->
    <div class="lg:col-span-4">
      <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900">
        Worked with
      </h2>
      <div class="w-[60px] h-[4px] mt-2 bg-blue-600 rounded-full"></div>
    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <!-- DESKTOP MARQUEE -->
      <div class="hidden sm:block relative overflow-hidden">

        <div class="fade-left"></div>
        <div class="fade-right"></div>

        <div class="marquee-track">
          {brands.map((b) => <img src={b.logo} class="logo" />)}
          {brands.map((b) => <img src={b.logo} class="logo" />)}
        </div>

      </div>

      <!-- MOBILE GRID (LIKE YOUR OLD STYLE) -->
      <div class="grid grid-cols-4 gap-6 sm:hidden mt-6">

        {brands.slice(0, 8).map((b) => (
          <div class="flex justify-center">
            <img src={b.logo} class="logo-mobile" />
          </div>
        ))}

      </div>

    </div>

  </div>

</section>

<style>
/* DESKTOP SCROLL */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 25s linear infinite;
}

.logo {
  height: 3rem;
  margin-right: 3rem;
  opacity: 0.6;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.1);
}

@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* MOBILE STYLE */
.logo-mobile {
  height: 2.2rem;
  opacity: 0.7;
  filter: grayscale(100%);
}

/* FADE */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 4rem;
  height: 100%;
  z-index: 10;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #f9fafb, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #f9fafb, transparent);
}
</style>
