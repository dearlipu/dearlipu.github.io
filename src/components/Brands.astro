---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-16 overflow-hidden">
  <p class="text-center text-sm text-gray-500 uppercase tracking-wider mb-8">
    Trusted by & tools I work with
  </p>

  <div class="relative w-full overflow-hidden">
  
    <div class="scroll-track">
  
      <!-- group 1 -->
      <div class="scroll-group">
        {brands.map((brand) => (
          <img
            src={brand.logo}
            alt={brand.name}
            class="logo"
          />
        ))}
      </div>
  
      <!-- group 2 (duplicate) -->
      <div class="scroll-group">
        {brands.map((brand) => (
          <img
            src={brand.logo}
            alt={brand.name}
            class="logo"
          />
        ))}
      </div>
  
    </div>
  
  </div>
</section>

<style>
.scroll-track {
  display: flex;
  width: max-content;
  will-change: transform;
  animation: scroll 40s linear infinite;
}

.scroll-group {
  display: flex;
  gap: 5rem; /* same spacing */
}

.logo {
  height: 4rem;
  opacity: 0.3;
}

/* KEY FIX */
@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-100%);
  }
}
</style>
