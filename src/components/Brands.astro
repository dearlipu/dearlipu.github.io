---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-16 overflow-hidden">
  <p class="text-center text-sm text-gray-500 uppercase tracking-wider mb-8">
    Trusted by
  </p>

  <div class="overflow-hidden w-full">
  
    <div class="slider">
  
      <!-- group 1 -->
      <div class="slide-track">
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}
      </div>
  
      <!-- group 2 -->
      <div class="slide-track">
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}
      </div>
  
    </div>
  
  </div>
</section>

<style>
.slider {
  overflow: hidden;
  width: 100%;
}

.slide-track {
  display: flex;
  width: calc(200%); /* because duplicated */
  animation: scroll 20s linear infinite;
}

.slide-track img {
  width: 120px; /* adjust */
  margin: 0 20px;
}

@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
</style>
