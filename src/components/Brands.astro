---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="py-4 md:py-6 px-6 md:px-16 bg-gray-50 border-t border-gray-200">

  <!-- SAME AS FOOTER -->
  <div class="mx-auto max-w-6xl flex items-center gap-3 md:gap-8">

    <!-- LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <div class="marquee-track">
        {brands.map((b) => <img src={b.logo} class="logo" alt={b.name} />)}
        {brands.map((b) => <img src={b.logo} class="logo" alt={b.name} />)}
      </div>

    </div>

  </div>

</section>

<style>

/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 35s linear infinite;
}

/* LOGO (FIX SIZE + HOVER COLOR LIKE FOOTER) */
.logo {
  height: 40px;              /* SAME SIZE ALL */
  width: 40px;               /* FORCE CONSISTENT BOX */
  object-fit: contain;

  margin-right: 3.2rem;
  opacity: 0.6;
  flex-shrink: 0;

  filter: grayscale(100%) brightness(0.7);
  transition: all 0.3s ease;
}

/* HOVER = REAL COLOR (LIKE FOOTER ICONS) */
.logo:hover {
  filter: grayscale(0%) brightness(1);
  opacity: 1;
  transform: scale(1.05);
}

/* ANIMATION */
@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* FADE */
.fade-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to right, #f9fafb, transparent);
  z-index: 10;
}

.fade-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to left, #f9fafb, transparent);
  z-index: 10;
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 28px;
    width: 28px;
    margin-right: 2rem;
  }
}

</style>
