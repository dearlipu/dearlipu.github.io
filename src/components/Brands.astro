---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-14 bg-gray-50 border-t border-gray-200">

  <!-- FULL WIDTH -->
  <div class="w-full flex items-center gap-6 px-6 md:px-16">

    <!-- LEFT TEXT (fixed width so it never jumps up) -->
    <div class="flex-shrink-0 min-w-[110px]">
      <p class="text-sm text-gray-600 uppercase tracking-wider">
        Worked with:
      </p>
    </div>

    <!-- RIGHT LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <!-- fade edges -->
      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <div class="marquee-track">

        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}

        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 18s linear infinite alternate;
}

/* LOGOS */
.logo {
  height: 2.5rem;
  margin-right: 3rem;
  opacity: 0.6;
  flex-shrink: 0;
  transition: all 0.3s ease;
  filter: grayscale(100%);
}

.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.08);
}

/* ANIMATION */
@keyframes scroll {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* FADE */
.fade-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 4rem;
  height: 100%;
  background: linear-gradient(to right, #f9fafb, transparent);
  z-index: 10;
}

.fade-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 4rem;
  height: 100%;
  background: linear-gradient(to left, #f9fafb, transparent);
  z-index: 10;
}

/* MOBILE IMPROVEMENT */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }

  .fade-left,
  .fade-right {
    width: 2.5rem;
  }
}
</style>
