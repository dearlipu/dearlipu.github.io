---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-16 bg-gray-50 border-t border-gray-200">

  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center gap-8">

    <!-- LEFT SIDE -->
    <div class="md:w-1/4 w-full">
      <p class="text-sm text-gray-500 uppercase tracking-wider">
        Worked with
      </p>
    </div>

    <!-- RIGHT SIDE -->
    <div class="md:w-3/4 w-full relative overflow-hidden">

      <!-- fade left -->
      <div class="fade-left"></div>

      <!-- fade right -->
      <div class="fade-right"></div>

      <div class="marquee-track">

        <!-- logos -->
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}

        <!-- duplicate for infinite loop -->
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 20s linear infinite alternate;
}

/* LOGO */
.logo {
  height: 3rem;
  margin-right: 4rem;
  opacity: 0.5;
  flex-shrink: 0;
  transition: 0.3s ease;
}

.logo:hover {
  opacity: 1;
  transform: scale(1.05);
}

/* ANIMATION */
@keyframes scroll {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* FADE EFFECT */
.fade-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 5rem;
  height: 100%;
  background: linear-gradient(to right, #f9fafb, transparent);
  z-index: 10;
}

.fade-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 5rem;
  height: 100%;
  background: linear-gradient(to left, #f9fafb, transparent);
  z-index: 10;
}
</style>
