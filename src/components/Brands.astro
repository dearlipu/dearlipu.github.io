---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">

  <div>
    <div class="flex items-center gap-6 lg:gap-10">

      <!-- TEXT -->
      <div class="flex-shrink-0 min-w-[140px]">
        <p class="text-base md:text-lg text-gray-900 font-semibold">
          Worked with:
        </p>
      </div>

      <!-- LOGOS -->
      <div class="relative flex-1 overflow-hidden">

        <div class="fade-left"></div>
        <div class="fade-right"></div>

        <div class="marquee-track">
          {brands.map((b) => <img src={b.logo} class="logo" />)}
          {brands.map((b) => <img src={b.logo} class="logo" />)}
        </div>

      </div>

    </div>
  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 30s linear infinite;
}

/* LOGO */
.logo {
  height: 2.8rem;
  margin-right: 3rem;
  opacity: 0.7;
  flex-shrink: 0;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

/* HOVER (premium feel) */
.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.05);
}

/* ANIMATION */
@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* FADE (match white bg) */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 60px;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #ffffff, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #ffffff, transparent);
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }
}
</style>
