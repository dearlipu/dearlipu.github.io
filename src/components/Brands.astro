---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-16 overflow-hidden">
  <p class="text-center text-sm text-gray-500 uppercase tracking-wider mb-8">
    Trusted by
  </p>

  <div class="overflow-hidden w-full">
  
    <div class="marquee">
  
      <!-- group 1 -->
      <div class="marquee-group">
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}
      </div>
  
      <!-- group 2 -->
      <div class="marquee-group ml-24 md:ml-32">
        {brands.map((brand) => (
          <img src={brand.logo} alt={brand.name} class="logo" />
        ))}
      </div>
  
    </div>
  
  </div>
</section>

<style>
.marquee {
  display: flex;
  width: max-content;
  animation: marquee 40s linear infinite;
}

.marquee-group {
  display: flex;
  align-items: center;
  gap: 6rem; 
}

.logo {
  height: 5rem; 
  opacity: 0.3;
  flex-shrink: 0;
}

@keyframes marquee {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
</style>
