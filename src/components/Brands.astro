---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="py-10 bg-gray-50 border-t border-gray-200">

  <div class="w-full flex items-center gap-8 px-6 md:px-16">

    <!-- TEXT -->
    <div class="flex-shrink-0 min-w-[140px]">
      <p class="text-base md:text-lg text-gray-800 font-bold">
        Worked with:
      </p>
    </div>

    <!-- LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <div class="marquee-track">

        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 30s linear infinite;
}

/* LOGO */
.logo {
  height: 3rem;
  margin-right: 3.2rem;
  opacity: 1;
  flex-shrink: 0;
  filter: grayscale(100%);
}

/* ANIMATION */
@keyframes scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-25%);
  }
}

/* FADE */
.fade-left {
  position: absolute;
  left: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to right, #f9fafb, transparent);
  z-index: 10;
}

.fade-right {
  position: absolute;
  right: 0;
  top: 0;
  width: 3rem;
  height: 100%;
  background: linear-gradient(to left, #f9fafb, transparent);
  z-index: 10;
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }
}
</style>
