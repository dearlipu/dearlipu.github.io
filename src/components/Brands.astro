---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-200">

  <!-- SAME CONTAINER SYSTEM -->
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-6 lg:gap-10">

    <!-- TEXT (PERFECT LEFT ALIGN) -->
    <div class="flex-shrink-0 min-w-[160px]">
      <p class="text-base md:text-lg text-gray-900 font-semibold">
        Worked with:
      </p>
    </div>

    <!-- LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <!-- FADE -->
      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <!-- TRACK -->
      <div class="marquee-track">
        {brands.map((b) => <img src={b.logo} alt={b.name} class="logo" />)}
        {brands.map((b) => <img src={b.logo} alt={b.name} class="logo" />)}
      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 26s linear infinite;
}

/* LOGO */
.logo {
  height: 2.8rem;
  margin-right: 2.8rem;
  opacity: 0.65;
  flex-shrink: 0;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.08);
}

/* ANIMATION */
@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* FADE EDGES */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 4rem;
  height: 100%;
  z-index: 10;
  pointer-events: none;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #f9fafb, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #f9fafb, transparent);
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }
}
</style>
