---
const brands = [
  { name: "YouTube", logo: "/brands/youtube.svg" },
  { name: "Instagram", logo: "/brands/instagram.svg" },
  { name: "Fiverr", logo: "/brands/fiverr.svg" },
  { name: "Adobe", logo: "/brands/adobe.svg" },
  { name: "Canva", logo: "/brands/canva.svg" },
];
---

<section class="py-16 overflow-hidden">
  <p class="text-center text-sm text-gray-500 uppercase tracking-wider mb-8">
    Trusted by & tools I work with
  </p>

  <div class="relative w-full overflow-hidden">
    
    <!-- SCROLL CONTAINER -->
    <div class="flex gap-16 md:gap-20 items-center animate-scroll whitespace-nowrap">
      
      <!-- duplicate for infinite scroll -->
      {[...brands, ...brands].map((brand) => (
        <img
          src={brand.logo}
          alt={brand.name}
          class="h-16 md:h-20 lg:h-24 opacity-30 blur-[0.3px]"
        />
      ))}

    </div>

  </div>
</section>

<style>
@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.animate-scroll {
  display: flex;
  width: max-content;
  animation: scroll 50s linear infinite;
}
</style>
