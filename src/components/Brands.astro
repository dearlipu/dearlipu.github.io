---
const brands = [
  { name: "icon1", logo: "/brands/icon1.svg" },
  { name: "icon2", logo: "/brands/icon2.svg" },
  { name: "icon3", logo: "/brands/icon3.svg" },
  { name: "icon4", logo: "/brands/icon4.svg" },
  { name: "icon5", logo: "/brands/icon5.svg" },
  { name: "icon6", logo: "/brands/icon6.svg" },
  { name: "icon7", logo: "/brands/icon7.svg" },
  { name: "icon8", logo: "/brands/icon8.svg" },
  { name: "icon9", logo: "/brands/icon9.svg" },
];
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-200">

  <!-- FIXED CONTAINER (same as other sections) -->
  <div class="max-w-7xl mx-auto flex items-center gap-8">

    <!-- TEXT -->
    <div class="flex-shrink-0 min-w-[160px]">
      <p class="text-base md:text-lg text-gray-800 font-bold">
        Worked with:
      </p>
      <div class="w-[60px] h-[4px] mt-2 bg-blue-600 rounded-full"></div>
    </div>

    <!-- LOGOS -->
    <div class="relative flex-1 overflow-hidden">

      <div class="fade-left"></div>
      <div class="fade-right"></div>

      <div class="marquee-track">

        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}
        {brands.map((b) => <img src={b.logo} class="logo" />)}

      </div>

    </div>

  </div>

</section>

<style>
/* TRACK */
.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll 28s linear infinite;
}

/* LOGO */
.logo {
  height: 3rem;
  margin-right: 3rem;
  opacity: 0.7;
  flex-shrink: 0;
  filter: grayscale(100%);
  transition: all 0.3s ease;
}

.logo:hover {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.08);
}

/* ANIMATION */
@keyframes scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-30%); }
}

/* FADE */
.fade-left,
.fade-right {
  position: absolute;
  top: 0;
  width: 4rem;
  height: 100%;
  z-index: 10;
}

.fade-left {
  left: 0;
  background: linear-gradient(to right, #f9fafb, transparent);
}

.fade-right {
  right: 0;
  background: linear-gradient(to left, #f9fafb, transparent);
}

/* MOBILE */
@media (max-width: 640px) {
  .logo {
    height: 2rem;
    margin-right: 2rem;
  }

  .max-w-7xl {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
}
</style>
