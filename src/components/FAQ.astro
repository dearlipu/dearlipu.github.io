---
const faqs = [
  {
    q: "How does the subscription model work?",
    a: "You subscribe to a plan and can request unlimited designs. I work on one request at a time and deliver them quickly."
  },
  {
    q: "What kind of design tasks can I request?",
    a: "UI design, branding, social media graphics, thumbnails, landing pages and more."
  },
  {
    q: "How fast will I receive my designs?",
    a: "Most requests are delivered within 24–48 hours depending on complexity."
  },
  {
    q: "What tools do you use?",
    a: "Figma, Notion, and modern async workflows for fast delivery."
  },
  {
    q: "Is there a limit to requests?",
    a: "No limit — I complete them one by one with priority."
  },
  {
    q: "Can I cancel anytime?",
    a: "Yes, you can pause or cancel anytime without lock-in."
  }
];
---

<section class="py-20 md:py-28 bg-[#F9FAFB]">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">

    <!-- LEFT (About-style heading) -->
    <div>
      <h2 class="text-4xl md:text-6xl font-bold text-gray-900">
        FAQs<span class="text-gray-400">.</span>
      </h2>

      <div class="w-[70px] h-[4px] mt-3 rounded-full bg-gray-900"></div>

      <p class="mt-6 text-gray-500 max-w-sm text-sm">
        Everything you need to know about how I work, deliver, and collaborate.
      </p>
    </div>

    <!-- RIGHT (Accordion) -->
    <div class="space-y-4">
      {faqs.map((item, i) => (
        <div class="faq-item group border border-gray-200 rounded-2xl bg-white transition-all duration-300">

          <button
            class="faq-btn w-full flex items-center justify-between p-5 text-left"
            data-index={i}
          >
            <span class="text-gray-800 font-medium">
              {item.q}
            </span>

            <span class="faq-icon transition-transform duration-300">
              +
            </span>
          </button>

          <div
            class="faq-content px-5 text-sm text-gray-600 overflow-hidden max-h-0 transition-all duration-300"
            id={`faq-${i}`}
          >
            <div class="pb-5 pt-1">
              {item.a}
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script>
  let activeIndex = null;

  document.querySelectorAll(".faq-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const index = btn.dataset.index;
      const content = document.getElementById(`faq-${index}`);
      const icon = btn.querySelector(".faq-icon");

      // close previous
      if (activeIndex !== null && activeIndex !== index) {
        const prevContent = document.getElementById(`faq-${activeIndex}`);
        const prevBtn = document.querySelector(`[data-index="${activeIndex}"]`);
        const prevIcon = prevBtn.querySelector(".faq-icon");

        prevContent.style.maxHeight = null;
        prevIcon.style.transform = "rotate(0deg)";
      }

      // toggle current
      if (content.style.maxHeight) {
        content.style.maxHeight = null;
        icon.style.transform = "rotate(0deg)";
        activeIndex = null;
      } else {
        content.style.maxHeight = content.scrollHeight + "px";
        icon.style.transform = "rotate(45deg)";
        activeIndex = index;
      }
    });
  });
</script>
