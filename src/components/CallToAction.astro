---
import { siteConfig } from "../config";

const PHONE = "918144991049";
const whatsappLink = `https://wa.me/${PHONE}?text=Hi Saurav, I want to work with you.`;
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">
  <div class="grid lg:grid-cols-12 gap-10 items-start">

    <!-- LEFT (TEXT + CTA) -->
    <div class="lg:col-span-4">

      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
        Let’s work together
      </h2>

      <a href={whatsappLink}
        class="inline-block mt-6 px-6 py-3 rounded-lg text-white font-medium shadow-sm"
        style={`background-color: ${siteConfig.accentColor}`}>
        Chat on WhatsApp
      </a>

      <p class="text-sm text-gray-500 mt-4">
        Trusted by 100+ clients
      </p>

    </div>


    <!-- MIDDLE (TESTIMONIALS) -->
    <div class="lg:col-span-5">

      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">

        <!-- RATING INSIDE CARD -->
        <div class="flex items-center justify-center gap-2 mb-4">
          <span class="text-lg font-semibold text-gray-900">4.9</span>

          <div class="flex gap-1 text-yellow-400">
            {Array(5).fill(0).map(() => (
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.243 7.34l-6.38 .925a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3a1 1 0 0 0 1.452 -1.054l-1.091 -6.355l4.624 -4.5a1 1 0 0 0 -.555 -1.705l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
              </svg>
            ))}
          </div>
        </div>

        <!-- TEXT -->
        <p class="text-gray-700 text-base text-center leading-relaxed">
          “Great work, fast delivery and very clean design. Communication was smooth and everything delivered on time.”
        </p>

        <!-- USER -->
        <div class="mt-6 text-center">
          <p class="font-semibold text-gray-900">Amit Sharma</p>
          <p class="text-sm text-gray-500">Startup Founder</p>
        </div>

      </div>

    </div>


    <!-- RIGHT (FAQ) -->
    <div class="lg:col-span-3">

      <div class="space-y-4">

        <!-- FAQ ITEM -->
        <div class="border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            What services do you offer?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Graphic design, video editing, branding, and digital content solutions.
          </p>
        </div>

        <div class="border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            How fast is delivery?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Most projects are delivered within 1–3 days depending on complexity.
          </p>
        </div>

        <div class="border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            Do you offer revisions?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Yes, revisions depend on the selected plan.
          </p>
        </div>

      </div>

    </div>

  </div>
</section>


<script>
  // FAQ toggle
  document.querySelectorAll(".faq-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      content.classList.toggle("hidden");
    });
  });
</script>
