---
import { siteConfig } from "../config";

const PHONE = "918144991049";
const whatsappLink = `https://wa.me/${PHONE}?text=Hi Saurav, I want to work with you.`;
---

<section id="cta" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <!-- Rating -->
      <div class="flex items-center gap-2 mb-4 text-sm text-gray-600 font-medium">
        <span class="text-lg font-semibold text-gray-900">4.9</span>

        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8.243 7.34l-6.38 .925a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3a1 1 0 0 0 1.452 -1.054l-1.091 -6.355l4.624 -4.5a1 1 0 0 0 -.555 -1.705l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
        </svg>

        <span class="uppercase tracking-wide">Rating</span>
      </div>

      <!-- Heading -->
      <h2 class="text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight">
        Let’s work together
      </h2>

      <!-- CTA -->
      <a href={whatsappLink}
        target="_blank"
        class="inline-block mt-6 px-6 py-3 rounded-lg text-white font-medium shadow-sm transition hover:opacity-90"
        style={`background-color: ${siteConfig.accentColor}`}>
        Chat on WhatsApp
      </a>

      <!-- Trust -->
      <p class="text-sm text-gray-500 mt-4">
        Trusted by 100+ clients
      </p>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <div class="relative overflow-hidden">

        <!-- SLIDER -->
        <div id="slider" class="flex transition-transform duration-500 ease-in-out">

          <!-- CARD -->
          {[
            {
              name: "Amit Sharma",
              role: "Startup Founder",
              text: "Great work, fast delivery and very clean design.",
              img: "/avatars/user1.jpg"
            },
            {
              name: "Riya Patel",
              role: "Content Creator",
              text: "Professional and easy to work with. Highly recommended.",
              img: "/avatars/user2.jpg"
            },
            {
              name: "Rahul Verma",
              role: "Business Owner",
              text: "Good communication and quality work.",
              img: "/avatars/user3.jpg"
            }
          ].map((item) => (
            <div class="min-w-full px-2">
              <div class="bg-white border border-gray-200 rounded-2xl p-6 pt-12 text-center relative shadow-sm">

                <!-- Avatar -->
                <img src={item.img}
                  class="w-16 h-16 rounded-full object-cover mx-auto -mt-10 border-4 border-white shadow-md" />

                <!-- Stars -->
                <div class="flex justify-center gap-1 mt-3 mb-3 text-yellow-400">
                  {Array(5).fill(0).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8.243 7.34l-6.38 .925a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3a1 1 0 0 0 1.452 -1.054l-1.091 -6.355l4.624 -4.5a1 1 0 0 0 -.555 -1.705l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
                    </svg>
                  ))}
                </div>

                <!-- Text -->
                <p class="text-gray-700 text-sm leading-relaxed">
                  “{item.text}”
                </p>

                <!-- Name -->
                <p class="mt-4 font-semibold text-gray-900">{item.name}</p>
                <p class="text-xs text-gray-500">{item.role}</p>

              </div>
            </div>
          ))}

        </div>

        <!-- DOTS -->
        <div class="flex justify-center gap-2 mt-6">
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
        </div>

      </div>

    </div>
  </div>
</section>


<script>
  let index = 0;
  const slider = document.getElementById("slider");
  const dots = document.querySelectorAll(".dot");
  const total = slider.children.length;

  function updateSlider() {
    slider.style.transform = `translateX(-${index * 100}%)`;

    dots.forEach((d, i) => {
      d.classList.remove("bg-blue-600");
      d.classList.add("bg-gray-300");

      if (i === index) {
        d.classList.remove("bg-gray-300");
        d.classList.add("bg-blue-600");
      }
    });
  }

  setInterval(() => {
    index = (index + 1) % total;
    updateSlider();
  }, 6000);

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      index = i;
      updateSlider();
    });
  });

  updateSlider();
</script>
