---
import { siteConfig } from "../config";

const PHONE = "918144991049"; // replace with your number
const whatsappLink = `https://wa.me/${PHONE}?text=Hi Saurav, I want to work with you.`;
---

<section id="cta" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <!-- LEFT SIDE -->
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          Let’s work together
        </h2>
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 px-5 py-2.5 rounded-md text-white font-medium transition"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          Chat on WhatsApp
        </a>
      </div>

      <!-- RIGHT SIDE -->
      <div class="lg:col-span-8 flex items-center">
      
        <div class="relative w-full overflow-hidden">
      
          <!-- SLIDER -->
          <div id="slider" class="flex transition-transform duration-500 ease-in-out">
      
            <!-- CARD 1 -->
            <div class="min-w-full px-2">
              <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 pt-12 text-center relative overflow-visible">
                
                <img src="/avatars/user1.jpg"
                     class="w-16 h-16 rounded-full object-cover mx-auto -mt-10 border-4 border-white shadow-lg" />
      
                <div class="text-yellow-500 text-sm mb-2 mt-2">★★★★★</div>
      
                <p class="text-sm text-gray-700">
                  “Great work, fast delivery and very clean design.”
                </p>
      
                <p class="mt-3 text-sm font-medium text-gray-900">Amit Sharma</p>
                <p class="text-xs text-gray-500">Startup Founder</p>
              </div>
            </div>
      
            <!-- CARD 2 -->
            <div class="min-w-full px-2">
              <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 pt-12 text-center relative overflow-visible">
                
                <img src="/avatars/user2.jpg"
                     class="w-16 h-16 rounded-full object-cover mx-auto -mt-10 border-4 border-white shadow-lg" />
      
                <div class="text-yellow-500 text-sm mb-2 mt-2">★★★</div>
      
                <p class="text-sm text-gray-700">
                  “Professional and easy to work with. Highly recommended.”
                </p>
      
                <p class="mt-3 text-sm font-medium text-gray-900">Riya Patel</p>
                <p class="text-xs text-gray-500">Content Creator</p>
              </div>
            </div>
      
            <!-- CARD 3 -->
            <div class="min-w-full px-2">
              <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 pt-12 text-center relative overflow-visible">
                
                <img src="/avatars/user3.jpg"
                     class="w-16 h-16 rounded-full object-cover mx-auto -mt-10 border-4 border-white shadow-lg" />
      
                <div class="text-yellow-500 text-sm mb-2 mt-2">★★★★</div>
      
                <p class="text-sm text-gray-700">
                  “Good communication and quality work.”
                </p>
      
                <p class="mt-3 text-sm font-medium text-gray-900">Rahul Verma</p>
                <p class="text-xs text-gray-500">Business Owner</p>
              </div>
            </div>
      
          </div>
      
          <!-- DOTS -->
          <div class="flex justify-center gap-2 mt-6">
            <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
            <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
            <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
          </div>
      
        </div>
      </div>

    </div>
  </div>
</section>

<script>
    let index = 0;
    const slider = document.getElementById("slider");
    const dots = document.querySelectorAll(".dot");
    const total = slider.children.length;
  
    let interval;
  
    function updateSlider() {
      slider.style.transform = `translateX(-${index * 100}%)`;
  
      dots.forEach((d, i) => {
        d.classList.remove("bg-blue-600");
        d.classList.add("bg-gray-300");
        if (i === index) {
          d.classList.remove("bg-gray-300");
          d.classList.add("bg-blue-600");
        }
      });
    }
  
    function startAuto() {
      interval = setInterval(() => {
        index = (index + 1) % total;
        updateSlider();
      }, 10000);
    }
  
    function stopAuto() {
      clearInterval(interval);
    }
  
    // dots click
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        index = i;
        updateSlider();
      });
    });
  
    // hover pause
    slider.addEventListener("mouseenter", stopAuto);
    slider.addEventListener("mouseleave", startAuto);
  
    // swipe
    let startX = 0;
  
    slider.addEventListener("touchstart", (e) => {
      startX = e.touches[0].clientX;
      stopAuto();
    });
  
    slider.addEventListener("touchend", (e) => {
      let endX = e.changedTouches[0].clientX;
      let diff = startX - endX;
  
      if (diff > 50) index = (index + 1) % total;
      if (diff < -50) index = (index - 1 + total) % total;
  
      updateSlider();
      startAuto();
    });
  
    // init
    updateSlider();
    startAuto();
</script>
