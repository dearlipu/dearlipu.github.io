---
import { siteConfig } from "../config";
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">

  <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 items-start">

    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Success Stories
      </h2>

      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-4 max-w-md">
        Discover how our design subscription helps innovative brands grow smarter and faster.
      </p>

    </div>


    <!-- RIGHT SIDE -->
    <div class="lg:col-span-8 grid sm:grid-cols-2 gap-6">

      <!-- 1️⃣ REVIEW SUMMARY CARD -->
      <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm flex flex-col justify-between">

        <div>
          <h3 class="text-3xl font-bold text-gray-900">4.9/5</h3>

          <p class="text-gray-500 mt-2 text-sm">
            100+ successful projects delivered with consistent results.
          </p>
        </div>

        <!-- STARS -->
        <div class="mt-4 flex gap-1 text-red-500">
          {Array(5).fill(0).map(() => (
            <svg xmlns="http://www.w3.org/2000/svg"
              width="16" height="16"
              viewBox="0 0 24 24"
              fill="currentColor">
              <path d="M8.243 7.34l-6.38 .925..." />
            </svg>
          ))}
        </div>

        <p class="text-sm text-gray-600 mt-2">
          Trusted by 100+ clients
        </p>

        <a href={reviewLink}
          class="mt-5 bg-[#0f172a] text-white rounded-full py-2.5 text-center text-sm font-medium">
          Leave a review
        </a>

      </div>


      <!-- 2️⃣ SINGLE REVIEW -->
      <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-sm flex flex-col justify-between">

        <div>
          <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
            <span class="font-semibold text-gray-900">4.9</span>
            <span class="text-red-500">★</span>
            <span>Rating</span>
          </div>

          <p class="text-gray-900 font-medium">
            "Proactive, precise, and easy to work with—no hand-holding needed."
          </p>
        </div>

        <div class="flex items-center gap-3 mt-6">
          <img src="/avatars/user1.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Jared Kim</p>
            <p class="text-xs text-gray-500 uppercase">Marketing Director</p>
          </div>
        </div>

      </div>


      <!-- 3️⃣ SLIDER REVIEW (FULL WIDTH) -->
      <div class="sm:col-span-2 bg-white rounded-2xl p-6 border border-gray-200 shadow-sm overflow-hidden">

        <div id="slider" class="flex transition-transform duration-500">

          <!-- REVIEW 1 -->
          <div class="min-w-full">
            <p class="text-gray-900 font-medium">
              "Fast delivery and very clean professional design work."
            </p>
          </div>

          <!-- REVIEW 2 -->
          <div class="min-w-full">
            <p class="text-gray-900 font-medium">
              "Reliable, creative, and easy to collaborate with."
            </p>
          </div>

          <!-- REVIEW 3 -->
          <div class="min-w-full">
            <p class="text-gray-900 font-medium">
              "Great communication and strong attention to detail."
            </p>
          </div>

        </div>

        <!-- USER -->
        <div class="flex items-center gap-3 mt-6">
          <img src="/avatars/user2.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Maya Collins</p>
            <p class="text-xs text-gray-500 uppercase">Head of Product</p>
          </div>
        </div>

      </div>

    </div>

  </div>

</section>


<script>
  let index = 0;
  const slider = document.getElementById("slider");
  const total = slider.children.length;

  setInterval(() => {
    index = (index + 1) % total;
    slider.style.transform = `translateX(-${index * 100}%)`;
  }, 3500);
</script>
