---
import { siteConfig } from "../config";

const PHONE = "918144991049";
const whatsappLink = `https://wa.me/${PHONE}?text=Hi Saurav, I want to work with you.`;
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">
  <div class="grid lg:grid-cols-12 gap-12 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <!-- RATING -->
      <div class="flex items-center gap-2 mb-4 text-sm text-gray-600 font-medium">
        <span class="text-lg font-semibold text-gray-900">4.9</span>
        <svg class="w-4 h-4 text-red-500" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8.243 7.34l-6.38 .925..." />
        </svg>
        <span class="uppercase tracking-wide">Rating</span>
      </div>

      <!-- TITLE -->
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
        Let’s work together
      </h2>

      <a href={whatsappLink}
        class="inline-block mt-6 px-6 py-3 rounded-lg text-white font-medium shadow-sm"
        style={`background-color: ${siteConfig.accentColor}`}>
        Chat on WhatsApp
      </a>

      <p class="text-sm text-gray-500 mt-4">
        Trusted by 100+ clients
      </p>

    </div>


    <!-- MIDDLE (TESTIMONIAL) -->
    <div class="lg:col-span-5">

      <h3 class="text-lg font-semibold text-gray-900 mb-4">
        What clients say
      </h3>

      <div class="relative overflow-hidden">

        <div id="slider" class="flex transition-transform duration-500 ease-in-out">

          <!-- CARD 1 -->
          <div class="min-w-full px-2">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 pt-14 text-center shadow-sm">

              <img src="/avatars/user1.jpg"
                class="w-16 h-16 rounded-full object-cover mx-auto -mt-12 border-4 border-white shadow-md" />

              <!-- RATING -->
              <div class="flex justify-center items-center gap-2 mt-3 mb-4">
                <span class="font-semibold">4.9</span>
                <div class="flex gap-1 text-yellow-400">
                  {Array(5).fill(0).map(() => (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8.243 7.34l-6.38 .925..." />
                    </svg>
                  ))}
                </div>
              </div>

              <p class="text-gray-700 text-base leading-relaxed">
                “Great work, fast delivery and very clean design.”
              </p>

              <p class="mt-5 font-semibold text-gray-900">Amit Sharma</p>
              <p class="text-sm text-gray-500">Startup Founder</p>

            </div>
          </div>

          <!-- CARD 2 -->
          <div class="min-w-full px-2">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 pt-14 text-center shadow-sm">

              <img src="/avatars/user2.jpg"
                class="w-16 h-16 rounded-full object-cover mx-auto -mt-12 border-4 border-white shadow-md" />

              <div class="flex justify-center items-center gap-2 mt-3 mb-4">
                <span class="font-semibold">4.9</span>
                <div class="flex gap-1 text-yellow-400">
                  {Array(5).fill(0).map(() => (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8.243 7.34l-6.38 .925..." />
                    </svg>
                  ))}
                </div>
              </div>

              <p class="text-gray-700 text-base leading-relaxed">
                “Professional and easy to work with. Highly recommended.”
              </p>

              <p class="mt-5 font-semibold text-gray-900">Riya Patel</p>
              <p class="text-sm text-gray-500">Content Creator</p>

            </div>
          </div>

          <!-- CARD 3 -->
          <div class="min-w-full px-2">
            <div class="bg-white border border-gray-200 rounded-2xl p-8 pt-14 text-center shadow-sm">

              <img src="/avatars/user3.jpg"
                class="w-16 h-16 rounded-full object-cover mx-auto -mt-12 border-4 border-white shadow-md" />

              <div class="flex justify-center items-center gap-2 mt-3 mb-4">
                <span class="font-semibold">4.9</span>
                <div class="flex gap-1 text-yellow-400">
                  {Array(5).fill(0).map(() => (
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8.243 7.34l-6.38 .925..." />
                    </svg>
                  ))}
                </div>
              </div>

              <p class="text-gray-700 text-base leading-relaxed">
                “Good communication and quality work.”
              </p>

              <p class="mt-5 font-semibold text-gray-900">Rahul Verma</p>
              <p class="text-sm text-gray-500">Business Owner</p>

            </div>
          </div>

        </div>

        <!-- DOTS -->
        <div class="flex justify-center gap-2 mt-6">
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
          <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300"></button>
        </div>

      </div>

    </div>


    <!-- RIGHT (FAQ) -->
    <div class="lg:col-span-3">

      <h3 class="text-lg font-semibold text-gray-900 mb-4">
        FAQs
      </h3>

      <div class="space-y-3">

        <div class="faq border border-gray-200 rounded-xl p-4 cursor-pointer">
          <p class="font-medium">What services do you offer?</p>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Graphic design, video editing, branding, and digital content.
          </p>
        </div>

        <div class="faq border border-gray-200 rounded-xl p-4 cursor-pointer">
          <p class="font-medium">How fast is delivery?</p>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Typically 1–3 days depending on the project.
          </p>
        </div>

        <div class="faq border border-gray-200 rounded-xl p-4 cursor-pointer">
          <p class="font-medium">Do you offer revisions?</p>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Yes, based on your selected plan.
          </p>
        </div>

      </div>

    </div>

  </div>
</section>


<script>
  // slider
  let index = 0;
  const slider = document.getElementById("slider");
  const dots = document.querySelectorAll(".dot");
  const total = slider.children.length;

  function updateSlider() {
    slider.style.transform = `translateX(-${index * 100}%)`;

    dots.forEach((d, i) => {
      d.classList.toggle("bg-blue-600", i === index);
      d.classList.toggle("bg-gray-300", i !== index);
    });
  }

  setInterval(() => {
    index = (index + 1) % total;
    updateSlider();
  }, 5000);

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      index = i;
      updateSlider();
    });
  });

  updateSlider();

  // FAQ toggle + hover
  document.querySelectorAll(".faq").forEach(item => {
    item.addEventListener("click", () => {
      const content = item.querySelector(".faq-content");
      content.classList.toggle("hidden");
    });

    item.addEventListener("mouseenter", () => {
      item.classList.add("bg-gray-100");
    });

    item.addEventListener("mouseleave", () => {
      item.classList.remove("bg-gray-100");
    });
  });
</script>
