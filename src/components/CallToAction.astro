---
import { siteConfig } from "../config";
---

<section class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50">

  <div class="grid lg:grid-cols-12 gap-8 items-start">

    <!-- LEFT: TITLE -->
    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900">
        Success Stories
      </h2>

      <!-- BLUE LINE -->
      <div
        class="w-[60px] h-[4px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-4 max-w-sm text-sm">
        Discover how our design subscription helps innovative brands grow smarter and faster.
      </p>

    </div>


    <!-- MIDDLE: SUMMARY CARD -->
    <div class="lg:col-span-4">

      <div class="bg-[#0f172a] text-white rounded-2xl p-6 h-full flex flex-col justify-between">

        <div>
          <h3 class="text-3xl font-bold">4.9/5</h3>

          <p class="text-gray-300 mt-2 text-sm">
            100+ successful projects delivered with consistent results.
          </p>
        </div>

        <!-- STARS -->
        <div class="mt-4">

          <div class="flex gap-1 text-red-500 mb-2">
            {Array(5).fill(0).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="currentColor">
                <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
              </svg>
            ))}
          </div>

          <p class="text-xs text-gray-400">
            Trusted by 100+ clients
          </p>

        </div>

      </div>

    </div>


    <!-- RIGHT: SLIDER -->
    <div class="lg:col-span-4 overflow-hidden">

      <div id="reviewSlider" class="flex transition-transform duration-500">

        <!-- CARD 1 -->
        <div class="min-w-full">
          <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">

            <p class="text-gray-900 text-sm">
              "Proactive, precise, and easy to work with—no hand-holding needed."
            </p>

            <div class="flex items-center gap-3 mt-4">
              <img src="/avatars/user1.jpg" class="w-9 h-9 rounded-full" />
              <div>
                <p class="text-sm font-semibold text-gray-900">Jared Kim</p>
                <p class="text-xs text-gray-500 uppercase">Marketing Director</p>
              </div>
            </div>

          </div>
        </div>

        <!-- CARD 2 -->
        <div class="min-w-full">
          <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">

            <p class="text-gray-900 text-sm">
              "Fast delivery and very clean professional design work."
            </p>

            <div class="flex items-center gap-3 mt-4">
              <img src="/avatars/user2.jpg" class="w-9 h-9 rounded-full" />
              <div>
                <p class="text-sm font-semibold text-gray-900">Maya Collins</p>
                <p class="text-xs text-gray-500 uppercase">Head of Product</p>
              </div>
            </div>

          </div>
        </div>

        <!-- CARD 3 -->
        <div class="min-w-full">
          <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">

            <p class="text-gray-900 text-sm">
              "Communication was smooth and everything delivered on time."
            </p>

            <div class="flex items-center gap-3 mt-4">
              <img src="/avatars/user3.jpg" class="w-9 h-9 rounded-full" />
              <div>
                <p class="text-sm font-semibold text-gray-900">Amit Sharma</p>
                <p class="text-xs text-gray-500 uppercase">Founder</p>
              </div>
            </div>

          </div>
        </div>

      </div>

    </div>

  </div>

</section>


<script>
  let index = 0;
  const slider = document.getElementById("reviewSlider");
  const total = slider.children.length;

  setInterval(() => {
    index = (index + 1) % total;
    slider.style.transform = `translateX(-${index * 100}%)`;
  }, 3000);
</script>
