---
import { siteConfig } from "../config";
---

<section class="p-6 sm:p-10 md:p-16 lg:p-24 bg-gray-50">

  <!-- HEADER -->
  <div class="flex flex-col lg:flex-row justify-between gap-6 mb-12">

    <h2 class="text-4xl md:text-5xl font-bold text-gray-900">
      Success Stories.
    </h2>

    <p class="text-gray-500 max-w-md">
      Discover how our design subscription helps innovative brands grow smarter and faster.
    </p>

  </div>


  <!-- MAIN GRID -->
  <div class="grid lg:grid-cols-12 gap-8">

    <!-- LEFT DARK CARD -->
    <div class="lg:col-span-4">

      <div class="bg-black text-white rounded-3xl p-8 h-full flex flex-col justify-between">

        <!-- TOP -->
        <div>
          <h3 class="text-4xl font-bold">4.9/5</h3>

          <p class="text-gray-400 mt-4 text-sm max-w-xs">
            We've delivered 100+ projects that drive real results.
          </p>
        </div>

        <!-- MIDDLE -->
        <div class="mt-8">

          <div class="flex -space-x-3 mb-4">
            <img src="/avatars/user1.jpg" class="w-10 h-10 rounded-full border-2 border-black" />
            <img src="/avatars/user2.jpg" class="w-10 h-10 rounded-full border-2 border-black" />
            <img src="/avatars/user3.jpg" class="w-10 h-10 rounded-full border-2 border-black" />
            <img src="/avatars/user4.jpg" class="w-10 h-10 rounded-full border-2 border-black" />
          </div>

          <!-- STARS -->
          <div class="flex gap-1 text-red-500 mb-2">
            {Array(5).fill(0).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="currentColor">
                <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
              </svg>
            ))}
          </div>

          <p class="text-sm text-gray-300">
            Trusted by 100+ businesses
          </p>

        </div>

        <!-- BUTTON -->
        <button class="mt-8 bg-white text-black rounded-full py-3 font-medium">
          Leave a review
        </button>

      </div>

    </div>


    <!-- RIGHT TESTIMONIAL GRID -->
    <div class="lg:col-span-8 grid sm:grid-cols-2 gap-6">

      <!-- CARD -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">

        <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
          <span class="font-semibold text-gray-900">4.9</span>
          <span class="text-red-500">★</span>
          <span>Rating</span>
        </div>

        <p class="text-gray-900 font-medium leading-relaxed">
          "Proactive, precise, and easy to work with—no hand-holding needed, just smooth collaboration from start to finish."
        </p>

        <div class="flex items-center gap-3 mt-5">
          <img src="/avatars/user1.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Jared Kim</p>
            <p class="text-xs text-gray-500 uppercase">Marketing Director</p>
          </div>
        </div>

      </div>


      <!-- CARD -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">

        <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
          <span class="font-semibold text-gray-900">5.0</span>
          <span class="text-red-500">★</span>
          <span>Rating</span>
        </div>

        <p class="text-gray-900 font-medium leading-relaxed">
          "Felt like an embedded team with zero friction; communication was clear, and revisions landed perfectly on the first go."
        </p>

        <div class="flex items-center gap-3 mt-5">
          <img src="/avatars/user2.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Maya Collins</p>
            <p class="text-xs text-gray-500 uppercase">Head of Product</p>
          </div>
        </div>

      </div>


      <!-- CARD -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">

        <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
          <span class="font-semibold text-gray-900">4.9</span>
          <span class="text-red-500">★</span>
          <span>Rating</span>
        </div>

        <p class="text-gray-900 font-medium leading-relaxed">
          "The quality was unmatched. We submitted our request on Monday and had polished designs by Wednesday."
        </p>

        <div class="flex items-center gap-3 mt-5">
          <img src="/avatars/user3.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Jesse Leigh</p>
            <p class="text-xs text-gray-500 uppercase">CEO & Founder</p>
          </div>
        </div>

      </div>


      <!-- CARD -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">

        <div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
          <span class="font-semibold text-gray-900">4.9</span>
          <span class="text-red-500">★</span>
          <span>Rating</span>
        </div>

        <p class="text-gray-900 font-medium leading-relaxed">
          "We’ve tried other design subscriptions — none compare. Professional, reliable, and seriously creative."
        </p>

        <div class="flex items-center gap-3 mt-5">
          <img src="/avatars/user4.jpg" class="w-10 h-10 rounded-full" />
          <div>
            <p class="font-semibold text-gray-900 text-sm">Benjamin Daul</p>
            <p class="text-xs text-gray-500 uppercase">Head of Engineering</p>
          </div>
        </div>

      </div>

    </div>

  </div>

</section>
