---
import { siteConfig } from "../config";

const PHONE = "918144991049";
const whatsappLink = `https://wa.me/${PHONE}?text=Hi Saurav, I want to work with you.`;
---

<section class="p-6 sm:p-10 md:p-16 lg:p-24 bg-gray-50">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <div class="flex items-center gap-2 mb-4 text-sm text-gray-600 font-medium">
        <span class="text-lg font-semibold text-gray-900">4.9</span>
        <span class="text-red-500">★</span>
        <span class="uppercase tracking-wide">Rating</span>
      </div>

      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
        Let’s work together
      </h2>

      <a href={whatsappLink}
        class="inline-block mt-5 px-5 py-2.5 rounded-lg text-white font-medium shadow-sm"
        style={`background-color: ${siteConfig.accentColor}`}>
        Chat on WhatsApp
      </a>

      <p class="text-sm text-gray-500 mt-3">
        Trusted by 100+ clients
      </p>

    </div>


    <!-- TESTIMONIAL -->
    <div class="lg:col-span-5">

      <h3 class="text-base font-semibold text-gray-900 mb-3">
        What clients say
      </h3>

      <div class="relative overflow-hidden">

        <div id="slider" class="flex transition-transform duration-500 ease-in-out">

          <!-- CARD -->
          <div class="min-w-full px-1">
            <div class="bg-white border border-gray-200 rounded-2xl p-6 pt-12 text-center shadow-sm min-h-[260px] flex flex-col justify-between">

              <img src="/avatars/user1.jpg"
                class="w-14 h-14 rounded-full object-cover mx-auto -mt-10 border-4 border-white shadow-md" />

              <!-- ⭐ FIXED SVG STARS -->
              <div class="flex justify-center gap-1 mt-3 text-yellow-400">
                {Array(5).fill(0).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="currentColor">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                ))}
              </div>

              <p class="text-gray-700 text-sm mt-3">
                “Professional and easy to work with. Highly recommended.”
              </p>

              <div class="mt-4">
                <p class="font-semibold text-gray-900">Riya Patel</p>
                <p class="text-xs text-gray-500">Content Creator</p>
              </div>

            </div>
          </div>

        </div>

        <!-- DOTS -->
        <div class="flex justify-center gap-2 mt-4">
          <button class="dot w-2 h-2 rounded-full bg-gray-300"></button>
          <button class="dot w-2 h-2 rounded-full bg-gray-300"></button>
          <button class="dot w-2 h-2 rounded-full bg-gray-300"></button>
        </div>

      </div>

    </div>


    <!-- FAQ -->
    <div class="lg:col-span-3">

      <h3 class="text-base font-semibold text-gray-900 mb-3">
        FAQs
      </h3>

      <div class="space-y-3">

        <!-- FAQ ITEM -->
        <div class="faq border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            What services do you offer?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            I provide graphic design, video editing, branding, and digital content services.
          </p>
        </div>

        <div class="faq border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            How fast is delivery?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Most work is delivered within 1–3 days depending on complexity.
          </p>
        </div>

        <div class="faq border border-gray-200 rounded-xl p-4">
          <button class="faq-btn w-full text-left font-medium">
            Do you offer revisions?
          </button>
          <p class="faq-content text-sm text-gray-600 mt-2 hidden">
            Yes, revisions depend on the plan you choose.
          </p>
        </div>

      </div>

    </div>

  </div>
</section>


<script>
  // SLIDER
  let index = 0;
  const slider = document.getElementById("slider");
  const dots = document.querySelectorAll(".dot");
  const total = slider.children.length;

  function updateSlider() {
    slider.style.transform = `translateX(-${index * 100}%)`;

    dots.forEach((d, i) => {
      d.classList.toggle("bg-blue-600", i === index);
      d.classList.toggle("bg-gray-300", i !== index);
    });
  }

  setInterval(() => {
    index = (index + 1) % total;
    updateSlider();
  }, 4000);

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      index = i;
      updateSlider();
    });
  });

  updateSlider();

  // FAQ CLICK (NOT HOVER)
  document.querySelectorAll(".faq-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      content.classList.toggle("hidden");
    });
  });
</script>
