---
import { siteConfig } from "../config";
const certs = siteConfig.badges || [];
---

{certs.length > 0 && (
  <section id="badges" class="py-12 overflow-hidden">

    <div class="relative w-full overflow-hidden">

      <!-- SCROLL WRAPPER -->
      <div class="flex gap-4 whitespace-nowrap animate-scroll">

        {/* Duplicate list for infinite loop */}
        {[...certs, ...certs].map((c) => (
          <a
            href={c.url ?? "#"}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-4 py-2 bg-gray-100 text-gray-800
                   rounded-full text-sm font-medium hover:bg-gray-200 transition
                   no-underline"
          >
            <span>{c.name}</span>

            <span class="ml-1 inline-flex items-center text-xs text-gray-600 bg-white/60 
                         px-2 py-0.5 rounded-full border border-gray-200">
              <span class="font-medium">{c.provider}</span>
              <span class="mx-1">•</span>
              <span class="font-medium">{c.year}</span>
            </span>
          </a>
        ))}

      </div>

    </div>

  </section>
)}

<style>
@keyframes scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

.animate-scroll {
  display: flex;
  width: max-content;
  animation: scroll 55s linear infinite;
}
</style>
