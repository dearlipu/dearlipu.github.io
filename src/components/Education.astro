---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;

showcaseImages: [
  "/showcase/1.jpg",
  "/showcase/2.jpg",
  "/showcase/3.jpg",
  "/showcase/4.jpg",
  "/showcase/5.jpg",
],
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

          <!-- LEFT -->
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              What I Offer.
            </h2>

            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />

            <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
              Creative work that looks professional and gets real results.
            </p>

            <!-- SHOWCASE BOX -->
            <div class="mt-8 showcase-box">
            
              <div class="fade-top"></div>
            
              <div class="showcase-track">
                {[...showcaseImages, ...showcaseImages].map((img) => (
                  <div class="showcase-card">
                    <img src={img} alt="work" loading="lazy" />
                  </div>
                ))}
              </div>
            
              <div class="fade-bottom"></div>
            
            </div>

          </div>

          <!-- RIGHT -->
          <div class="lg:col-span-8 space-y-8">

            {siteConfig.education.map((edu, index) => (

              <div class="bg-gray-50 rounded-xl border border-gray-200 
                          flex flex-col md:flex-row overflow-hidden 
                          transition-all duration-300 hover:shadow-md">

                <div class="flex-1 p-5 md:p-6">

                  <div class="mb-4">
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                      {edu.degree}
                    </h3>

                    <p
                      class="text-base sm:text-lg"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      {edu.school}
                    </p>
                  </div>

                  <ul class="space-y-2">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3"></span>
                        <span class="text-sm sm:text-base text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>

                </div>

                <div class="md:w-[320px] w-full aspect-[4/3] md:aspect-auto flex-shrink-0">

                  <div class="image-full">
                    <img 
                      src={`/images/edu-${index + 1}.gif`} 
                      alt={edu.degree} 
                    />
                  </div>

                </div>

              </div>

            ))}

          </div>
        </div>
      </div>
    </section>
  )
}

<style>
.image-full {
  width: 100%;
  height: 100%;
  overflow: hidden;

  clip-path: polygon(
    20% 0,
    100% 0,
    100% 100%,
    0% 100%,
    0% 25%
  );
}

.image-full img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* SHOWCASE BOX */
.showcase-box {
  position: relative;
  height: 420px;
  overflow: hidden;
}

/* TRACK */
.showcase-track {
  display: flex;
  flex-direction: column;
  animation: scrollY 25s linear infinite;
  will-change: transform;
}

/* CARD */
.showcase-card {
  padding: 10px 0;
}

.showcase-card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 16px;
  display: block;
  transition: transform 0.3s ease;
}

.showcase-card img:hover {
  transform: scale(1.05);
}

/* LOOP FIX */
@keyframes scrollY {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

/* FADE */
.fade-top,
.fade-bottom {
  position: absolute;
  left: 0;
  width: 100%;
  height: 60px;
  z-index: 10;
  pointer-events: none;
}

.fade-top {
  top: 0;
  background: linear-gradient(to bottom, white, transparent);
}

.fade-bottom {
  bottom: 0;
  background: linear-gradient(to top, white, transparent);
}

/* HOVER PAUSE */
.showcase-track:hover {
  animation-play-state: paused;
}

/* MOBILE */
@media (max-width: 1024px) {
  .showcase-box {
    height: 320px;
  }

  .showcase-card img {
    height: 140px;
  }

  .showcase-track {
    animation-duration: 35s;
  }
}
</style>
