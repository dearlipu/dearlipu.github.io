---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;

const showcaseImages = [
  "/showcase/sc1.jpg",
  "/showcase/sc2.jpg",
  "/showcase/sc3.jpg",
  "/showcase/sc4.jpg",
  "/showcase/sc5.jpg",
];
---

{hasEducation && (
  <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
    <div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4 flex flex-col min-h-0">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            What I Offer.
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
            Creative work that looks professional and gets real results.
          </p>

          <!-- SHOWCASE BOX -->
          <div class="mt-8 showcase-box" id="showcaseBox">
            <div class="showcase-track">
              {[...showcaseImages, ...showcaseImages].map((img) => (
                <div class="showcase-card">
                  <img src={img} alt="work" loading="lazy" />
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 space-y-8" id="rightColumn">

          {siteConfig.education.map((edu, index) => (

            <div class="bg-gray-50 rounded-xl border border-gray-200 
                        flex flex-col md:flex-row overflow-hidden 
                        transition-all duration-300 hover:shadow-md">

              <div class="flex-1 p-5 md:p-6">

                <div class="mb-4">
                  <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                    {edu.degree}
                  </h3>

                  <p
                    class="text-base sm:text-lg"
                    style={`color: ${siteConfig.accentColor}`}
                  >
                    {edu.school}
                  </p>
                </div>

                <ul class="space-y-2">
                  {edu.achievements.map((achievement) => (
                    <li class="flex items-start">
                      <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3"></span>
                      <span class="text-sm sm:text-base text-gray-600">
                        {achievement}
                      </span>
                    </li>
                  ))}
                </ul>

              </div>

              <div class="md:w-[320px] w-full aspect-[4/3] md:aspect-auto flex-shrink-0">
                <div class="image-full">
                  <img 
                    src={`/images/edu-${index + 1}.gif`} 
                    alt={edu.degree} 
                  />
                </div>
              </div>

            </div>

          ))}

        </div>
      </div>
    </div>
  </section>
)}

<!-- HEIGHT SYNC SCRIPT -->
<script>
  function syncHeights() {
    const leftBox = document.getElementById("showcaseBox");
    const rightCol = document.getElementById("rightColumn");

    if (!leftBox || !rightCol) return;

    // get full height of right column
    const rightHeight = rightCol.offsetHeight;

    // subtract top content height (title + text)
    const leftTop = leftBox.getBoundingClientRect().top;
    const rightTop = rightCol.getBoundingClientRect().top;

    const offset = leftTop - rightTop;

    leftBox.style.height = (rightHeight - offset) + "px";
  }

  // run after load
  window.addEventListener("load", syncHeights);

  // run on resize
  window.addEventListener("resize", syncHeights);
</script>

<style>
/* RIGHT IMAGE */
.image-full {
  width: 100%;
  height: 100%;
  overflow: hidden;
  clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%, 0% 25%);
}

.image-full img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* SHOWCASE BOX */
.showcase-box {
  overflow: hidden;

  background: #f9fafb;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  padding: 12px;
}

/* TRACK */
.showcase-track {
  display: flex;
  flex-direction: column;
  gap: 10px;
  animation: scrollY 25s linear infinite;
}

.showcase-track:hover {
  animation-play-state: paused;
}

/* CARD */
.showcase-card {
  background: #ffffff;
  border-radius: 10px;
  padding: 6px;
}

/* IMAGE */
.showcase-card img {
  width: 100%;
  height: 130px;
  object-fit: cover;
  border-radius: 8px;
  display: block;
  transition: transform 0.3s ease;
}

.showcase-card img:hover {
  transform: scale(1.05);
}

/* LOOP */
@keyframes scrollY {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

/* MOBILE */
@media (max-width: 1024px) {
  .showcase-box {
    height: 300px !important;
  }

  .showcase-card img {
    height: 120px;
  }

  .showcase-track {
    animation-duration: 40s;
  }
}
</style>
