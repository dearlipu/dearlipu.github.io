---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-stretch">

          <!-- LEFT -->
          <div class="lg:col-span-4 flex flex-col">
          
            <!-- TITLE -->
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              What I Offer.
            </h2>
          
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />

            <!-- SCROLL BOX -->
            <div class="mt-8 relative flex-1 overflow-hidden rounded-2xl border bg-gray-50">
          
              <!-- FADE TOP -->
              <div class="fade-top"></div>
          
              <!-- TRACK -->
              <div class="vertical-track">
                
                {[...siteConfig.projects, ...siteConfig.projects].map((p) => (
                  <div class="project-card">
                    
                    <div class="image-stack">
                      {(p.images || []).map((img) => (
                        <img src={img} alt={p.name} loading="lazy" />
                      ))}
                    </div>

                  </div>
                ))}
          
              </div>
          
              <!-- FADE BOTTOM -->
              <div class="fade-bottom"></div>
          
            </div>
          
          </div>

          <!-- RIGHT -->
          <div class="lg:col-span-8 space-y-8">

            {siteConfig.education.map((edu, index) => (

              <div class="bg-gray-50 rounded-xl border border-gray-200 
                          flex flex-col md:flex-row overflow-hidden 
                          transition-all duration-300 hover:shadow-md">

                <!-- TEXT -->
                <div class="flex-1 p-5 md:p-6">

                  <div class="mb-4">
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                      {edu.degree}
                    </h3>

                    <p
                      class="text-base sm:text-lg"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      {edu.school}
                    </p>
                  </div>

                  <ul class="space-y-2">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3"></span>
                        <span class="text-sm sm:text-base text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>

                </div>

                <!-- IMAGE -->
                <div class="md:w-[320px] w-full aspect-[4/3] md:aspect-auto flex-shrink-0">

                  <div class="image-full">
                    <img 
                      src={`/images/edu-${index + 1}.gif`} 
                      alt={edu.degree} 
                      loading="lazy"
                    />
                  </div>

                </div>

              </div>

            ))}

          </div>
        </div>
      </div>
    </section>
  )
}

<style>
.image-full {
  width: 100%;
  height: 100%;
  overflow: hidden;

  clip-path: polygon(
    20% 0,
    100% 0,
    100% 100%,
    0% 100%,
    0% 25%
  );
}

.image-full img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* TRACK */
.vertical-track {
  display: flex;
  flex-direction: column;
  animation: scrollY 25s linear infinite;
  will-change: transform;
}

/* CARD */
.project-card {
  padding: 10px;
}

/* MULTI IMAGE */
.image-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.image-stack img {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 14px;
  display: block;
  transition: transform 0.3s ease;
}

.image-stack img:hover {
  transform: scale(1.04);
}

/* ANIMATION (perfect loop) */
@keyframes scrollY {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(-50%);
  }
}

/* FADE */
.fade-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 60px;
  background: linear-gradient(to bottom, #f9fafb, transparent);
  z-index: 10;
}

.fade-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 60px;
  background: linear-gradient(to top, #f9fafb, transparent);
  z-index: 10;
}

/* PAUSE ON HOVER */
.vertical-track:hover {
  animation-play-state: paused;
}

/* MOBILE FIX */
@media (max-width: 1024px) {
  .vertical-track {
    animation-duration: 35s;
  }

  .image-stack img {
    height: 140px;
  }
}
</style>
