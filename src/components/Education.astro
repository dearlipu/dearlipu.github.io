---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

          <!-- LEFT -->
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              What I Offer.
            </h2>

            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />

            <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
              Creative work that looks professional and gets real results.
            </p>
          </div>

          <!-- RIGHT -->
          <div class="lg:col-span-8 space-y-8">

            {siteConfig.education.map((edu, index) => (

              <div class="bg-gray-50 rounded-xl border border-gray-200 
                          flex flex-col md:flex-row overflow-hidden 
                          transition-all duration-300 hover:shadow-md">

                <!-- TEXT -->
                <div class="flex-1 p-5 md:p-6">

                  <div class="mb-4">
                    <h3 class="text-lg sm:text-xl font-semibold text-gray-900">
                      {edu.degree}
                    </h3>

                    <p
                      class="text-base sm:text-lg"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      {edu.school}
                    </p>
                  </div>

                  <ul class="space-y-2 achievements">
                    {edu.achievements.map((achievement, i) => (
                      <li class={`flex items-start extra ${i > 2 ? "collapsed" : ""}`}>
                        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mt-2 mr-3"></span>
                        <span class="text-sm sm:text-base text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>
                  
                  <button class="toggle-btn mt-3 text-sm font-medium"
                    style={`color: ${siteConfig.accentColor}`}
                  >
                    + More details
                  </button>

                </div>

                <!-- IMAGE -->
                <div class="md:w-[320px] w-full aspect-[4/3] md:aspect-auto flex-shrink-0">

                  <div class="image-full">
                    <img 
                      src={`/images/edu-${index + 1}.gif`} 
                      alt={edu.degree} 
                    />
                  </div>

                </div>

              </div>

            ))}

          </div>
        </div>
      </div>
    </section>
  )
}

<style>
.image-full {
  width: 100%;
  height: 100%;
  overflow: hidden;

  /* clean angled cut */
  clip-path: polygon(
    20% 0,
    100% 0,
    100% 100%,
    0% 100%,
    0% 25%
  );
}

.image-full img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.extra {
  max-height: 40px;
  opacity: 1;
  overflow: hidden;
  transition: all 0.35s ease;
}

.extra.collapsed {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
}
</style>

<script>
  const cards = document.querySelectorAll(".bg-gray-50");
  let activeCard = null;

  cards.forEach(card => {
    const btn = card.querySelector(".toggle-btn");
    const extras = card.querySelectorAll(".extra");

    if (!btn) return;

    function openCard() {
      // close other card
      if (activeCard && activeCard !== card) {
        activeCard.close();
      }

      extras.forEach(el => el.classList.remove("collapsed"));
      btn.textContent = "Show less";

      activeCard = {
        el: card,
        close: closeCard
      };
    }

    function closeCard() {
      extras.forEach(el => el.classList.add("collapsed"));
      btn.textContent = "+ More details";

      if (activeCard?.el === card) {
        activeCard = null;
      }
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();

      const isOpen = !extras[0].classList.contains("collapsed");
      isOpen ? closeCard() : openCard();
    });
  });
</script>
