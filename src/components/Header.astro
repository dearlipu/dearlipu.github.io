---
const navItems = [
  { label: "Work", href: "#work" },
  { label: "Services", href: "#services" },
  { label: "Process", href: "#process" },
  { label: "Pricing", href: "#pricing" },
  { label: "Testimonials", href: "#testimonials" },
  { label: "FAQ", href: "#faq" },
  { label: "Contact", href: "#contact" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/60 bg-white/75 backdrop-blur-xl">
  <div class="section-shell flex h-[72px] items-center justify-between">
    <a href="#hero" class="text-sm font-semibold tracking-[0.16em] text-gray-900">DEARLIPU</a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={item.href} class="text-sm font-medium text-gray-600 transition hover:text-gray-950">
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#contact"
      class="rounded-full bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-indigo-600"
    >
      Start a Project
    </a>
  </div>
</header>
