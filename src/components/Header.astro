---
import { siteConfig } from "../config";

const navItems = [
  { label: "About", href: "#about", enabled: true },
  { label: "Projects", href: "#projects", enabled: Boolean(siteConfig.projects?.length) },
  { label: "Services", href: "#services", enabled: Boolean(siteConfig.services?.length) },
  { label: "Pricing", href: "#pricing", enabled: true },
  { label: "Reviews", href: "#testimonials", enabled: true },
  { label: "Contact", href: "#contact", enabled: true },
];

const legalItems = [
  { label: "FAQs", href: "/faq" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
];
---

<header id="header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300 bg-transparent">
  <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
    <div class="header-shell flex items-center justify-between rounded-2xl px-3 py-2 md:px-4">
      <a href="#" class="brand-link" aria-label="Go to top">
        <span class="brand-dot" style={`background-color: ${siteConfig.accentColor}`}></span>
        <span class="brand-text">@dearlipu</span>
      </a>

      <nav class="hidden md:block" aria-label="Desktop navigation">
        <ul class="flex items-center gap-6">
          {navItems.filter((item) => item.enabled).map((item) => <li><a href={item.href} class="nav-link">{item.label}</a></li>)}
        </ul>
      </nav>

      <a href="#contact" class="hidden md:inline-flex contact-cta" style={`--accent: ${siteConfig.accentColor}`}>
        Start Project
      </a>

      <button
        id="menuBtn"
        class="md:hidden inline-flex items-center gap-2 rounded-full bg-[#101828] px-4 py-2 text-sm font-semibold text-white shadow-lg transition active:scale-95"
        type="button"
        aria-expanded="false"
        aria-controls="menuPanel"
      >
        Menu
        <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path id="iconPath" stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="menuPanel"
    class="fixed right-4 top-20 z-50 w-[90%] max-w-sm rounded-3xl border border-gray-700 bg-[#101828] p-6 text-white shadow-2xl opacity-0 scale-90 translate-y-6 pointer-events-none origin-[90%_-10px] transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
  >
    <nav aria-label="Mobile navigation">
      <ul class="text-lg">
        {navItems.filter((item) => item.enabled).map((item) => (
          <li class="menu-item">
            <a href={item.href} class="menu-link">
              {item.label}
              <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </a>
          </li>
        ))}

        {legalItems.map((item) => (
          <li class="menu-item">
            <a href={item.href} class="menu-link">
              {item.label}
              <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"></path>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("header");
    const btn = document.getElementById("menuBtn");
    const panel = document.getElementById("menuPanel");
    const icon = document.getElementById("menuIcon");
    const path = document.getElementById("iconPath");

    if (!header || !btn || !panel || !icon || !path) return;

    let open = false;

    function openMenu() {
      panel.classList.remove("opacity-0", "scale-90", "translate-y-6", "pointer-events-none");
      panel.classList.add("opacity-100", "scale-100", "translate-y-0");
      icon.style.transform = "rotate(180deg)";
      path.setAttribute("d", "M6 6l12 12M6 18L18 6");
      btn.setAttribute("aria-expanded", "true");
      open = true;
    }

    function closeMenu() {
      panel.classList.add("opacity-0", "scale-90", "translate-y-6", "pointer-events-none");
      panel.classList.remove("opacity-100", "scale-100", "translate-y-0");
      icon.style.transform = "rotate(0deg)";
      path.setAttribute("d", "M12 5v14M5 12h14");
      btn.setAttribute("aria-expanded", "false");
      open = false;
    }

    btn.addEventListener("click", () => {
      open ? closeMenu() : openMenu();
    });

    document.addEventListener("click", (event) => {
      if (!open) return;
      const target = event.target;
      if (target instanceof Node && !panel.contains(target) && !btn.contains(target)) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && open) closeMenu();
    });

    document.querySelectorAll('a[href^="#"]').forEach((link) => {
      link.addEventListener("click", function (event) {
        event.preventDefault();
        const targetSelector = this.getAttribute("href");
        if (!targetSelector) return;

        const target = document.querySelector(targetSelector);
        if (target) {
          const y = target.getBoundingClientRect().top + window.scrollY - 90;
          window.scrollTo({ top: y, behavior: "smooth" });
        }

        closeMenu();
      });
    });

    window.addEventListener("scroll", () => {
      if (open) closeMenu();
      if (window.scrollY > 50) {
        header.classList.add("header-scrolled");
      } else {
        header.classList.remove("header-scrolled");
      }
    });
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }

  .header-shell {
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(229, 231, 235, 0.85);
    box-shadow: 0 6px 25px rgba(15, 23, 42, 0.06);
  }

  .header-scrolled .header-shell {
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.1);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #111827;
  }

  .brand-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    box-shadow: 0 0 0 4px rgba(29, 78, 216, 0.12);
  }

  .brand-text {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .nav-link {
    font-size: 0.92rem;
    font-weight: 600;
    color: #374151;
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: #111827;
    outline: none;
  }

  .contact-cta {
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid #d1d5db;
    background: #fff;
    padding: 0.52rem 0.95rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #111827;
    transition: transform 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .contact-cta:hover,
  .contact-cta:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
    outline: none;
  }

  .menu-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.25s ease;
  }

  .menu-item:first-child .menu-link {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .menu-link:hover {
    opacity: 0.8;
    transform: translateX(4px);
  }

  .arrow-icon {
    width: 22px;
    height: 22px;
    stroke: white;
    stroke-width: 2;
    opacity: 0.9;
    transition: transform 0.25s ease;
  }

  .menu-link:hover .arrow-icon {
    transform: translate(3px, -3px);
  }

  .menu-item {
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 0.4s ease forwards;
  }

  .menu-item:nth-child(1) {
    animation-delay: 0.05s;
  }

  .menu-item:nth-child(2) {
    animation-delay: 0.1s;
  }

  .menu-item:nth-child(3) {
    animation-delay: 0.15s;
  }

  .menu-item:nth-child(4) {
    animation-delay: 0.2s;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
