---
import { siteConfig } from "../config";
const nav = [["Work","/#work"],["Services","/#services"],["Pricing","/#pricing"],["Contact","/contact"]];
---
<header class="site-header">
  <a class="brand" href="/" aria-label={`${siteConfig.name} home`}><span>DearLipu</span><em>Studio</em></a>
  <nav aria-label="Primary navigation">{nav.map(([label,href])=><a href={href}>{label}</a>)}</nav>
  <a class="header-cta" href="/contact">Start a Project</a>
</header>
<style>
.site-header{position:fixed;z-index:50;top:16px;left:50%;transform:translateX(-50%);width:min(1180px,calc(100% - 32px));display:flex;align-items:center;justify-content:space-between;gap:16px;padding:10px 12px 10px 18px;border:1px solid #e5e7eb;border-radius:999px;background:rgba(255,255,255,.82);backdrop-filter:blur(18px);box-shadow:0 18px 40px #10182812}.brand{font-weight:900;letter-spacing:-.04em}.brand span{color:#101828}.brand em{font-style:normal;color:#1d4ed8}nav{display:flex;gap:22px}nav a{font-size:14px;font-weight:800;color:#475467}.header-cta{display:inline-flex;align-items:center;min-height:40px;padding:0 16px;border-radius:999px;background:#101828;color:white;font-size:14px;font-weight:900}@media(max-width:760px){nav{display:none}.site-header{top:10px}}@media(prefers-color-scheme:dark){.site-header{background:rgba(15,23,42,.82);border-color:#1e293b}.brand span{color:#fff}nav a{color:#cbd5e1}.header-cta{background:#1d4ed8}}
</style>
