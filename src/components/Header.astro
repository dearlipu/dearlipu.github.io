---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects?.length > 0;
const hasEducation = siteConfig.education?.length > 0;
---

<header id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">

  <!-- MOBILE BUTTON -->
  <div class="flex md:hidden justify-end px-6 py-4">
    <button id="menuBtn"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium 
      bg-[#101828] text-white shadow-lg transition active:scale-90">

      Menu

      <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 transition-transform duration-300"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        
        <path id="iconPath"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 5v14M5 12h14" />
      </svg>
    </button>
  </div>

  <!-- OVERLAY -->
  <div id="menuOverlay"
    class="fixed inset-0 bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 z-40"></div>

  <!-- MENU -->
  <div id="menuPanel"
    class="fixed top-20 right-4 w-[90%] max-w-sm bg-[#101828] text-white rounded-3xl p-6 shadow-2xl border border-gray-700 z-50
    opacity-0 scale-90 translate-y-6 pointer-events-none origin-[90%_-10px]
    transition-all duration-300">

    <ul class="text-lg">

      <li class="menu-item">
        <a href="#about" class="menu-link">
          <span>About</span>
          <svg class="arrow-icon" viewBox="0 0 24 24">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

      {hasProjects && (
        <li class="menu-item">
          <a href="#projects" class="menu-link">
            <span>Projects</span>
            <svg class="arrow-icon" viewBox="0 0 24 24">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        </li>
      )}

      {hasEducation && (
        <li class="menu-item">
          <a href="#education" class="menu-link">
            <span>Services</span>
            <svg class="arrow-icon" viewBox="0 0 24 24">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        </li>
      )}

      <li class="menu-item">
        <a href="#pricing" class="menu-link">
          <span>Pricing</span>
          <svg class="arrow-icon" viewBox="0 0 24 24">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

    </ul>
  </div>

  <!-- DESKTOP -->
  <nav class="hidden md:block max-w-7xl mx-auto px-8 py-4">
    <ul class="flex gap-8 justify-center">
      <li><a href="#about" class="nav-link">About</a></li>
      {hasProjects && <li><a href="#projects" class="nav-link">Projects</a></li>}
      {hasEducation && <li><a href="#education" class="nav-link">Services</a></li>}
      <li><a href="#pricing" class="nav-link">Pricing</a></li>
    </ul>
  </nav>

</header>

<!-- 🔥 IMPORTANT: client-only script -->
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {

    const btn = document.getElementById("menuBtn");
    const panel = document.getElementById("menuPanel");
    const overlay = document.getElementById("menuOverlay");
    const icon = document.getElementById("menuIcon");
    const path = document.getElementById("iconPath");

    if (!btn) return;

    let open = false;

    function openMenu() {
      panel.classList.remove("opacity-0","scale-90","translate-y-6","pointer-events-none");
      panel.classList.add("opacity-100","scale-100","translate-y-0");

      overlay.classList.remove("opacity-0","pointer-events-none");
      overlay.classList.add("opacity-100");

      icon.style.transform = "rotate(180deg)";
      path.setAttribute("d","M6 6l12 12M6 18L18 6");

      open = true;
    }

    function closeMenu() {
      panel.classList.add("opacity-0","scale-90","translate-y-6","pointer-events-none");
      panel.classList.remove("opacity-100","scale-100","translate-y-0");

      overlay.classList.add("opacity-0","pointer-events-none");

      icon.style.transform = "rotate(0deg)";
      path.setAttribute("d","M12 5v14M5 12h14");

      open = false;
    }

    btn.addEventListener("click", () => open ? closeMenu() : openMenu());
    overlay.addEventListener("click", closeMenu);

  });
</script>

<style>
.menu-link {
  display: flex;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.arrow-icon {
  width: 20px;
  height: 20px;
  stroke: white;
  stroke-width: 2;
}

.nav-link {
  color: #4b5563;
  transition: 0.25s;
}
.nav-link:hover {
  color: black;
}
</style>
