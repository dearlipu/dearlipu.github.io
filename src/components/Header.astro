---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<header id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">

  <!-- MOBILE BUTTON -->
  <div class="flex md:hidden justify-end px-6 py-4 relative z-[9999]">
    <button id="menuBtn"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium 
      bg-[#101828] text-white shadow-lg active:scale-95 transition-all duration-300">

      Menu

      <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 transition-transform duration-300"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        
        <path id="iconPath"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 5v14M5 12h14" />
      </svg>
    </button>
  </div>


  <!-- BACKDROP -->
  <div id="menuBackdrop"
    class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none transition duration-300 z-40">
  </div>


  <!-- MENU -->
  <div id="menuPanel"
    class="fixed top-20 right-4 w-[90%] max-w-sm bg-[#04060a] text-white rounded-3xl p-6 shadow-2xl border border-gray-700 z-50
    
    opacity-0 scale-90 translate-y-4 pointer-events-none
    transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] origin-top-right">

    <ul class="text-lg space-y-1">

      <!-- ITEM -->
      <li><a href="#about" class="menu-link">Home {arrow}</a></li>
      <li><a href="#projects" class="menu-link">Services {arrow}</a></li>
      <li><a href="#experience" class="menu-link">Benefits {arrow}</a></li>
      <li><a href="#education" class="menu-link">Work {arrow}</a></li>
      <li><a href="#pricing" class="menu-link">Pricing {arrow}</a></li>
      <li><a href="#cta" class="menu-link">Contact {arrow}</a></li>

    </ul>
  </div>


  <!-- DESKTOP -->
  <nav class="hidden md:block max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li><a href="#about">About</a></li>
      {hasProjects && <li><a href="#projects">Projects</a></li>}
      {hasExperience && <li><a href="#experience">Client Work</a></li>}
      {hasEducation && <li><a href="#education">Expertise</a></li>}
      <li><a href="#pricing">Pricing</a></li>
    </ul>
  </nav>

</header>


<script>
  const header = document.getElementById("header");
  const btn = document.getElementById("menuBtn");
  const panel = document.getElementById("menuPanel");
  const backdrop = document.getElementById("menuBackdrop");
  const icon = document.getElementById("menuIcon");
  const path = document.getElementById("iconPath");

  let open = false;

  function openMenu() {
    panel.classList.remove("opacity-0","scale-90","translate-y-4","pointer-events-none");
    panel.classList.add("opacity-100","scale-100","translate-y-0");

    backdrop.classList.remove("opacity-0","pointer-events-none");
    backdrop.classList.add("opacity-100");

    icon.style.transform = "rotate(180deg)";
    path.setAttribute("d","M6 6l12 12M6 18L18 6");

    btn.classList.remove("bg-[#101828]", "text-white");
    btn.classList.add("bg-white", "text-black");

    document.body.style.overflow = "hidden";

    open = true;
  }

  function closeMenu() {
    panel.classList.add("opacity-0","scale-90","translate-y-4","pointer-events-none");
    panel.classList.remove("opacity-100","scale-100","translate-y-0");

    backdrop.classList.add("opacity-0","pointer-events-none");
    backdrop.classList.remove("opacity-100");

    icon.style.transform = "rotate(0deg)";
    path.setAttribute("d","M12 5v14M5 12h14");

    btn.classList.add("bg-[#101828]", "text-white");
    btn.classList.remove("bg-white", "text-black");

    document.body.style.overflow = "";

    open = false;
  }

  btn.addEventListener("click", () => {
    open ? closeMenu() : openMenu();
  });

  backdrop.addEventListener("click", closeMenu);

  // CLOSE ON LINK CLICK
  document.querySelectorAll(".menu-link").forEach(link => {
    link.addEventListener("click", closeMenu);
  });

  // HEADER BLUR ON SCROLL
  window.addEventListener("scroll", () => {
    if (window.scrollY > 100) {
      header.classList.add("bg-white/80", "backdrop-blur-sm");
      header.classList.remove("bg-transparent");
    } else {
      header.classList.remove("bg-white/80", "backdrop-blur-sm");
      header.classList.add("bg-transparent");
    }
  });
</script>


<style>
.menu-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  transition: all 0.25s ease;
}

.menu-link:hover {
  opacity: 0.7;
  transform: translateX(4px);
}

/* YOUR EXACT SVG STYLE */
.menu-link::after {
  content: "";
}

/* Arrow */
.menu-link svg {
  width: 22px;
  height: 22px;
  stroke: white;
  stroke-width: 2;
  margin-left: 10px;
}

.menu-link:hover svg {
  transform: translate(3px, -3px);
}
</style>
