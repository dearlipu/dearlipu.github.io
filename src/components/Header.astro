---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
// const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<header id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">

  <!-- MOBILE BUTTON -->
  <div class="flex md:hidden justify-end px-6 py-4">
    <button id="menuBtn"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium 
      bg-[#101828] text-white shadow-lg transition active:scale-95">

      Menu

      <svg id="menuIcon" xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 transition-transform duration-300"
        fill="none" viewBox="0 0 24 24"
        stroke="currentColor" stroke-width="2">
        
        <path id="iconPath"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 5v14M5 12h14" />
      </svg>
    </button>
  </div>

  <!-- FLOATING MENU -->
  <div id="menuPanel"
    class="fixed top-20 right-4 w-[90%] max-w-sm bg-[#101828] text-white rounded-3xl p-6 shadow-2xl border border-gray-700 z-50
    
    opacity-0 scale-90 translate-y-6 pointer-events-none origin-[90%_-10px]
    transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]">

    <ul class="text-lg">

      <li class="menu-item">
        <a href="#about" class="menu-link">
          About
          <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#projects" class="menu-link">
          Projects
          <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#education" class="menu-link">
          Services
          <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#pricing" class="menu-link">
          Pricing
          <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

      <li class="menu-item">
        <a href="#testimonials" class="menu-link">
          Review
          <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </li>

    </ul>
  </div>

  <!-- DESKTOP NAV -->
  <nav class="hidden md:block max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li><a href="#about" class="nav-link">About</a></li>
      {hasProjects && <li><a href="#projects" class="nav-link">Projects</a></li>}
      {hasEducation && <li><a href="#education" class="nav-link">Services</a></li>}
      <li><a href="#pricing" class="nav-link">Pricing</a></li>
      <li><a href="#testimonials" class="nav-link">Review</a></li>
    </ul>
  </nav>

</header>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {

  const header = document.getElementById("header");
  const btn = document.getElementById("menuBtn");
  const panel = document.getElementById("menuPanel");
  const icon = document.getElementById("menuIcon");
  const path = document.getElementById("iconPath");

  let open = false;

  function openMenu() {
    panel.classList.remove("opacity-0","scale-90","translate-y-6","pointer-events-none");
    panel.classList.add("opacity-100","scale-100","translate-y-0");

    icon.style.transform = "rotate(180deg)";
    path.setAttribute("d","M6 6l12 12M6 18L18 6");

    open = true;
  }

  function closeMenu() {
    panel.classList.add("opacity-0","scale-90","translate-y-6","pointer-events-none");
    panel.classList.remove("opacity-100","scale-100","translate-y-0");

    icon.style.transform = "rotate(0deg)";
    path.setAttribute("d","M12 5v14M5 12h14");

    open = false;
  }

  btn.addEventListener("click", () => {
    open ? closeMenu() : openMenu();
  });

  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener("click", function(e) {
      e.preventDefault();

      const target = document.querySelector(this.getAttribute("href"));

      if (target) {
        const y = target.getBoundingClientRect().top + window.scrollY - 80;

        window.scrollTo({
          top: y,
          behavior: "smooth"
        });
      }

      closeMenu();
    });
  });

  // scroll header effect
  window.addEventListener("scroll", () => {
    if (open) closeMenu();

    if (window.scrollY > 100) {
      header.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });

});
</script>

<style>
html {
  scroll-behavior: smooth;
}

.menu-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  transition: all 0.25s ease;
}

/* only first item gets top border */
.menu-item:first-child .menu-link {
  border-top: 1px solid rgba(255,255,255,0.06);
}

.menu-link:hover {
  opacity: 0.7;
  transform: translateX(4px);
}

.arrow-icon {
  width: 22px;
  height: 22px;
  stroke: white;
  stroke-width: 2;
  opacity: 0.9;
  transition: transform 0.25s ease;
}

.menu-link:hover .arrow-icon {
  transform: translate(3px, -3px);
}

.menu-item {
  opacity: 0;
  transform: translateY(10px);
  animation: fadeUp 0.4s ease forwards;
}

.menu-item:nth-child(1) { animation-delay: 0.05s; }
.menu-item:nth-child(2) { animation-delay: 0.1s; }
.menu-item:nth-child(3) { animation-delay: 0.15s; }
.menu-item:nth-child(4) { animation-delay: 0.2s; }

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
