---
import { siteConfig } from "../config";
---

<section id="hero" class="relative isolate overflow-hidden px-6 pb-16 pt-28 sm:px-10 md:px-14 lg:px-20 lg:pt-36" style={`--accent: ${siteConfig.accentColor}`}>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 lg:grid-cols-12 lg:items-center lg:gap-14">
    <div class="lg:col-span-7">
      <p class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-gray-700 backdrop-blur-sm">
        <span class="inline-block h-2 w-2 rounded-full bg-green-500"></span>
        Available for new projects
      </p>

      <h1 class="mt-5 text-balance text-4xl font-bold leading-tight text-gray-900 sm:text-5xl md:text-6xl lg:text-7xl">
        I’m <span style={`color: ${siteConfig.accentColor}`}>{siteConfig.name}</span> —
        <br class="hidden sm:block" />
        visual design that helps your brand stand out.
      </h1>

      <p class="mt-5 max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg md:text-xl">
        {siteConfig.title}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#contact" class="hero-cta primary" style={`--accent: ${siteConfig.accentColor}`}>Start a Project</a>
        <a href="#services" class="hero-cta secondary">View Services</a>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-3 text-gray-700">
        {
          siteConfig.social?.email && (
            <a href={`mailto:${siteConfig.social.email}`} data-email={siteConfig.social.email} class="email-trigger social-icon" aria-label="Email">
              ✉️
            </a>
          )
        }
        {
          siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon">◎</a>
          )
        }
        {
          siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="social-icon">𝕏</a>
          )
        }
        {
          siteConfig.social?.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-icon">▶</a>
          )
        }
      </div>
    </div>

    <div class="lg:col-span-5">
      <div class="hero-card">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">Quick Snapshot</p>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <div class="metric-box">
            <p class="metric-value">100+</p>
            <p class="metric-label">Projects Delivered</p>
          </div>
          <div class="metric-box">
            <p class="metric-value">4.9/5</p>
            <p class="metric-label">Client Rating</p>
          </div>
          <div class="metric-box">
            <p class="metric-value">Fast</p>
            <p class="metric-label">Turnaround</p>
          </div>
          <div class="metric-box">
            <p class="metric-value">Multi</p>
            <p class="metric-label">Design Formats</p>
          </div>
        </div>

        <p class="mt-5 rounded-xl border border-gray-200 bg-gray-50 px-3 py-2 text-sm leading-relaxed text-gray-600">
          From social content and video editing to branding and print systems — built for clarity, consistency, and conversion.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    min-height: 85vh;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(900px 420px at -5% 0%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 60%),
      radial-gradient(750px 390px at 110% 20%, rgba(15, 23, 42, 0.12), transparent 60%);
  }

  .hero-cta {
    border-radius: 999px;
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
    font-weight: 700;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .hero-cta.primary {
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .hero-cta.primary:hover,
  .hero-cta.primary:focus-visible {
    transform: translateY(-1px);
    filter: brightness(0.95);
    outline: none;
  }

  .hero-cta.secondary {
    border: 1px solid #d1d5db;
    background: #fff;
    color: #111827;
  }

  .hero-cta.secondary:hover,
  .hero-cta.secondary:focus-visible {
    transform: translateY(-1px);
    border-color: #9ca3af;
    outline: none;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid #d1d5db;
    background: #fff;
    font-size: 0.95rem;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .social-icon:hover,
  .social-icon:focus-visible {
    transform: translateY(-1px);
    border-color: var(--accent);
    color: var(--accent);
    outline: none;
  }

  .hero-card {
    border-radius: 1.1rem;
    border: 1px solid rgba(209, 213, 219, 0.8);
    background: rgba(255, 255, 255, 0.8);
    padding: 1rem;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
    backdrop-filter: blur(8px);
  }

  .metric-box {
    border-radius: 0.9rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, #fff, #f8fafc);
    padding: 0.75rem;
  }

  .metric-value {
    font-size: 1.05rem;
    font-weight: 800;
    color: #111827;
  }

  .metric-label {
    margin-top: 0.15rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }
</style>
