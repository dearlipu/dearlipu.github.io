---
import { siteConfig } from "../config";

const heroMetrics = [
  { value: "48", suffix: "h", label: "first design direction" },
  { value: "3", suffix: "x", label: "visual formats per campaign" },
  { value: "100", suffix: "%", label: "ready-to-publish files" },
];
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white px-6 pb-32 pt-28 sm:px-10 sm:py-24 md:min-h-screen md:px-14 lg:px-20"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div
    class="absolute inset-0 -z-20"
    style={`background: radial-gradient(ellipse 800px 1000px at 5% 0%, ${siteConfig.accentColor}33 0%, ${siteConfig.accentColor}18 32%, rgba(255,255,255,.7) 66%, #fff 100%)`}
  ></div>
  <div class="hero-grid absolute inset-0 -z-10 opacity-70"></div>
  <div class="blob blob-one" aria-hidden="true"></div>
  <div class="blob blob-two" aria-hidden="true"></div>

  <div class="mx-auto grid min-h-[72vh] max-w-6xl items-center gap-12 lg:grid-cols-[1.04fr_.96fr]">
    <div class="relative z-10">
      <p class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-white/80 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-blue-700 shadow-sm animate-fade-in">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        Available for creative work
      </p>

      <h2 class="mt-8 text-pretty text-xl font-bold tracking-tight text-gray-700 sm:text-2xl md:text-4xl animate-fade-in animation-delay-100">
        Hey! <span class="wave-hand">👋</span>
      </h2>
      <h1 class="mt-4 max-w-4xl text-pretty text-5xl font-extrabold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl xl:text-8xl animate-fade-in animation-delay-200">
        I turn ideas into <span class="text-gradient">visual stories people remember.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-pretty text-base font-medium leading-8 text-gray-600 sm:text-lg md:text-xl animate-fade-in animation-delay-300">
        Strategy, design, video, and motion assets that feel connected from the first scroll to the final click.
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row animate-fade-in animation-delay-400">
        <a href="#contact" class="hero-btn hero-btn-primary">Start a project</a>
        <a href="#services" class="hero-btn hero-btn-secondary">See the journey</a>
      </div>

      <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3 animate-fade-in animation-delay-500">
        {heroMetrics.map((metric) => (
          <div class="rounded-2xl border border-gray-200 bg-white/75 p-3 shadow-sm backdrop-blur">
            <dt class="text-2xl font-extrabold text-gray-900 sm:text-3xl">
              <span class="hero-counter" data-target={metric.value}>0</span><span>{metric.suffix}</span>
            </dt>
            <dd class="mt-1 text-xs font-medium leading-snug text-gray-500 sm:text-sm">{metric.label}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="relative min-h-[460px] animate-fade-in animation-delay-400 lg:min-h-[560px]" aria-label="Creative work preview collage">
      <div class="phone-card floating-card">
        <div class="phone-top"></div>
        <img src="/projects/p1-1.gif" alt="Animated social design preview" class="h-full w-full rounded-[1.75rem] object-cover" decoding="async" />
      </div>
      <div class="shot-card shot-card-one floating-card animation-float-delay">
        <img src="/projects/p1-4.webp" alt="Brand visual preview" class="h-full w-full object-cover" decoding="async" />
      </div>
      <div class="shot-card shot-card-two floating-card">
        <img src="/projects/p1-7.webp" alt="Campaign design preview" class="h-full w-full object-cover" decoding="async" />
      </div>
      <div class="insight-card floating-card animation-float-delay-2">
        <span class="text-xs font-bold uppercase tracking-[0.16em] text-blue-700">Creative system</span>
        <p class="mt-2 text-lg font-extrabold text-gray-900">Hook → Story → Scroll-stopping asset</p>
        <div class="mt-4 flex gap-2">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes wave { 0%, 60%, 100% { transform: rotate(0deg); } 10% { transform: rotate(14deg); } 20% { transform: rotate(-8deg); } 30% { transform: rotate(14deg); } 40% { transform: rotate(-4deg); } 50% { transform: rotate(10deg); } }
  @keyframes float { 0%, 100% { transform: translateY(0) rotate(var(--rotate, 0deg)); } 50% { transform: translateY(-14px) rotate(var(--rotate, 0deg)); } }
  @keyframes blobMove { 0%, 100% { transform: translate3d(0,0,0) scale(1); } 50% { transform: translate3d(18px,-24px,0) scale(1.08); } }

  .animate-fade-in { animation: fadeIn .8s ease-out forwards; opacity: 0; }
  .animation-delay-100 { animation-delay: .1s; }
  .animation-delay-200 { animation-delay: .2s; }
  .animation-delay-300 { animation-delay: .3s; }
  .animation-delay-400 { animation-delay: .4s; }
  .animation-delay-500 { animation-delay: .5s; }
  .wave-hand { display: inline-block; transform-origin: 70% 70%; animation: wave 1.8s ease-in-out infinite; }
  .text-gradient { background: linear-gradient(90deg, #111827, var(--accent-color), #06b6d4); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .hero-grid { background-image: linear-gradient(rgba(15,23,42,.06) 1px, transparent 1px), linear-gradient(90deg, rgba(15,23,42,.06) 1px, transparent 1px); background-size: 120px 120px; mask-image: radial-gradient(80% 70% at 50% 20%, #000, transparent); }
  .blob { position: absolute; border-radius: 999px; filter: blur(8px); opacity: .24; animation: blobMove 7s ease-in-out infinite; }
  .blob-one { right: 11%; top: 16%; width: 10rem; height: 10rem; background: #60a5fa; }
  .blob-two { right: 28%; bottom: 14%; width: 7rem; height: 7rem; background: #22d3ee; animation-delay: -2s; }
  .hero-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: .9rem 1.2rem; font-weight: 800; transition: transform .2s ease, box-shadow .2s ease, background .2s ease; }
  .hero-btn:hover { transform: translateY(-2px); }
  .hero-btn-primary { background: #0f172a; color: #fff; box-shadow: 0 18px 35px rgba(15,23,42,.18); }
  .hero-btn-primary:hover { background: var(--accent-color); }
  .hero-btn-secondary { border: 1px solid #d1d5db; background: rgba(255,255,255,.8); color: #111827; }
  .floating-card { animation: float 5.5s ease-in-out infinite; box-shadow: 0 24px 60px rgba(15,23,42,.16); }
  .animation-float-delay { animation-delay: -1.4s; }
  .animation-float-delay-2 { animation-delay: -2.4s; }
  .phone-card { position: absolute; right: 8%; top: 4%; height: 430px; width: 245px; overflow: hidden; border: 10px solid #111827; border-radius: 2.4rem; background: #111827; --rotate: 4deg; }
  .phone-top { position: absolute; left: 50%; top: .55rem; z-index: 2; height: .45rem; width: 4rem; transform: translateX(-50%); border-radius: 999px; background: #111827; }
  .shot-card { position: absolute; overflow: hidden; border: 8px solid #fff; border-radius: 1.6rem; background: #fff; }
  .shot-card-one { left: 0; top: 14%; height: 185px; width: 260px; --rotate: -5deg; }
  .shot-card-two { bottom: 4%; right: 0; height: 185px; width: 285px; --rotate: 3deg; }
  .insight-card { position: absolute; bottom: 16%; left: 7%; width: 270px; border: 1px solid rgba(229,231,235,.9); border-radius: 1.5rem; background: rgba(255,255,255,.88); padding: 1.1rem; backdrop-filter: blur(14px); --rotate: -2deg; }
  .insight-card span:not(:first-child), .insight-card div span { display: block; height: .45rem; flex: 1; border-radius: 999px; background: linear-gradient(90deg, var(--accent-color), #67e8f9); }
  @media (max-width: 1023px) { .phone-card { right: 18%; } .shot-card-one { left: 7%; } }
  @media (max-width: 640px) { .phone-card { right: 4%; height: 360px; width: 205px; } .shot-card { border-width: 6px; } .shot-card-one { left: -4%; width: 210px; height: 150px; } .shot-card-two { width: 225px; height: 145px; } .insight-card { left: 0; bottom: 20%; width: 225px; } }
</style>

<script>
  const heroCounters = document.querySelectorAll(".hero-counter");

  if (heroCounters.length) {
    const duration = 1300;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const frameIds = new WeakMap();

    const animateCounter = (counter) => {
      const target = Number(counter.getAttribute("data-target") || 0);

      if (prefersReducedMotion) {
        counter.textContent = target.toString();
        return;
      }

      const start = performance.now();

      const tick = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        counter.textContent = Math.floor(target * eased).toString();

        if (progress < 1) {
          frameIds.set(counter, requestAnimationFrame(tick));
        } else {
          counter.textContent = target.toString();
        }
      };

      counter.textContent = "0";
      frameIds.set(counter, requestAnimationFrame(tick));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const counter = entry.target;

          if (!(counter instanceof HTMLElement)) {
            return;
          }

          if (entry.isIntersecting) {
            animateCounter(counter);
          } else {
            const frameId = frameIds.get(counter);
            if (frameId) {
              cancelAnimationFrame(frameId);
            }
            counter.textContent = "0";
          }
        });
      },
      { threshold: 0.5 },
    );

    heroCounters.forEach((counter) => observer.observe(counter));
  }
</script>
