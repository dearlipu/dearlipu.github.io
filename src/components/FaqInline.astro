---
const faqs = [
  {
    question: "How fast can we start?",
    answer: "Most projects start within 3-5 business days after scope and timeline are confirmed.",
  },
  {
    question: "Do you handle both design and video in one package?",
    answer: "Yes. I can combine graphic design, editing, and motion into one streamlined workflow.",
  },
  {
    question: "What do you need from me before starting?",
    answer: "Your offer, audience context, references you like, and any current brand assets. I handle the structure from there.",
  },
  {
    question: "How do revisions work?",
    answer: "You get focused revision rounds per deliverable, so feedback stays clear and the project moves quickly.",
  },
];
---

<section id="faq" class="section-anchor py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">FAQ</p>
    <h2 class="section-title mt-5 max-w-3xl">Answers to the questions clients ask before booking.</h2>

    <div class="mt-10 space-y-4">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-[0_8px_24px_rgba(15,23,42,0.04)]">
            <summary class="cursor-pointer list-none pr-8 text-base font-semibold text-gray-900 marker:content-none">
              {faq.question}
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
