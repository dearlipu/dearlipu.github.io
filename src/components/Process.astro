---
const steps = [
  {
    step: "01",
    title: "Clarity call",
    text: "I map your audience, offer, and content goals so the creative direction is aligned from day one.",
  },
  {
    step: "02",
    title: "Creative direction",
    text: "I define references, layout system, and motion style before full production starts.",
  },
  {
    step: "03",
    title: "Production + feedback",
    text: "I deliver in focused batches with fast review loops, so decisions stay simple and momentum stays high.",
  },
  {
    step: "04",
    title: "Final delivery",
    text: "You receive platform-ready files, organized exports, and reusable templates where needed.",
  },
];
---

<section id="process" class="section-anchor bg-white py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">Process</p>
    <h2 class="section-title mt-5 max-w-3xl">A clean workflow that keeps quality high and communication simple.</h2>

    <ol class="mt-10 grid gap-4 md:grid-cols-2">
      {
        steps.map((item) => (
          <li class="rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_10px_24px_rgba(15,23,42,0.04)]">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-indigo-600">Step {item.step}</p>
            <h3 class="mt-2 text-xl font-semibold text-gray-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
