---
import { siteConfig } from "../config";
---

<footer class="relative bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">

      <!-- LEFT -->
      <div class="flex flex-col gap-2">
        <h3 class="footer-name text-2xl font-bold text-gray-800 relative inline-block footer-brand">
          <span class="name-front inline-flex items-center gap-1">
            @dearlipu
          </span>
          <span class="name-back">Saurav Panda</span>
        </h3>

        <p class="text-base text-gray-600">
          {siteConfig.title}
        </p>

        <!-- SOCIAL -->
        <div class="flex gap-x-6">
          <a href={`mailto:${siteConfig.social.email}`} class="text-gray-600 hover:text-black">Email</a>
          <a href={siteConfig.social.instagram} target="_blank" class="text-gray-600 hover:text-black">Instagram</a>
          <a href={siteConfig.social.twitter} target="_blank" class="text-gray-600 hover:text-black">Twitter</a>
          <a href={siteConfig.social.youtube} target="_blank" class="text-gray-600 hover:text-black">YouTube</a>
        </div>
      </div>

      <!-- RIGHT (UPDATED LINKS) -->
      <div class="flex flex-col md:items-end gap-4">

        <!-- POPUP LINKS -->
        <nav class="flex gap-x-6 flex-wrap justify-start md:justify-end">
          <button class="footer-link" data-modal="faq">FAQ</button>
          <button class="footer-link" data-modal="privacy">Privacy Policy</button>
          <button class="footer-link" data-modal="terms">Terms of Service</button>
          <button class="footer-link" data-modal="form">Contact</button>
        </nav>

        <p class="text-sm text-gray-500">
          © {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
        </p>
      </div>

    </div>
  </div>

  <!-- MODAL -->
  <div id="modal" class="fixed inset-0 z-[999] hidden items-center justify-center">

    <!-- BACKDROP -->
    <div id="modalBackdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- CONTENT -->
    <div class="relative bg-white w-[92%] max-w-2xl rounded-2xl p-6 md:p-8 shadow-xl z-10 animate-modal max-h-[85vh] overflow-y-auto">

      <!-- CLOSE -->
      <button id="closeModal" class="absolute top-4 right-4 text-gray-500 hover:text-black text-xl">
        ✕
      </button>

      <!-- DYNAMIC -->
      <div id="modalContent" class="text-gray-700 text-sm md:text-base"></div>

    </div>
  </div>

</footer>

<script>
  const modal = document.getElementById("modal");
  const content = document.getElementById("modalContent");
  const closeBtn = document.getElementById("closeModal");
  const backdrop = document.getElementById("modalBackdrop");

  // CONTENT SYSTEM (you can expand later)
  const data = {
    faq: `
      <h2 class="text-xl font-bold mb-4">FAQ</h2>
      <div class="space-y-3">
        <p><strong>How fast delivery?</strong><br/>Usually 1–2 days.</p>
        <p><strong>Revisions?</strong><br/>Depends on plan.</p>
      </div>
    `,
    privacy: `
      <h2 class="text-xl font-bold mb-4">Privacy Policy</h2>
      <p>Your data is safe. No selling or misuse.</p>
    `,
    terms: `
      <h2 class="text-xl font-bold mb-4">Terms of Service</h2>
      <p>Use responsibly. No misuse of content.</p>
    `,
    form: `
      <h2 class="text-xl font-bold mb-4">Contact</h2>
      <input placeholder="Your Email" class="border p-2 w-full mb-3 rounded"/>
      <textarea placeholder="Message" class="border p-2 w-full rounded"></textarea>
      <button class="mt-3 px-4 py-2 bg-black text-white rounded w-full">Send</button>
    `
  };

  document.querySelectorAll(".footer-link").forEach(btn => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.modal;
      content.innerHTML = data[key];

      modal.classList.remove("hidden");
      modal.classList.add("flex");

      document.body.style.overflow = "hidden"; // scroll lock
    });
  });

  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    document.body.style.overflow = "";
  }

  closeBtn.onclick = closeModal;
  backdrop.onclick = closeModal;

  // ESC KEY SUPPORT
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<style>
.footer-name { cursor: pointer; }
.footer-name .name-front, .footer-name .name-back {
  display: block;
  transition: opacity .25s, transform .25s;
}
.name-back {
  opacity:0;
  transform: translateY(6px);
  position:absolute;
  left:0;
  top:0;
}
.footer-name:hover .name-front {
  opacity:0;
  transform: translateY(-6px);
}
.footer-name:hover .name-back {
  opacity:1;
  transform: translateY(0);
}

/* LINKS */
.footer-link {
  font-size: 14px;
  color: #6b7280;
  transition: 0.2s;
}
.footer-link:hover {
  color: #111;
}

/* MODAL ANIMATION */
@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(10px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.animate-modal {
  animation: modalIn 0.25s ease;
}
</style>
