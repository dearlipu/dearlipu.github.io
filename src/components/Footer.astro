---
import { siteConfig } from "../config";

const quickLinks = [
  { label: "About", href: "#about" },
  { label: "Projects", href: "#projects" },
  { label: "Services", href: "#services" },
  { label: "Pricing", href: "#pricing" },
  { label: "Reviews", href: "#testimonials" },
  { label: "Contact", href: "#contact" },
];

const legalLinks = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "FAQs", href: "/faq" },
];
---

<footer class="relative border-t border-gray-200 bg-white/70 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-6 py-12 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-5">
        <a href="#" class="inline-flex items-center gap-2" aria-label="Back to top">
          <span class="h-2.5 w-2.5 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></span>
          <span class="text-lg font-bold text-gray-900">@dearlipu</span>
        </a>

        <p class="mt-4 max-w-md text-sm leading-relaxed text-gray-600 sm:text-base">{siteConfig.title}</p>

        <div class="mt-5 flex flex-wrap gap-3">
          {siteConfig.social?.email && (
            <a
              href={`mailto:${siteConfig.social.email}`}
              data-email={siteConfig.social.email}
              class="email-trigger social-pill"
              style={`--accent: ${siteConfig.accentColor}`}
            >
              Email
            </a>
          )}
          {siteConfig.social?.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="social-pill" style={`--accent: ${siteConfig.accentColor}`}>Instagram</a>
          )}
          {siteConfig.social?.twitter && (
            <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="social-pill" style={`--accent: ${siteConfig.accentColor}`}>X / Twitter</a>
          )}
          {siteConfig.social?.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class="social-pill" style={`--accent: ${siteConfig.accentColor}`}>YouTube</a>
          )}
        </div>
      </div>

      <div class="lg:col-span-7 grid grid-cols-1 gap-8 sm:grid-cols-2">
        <div>
          <h3 class="footer-heading">Quick Links</h3>
          <ul class="mt-3 space-y-2">
            {quickLinks.map((item) => (
              <li><a href={item.href} class="footer-link">{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="footer-heading">Legal</h3>
          <ul class="mt-3 space-y-2">
            {legalLinks.map((item) => (
              <li><a href={item.href} class="footer-link">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-gray-200 pt-5 text-sm text-gray-500 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
      <p>Designed for clarity, consistency, and conversion.</p>
    </div>
  </div>

  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -bottom-28 -left-20 h-56 w-56 rounded-full bg-blue-100/40 blur-3xl"></div>
    <div class="absolute -top-28 -right-20 h-56 w-56 rounded-full bg-slate-200/45 blur-3xl"></div>
  </div>
</footer>

<style>
  .footer-heading {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .footer-link {
    color: #374151;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: #111827;
    outline: none;
  }

  .social-pill {
    border-radius: 999px;
    border: 1px solid #d1d5db;
    background: #fff;
    padding: 0.38rem 0.78rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #374151;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .social-pill:hover,
  .social-pill:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
    outline: none;
  }
</style>
