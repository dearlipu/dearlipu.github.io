---
import { siteConfig } from "../config";
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-white py-8">
  <div class="section-shell flex flex-col gap-4 text-sm text-gray-600 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {siteConfig.name}. Built for premium client work.</p>
    <div class="flex gap-4">
      <a href="/privacy" class="transition hover:text-gray-900">Privacy</a>
      <a href="/terms" class="transition hover:text-gray-900">Terms</a>
      <a href="/faq" class="transition hover:text-gray-900">Full FAQ</a>
    </div>
  </div>
</footer>
