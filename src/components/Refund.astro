---
import { siteConfig } from "../config";
---

<section id="refund" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Refund Policy
      </h2>

      <div class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}>
      </div>

      <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
        Conditions and guidelines for refunds on services provided.
      </p>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                  p-6 sm:p-8 md:p-10 lg:p-12
                  shadow-sm hover:shadow-lg transition duration-300">

        <p class="text-xs text-gray-400 mb-6">
          Last updated: April 2026
        </p>

        <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

          <p class="whitespace-pre-line text-gray-700">
            This Refund Policy explains the conditions under which refunds may be issued for services provided.
          </p>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              1. Nature of Services
            </h2>
            <p>
              All services are digital and customized. Due to time and effort involved, refunds are limited once work begins.
            </p>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              2. Eligibility
            </h2>
            <p>
              Refunds may only be considered if no work has been started or delivered.
            </p>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              3. Partial Refunds
            </h2>
            <p>
              Partial refunds may be issued depending on the stage of completion.
            </p>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              4. Revisions
            </h2>
            <p>
              Revisions will be provided instead of refunds where applicable.
            </p>
          </div>

          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              5. Contact
            </h2>
            <p>
              Contact: <span class="text-gray-900 font-medium">{siteConfig.social.email}</span>
            </p>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>
