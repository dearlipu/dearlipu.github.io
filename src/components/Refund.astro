<section id="refund" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Refund Policy
      </h2>

      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
        Conditions and guidelines for refunds on services provided.
      </p>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                  p-6 sm:p-8 md:p-10 lg:p-12
                  shadow-sm hover:shadow-lg transition duration-300">

        <!-- META -->
        <p class="text-xs text-gray-400 mb-6">
          Last updated: April 2026
        </p>

        <!-- CONTENT -->
        <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

          <!-- INTRO -->
          <p class="text-gray-700">
            This Refund Policy outlines the conditions under which refunds may be issued for services provided. By working with us, you agree to the terms described below.
          </p>

          <!-- 1 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              1. Nature of Services
            </h2>
            <p>
              All services offered are digital and creative in nature (including design, editing, and content production). Due to the time, effort, and customization involved, refunds are limited once work has begun.
            </p>
          </div>

          <!-- 2 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              2. Eligibility for Refund
            </h2>
            <p>
              Refunds may be considered only if no significant work has been completed or delivered. Once initial concepts, drafts, or edits are shared, the service is considered in progress and non-refundable.
            </p>
          </div>

          <!-- 3 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              3. Partial Refunds
            </h2>
            <p>
              In some cases, partial refunds may be issued based on the stage of the project. The amount will depend on the work already completed and resources invested.
            </p>
          </div>

          <!-- 4 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              4. Revisions Instead of Refunds
            </h2>
            <p>
              We aim to ensure client satisfaction through revisions and improvements. Instead of refunds, reasonable revisions will be provided to meet the agreed expectations.
            </p>
          </div>

          <!-- 5 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              5. Cancellation Policy
            </h2>
            <p>
              If a project is canceled by the client after work has started, no full refund will be issued. Any completed portion of the work will be billed accordingly.
            </p>
          </div>

          <!-- 6 -->
          <div class="border-t border-gray-200 pt-6">
            <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
              6. Contact
            </h2>
            <p>
              For any refund-related inquiries, contact:
              <span class="text-gray-900 font-medium">
                {siteConfig.social.email}
              </span>
            </p>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>
