---
import { siteConfig } from "../config";

const stats = [
  { value: 150, suffix: "+", title: "Project success", desc: "Delivered in 20+ countries." },
  { value: 100, suffix: "%", title: "Client efficiency", desc: "Clients report higher efficiency." },
  { value: 300, suffix: "+", title: "AI innovation", desc: "Hours building smart workflows." },
];
---

<section id="results" class="p-6 sm:p-10 md:p-14 lg:p-20 bg-white">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT -->
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
          My Results.
        </h2>

        <div
          class="w-[75px] h-[5px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        />

        <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
          Real outcomes, not promises — we build systems that save time and scale work.
        </p>
      </div>

      <!-- RIGHT -->
      <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        {stats.map((stat) => (
          <div class="result-card">

            <div class="result-number" data-target={stat.value}>
              0{stat.suffix}
            </div>

            <div class="result-content">
              <h3>{stat.title}</h3>
              <p>{stat.desc}</p>
            </div>

          </div>
        ))}

      </div>

    </div>
  </div>
</section>

<!-- JS -->
<script>
  const cards = document.querySelectorAll(".result-card");

  const animateNumber = (el) => {
    const target = +el.dataset.target;
    const suffix = el.innerText.replace(/[0-9]/g, "");
    let count = 0;

    const step = target / 50;

    const update = () => {
      count += step;

      if (count < target) {
        el.innerText = Math.floor(count) + suffix;
        requestAnimationFrame(update);
      } else {
        el.innerText = target + suffix;
      }
    };

    update();
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const card = entry.target;

      if (entry.isIntersecting) {
        const num = card.querySelector(".result-number");

        // reset every time visible
        num.innerText = "0" + num.innerText.replace(/[0-9]/g, "");

        animateNumber(num);
      }
    });
  }, { threshold: 0.4 });

  cards.forEach(card => observer.observe(card));
</script>

<style>
/* CARD (match your site) */
.result-card {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  padding: 18px;
  transition: 0.3s ease;
}

.result-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(0,0,0,0.06);
}

/* NUMBER */
.result-number {
  font-size: 32px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 14px;
}

/* INNER */
.result-content {
  background: #f3f4f6;
  border-radius: 10px;
  padding: 12px;
}

.result-content h3 {
  font-size: 15px;
  font-weight: 600;
}

.result-content p {
  font-size: 13px;
  color: #6b7280;
  margin-top: 4px;
}

/* MOBILE */
@media (max-width: 640px) {
  .result-number {
    font-size: 26px;
  }
}
</style>
