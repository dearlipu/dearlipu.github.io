---
import { siteConfig } from "../config";

const stats = [
  { value: 150, suffix: "+", title: "Project success", desc: "Delivered in 20+ countries." },
  { value: 100, suffix: "%", title: "Client efficiency", desc: "Clients report higher efficiency." },
  { value: 300, suffix: "+", title: "AI innovation", desc: "Hours building smart workflows." },
];
---

<section id="results" class="results-section">
  <div class="results-container">

    <!-- LEFT -->
    <div class="results-left">
      <h2>My Results.</h2>

      <div
        class="accent-line"
        style={`background-color: ${siteConfig.accentColor}`}
      />

      <p>
        Real outcomes, not promises — we build systems that save time and scale work.
      </p>
    </div>

    <!-- RIGHT -->
    <div class="results-grid">

      {stats.map((stat) => (
        <div class="result-card reveal">

          <div class="result-number" data-target={stat.value}>
            0{stat.suffix}
          </div>

          <div class="result-content">
            <h3>{stat.title}</h3>
            <p>{stat.desc}</p>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>

<!-- JS -->
<script>
  const cards = document.querySelectorAll(".result-card");

  const animateNumber = (el) => {
    const target = +el.dataset.target;
    const suffix = el.innerText.replace(/[0-9]/g, "");
    let count = 0;

    const step = target / 50;

    const update = () => {
      count += step;

      if (count < target) {
        el.innerText = Math.floor(count) + suffix;
        requestAnimationFrame(update);
      } else {
        el.innerText = target + suffix;
      }
    };

    update();
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const card = entry.target;

      if (entry.isIntersecting) {
        card.classList.add("active");

        const num = card.querySelector(".result-number");

        // reset every time visible
        num.innerText = "0" + num.innerText.replace(/[0-9]/g, "");

        animateNumber(num);
      }
    });
  }, { threshold: 0.4 });

  cards.forEach(card => observer.observe(card));
</script>

<style>
/* SECTION SPACING */
.results-section {
  padding: 80px 24px;
  background: #ffffff;
}

@media (min-width: 768px) {
  .results-section {
    padding: 100px 40px;
  }
}

@media (min-width: 1024px) {
  .results-section {
    padding: 120px 80px;
  }
}

/* LAYOUT */
.results-container {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
}

@media (min-width: 1024px) {
  .results-container {
    grid-template-columns: 4fr 8fr;
    gap: 60px;
  }
}

/* LEFT */
.results-left h2 {
  font-size: 40px;
  font-weight: 700;
  color: #111827;
}

.accent-line {
  width: 70px;
  height: 4px;
  margin-top: 10px;
  border-radius: 999px;
}

.results-left p {
  margin-top: 16px;
  font-size: 14px;
  color: #6b7280;
  max-width: 320px;
}

/* GRID */
.results-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

@media (min-width: 640px) {
  .results-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (min-width: 1024px) {
  .results-grid {
    grid-template-columns: 1fr 1fr 1fr;
  }
}

/* CARD */
.result-card {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  padding: 18px;

  opacity: 0;
  transform: translateY(20px);
  transition: all 0.5s ease;
}

.result-card.active {
  opacity: 1;
  transform: translateY(0);
}

.result-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(0,0,0,0.06);
}

/* NUMBER */
.result-number {
  font-size: 32px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 14px;
}

/* INNER BOX */
.result-content {
  background: #f3f4f6;
  border-radius: 10px;
  padding: 12px;
}

.result-content h3 {
  font-size: 15px;
  font-weight: 600;
}

.result-content p {
  font-size: 13px;
  color: #6b7280;
  margin-top: 4px;
}

/* MOBILE */
@media (max-width: 640px) {
  .results-left h2 {
    font-size: 32px;
  }

  .result-number {
    font-size: 26px;
  }
}
</style>
