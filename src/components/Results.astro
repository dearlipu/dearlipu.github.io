---
import { siteConfig } from "../config";

const stats = [
  { value: 150, suffix: "+", title: "Project success", desc: "Delivered in 20+ countries." },
  { value: 100, suffix: "%", title: "Client efficiency", desc: "Clients report higher efficiency." },
  { value: 300, suffix: "+", title: "AI innovation", desc: "Hours building smart workflows." },
];
---

<section id="results" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">
      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Our Results.
      </h2>

      <!-- ACCENT BAR (your theme color) -->
      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      />

      <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
        Real outcomes, not promises — we build systems that save time and scale work.
      </p>
    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      {stats.map((stat) => (
        <div class="result-card">

          <div class="result-number" data-target={stat.value}>
            0{stat.suffix}
          </div>

          <div class="result-content">
            <h3>{stat.title}</h3>
            <p>{stat.desc}</p>
          </div>

        </div>
      ))}

    </div>
  </div>
</section>

<!-- COUNT ANIMATION -->
<script>
  const counters = document.querySelectorAll(".result-number");

  const animate = (el) => {
    const target = +el.dataset.target;
    const suffix = el.innerText.replace(/[0-9]/g, "");
    let count = 0;

    const speed = target / 50;

    const update = () => {
      count += speed;

      if (count < target) {
        el.innerText = Math.floor(count) + suffix;
        requestAnimationFrame(update);
      } else {
        el.innerText = target + suffix;
      }
    };

    update();
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const el = entry.target;

      if (entry.isIntersecting) {
        el.innerText = "0" + el.innerText.replace(/[0-9]/g, "");
        animate(el);
      }
    });
  }, { threshold: 0.6 });

  counters.forEach(el => observer.observe(el));
</script>

<style>
/* CARD */
.result-card {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 14px;
  padding: 18px;
  transition: 0.3s ease;
}

.result-card:hover {
  box-shadow: 0 10px 25px rgba(0,0,0,0.06);
}

/* NUMBER */
.result-number {
  font-size: 32px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 14px;
}

/* INNER BOX */
.result-content {
  background: #f3f4f6;
  border-radius: 10px;
  padding: 12px;
}

.result-content h3 {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 4px;
}

.result-content p {
  font-size: 13px;
  color: #6b7280;
}

/* MOBILE */
@media (max-width: 640px) {
  .result-number {
    font-size: 26px;
  }
}
</style>
