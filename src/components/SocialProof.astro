---
const stats = [
  { label: "Client projects delivered", value: "140+" },
  { label: "Average turnaround", value: "3.2 days" },
  { label: "Repeat client rate", value: "82%" },
  { label: "Average rating", value: "4.9/5" },
];

const clients = ["Creator-led brands", "Ecommerce teams", "YouTube educators", "SaaS founders", "Lifestyle startups"];
---

<section class="section-anchor pb-18 sm:pb-22" id="proof">
  <div class="section-shell">
    <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_14px_35px_rgba(15,23,42,0.06)] sm:p-8">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-gray-100 pb-6">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-gray-500">Social proof</p>
        <p class="text-sm text-gray-600">Recent clients include:</p>
        <ul class="flex flex-wrap gap-2 text-sm text-gray-700">
          {clients.map((client) => <li class="rounded-full border border-gray-200 px-3 py-1">{client}</li>)}
        </ul>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <article class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
              <p class="text-3xl font-semibold tracking-tight text-gray-900">{stat.value}</p>
              <p class="mt-2 text-sm text-gray-600">{stat.label}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
