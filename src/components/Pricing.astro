---
import { siteConfig } from "../config";

const PHONE = "918144991049";

const createWhatsApp = (plan, mode) => {
  const type = mode === "monthly" ? "Monthly" : "Per Project";

  const message = encodeURIComponent(
`Hi Saurav,

I’m interested in your ${plan} (${type}) plan.
Please share more details.`
  );

  return `https://wa.me/${PHONE}?text=${message}`;
};
---

<section id="pricing" class="p-6 sm:p-10 md:p-14 lg:p-20">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- LEFT -->
      <div class="lg:col-span-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
          Flexible Pricing.
        </h2>

        <div class="w-[70px] h-[4px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`} />

        <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
          100+ projects delivered • Fast turnaround • Clear communication
        </p>

        <!-- TOGGLE -->
        <div class="mt-6 flex justify-center lg:justify-start">
          <div class="relative grid grid-cols-2 bg-gray-200 rounded-full p-1 w-full max-w-[320px] h-[44px]">

            <div id="toggleSlider"
              class="absolute top-1 left-1 w-[calc(50%-4px)] h-[calc(100%-8px)]
                     bg-white rounded-full shadow-sm transition-transform duration-300">
            </div>

            <button id="perProjectBtn"
              class="flex items-center justify-center text-sm font-semibold text-gray-900 z-10">
              Per Project
            </button>

            <button id="monthlyBtn"
              class="flex items-center justify-center text-sm font-semibold text-gray-500 z-10">
              Monthly
            </button>

          </div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="lg:col-span-8">

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- BASIC -->
        <div class="relative bg-gray-50 rounded-xl border border-gray-200 p-5 hover:shadow-lg transition overflow-hidden">
        
          <!-- ICON -->
          <div class="absolute right-[-30px] top-[-30px] opacity-10 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-[140px] h-[140px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5">
              <path d="M5 7.2a2.2 2.2 0 0 1 2.2 -2.2h1a2.2 2.2 0 0 0 1.55 -.64l.7 -.7a2.2 2.2 0 0 1 3.12 0l.7 .7c.412 .41 .97 .64 1.55 .64h1a2.2 2.2 0 0 1 2.2 2.2v1c0 .58 .23 1.138 .64 1.55l.7 .7a2.2 2.2 0 0 1 0 3.12l-.7 .7a2.2 2.2 0 0 0 -.64 1.55v1a2.2 2.2 0 0 1 -2.2 2.2h-1a2.2 2.2 0 0 0 -1.55 .64l-.7 .7a2.2 2.2 0 0 1 -3.12 0l-.7 -.7a2.2 2.2 0 0 0 -1.55 -.64h-1a2.2 2.2 0 0 1 -2.2 -2.2v-1a2.2 2.2 0 0 0 -.64 -1.55l-.7 -.7a2.2 2.2 0 0 1 0 -3.12l.7 -.7a2.2 2.2 0 0 0 .64 -1.55v-1" />
              <path d="M9 12l2 2l4 -4" />
            </svg>
          </div>
        
          <h3 class="text-lg font-bold text-gray-900">Basic</h3>
        
          <p class="price text-xl font-bold mt-2 text-gray-800 transition-all duration-300"
             data-project="₹999+"
             data-monthly="₹8,999/mo">₹999+</p>
        
          <ul class="features mt-4 space-y-3 text-sm text-gray-600"></ul>
        
          <button
            data-plan="Basic"
            class="whatsapp-btn btn-primary mt-6 w-full px-4 py-2 rounded-md font-medium text-center"
            style={`--accent: ${siteConfig.accentColor}`}>
            Get Started
          </button>
        </div>
        
        <!-- STANDARD -->
        <div class="relative bg-gray-50 rounded-xl border-2 p-5 pt-7 hover:shadow-xl transition overflow-hidden"
             style={`border-color: ${siteConfig.accentColor}`}>
        
          <!-- ICON -->
          <div class="absolute right-[-30px] top-[-30px] opacity-10 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-[140px] h-[140px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5">
              <path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572"/>
            </svg>
          </div>
        
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="text-xs px-3 py-1 rounded-full text-white font-medium shadow"
              style={`background-color: ${siteConfig.accentColor}`}>
              Most Popular
            </span>
          </div>
        
          <h3 class="text-lg font-bold text-gray-900">Standard</h3>
        
          <p class="price text-xl font-bold mt-2 text-gray-800 transition-all duration-300"
             data-project="₹2,999+"
             data-monthly="₹19,999/mo">₹2,999+</p>
        
          <ul class="features mt-4 space-y-3 text-sm text-gray-600"></ul>
        
          <button
            data-plan="Standard"
            class="whatsapp-btn btn-primary mt-6 w-full px-4 py-2 rounded-md font-medium text-center"
            style={`--accent: ${siteConfig.accentColor}`}>
            Get Started
          </button>
        </div>
        
        <!-- PREMIUM -->
        <div class="relative bg-gray-50 rounded-xl border border-gray-200 p-5 hover:shadow-lg transition overflow-hidden">
        
          <!-- ICON -->
          <div class="absolute right-[-30px] top-[-30px] opacity-10 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg"
              class="w-[140px] h-[140px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5">
              <path d="M16 18a2 2 0 0 1 2 2a2 2 0 0 1 2 -2a2 2 0 0 1 -2 -2a2 2 0 0 1 -2 2m0 -12a2 2 0 0 1 2 2a2 2 0 0 1 2 -2a2 2 0 0 1 -2 -2a2 2 0 0 1 -2 2m-7 12a6 6 0 0 1 6 -6a6 6 0 0 1 -6 -6a6 6 0 0 1 -6 6a6 6 0 0 1 6 6"/>
            </svg>
          </div>
        
          <h3 class="text-lg font-bold text-gray-900">Premium</h3>
        
          <p class="price text-xl font-bold mt-2 text-gray-800 transition-all duration-300"
             data-project="₹7,999+"
             data-monthly="₹39,999/mo">₹7,999+</p>
        
          <ul class="features mt-4 space-y-3 text-sm text-gray-600"></ul>
        
          <button
            data-plan="Premium"
            class="whatsapp-btn btn-primary mt-6 w-full px-4 py-2 rounded-md font-medium text-center"
            style={`--accent: ${siteConfig.accentColor}`}>
            Get Started
          </button>
        </div>

        </div>

        <p class="mt-6 text-sm text-gray-500">
          Final pricing depends on project scope. Custom quotes available.
        </p>

      </div>
    </div>
  </div>
</section>

<style>
.btn-primary {
  background-color: #101828;
  color: white;
  transition: all 0.3s ease;
}
.btn-primary:hover {
  background-color: var(--accent);
}
</style>

<script>
  let currentMode = "monthly";

  const perBtn = document.getElementById("perProjectBtn");
  const monthlyBtn = document.getElementById("monthlyBtn");
  const slider = document.getElementById("toggleSlider");

  const prices = document.querySelectorAll(".price");
  const features = document.querySelectorAll(".features");
  const buttons = document.querySelectorAll(".whatsapp-btn");

  const featureData = {
    project: [
      ["1 design","1 revision","1–2 days delivery"],
      ["3–5 designs / 1 video","2–3 revisions","Priority delivery"],
      ["Unlimited requests","Unlimited revisions","Fast delivery"]
    ],
    monthly: [
      ["Unlimited designs","Priority delivery","Pause anytime"],
      ["Unlimited requests","Priority queue","Multi-format"],
      ["Unlimited everything","Top priority","Dedicated support"]
    ]
  };

  function setMode(mode) {
    currentMode = mode;

    prices.forEach((p, i) => {
      p.style.opacity = "0";
      setTimeout(() => {
        p.textContent = mode === "monthly"
          ? p.dataset.monthly
          : p.dataset.project;
        p.style.opacity = "1";
      }, 150);

      const list = featureData[mode][i];
      features[i].innerHTML = list.map(item => `
        <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-gray-400 flex-shrink-0"
                  fill="none" viewBox="0 0 24 24"
                  stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" />
                  <path d="M9 12h6" />
                  <path d="M12 9v6" />
                </svg>
          ${item}
        </li>
      `).join("");
    });

    if (mode === "monthly") {
      slider.style.transform = "translateX(100%)";
      monthlyBtn.classList.replace("text-gray-500","text-gray-900");
      perBtn.classList.replace("text-gray-900","text-gray-500");
    } else {
      slider.style.transform = "translateX(0)";
      perBtn.classList.replace("text-gray-500","text-gray-900");
      monthlyBtn.classList.replace("text-gray-900","text-gray-500");
    }
  }

  // CLICK HANDLER
  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const plan = btn.dataset.plan;

      const message = `Hi Saurav,

I’m interested in your ${plan} (${currentMode === "monthly" ? "Monthly" : "Per Project"}) plan.
Please share more details.`;

      const url = `https://wa.me/918144991049?text=${encodeURIComponent(message)}`;

      window.open(url, "_blank");
    });
  });

  perBtn.onclick = () => setMode("project");
  monthlyBtn.onclick = () => setMode("monthly");

  setMode("monthly");
</script>
