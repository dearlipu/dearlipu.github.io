---
const plans = [
  {
    name: "Starter",
    price: "$450",
    period: "per project",
    forWho: "For solo creators needing polished visuals fast.",
    features: ["1 core deliverable", "2 revision rounds", "3-5 day turnaround", "Delivery-ready exports"],
  },
  {
    name: "Growth",
    price: "$1,250",
    period: "per month",
    forWho: "For brands publishing weekly content and campaigns.",
    features: ["Ongoing design + editing", "Priority turnaround", "Weekly planning touchpoint", "Performance-focused iterations"],
    featured: true,
  },
  {
    name: "Pro",
    price: "$2,400",
    period: "per month",
    forWho: "For teams that need a premium creative partner.",
    features: ["High-volume asset production", "Advanced motion graphics", "Creative direction support", "Dedicated async communication"],
  },
];
---

<section id="pricing" class="section-anchor py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">Pricing</p>
    <h2 class="section-title mt-5 max-w-3xl">Transparent packages with clear value at every stage.</h2>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        plans.map((plan) => (
          <article
            class={`relative rounded-3xl border bg-white p-6 shadow-[0_12px_30px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 ${
              plan.featured ? "border-indigo-400" : "border-gray-200"
            }`}
          >
            {plan.featured && (
              <p class="absolute -top-3 left-6 rounded-full bg-indigo-600 px-3 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-white">
                Most selected
              </p>
            )}
            <h3 class="text-2xl font-semibold text-gray-900">{plan.name}</h3>
            <p class="mt-4 text-3xl font-semibold tracking-tight text-gray-900">{plan.price}</p>
            <p class="mt-1 text-sm text-gray-500">{plan.period}</p>
            <p class="mt-4 text-sm text-gray-600">{plan.forWho}</p>

            <ul class="mt-6 space-y-2 text-sm text-gray-700">
              {plan.features.map((feature) => <li>• {feature}</li>)}
            </ul>

            <a
              href="#contact"
              class={`mt-7 inline-flex w-full justify-center rounded-full px-4 py-2.5 text-sm font-semibold transition ${
                plan.featured
                  ? "bg-indigo-600 text-white hover:bg-indigo-700"
                  : "border border-gray-300 bg-white text-gray-800 hover:border-gray-900"
              }`}
            >
              Choose {plan.name}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
