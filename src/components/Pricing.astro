---
import { siteConfig } from "../config";

const plans = [
  {
    name: "Basic",
    badge: null,
    projectPrice: "₹999+",
    monthlyPrice: "₹8,999/mo",
  },
  {
    name: "Standard",
    badge: "Most Popular",
    projectPrice: "₹2,999+",
    monthlyPrice: "₹19,999/mo",
  },
  {
    name: "Premium",
    badge: "Best for teams",
    projectPrice: "₹7,999+",
    monthlyPrice: "₹39,999/mo",
  },
];
---

<section id="pricing" class="px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-4">
        <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
          Pricing
        </p>

        <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
          Flexible Pricing.
        </h2>

        <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

        <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
          Transparent starting prices. Final quote depends on complexity, volume, and turnaround.
        </p>

        <div class="mt-6" role="group" aria-label="Pricing mode toggle">
          <div class="relative grid h-11 w-full max-w-[340px] grid-cols-2 rounded-full bg-gray-200 p-1">
            <div id="toggleSlider" class="toggle-slider"></div>

            <button id="perProjectBtn" type="button" class="toggle-btn toggle-btn-active" aria-pressed="true">
              Per Project
            </button>
            <button id="monthlyBtn" type="button" class="toggle-btn" aria-pressed="false">
              Monthly Retainer
            </button>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            plans.map((plan) => (
              <article class={`pricing-card ${plan.badge ? "pricing-card-featured" : ""}`} style={`--accent-color: ${siteConfig.accentColor}`}>
                {
                  plan.badge && (
                    <span class="pricing-badge" style={`background-color: ${siteConfig.accentColor}`}>
                      {plan.badge}
                    </span>
                  )
                }

                <h3 class="text-lg font-bold text-gray-900">{plan.name}</h3>
                <p
                  class="price mt-2 text-xl font-bold text-gray-800 transition-opacity duration-200"
                  data-project={plan.projectPrice}
                  data-monthly={plan.monthlyPrice}
                >
                  {plan.projectPrice}
                </p>

                <ul class="features mt-4 space-y-2 text-sm leading-relaxed text-gray-600"></ul>

                <button
                  type="button"
                  data-plan={plan.name}
                  class="whatsapp-btn btn-primary mt-6 w-full rounded-xl px-4 py-2.5 text-center text-sm font-semibold"
                  style={`--accent: ${siteConfig.accentColor}`}
                >
                  Request Quote
                </button>
              </article>
            ))
          }
        </div>

        <p class="mt-6 text-sm text-gray-500">Need a custom package? I can combine services based on your exact goals.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .toggle-slider {
    position: absolute;
    top: 4px;
    left: 4px;
    z-index: 0;
    height: calc(100% - 8px);
    width: calc(50% - 4px);
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.2);
    transition: transform 0.25s ease;
  }

  .toggle-btn {
    z-index: 1;
    border: 0;
    background: transparent;
    font-size: 0.85rem;
    font-weight: 600;
    color: #6b7280;
  }

  .toggle-btn-active {
    color: #111827;
  }

  .pricing-card {
    position: relative;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, #ffffff, #f8fafc);
    padding: 1.25rem;
    box-shadow: 0 8px 30px rgba(15, 23, 42, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .pricing-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.08);
  }

  .pricing-card-featured {
    border-width: 2px;
    border-color: var(--accent-color, #1d4ed8);
  }

  .pricing-badge {
    position: absolute;
    top: -0.65rem;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    box-shadow: 0 8px 20px rgba(29, 78, 216, 0.22);
    white-space: nowrap;
  }

  .btn-primary {
    border: 0;
    background-color: #0f172a;
    color: #fff;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background-color: var(--accent);
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 640px) {
    .toggle-btn {
      font-size: 0.78rem;
    }
  }
</style>

<script define:vars={{ whatsappNumber: siteConfig.social.whatsapp }}>
  let currentMode = "project";

  const perBtn = document.getElementById("perProjectBtn");
  const monthlyBtn = document.getElementById("monthlyBtn");
  const slider = document.getElementById("toggleSlider");

  const prices = document.querySelectorAll(".price");
  const features = document.querySelectorAll(".features");
  const buttons = document.querySelectorAll(".whatsapp-btn");

  const featureData = {
    project: [
      ["One focused deliverable", "1 revision included", "Ideal for quick, small tasks", "Delivery in 24–48 hours"],
      ["Best for social content batches", "2–3 revisions included", "Balanced speed + quality", "Delivered within a few days"],
      ["Complex campaigns and systems", "Priority support", "Flexible revisions", "Tailored strategy + execution"],
    ],
    monthly: [
      ["Ongoing design support", "1 active request at a time", "Multi-format output", "Pause or resume anytime"],
      ["Consistent high-volume delivery", "2 active requests", "Priority turnaround", "Best for growing brands"],
      ["Dedicated creative partner", "Multiple active requests", "Fast-track workflow", "Best for teams and agencies"],
    ],
  };

  function setMode(mode) {
    currentMode = mode;

    prices.forEach((price, index) => {
      price.style.opacity = "0.2";
      setTimeout(() => {
        price.textContent = mode === "monthly" ? price.dataset.monthly : price.dataset.project;
        price.style.opacity = "1";
      }, 120);

      const list = featureData[mode][index];
      features[index].innerHTML = list
        .map(
          (item) => `
            <li class="flex items-start gap-2">
              <span class="mt-[2px] inline-block h-1.5 w-1.5 rounded-full bg-gray-400"></span>
              <span>${item}</span>
            </li>
          `,
        )
        .join("");
    });

    const isMonthly = mode === "monthly";
    slider.style.transform = isMonthly ? "translateX(100%)" : "translateX(0)";

    perBtn.classList.toggle("toggle-btn-active", !isMonthly);
    monthlyBtn.classList.toggle("toggle-btn-active", isMonthly);
    perBtn.setAttribute("aria-pressed", String(!isMonthly));
    monthlyBtn.setAttribute("aria-pressed", String(isMonthly));
  }

  function createWhatsAppUrl(plan, mode) {
    const number = String(whatsappNumber || "").replace(/\D/g, "");
    const modeLabel = mode === "monthly" ? "Monthly Retainer" : "Per Project";

    const text = `Hi Saurav,\n\nI'm interested in your ${plan} (${modeLabel}) plan.\n\nPlease share pricing and timeline details for my requirement.\n\nThank you.`;
    return `https://api.whatsapp.com/send?phone=${number}&text=${encodeURIComponent(text)}`;
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const plan = button.dataset.plan || "";
      const url = createWhatsAppUrl(plan, currentMode);

      if (/Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent)) {
        const number = String(whatsappNumber || "").replace(/\D/g, "");
        const appUrl = `whatsapp://send?phone=${number}&text=${encodeURIComponent(`Hi Saurav, I'm interested in your ${plan} (${currentMode === "monthly" ? "Monthly Retainer" : "Per Project"}) plan.`)}`;
        window.location.href = appUrl;

        setTimeout(() => {
          window.location.href = url;
        }, 900);
        return;
      }

      window.open(url, "_blank", "noopener,noreferrer");
    });
  });

  perBtn?.addEventListener("click", () => setMode("project"));
  monthlyBtn?.addEventListener("click", () => setMode("monthly"));

  setMode("project");
</script>
