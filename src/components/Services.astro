---
import { siteConfig } from "../config";

const services = siteConfig.services || [];
const hasServices = services.length > 0;
---

{
  hasServices && (
    <section id="services" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Services
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Creative services built for growth
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              I help brands and creators with design, editing, and motion deliverables that look premium and perform across platforms.
            </p>
          </div>

          <div class="space-y-6 lg:col-span-8">
            {
              services.map((service, index) => (
                <article class="service-card group">
                  <div class="flex-1 p-5 md:p-6">
                    <div class="mb-4 flex items-start justify-between gap-3">
                      <div>
                        <h3 class="text-lg font-bold text-gray-900 sm:text-xl">{service.degree}</h3>
                        <p class="mt-1 text-sm sm:text-base" style={`color: ${siteConfig.accentColor}`}>{service.school}</p>
                      </div>
                    </div>

                    <ul class="space-y-2.5">
                      {
                        service.achievements.map((achievement) => (
                          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-600 sm:text-base">
                            <span class="service-bullet" aria-hidden="true"></span>
                            <span class="min-w-0 flex-1">{achievement}</span>
                          </li>
                        ))
                      }
                    </ul>
                  </div>

                  <div class="service-media md:w-[320px] w-full aspect-[4/3] md:aspect-auto flex-shrink-0">
                    <img src={`/images/edu-${index + 1}.gif`} alt={`${service.degree} service preview`} loading="lazy" decoding="async" />
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .service-bullet {
    margin-top: 0.62em;
    display: inline-block;
    height: 0.375rem;
    width: 0.375rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: #9ca3af;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, #ffffff, #f8fafc);
    box-shadow: 0 8px 28px rgba(15, 23, 42, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.09);
  }

  .service-media {
    position: relative;
    overflow: hidden;
    clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%, 0% 24%);
  }

  .service-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .service-card:hover .service-media img {
    transform: scale(1.04);
  }

  @media (min-width: 768px) {
    .service-card {
      flex-direction: row;
    }
  }
</style>
