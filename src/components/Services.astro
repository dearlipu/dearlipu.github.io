---
const services = [
  {
    title: "Graphic Design",
    scope: "Social media, branding, print",
    benefit: "I build a cohesive visual language so every asset feels premium and instantly recognizable.",
  },
  {
    title: "Video Editing",
    scope: "Short-form + YouTube",
    benefit: "I edit for retention: stronger hooks, tighter rhythm, clearer storytelling, and purposeful visuals.",
  },
  {
    title: "Motion Graphics",
    scope: "Explainers, titles, transitions",
    benefit: "I turn complex messages into motion that feels clear, modern, and easy to remember.",
  },
];
---

<section id="services" class="section-anchor py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">Services</p>
    <h2 class="section-title mt-5 max-w-3xl">Creative execution designed to improve how your brand is seen.</h2>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        services.map((service) => (
          <article class="rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_10px_30px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:border-indigo-200">
            <h3 class="text-xl font-semibold text-gray-900">{service.title}</h3>
            <p class="mt-2 text-sm font-medium text-indigo-600">{service.scope}</p>
            <p class="mt-5 text-sm leading-relaxed text-gray-600">{service.benefit}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
