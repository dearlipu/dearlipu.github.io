---
import { siteConfig } from "../config";
---

<section id="privacy" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900 leading-tight">
        Privacy Policy
      </h2>

      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
        How your data is collected, used, and protected when you use this website and services.
      </p>

    </div>

    <!-- RIGHT -->
    <div class="lg:col-span-8">

      <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                  p-6 sm:p-8 md:p-10 lg:p-12
                  shadow-sm hover:shadow-lg transition duration-300">

        <!-- META -->
        <p class="text-xs text-gray-400 mb-6">
          Last updated: April 2026
        </p>

        <!-- CONTENT -->
        <div class="space-y-8 text-base sm:text-lg md:text-lg leading-relaxed text-gray-600">

          <!-- INTRO -->
          <p class="text-gray-700">
            This Privacy Policy outlines how we collect, use, and protect your information when you interact with our website and services.
          </p>

          <!-- 1 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              1. Information We Collect
            </h2>
            <p>
              We may collect personal information such as your name, email address, and contact details when you contact us or request services.
            </p>
          </div>

          <!-- 2 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              2. How We Use Your Information
            </h2>
            <p>
              Your information is used to communicate, deliver services, and manage projects efficiently.
            </p>
          </div>

          <!-- 3 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              3. Client Materials
            </h2>
            <p>
              Any files or references provided are used only for project work and are not reused without permission.
            </p>
          </div>

          <!-- 4 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              4. Cookies & Analytics
            </h2>
            <p>
              Basic analytics or cookies may be used to improve performance and user experience.
            </p>
          </div>

          <!-- 5 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              5. Third-Party Services
            </h2>
            <p>
              External platforms may be used and operate under their own privacy policies.
            </p>
          </div>

          <!-- 6 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              6. Data Protection
            </h2>
            <p>
              We apply reasonable safeguards, but complete security cannot be guaranteed.
            </p>
          </div>

          <!-- 7 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              7. Your Rights
            </h2>
            <p>
              You may request access, correction, or deletion of your data at any time.
            </p>
          </div>

          <!-- 8 -->
          <div class="border-t border-gray-200 pt-5">
            <h2 class="text-sm sm:text-base md:text-lg font-semibold text-gray-900 mb-1">
              8. Contact
            </h2>
            <p>
              Contact:
              <span class="text-gray-900 font-medium">
                {siteConfig.social.email}
              </span>
            </p>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>
