---
const projects = [
  {
    title: "Content System for a Fitness Creator",
    category: "Graphic design + motion",
    result: "Increased average post saves by 63% in 8 weeks.",
    summary:
      "I redesigned their post templates, reel covers, and CTA slides into one clean system that kept the brand consistent while speeding up weekly production.",
  },
  {
    title: "YouTube Edit Overhaul for an Education Channel",
    category: "Video editing",
    result: "Raised average watch duration from 38% to 52%.",
    summary:
      "I restructured intros, pacing, and visual callouts so key points landed faster and viewers stayed engaged past the first minute.",
  },
  {
    title: "Launch Visuals for a Product Brand",
    category: "Branding + campaign design",
    result: "Generated a stronger launch week with 2.4x click-through from paid creatives.",
    summary:
      "I built a focused campaign kit: paid ads, social cutdowns, and print-ready assets with one premium visual language.",
  },
];
---

<section id="work" class="section-anchor bg-white py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">Selected work</p>
    <div class="mt-5 flex flex-wrap items-end justify-between gap-5">
      <h2 class="section-title max-w-3xl">Case-style projects built around measurable outcomes.</h2>
      <a href="#contact" class="text-sm font-semibold text-indigo-600 transition hover:text-indigo-800">Discuss your project →</a>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        projects.map((project, index) => (
          <article class="group rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_10px_30px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:shadow-[0_18px_44px_rgba(15,23,42,0.1)]">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gray-500">Case {index + 1}</p>
            <h3 class="mt-3 text-xl font-semibold text-gray-900">{project.title}</h3>
            <p class="mt-2 text-sm font-medium text-indigo-600">{project.category}</p>
            <p class="mt-4 text-sm leading-relaxed text-gray-600">{project.summary}</p>
            <div class="mt-6 rounded-2xl bg-gray-50 px-4 py-3">
              <p class="text-sm font-semibold text-gray-900">Result</p>
              <p class="mt-1 text-sm text-gray-700">{project.result}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
