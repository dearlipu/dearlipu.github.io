---
import { siteConfig } from "../config";

const projects = siteConfig.projects || [];
const hasProjects = projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Projects
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Featured work with real-world impact.
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              Selected case studies that highlight strategy, craft, and measurable results across each project.
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class={`block relative p-5 sm:p-6 bg-gray-50 rounded-xl sm:rounded-2xl border border-gray-200 transition-all duration-300 ${
                        project.link
                          ? "hover:bg-white hover:shadow-xl hover:border-gray-300 hover:-translate-y-1"
                          : ""
                        }`}
                    >
                      {project.link && (
                        <div class="absolute top-4 right-4 sm:top-6 sm:right-6 md:top-8 md:right-8 w-10 h-10 sm:w-11 sm:h-11 md:w-12 md:h-12 flex items-center justify-center bg-gray-900 rounded-full text-white transition-all duration-300 group-hover:bg-gray-700">
                          <svg
                            class="w-4 h-4 sm:w-4.5 sm:h-4.5 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-4">
                        <div>
                          <span
                            class="text-sm font-mono"
                            style={{ color: siteConfig.accentColor }}
                          >
                            0{index + 1}
                          </span>
                          <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mt-1">
                            {project.name}
                          </h3>
                        </div>

                        <p class={`text-base sm:text-lg text-gray-600 leading-relaxed ${project.link ? "pr-12 sm:pr-14" : ""}`}>

                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span
                                class={`px-2.5 sm:px-3 py-1 sm:py-1.5 bg-gray-900 text-white rounded-md sm:rounded-lg text-xs sm:text-sm font-medium transition-all duration-300 ${
                                  project.link ? "group-hover:bg-gray-800" : ""
                                }`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}

                        {project.link && <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">View project details</p>}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .project-card {
    display: block;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: #f9fafb;
    padding: 1.25rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  .project-card-link:hover,
  .project-card-link:focus-visible {
    transform: translateY(-3px);
    background: #fff;
    border-color: #cbd5e1;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
    outline: none;
  }

  .project-index {
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, #d1d5db);
    background: color-mix(in srgb, var(--accent) 8%, #fff);
    padding: 0.2rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #374151;
  }

  .project-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.5rem;
    width: 2.5rem;
    border-radius: 999px;
    background: #111827;
    color: #fff;
    transition: background-color 0.3s ease;
  }

  .project-card-link:hover .project-icon,
  .project-card-link:focus-visible .project-icon {
    background: #1f2937;
  }

  .project-icon-svg {
    transition: transform 0.3s ease;
  }

  .project-card-link:hover .project-icon-svg,
  .project-card-link:focus-visible .project-icon-svg {
    transform: translate(2px, -2px);
  }

  .skill-chip {
    border-radius: 0.5rem;
    background: #111827;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    transition: background-color 0.2s ease;
  }

  .project-card-link:hover .skill-chip,
  .project-card-link:focus-visible .skill-chip {
    background: #1f2937;
  }
</style>
