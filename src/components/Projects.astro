---
import { siteConfig } from "../config";

const projects = siteConfig.projects || [];
const hasProjects = projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Projects
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Featured work with real outcomes
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              Case-style highlights that show strategy, execution quality, and measurable value for each project.
            </p>
          </div>

          <div class="space-y-6 lg:col-span-8">
            {
              projects.map((project, index) => {
                const Component = project.link ? "a" : "article";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <Component
                    {...linkProps}
                    class={`project-card group ${project.link ? "project-card-link" : ""}`}
                    aria-label={project.link ? `Open project: ${project.name}` : undefined}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <span class="project-index" style={`--accent: ${siteConfig.accentColor}`}>0{index + 1}</span>

                      {project.link && (
                        <span class="project-icon" aria-hidden="true">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                          </svg>
                        </span>
                      )}
                    </div>

                    <h3 class="mt-4 text-xl font-bold text-gray-900 sm:text-2xl">{project.name}</h3>

                    <p class="mt-3 text-sm leading-relaxed text-gray-600 sm:text-base">{project.description}</p>

                    {project.skills && project.skills.length > 0 && (
                      <div class="mt-5 flex flex-wrap gap-2">
                        {project.skills.map((skill) => <span class="skill-chip">{skill}</span>)}
                      </div>
                    )}

                    {project.link && <p class="mt-5 text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">View project details</p>}
                  </Component>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .project-card {
    display: block;
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, #fff, #f8fafc);
    padding: 1.25rem;
    box-shadow: 0 8px 28px rgba(15, 23, 42, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .project-card-link:hover,
  .project-card-link:focus-visible {
    transform: translateY(-3px);
    border-color: #cbd5e1;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
    outline: none;
  }

  .project-index {
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, #d1d5db);
    background: color-mix(in srgb, var(--accent) 8%, #fff);
    padding: 0.2rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #374151;
  }

  .project-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2rem;
    width: 2rem;
    border-radius: 999px;
    background: #111827;
    color: #fff;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .project-card-link:hover .project-icon,
  .project-card-link:focus-visible .project-icon {
    transform: translate(1px, -1px);
    background: #1f2937;
  }

  .skill-chip {
    border-radius: 999px;
    border: 1px solid #d1d5db;
    background: #fff;
    padding: 0.25rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #374151;
  }
</style>
