---
import { siteConfig } from "../config";

const projects = siteConfig.projects || [];
const hasProjects = projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl reveal-up">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Projects
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Selected Work.
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              Real projects with clear goals, smart execution, and measurable outcomes you can trust.
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {projects.map((project, index) => {
                const previewImages = project.images || [];

                return (
                  <article
                    class="project-card group relative overflow-hidden rounded-xl border border-gray-200 bg-gray-50 p-5 transition-all duration-500 hover:-translate-y-1 hover:border-gray-300 hover:bg-white hover:shadow-xl sm:rounded-2xl sm:p-6"
                    data-project-card
                  >
                    <button
                      type="button"
                      class="project-toggle relative z-10 block w-full text-left"
                      aria-expanded="false"
                    >
                      <span class="sr-only">Toggle {project.name} image preview</span>
                      <div class="flex flex-col gap-6 md:grid md:grid-cols-[minmax(0,1fr)_260px] md:items-center lg:grid-cols-[minmax(0,1fr)_300px]">
                        <div class="space-y-4">
                          <div>
                            <span class="font-mono text-sm" style={{ color: siteConfig.accentColor }}>
                              0{index + 1}
                            </span>
                            <h3 class="mt-1 text-xl font-bold text-gray-900 sm:text-2xl">
                              {project.name}
                            </h3>
                          </div>

                          <p class="text-base leading-relaxed text-gray-600 sm:text-lg">
                            {project.description}
                          </p>

                          {project.skills && project.skills.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 pt-2 sm:gap-2">
                              {project.skills.map((skill) => (
                                <span class="rounded-md bg-gray-900 px-2.5 py-1 text-xs font-medium text-white transition-all duration-300 group-hover:bg-gray-800 sm:rounded-lg sm:px-3 sm:py-1.5 sm:text-sm">
                                  {skill}
                                </span>
                              ))}
                            </div>
                          )}

                          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500">
                            Hover or tap to preview
                          </p>
                        </div>

                        {previewImages.length > 0 && (
                          <div class="project-preview relative h-48 overflow-hidden rounded-2xl bg-gray-900 shadow-inner sm:h-56 md:h-64">
                            {previewImages.map((image, imageIndex) => (
                              <img
                                src={image.src}
                                alt={image.alt || `${project.name} preview ${imageIndex + 1}`}
                                loading={imageIndex === 0 ? "eager" : "lazy"}
                                class="project-preview-image absolute inset-0 h-full w-full object-cover opacity-0 transition-all duration-700 ease-out"
                                style={`--slide-index: ${imageIndex}; --slide-count: ${previewImages.length};`}
                              />
                            ))}
                            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-white/10"></div>
                            <div class="pointer-events-none absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-gray-900 shadow-sm">
                              {previewImages.length} images
                            </div>
                          </div>
                        )}
                      </div>
                    </button>
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <script is:inline>
        (() => {
          const cards = Array.from(document.querySelectorAll("[data-project-card]"));
          const closeCard = (card) => {
            card.removeAttribute("data-active");
            card.querySelector(".project-toggle")?.setAttribute("aria-expanded", "false");
          };

          cards.forEach((card) => {
            const toggle = card.querySelector(".project-toggle");
            toggle?.addEventListener("click", () => {
              const isActive = card.hasAttribute("data-active");
              cards.forEach(closeCard);
              if (!isActive) {
                card.setAttribute("data-active", "true");
                toggle.setAttribute("aria-expanded", "true");
              }
            });
          });

          let lastScrollY = window.scrollY;
          window.addEventListener(
            "scroll",
            () => {
              if (Math.abs(window.scrollY - lastScrollY) < 12) return;
              lastScrollY = window.scrollY;
              cards.forEach(closeCard);
            },
            { passive: true }
          );
        })();
      </script>
    </section>
  )
}

<style>
  .project-card .project-preview {
    max-height: 0;
    opacity: 0;
    transform: translateY(14px) scale(0.98);
    transition: max-height 0.6s ease, opacity 0.45s ease, transform 0.55s ease;
  }

  .project-card:hover .project-preview,
  .project-card[data-active="true"] .project-preview {
    max-height: 20rem;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .project-card .project-preview-image:first-child {
    opacity: 1;
  }

  .project-card:hover .project-preview-image,
  .project-card[data-active="true"] .project-preview-image {
    animation: projectPreviewFade calc(var(--slide-count) * 2.4s) infinite;
    animation-delay: calc(var(--slide-index) * 2.4s);
  }

  @keyframes projectPreviewFade {
    0%, 10% {
      opacity: 0;
      transform: scale(1.04);
    }

    14%, 32% {
      opacity: 1;
      transform: scale(1);
    }

    38%, 100% {
      opacity: 0;
      transform: scale(1.02);
    }
  }

  @media (min-width: 768px) {
    .project-card .project-preview {
      max-height: none;
      opacity: 0.18;
      transform: translateX(18px) scale(0.96);
    }

    .project-card:hover .project-preview,
    .project-card[data-active="true"] .project-preview {
      max-height: none;
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }
</style>
