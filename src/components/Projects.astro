---
import { siteConfig } from "../config";

const projects = siteConfig.projects || [];
const hasProjects = projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="bg-white px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
      <div class="mx-auto max-w-6xl reveal-up">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
          <div class="lg:col-span-4">
            <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
              Projects
            </p>

            <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
              Selected Work.
            </h2>

            <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

            <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
              Real projects with clear goals, smart execution, and measurable outcomes you can trust.
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {projects.map((project, index) => {
                const previewImages = project.images || [];

                return (
                  <article
                    class="project-card group relative overflow-hidden rounded-xl border border-gray-200 bg-gray-50 shadow-sm transition-all duration-500 hover:border-gray-300 hover:bg-white hover:shadow-2xl hover:shadow-gray-200/80 sm:rounded-2xl"
                    data-project-card
                  >
                    <button
                      type="button"
                      class="project-toggle block w-full p-6 text-left sm:p-8"
                      aria-expanded="false"
                    >
                      <span class="sr-only">Toggle {project.name} image preview</span>
                      <div class="project-card-grid grid gap-6 md:grid-cols-[minmax(0,1fr)_minmax(0,300px)] md:items-center">
                        <div class="project-copy min-w-0 space-y-5">
                          <div>
                            <span class="font-mono text-sm" style={{ color: siteConfig.accentColor }}>
                              0{index + 1}
                            </span>
                            <h3 class="mt-2 text-2xl font-bold leading-tight text-gray-950">
                              {project.name}
                            </h3>
                          </div>

                          <p class="max-w-2xl text-base leading-8 text-gray-700 sm:text-lg">
                            {project.description}
                          </p>

                          {project.skills && project.skills.length > 0 && (
                            <div class="flex flex-wrap gap-2 pt-1">
                              {project.skills.map((skill) => (
                                <span class="rounded-lg bg-gray-950 px-3 py-2 text-xs font-bold text-white transition-all duration-300 group-hover:bg-gray-900 sm:text-sm">
                                  {skill}
                                </span>
                              ))}
                            </div>
                          )}

                          <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-500">
                            Hover or tap to preview
                          </p>
                        </div>

                        {previewImages.length > 0 && (
                          <div class="project-preview relative overflow-hidden rounded-2xl bg-gray-950 shadow-inner">
                            {previewImages.map((image, imageIndex) => (
                              <img
                                src={image.src}
                                alt={image.alt || `${project.name} preview ${imageIndex + 1}`}
                                loading={imageIndex === 0 ? "eager" : "lazy"}
                                class="project-preview-image absolute inset-0 h-full w-full object-cover opacity-0"
                                style={`--slide-index: ${imageIndex}; --slide-count: ${previewImages.length};`}
                              />
                            ))}
                            <div class="project-preview-shade pointer-events-none absolute inset-0 bg-gray-950/55 transition-opacity duration-500 group-hover:bg-gray-950/20"></div>
                            <div class="pointer-events-none absolute bottom-3 left-3 rounded-full bg-white px-3 py-1 text-xs font-bold text-gray-950 shadow-sm">
                              {previewImages.length} images
                            </div>
                          </div>
                        )}
                      </div>
                    </button>
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      </div>

      <script is:inline>
        (() => {
          const cards = Array.from(document.querySelectorAll("[data-project-card]"));
          const closeCard = (card) => {
            card.removeAttribute("data-active");
            card.querySelector(".project-toggle")?.setAttribute("aria-expanded", "false");
          };

          cards.forEach((card) => {
            const toggle = card.querySelector(".project-toggle");
            toggle?.addEventListener("click", () => {
              const isActive = card.hasAttribute("data-active");
              cards.forEach(closeCard);
              if (!isActive) {
                card.setAttribute("data-active", "true");
                toggle.setAttribute("aria-expanded", "true");
              }
            });
          });

          let lastScrollY = window.scrollY;
          window.addEventListener(
            "scroll",
            () => {
              if (Math.abs(window.scrollY - lastScrollY) < 12) return;
              lastScrollY = window.scrollY;
              cards.forEach(closeCard);
            },
            { passive: true }
          );
        })();
      </script>
    </section>
  )
}

<style>
  .project-preview {
    height: 0;
    min-height: 0;
    opacity: 0;
    transform: translateY(18px) scale(0.98);
    transition: height 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.45s ease, transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card:hover .project-preview,
  .project-card[data-active="true"] .project-preview {
    height: 15.5rem;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .project-preview-image:first-child {
    opacity: 1;
  }

  .project-card:hover .project-preview-image,
  .project-card[data-active="true"] .project-preview-image {
    animation: projectPreviewFade calc(var(--slide-count) * 2.5s) infinite ease-in-out;
    animation-delay: calc(var(--slide-index) * 2.5s);
  }

  .project-card[data-active="true"] .project-preview-shade {
    background-color: rgb(3 7 18 / 0.2);
  }

  @keyframes projectPreviewFade {
    0%, 9% {
      opacity: 0;
      transform: scale(1.06);
    }

    14%, 35% {
      opacity: 1;
      transform: scale(1);
    }

    42%, 100% {
      opacity: 0;
      transform: scale(1.03);
    }
  }

  @media (min-width: 768px) {
    .project-card-grid {
      gap: 0;
      grid-template-columns: minmax(0, 1fr) 0fr;
      transition: grid-template-columns 0.62s cubic-bezier(0.22, 1, 0.36, 1), gap 0.62s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .project-preview {
      height: 15.5rem;
      width: 0;
      opacity: 0;
      transform: translateX(28px) scale(0.96);
      transition: width 0.62s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.45s ease, transform 0.62s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .project-card:hover .project-card-grid,
    .project-card[data-active="true"] .project-card-grid {
      gap: 1.5rem;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 300px);
    }

    .project-card:hover .project-preview,
    .project-card[data-active="true"] .project-preview {
      height: 15.5rem;
      width: 100%;
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }
</style>
