---
import { siteConfig } from "../config";

const testimonials = [
  {
    rating: 4.9,
    quote:
      "The quality was unmatched. We submitted our request on Monday and had polished designs by Wednesday.",
    name: "Sunita Maharana",
    role: "Marketing Director",
    avatar: "/avatars/user5.webp",
  },
  {
    rating: 4.9,
    quote:
      "We’ve tried other design subscriptions — none compare to Saurav's service. Professional, reliable, and seriously creative.",
    name: "B Pramit Patra",
    role: "Product Manager",
    avatar: "/avatars/user6.webp",
  },
  {
    rating: 4.9,
    quote:
      "Felt like an embedded team with zero friction; communication was clear, and revisions landed perfectly on the first go.",
    name: "Ajaya Sahoo",
    role: "CEO",
    avatar: "/avatars/user7.webp",
  },
];
---

<section id="testimonials" class="testimonial-wrap px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-4">
        <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
          Testimonials
        </p>

        <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
          Success stories.
        </h2>

        <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

        <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
          Honest feedback from people I’ve worked with across branding, social content, and video projects.
        </p>
      </div>

      <div class="lg:col-span-4">
        <article class="summary-card h-full">
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-blue-200">Average rating</p>
            <h3 class="mt-2 text-4xl font-bold">4.9/5</h3>
            <p class="mt-2 text-sm text-gray-200">Trusted by 100+ businesses and creators.</p>
          </div>

          <div class="mt-6 flex -space-x-3">
            <img src="/avatars/user1.webp" alt="Client avatar 1" class="avatar" />
            <img src="/avatars/user2.webp" alt="Client avatar 2" class="avatar" />
            <img src="/avatars/user3.webp" alt="Client avatar 3" class="avatar" />
            <img src="/avatars/user4.webp" alt="Client avatar 4" class="avatar" />
            <div class="avatar avatar-more">+99</div>
          </div>

          <div class="mt-4 inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs text-blue-100">
            Premium quality • Fast turnaround
          </div>
        </article>
      </div>

      <div class="lg:col-span-4">
        <div class="review-shell">
          <div id="reviewSlider" class="review-slider" aria-live="polite">
            {
              testimonials.map((item) => (
                <article class="review-card" aria-label={`Review by ${item.name}`}>
                  <div>
                    <p class="mb-2 text-3xl leading-none text-gray-300">“</p>
                    <div class="mb-2 flex items-center gap-2 text-sm">
                      <span class="font-semibold text-gray-900">{item.rating}</span>
                      <div class="flex text-amber-500" aria-hidden="true">
                        {
                          Array(5)
                            .fill(0)
                            .map(() => (
                              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                                <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"></path>
                              </svg>
                            ))
                        }
                      </div>
                      <span class="text-gray-500">Rating</span>
                    </div>

                    <p class="text-sm leading-relaxed text-gray-700">{item.quote}</p>
                  </div>

                  <div class="mt-6 flex items-center gap-3 border-t border-gray-100 pt-4">
                    <img src={item.avatar} alt={`${item.name} avatar`} class="h-10 w-10 rounded-full border border-white object-cover shadow" />
                    <div>
                      <p class="text-sm font-semibold text-gray-900">{item.name}</p>
                      <p class="text-xs text-gray-500">{item.role}</p>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="mt-4 flex items-center justify-between">
            <div id="reviewDots" class="flex items-center gap-2"></div>
            <div class="flex items-center gap-2">
              <button id="prevReview" type="button" class="nav-btn" aria-label="Previous review">←</button>
              <button id="nextReview" type="button" class="nav-btn" aria-label="Next review">→</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-wrap {
    background: radial-gradient(130% 80% at 10% 0%, rgba(59, 130, 246, 0.08), transparent 55%),
      radial-gradient(110% 75% at 100% 100%, rgba(17, 24, 39, 0.06), transparent 50%);
  }

  .summary-card {
    border-radius: 1.1rem;
    background: linear-gradient(160deg, #0b1220, #111827 60%, #1f2937);
    padding: 1.25rem;
    color: #fff;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.3);
  }

  .avatar {
    height: 2.5rem;
    width: 2.5rem;
    border-radius: 999px;
    border: 2px solid #fff;
    object-fit: cover;
  }

  .avatar-more {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
  }

  .review-shell {
    border-radius: 1.1rem;
    border: 1px solid rgba(209, 213, 219, 0.7);
    background: rgba(255, 255, 255, 0.85);
    padding: 0.55rem;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.09);
    backdrop-filter: blur(8px);
  }

  .review-slider {
    display: flex;
    transition: transform 0.45s ease;
  }

  .review-card {
    min-width: 100%;
    border-radius: 0.95rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(170deg, #fff, #f8fafc);
    padding: 1rem;
  }

  .review-dot {
    height: 0.48rem;
    width: 0.48rem;
    border-radius: 999px;
    border: 0;
    background: #d1d5db;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .review-dot-active {
    transform: scale(1.3);
    background: #111827;
  }

  .nav-btn {
    border: 1px solid #d1d5db;
    background: #fff;
    color: #111827;
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    line-height: 1;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .nav-btn:hover,
  .nav-btn:focus-visible {
    transform: translateY(-1px);
    border-color: #111827;
    color: #111827;
    outline: none;
  }
</style>

<script>
  const slider = document.getElementById("reviewSlider");
  const dotsContainer = document.getElementById("reviewDots");
  const prevButton = document.getElementById("prevReview");
  const nextButton = document.getElementById("nextReview");

  if (slider && dotsContainer) {
    const total = slider.children.length;
    let index = 0;
    let timer;

    function renderDots() {
      dotsContainer.innerHTML = "";
      for (let i = 0; i < total; i += 1) {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = `review-dot ${i === 0 ? "review-dot-active" : ""}`;
        dot.setAttribute("aria-label", `Go to review ${i + 1}`);
        dot.addEventListener("click", () => {
          index = i;
          updateSlider();
          startAutoRotate();
        });
        dotsContainer.appendChild(dot);
      }
    }

    function updateSlider() {
      slider.style.transform = `translateX(-${index * 100}%)`;
      dotsContainer.querySelectorAll(".review-dot").forEach((dot, dotIndex) => {
        dot.classList.toggle("review-dot-active", dotIndex === index);
      });
    }

    function startAutoRotate() {
      clearInterval(timer);
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      timer = window.setInterval(() => {
        index = (index + 1) % total;
        updateSlider();
      }, 3500);
    }

    function goPrev() {
      index = (index - 1 + total) % total;
      updateSlider();
      startAutoRotate();
    }

    function goNext() {
      index = (index + 1) % total;
      updateSlider();
      startAutoRotate();
    }

    slider.addEventListener("mouseenter", () => clearInterval(timer));
    slider.addEventListener("mouseleave", startAutoRotate);
    prevButton?.addEventListener("click", goPrev);
    nextButton?.addEventListener("click", goNext);

    renderDots();
    updateSlider();
    startAutoRotate();
  }
</script>
