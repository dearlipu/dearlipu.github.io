---
import { siteConfig } from "../config";
---

<section id="testimonials" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-white">

  <div class="grid lg:grid-cols-12 gap-8 items-stretch">

    <!-- LEFT -->
    <div class="lg:col-span-4">

      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Success Stories.
      </h2>

      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
        Real feedback from people I’ve worked with — honest, unfiltered, and results-driven.
      </p>

    </div>


    <!-- MIDDLE (BLACK SUMMARY CARD) -->
    <div class="lg:col-span-4">

      <div class="relative bg-[#101828] text-white rounded-xl p-5 h-full flex flex-col justify-between overflow-hidden">

        <!-- BIG BACKGROUND SVG -->
        <div class="absolute right-[-40px] bottom-[-40px] opacity-10 pointer-events-none">
        
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-[180px] h-[180px]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M20.985 12.528a9 9 0 1 0 -8.45 8.456" />
            <path d="M16 19h6" />
            <path d="M19 16v6" />
            <path d="M9 10h.01" />
            <path d="M15 10h.01" />
            <path d="M9.5 15c.658 .64 1.56 1 2.5 1s1.842 -.36 2.5 -1" />
          </svg>
        
        </div>

        <div>
          <h3 class="text-xl font-bold">4.9/5 Rating</h3>

          <p class="text-gray-300 text-sm mt-2">
            They hit their targets — you’re next.
          </p>
        </div>

        <!-- AVATARS -->
        <div class="flex -space-x-5 mt-4">
          <img src="/avatars/user1.png" class="w-10 h-10 rounded-full border-2 border-white" />
          <img src="/avatars/user2.png" class="w-10 h-10 rounded-full border-2 border-white" />
          <img src="/avatars/user3.png" class="w-10 h-10 rounded-full border-2 border-white" />
          <img src="/avatars/user4.png" class="w-10 h-10 rounded-full border-2 border-white" />

          <!-- ICON AVATAR -->
            <div class="w-10 h-10 rounded-full border-2 border-white bg-black/40 backdrop-blur-sm flex items-center justify-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-white"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M12 5l0 14" />
                <path d="M5 12l14 0" />
              </svg>
            </div>

        </div>

        <!-- STARS -->
        <div class="mt-4">

          <div class="flex gap-1 text-red-500 mb-2">

            {Array(5).fill(0).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="currentColor">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
              </svg>
            ))}

          </div>

          <p class="text-xs text-gray-400">
            Trusted by 100+ businesses
          </p>

        </div>

      </div>

    </div>


    <!-- RIGHT (SLIDER) -->
    <div class="lg:col-span-4 overflow-hidden">
    
      <div id="reviewSlider" class="flex transition-transform duration-500 h-full">

        <!-- CARD 1 -->
        <div class="min-w-full px-2 h-full">
          <div class="group bg-gray-50 border border-gray-200 rounded-xl p-5 h-full 
                      transition-all duration-300 flex flex-col justify-between relative">
        
            <!-- TOP -->
            <div>
        
              <!-- RATING (NEW STYLE) -->
              <div class="flex items-center gap-2 text-sm mb-2">
                <span class="font-semibold text-gray-900">4.9</span>
        
                <div class="flex text-red-500">
                  {Array(1).fill(0).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg"
                      width="14" height="14"
                      viewBox="0 0 24 24"
                      fill="currentColor">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
                    </svg>
                  ))}
                </div>
        
                <span class="text-gray-500">Rating</span>
              </div>
        
              <!-- TEXT -->
              <p class="text-sm text-gray-700 leading-relaxed">
                "The quality were unmatched. We submitted our request on Monday and had polished designs by Wednesday."
              </p>
        
            </div>
        
            <!-- USER -->
            <div class="flex items-center gap-3 mt-6">
              <img src="/avatars/user5.png"
                   class="w-10 h-10 rounded-full object-cover border border-white shadow" />
        
              <div>
                <p class="text-sm font-medium text-gray-900">Sunita Maharana</p>
                <p class="text-xs text-gray-500">Marketing Director</p>
              </div>
            </div>
        
          </div>
        </div>

        <!-- CARD 2 -->
        <div class="min-w-full px-2 h-full">
          <div class="group bg-gray-50 border border-gray-200 rounded-xl p-5 h-full 
                      transition-all duration-300 flex flex-col justify-between relative">
        
            <!-- TOP -->
            <div>
        
              <!-- RATING (NEW STYLE) -->
              <div class="flex items-center gap-2 text-sm mb-2">
                <span class="font-semibold text-gray-900">4.9</span>
        
                <div class="flex text-red-500">
                  {Array(1).fill(0).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg"
                      width="14" height="14"
                      viewBox="0 0 24 24"
                      fill="currentColor">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
                    </svg>
                  ))}
                </div>
        
                <span class="text-gray-500">Rating</span>
              </div>
        
              <!-- TEXT -->
              <p class="text-sm text-gray-700 leading-relaxed">
                "We’ve tried other design subscriptions — none compare to Formix. Professional, reliable, and seriously creative."
              </p>
        
            </div>
        
            <!-- USER -->
            <div class="flex items-center gap-3 mt-6">
              <img src="/avatars/user6.png"
                   class="w-10 h-10 rounded-full object-cover border border-white shadow" />
        
              <div>
                <p class="text-sm font-medium text-gray-900">B Pramit Patra</p>
                <p class="text-xs text-gray-500">R.E. Manager</p>
              </div>
            </div>
        
          </div>
        </div>

        <!-- CARD 3 -->
        <div class="min-w-full px-2 h-full">
          <div class="group bg-gray-50 border border-gray-200 rounded-xl p-5 h-full 
                      transition-all duration-300 flex flex-col justify-between relative">
        
            <!-- TOP -->
            <div>
        
              <!-- RATING -->
              <div class="flex items-center gap-2 text-sm mb-2">
                <span class="font-semibold text-gray-900">4.9</span>
        
                <div class="flex text-red-500">
                  {Array(1).fill(0).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg"
                      width="14" height="14"
                      viewBox="0 0 24 24"
                      fill="currentColor">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M8.243 7.34l-6.38 .925l-.113 .023a1 1 0 0 0 -.44 1.684l4.622 4.499l-1.09 6.355l-.013 .11a1 1 0 0 0 1.464 .944l5.706 -3l5.693 3l.1 .046a1 1 0 0 0 1.352 -1.1l-1.091 -6.355l4.624 -4.5l.078 -.085a1 1 0 0 0 -.633 -1.62l-6.38 -.926l-2.852 -5.78a1 1 0 0 0 -1.794 0l-2.853 5.78z"/>
                    </svg>
                  ))}
                </div>
        
                <span class="text-gray-500">Rating</span>
              </div>
        
              <!-- TEXT -->
              <p class="text-sm text-gray-700 leading-relaxed">
                "Felt like an embedded team with zero friction; communication was clear, and revisions landed perfectly on the first go."
              </p>
        
            </div>
        
            <!-- USER -->
            <div class="flex items-center gap-3 mt-6">
              <img src="/avatars/user7.png"
                   class="w-10 h-10 rounded-full object-cover border border-white shadow" />
        
              <div>
                <p class="text-sm font-medium text-gray-900">Ajaya Sahoo</p>
                <p class="text-xs text-gray-500">G.L. Artist</p>
              </div>
            </div>
        
          </div>
        </div>
    
      </div>
    
    </div>

  </div>

</section>


<script>
  let index = 0;
  const slider = document.getElementById("reviewSlider");
  const total = slider.children.length;

  setInterval(() => {
    index = (index + 1) % total;
    slider.style.transform = `translateX(-${index * 100}%)`;
  }, 3000);
</script>
