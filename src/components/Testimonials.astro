---
const testimonials = [
  {
    quote:
      "I needed someone who could think like a designer and an editor. He delivered a full system, not just random assets.",
    name: "Riya Sharma",
    role: "YouTube Creator",
  },
  {
    quote:
      "Our launch visuals finally looked like a premium brand. Feedback from customers changed immediately.",
    name: "Daniel Kim",
    role: "DTC Founder",
  },
  {
    quote:
      "Fast turnaround, clear process, and every revision felt strategic. It saved my team hours every week.",
    name: "Ananya Rao",
    role: "Marketing Lead",
  },
];
---

<section id="testimonials" class="section-anchor bg-white py-18 sm:py-22">
  <div class="section-shell">
    <p class="section-eyebrow">Testimonials</p>
    <h2 class="section-title mt-5 max-w-3xl">Trusted by clients who need work that performs, not just looks good.</h2>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        testimonials.map((item) => (
          <blockquote class="rounded-3xl border border-gray-200 bg-white p-6 shadow-[0_12px_25px_rgba(15,23,42,0.05)]">
            <p class="text-sm leading-relaxed text-gray-700">“{item.quote}”</p>
            <footer class="mt-6 border-t border-gray-100 pt-4">
              <p class="text-sm font-semibold text-gray-900">{item.name}</p>
              <p class="text-sm text-gray-500">{item.role}</p>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
