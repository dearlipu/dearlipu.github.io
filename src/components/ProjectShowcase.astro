---
import { siteConfig } from "../config";
import "../styles/global.css";
//gg
interface MediaItem {
  type: "image" | "video";
  src: string;
  name: string;
  thumb?: string;
}

interface CaseData {
  title: string;
  media: MediaItem[];
}

const { caseData } = Astro.props as {
  caseData: CaseData;
};

const getMediaThumb = (item: MediaItem) => {
  if (item.type === "video") return item.thumb ?? "/social-card.png";
  return item.src;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={`${caseData.title} case study by ${siteConfig.name}: strategy, creative execution, and measurable outcomes.`} />
    <title>{caseData.title} — Case Study | {siteConfig.name}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anek+Devanagari:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#f6f3ee] text-zinc-900">
    <main class="px-6 py-12 sm:px-10 md:px-14 lg:px-20 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <section class="reveal mt-12 rounded-3xl border border-zinc-200/70 bg-[#f9f6ef] p-5 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">Media Gallery</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Interactive media showcase</h2>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-zinc-600 sm:text-base">Browse stills and motion previews. Click any tile to open a full-screen preview.</p>

          <div class="mt-7 grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-6">
            {caseData.media.map((item) => (
              <figure class="group">
                <button
                  class="media-trigger relative block w-full overflow-hidden rounded-md border border-zinc-300 bg-white p-1 shadow-sm transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md"
                  data-type={item.type}
                  data-src={item.src}
                  data-title={item.name}
                >
                  <img
                    src={getMediaThumb(item)}
                    alt={item.name}
                    loading="lazy"
                    class="h-28 w-full rounded-[2px] object-cover sm:h-32"
                  />
                  {item.type === "video" && (
                    <span class="pointer-events-none absolute inset-0 grid place-items-center rounded-[4px] bg-gradient-to-t from-zinc-950/45 via-zinc-950/15 to-zinc-950/10">
                      <span class="grid h-10 w-10 place-items-center rounded-full border border-white/70 bg-white/90 text-zinc-900 shadow-[0_8px_20px_rgba(0,0,0,0.25)] backdrop-blur-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-player-play h-4 w-4">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                          <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" />
                        </svg>
                      </span>
                    </span>
                  )}
                </button>
                <figcaption class="mt-3 text-center text-[15px] font-medium tracking-tight text-zinc-900">{item.name}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <div class="mt-12 flex justify-center">
          <a
            href="/#projects"
            class="inline-flex items-center gap-2 rounded-full border border-zinc-900/15 bg-white/90 px-4 py-2 text-sm font-semibold tracking-wide text-zinc-700 transition duration-300 hover:-translate-y-0.5 hover:bg-white"
          >
            <span aria-hidden="true">←</span>
            Back to Home
          </a>
        </div>

      </div>
    </main>

    <div id="media-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/0 p-4 transition-colors duration-300">
      <div id="modal-panel" class="relative w-full max-w-5xl scale-[0.96] opacity-0 transition duration-300 ease-out">
        <button id="modal-close" class="absolute -top-12 right-0 rounded-full border border-white/40 bg-white px-4 py-2 text-sm font-semibold text-zinc-900 shadow-md transition hover:-translate-y-0.5 hover:bg-zinc-50">Close ✕</button>
        <div id="modal-content" class="overflow-hidden rounded-2xl border border-white/30 bg-black"></div>
      </div>
    </div>

    <script is:inline>
      const reveals = document.querySelectorAll(".reveal");
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
          });
        },
        { threshold: 0.16 }
      );
      reveals.forEach((section) => revealObserver.observe(section));

      const modal = document.getElementById("media-modal");
      const modalPanel = document.getElementById("modal-panel");
      const modalClose = document.getElementById("modal-close");
      const modalContent = document.getElementById("modal-content");
      const mediaButtons = document.querySelectorAll(".media-trigger");

      const resolveInstagramEmbed = (url) => {
        const match = url.match(/instagram\.com\/(p|reel)\/([^/?#]+)/);
        if (!match) return null;
        return `https://www.instagram.com/${match[1]}/${match[2]}/embed`;
      };

      const openModal = () => {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        requestAnimationFrame(() => {
          modal.classList.remove("bg-zinc-950/0");
          modal.classList.add("bg-zinc-950/80");
          modalPanel?.classList.remove("scale-[0.96]", "opacity-0");
          modalPanel?.classList.add("scale-100", "opacity-100");
        });
      };

      const closeModal = () => {
        modal.classList.remove("bg-zinc-950/80");
        modal.classList.add("bg-zinc-950/0");
        modalPanel?.classList.remove("scale-100", "opacity-100");
        modalPanel?.classList.add("scale-[0.96]", "opacity-0");
        setTimeout(() => {
          modal.classList.add("hidden");
          modal.classList.remove("flex");
          modalContent.innerHTML = "";
        }, 220);
      };

      mediaButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const type = button.dataset.type;
          const src = button.dataset.src;
          const title = button.dataset.title || "Media Preview";

          if (!src) return;

          const instagramEmbed = resolveInstagramEmbed(src);
          if (type === "video") {
            const embedSrc = instagramEmbed ?? src;
            modalContent.innerHTML = `<iframe src="${embedSrc}" title="${title}" class="aspect-video w-full" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>`;
          } else if (instagramEmbed) {
            modalContent.innerHTML = `<iframe src="${instagramEmbed}" title="${title}" class="aspect-video w-full bg-white" allowfullscreen></iframe>`;
          } else {
            modalContent.innerHTML = `<img src="${src}" alt="${title}" class="max-h-[84vh] w-full object-contain bg-black" />`;
          }
          openModal();
        });
      });

      modalClose?.addEventListener("click", closeModal);
      modal?.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });
    </script>
  </body>
</html>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 700ms ease, transform 700ms ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
