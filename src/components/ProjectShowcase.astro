---
import { siteConfig } from "../config";
import "../styles/global.css";

interface StarBlock {
  situation: string;
  task: string;
  action: string;
  result: string;
}

interface MetricBlock {
  target: number;
  format: "compact" | "number";
  prefix: string;
  label: string;
}

interface MediaItem {
  type: "image" | "video";
  src: string;
  name: string;
  thumb?: string;
}

interface BeforeAfterItem {
  title: string;
  description: string;
  media: string;
}

interface CaseData {
  title: string;
  summary: string;
  metric: MetricBlock;
  timeline: string;
  tags: string[];
  star: StarBlock;
  media: MediaItem[];
  beforeAfter: {
    before: BeforeAfterItem;
    after: BeforeAfterItem;
  };
  insights: string[];
}

const { caseData, projectNumber } = Astro.props as {
  caseData: CaseData;
  projectPrefix: string;
  projectNumber: number;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={`${caseData.title} case study by ${siteConfig.name}: strategy, creative execution, and measurable outcomes.`} />
    <title>{caseData.title} — Case Study | {siteConfig.name}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anek+Devanagari:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#f6f3ee] text-zinc-900">
    <main class="px-6 py-12 sm:px-10 md:px-14 lg:px-20 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-900/15 bg-white/90 px-4 py-2 text-sm font-semibold tracking-wide text-zinc-700 transition duration-300 hover:-translate-y-0.5 hover:bg-white"
        >
          <span aria-hidden="true">←</span>
          Back to Home
        </a>

        <section class="reveal mt-8 overflow-hidden rounded-3xl border border-white/70 bg-white/75 p-6 shadow-[0_20px_70px_rgba(0,0,0,0.08)] backdrop-blur sm:p-9 lg:p-12">
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(29,78,216,0.13),transparent_35%)]"></div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">Featured Project {projectNumber}</p>
          <h1 class="mt-3 text-3xl font-extrabold leading-tight text-zinc-900 sm:text-4xl lg:text-5xl">{caseData.title}</h1>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-700 sm:text-lg">{caseData.summary}</p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Primary Metric</p>
              <p class="mt-2 text-xl font-bold text-zinc-900">
                <span
                  class="counter"
                  data-target={caseData.metric.target}
                  data-format={caseData.metric.format}
                  data-prefix={caseData.metric.prefix}
                >
                  {caseData.metric.prefix}0
                </span>
                {" "}{caseData.metric.label}
              </p>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Project Timeline</p>
              <p class="mt-2 text-xl font-bold text-zinc-900">{caseData.timeline}</p>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm sm:col-span-2 lg:col-span-1 transition duration-300 hover:-translate-y-1 hover:shadow-md">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Focus Areas</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {caseData.tags.map((tag) => <span class="rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold text-zinc-700">{tag}</span>)}
              </div>
            </div>
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200 bg-white p-6 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Before vs After</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Transformation at a glance</h2>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-zinc-600 sm:text-base">A direct comparison of the original direction and the final refined outcome.</p>
          <div class="mt-7 grid gap-5 md:grid-cols-2">
            {([caseData.beforeAfter.before, caseData.beforeAfter.after] as const).map((item, index) => (
              <article class="group rounded-2xl border border-zinc-200 bg-zinc-50 p-4 transition duration-300 hover:-translate-y-1 hover:shadow-lg">
                <p class={`text-xs font-semibold uppercase tracking-[0.14em] ${index === 0 ? "text-zinc-500" : "text-blue-700"}`}>
                  {index === 0 ? "Before" : "After"}
                </p>
                <h3 class="mt-2 text-lg font-bold text-zinc-900">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-zinc-700">{item.description}</p>
                <button
                  class="media-trigger mt-4 w-full overflow-hidden rounded-xl border border-zinc-300 bg-white"
                  data-type="image"
                  data-src={item.media}
                  data-title={item.title}
                >
                  <img src={item.media} alt={item.title} class="h-44 w-full object-cover transition duration-300 group-hover:scale-[1.02]" />
                </button>
              </article>
            ))}
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200/70 bg-[#f9f6ef] p-5 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">Media Gallery</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Interactive media showcase</h2>
          <p class="mt-2 max-w-3xl text-sm leading-relaxed text-zinc-600 sm:text-base">Browse stills and motion previews. Click any tile to open a full-screen preview.</p>

          <div class="mt-7 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {caseData.media.map((item) => (
              <article class="group relative rounded-2xl border border-zinc-300 bg-white p-2 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
                <button
                  class="media-trigger relative block w-full overflow-hidden rounded-xl"
                  data-type={item.type}
                  data-src={item.src}
                  data-title={item.name}
                >
                  <img
                    src={item.type === "video" ? item.thumb ?? "/social-card.png" : item.src}
                    alt={item.name}
                    loading="lazy"
                    class="h-52 w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  />
                  {item.type === "video" && (
                    <span class="pointer-events-none absolute inset-0 grid place-items-center bg-gradient-to-t from-zinc-950/45 via-zinc-950/20 to-zinc-950/20">
                      <span class="grid h-16 w-16 place-items-center rounded-full border border-white/60 bg-white/90 text-zinc-900 shadow-[0_8px_30px_rgba(0,0,0,0.25)] backdrop-blur-sm">
                        <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 translate-x-[1px]">
                          <path d="M8 5v14l11-7z"></path>
                        </svg>
                      </span>
                    </span>
                  )}
                </button>
                <p class="px-2 pb-2 pt-3 text-sm font-semibold text-zinc-800">{item.name}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200 bg-white p-6 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Case Study Highlights</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Why this project performed</h2>
          <div class="mt-7 grid gap-4 md:grid-cols-3">
            {caseData.insights.map((item) => (
              <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
                <p class="text-sm leading-relaxed text-zinc-700">{item}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200 bg-white p-6 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">S.T.A.R. Breakdown</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Situation · Task · Action · Result</h2>

          <dl class="mt-8 grid gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Situation</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.situation}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Task</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.task}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Action</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.action}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Result</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.result}</dd>
            </div>
          </dl>
        </section>
      </div>
    </main>

    <div id="media-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/80 p-4">
      <div class="relative w-full max-w-5xl">
        <button id="modal-close" class="absolute -top-12 right-0 rounded-full border border-white/40 bg-white px-4 py-2 text-sm font-semibold text-zinc-900 shadow-md transition hover:-translate-y-0.5 hover:bg-zinc-50">Close ✕</button>
        <div id="modal-content" class="overflow-hidden rounded-2xl border border-white/30 bg-black"></div>
      </div>
    </div>

    <script is:inline>
      const formatCounterValue = (value, format) => {
        if (format === "compact" && value >= 1000) {
          return `${(value / 1000).toFixed(value % 1000 === 0 ? 0 : 1)}k`;
        }
        return `${Math.round(value)}`;
      };

      const counters = document.querySelectorAll(".counter");
      const animations = new WeakMap();

      const startCounter = (el) => {
        const target = Number(el.dataset.target || "0");
        const prefix = el.dataset.prefix || "";
        const format = el.dataset.format || "number";
        const duration = 1200;
        const start = performance.now();

        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = target * eased;
          el.textContent = `${prefix}${formatCounterValue(value, format)}`;
          if (progress < 1 && animations.get(el) !== null) {
            const rafId = requestAnimationFrame(tick);
            animations.set(el, rafId);
          } else {
            animations.set(el, null);
          }
        };

        const rafId = requestAnimationFrame(tick);
        animations.set(el, rafId);
      };

      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const el = entry.target;
            if (entry.isIntersecting) {
              const existing = animations.get(el);
              if (typeof existing === "number") cancelAnimationFrame(existing);
              startCounter(el);
            } else {
              const existing = animations.get(el);
              if (typeof existing === "number") cancelAnimationFrame(existing);
              animations.set(el, null);
              const prefix = el.dataset.prefix || "";
              el.textContent = `${prefix}0`;
            }
          });
        },
        { threshold: 0.55 }
      );

      counters.forEach((counter) => {
        animations.set(counter, null);
        counterObserver.observe(counter);
      });

      const reveals = document.querySelectorAll(".reveal");
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
          });
        },
        { threshold: 0.16 }
      );
      reveals.forEach((section) => revealObserver.observe(section));

      const modal = document.getElementById("media-modal");
      const modalClose = document.getElementById("modal-close");
      const modalContent = document.getElementById("modal-content");
      const mediaButtons = document.querySelectorAll(".media-trigger");

      const closeModal = () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        modalContent.innerHTML = "";
      };

      mediaButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const type = button.dataset.type;
          const src = button.dataset.src;
          const title = button.dataset.title || "Media Preview";

          if (!src) return;

          if (type === "video") {
            modalContent.innerHTML = `<iframe src="${src}" title="${title}" class="aspect-video w-full" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>`;
          } else {
            modalContent.innerHTML = `<img src="${src}" alt="${title}" class="max-h-[84vh] w-full object-contain bg-black" />`;
          }

          modal.classList.remove("hidden");
          modal.classList.add("flex");
        });
      });

      modalClose?.addEventListener("click", closeModal);
      modal?.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeModal();
      });
    </script>
  </body>
</html>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 700ms ease, transform 700ms ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
