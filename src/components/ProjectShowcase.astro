---
import { siteConfig } from "../config";
import "../styles/global.css";

interface StarBlock {
  situation: string;
  task: string;
  action: string;
  result: string;
}

interface MetricBlock {
  target: number;
  format: "compact" | "number";
  prefix: string;
  label: string;
}

interface CaseData {
  title: string;
  summary: string;
  metric: MetricBlock;
  timeline: string;
  tags: string[];
  star: StarBlock;
}

const { caseData, projectPrefix, projectNumber } = Astro.props as {
  caseData: CaseData;
  projectPrefix: string;
  projectNumber: number;
};

const imageLabels = Array.from({ length: 12 }, (_, index) => {
  const number = String(97 + index).padStart(5, "0");
  return {
    src: `/projects/${projectPrefix}-${index + 1}.webp`,
    name: `image${number}.jpeg`,
  };
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Case study details for ${caseData.title} by ${siteConfig.name}.`} />
    <title>{caseData.title} Case Study | {siteConfig.name}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anek+Devanagari:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-[#f6f3ee] text-zinc-900">
    <main class="px-6 py-12 sm:px-10 md:px-14 lg:px-20 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-900/15 bg-white/90 px-4 py-2 text-sm font-semibold tracking-wide text-zinc-700 transition duration-300 hover:-translate-y-0.5 hover:bg-white"
        >
          <span aria-hidden="true">←</span>
          Back to Home
        </a>

        <section class="reveal mt-8 rounded-3xl border border-white/70 bg-white/75 p-6 shadow-[0_20px_70px_rgba(0,0,0,0.08)] backdrop-blur sm:p-9 lg:p-12">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-700">Project {projectNumber}</p>
          <h1 class="mt-3 text-3xl font-extrabold leading-tight text-zinc-900 sm:text-4xl lg:text-5xl">{caseData.title}</h1>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-700 sm:text-lg">{caseData.summary}</p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Primary metric</p>
              <p class="mt-2 text-xl font-bold text-zinc-900">
                <span
                  class="counter"
                  data-target={caseData.metric.target}
                  data-format={caseData.metric.format}
                  data-prefix={caseData.metric.prefix}
                >
                  {caseData.metric.prefix}0
                </span>
                {" "}{caseData.metric.label}
              </p>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Timeline</p>
              <p class="mt-2 text-xl font-bold text-zinc-900">{caseData.timeline}</p>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm sm:col-span-2 lg:col-span-1">
              <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">Focus areas</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {caseData.tags.map((tag) => <span class="rounded-full bg-zinc-100 px-3 py-1 text-xs font-semibold text-zinc-700">{tag}</span>)}
              </div>
            </div>
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200/70 bg-[#f9f6ef] p-5 sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">Gallery</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Curated visual wall</h2>

          <div class="mt-7 grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-6">
            {imageLabels.map((item) => (
              <figure class="group">
                <div class="rounded-md border border-zinc-300 bg-white p-1 shadow-sm transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md">
                  <img
                    src={item.src}
                    alt={`${caseData.title} ${item.name}`}
                    loading="lazy"
                    class="h-28 w-full rounded-[2px] object-cover sm:h-32"
                  />
                </div>
                <figcaption class="mt-3 text-center text-lg font-medium tracking-tight text-zinc-900">{item.name}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section class="reveal mt-12 rounded-3xl border border-zinc-200 bg-white p-6 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">S.T.A.R. Breakdown</p>
          <h2 class="mt-2 text-2xl font-bold text-zinc-900 sm:text-3xl">Situation · Task · Action · Result</h2>

          <dl class="mt-8 grid gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Situation</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.situation}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Task</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.task}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Action</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.action}</dd>
            </div>
            <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Result</dt>
              <dd class="mt-2 text-sm leading-relaxed text-zinc-700">{caseData.star.result}</dd>
            </div>
          </dl>
        </section>
      </div>
    </main>

    <script is:inline>
      const formatCounterValue = (value, format) => {
        if (format === "compact" && value >= 1000) {
          return `${(value / 1000).toFixed(value % 1000 === 0 ? 0 : 1)}k`;
        }
        return `${Math.round(value)}`;
      };

      const counters = document.querySelectorAll(".counter");
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            const el = entry.target;
            const target = Number(el.dataset.target || "0");
            const prefix = el.dataset.prefix || "";
            const format = el.dataset.format || "number";
            const duration = 1400;
            const start = performance.now();

            const tick = (now) => {
              const progress = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const value = target * eased;
              el.textContent = `${prefix}${formatCounterValue(value, format)}`;
              if (progress < 1) requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
            counterObserver.unobserve(el);
          });
        },
        { threshold: 0.45 }
      );

      counters.forEach((counter) => counterObserver.observe(counter));

      const reveals = document.querySelectorAll(".reveal");
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.2 }
      );
      reveals.forEach((section) => revealObserver.observe(section));
    </script>
  </body>
</html>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 700ms ease, transform 700ms ease;
  }

  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
