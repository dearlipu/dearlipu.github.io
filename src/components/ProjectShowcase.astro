---
import { siteConfig } from "../config";
import "../styles/global.css";

interface MediaItem {
  type: "image" | "video";
  src: string;
  name: string;
  thumb?: string;
}

interface CaseData {
  title: string;
  media: MediaItem[];
}

const { caseData } = Astro.props as {
  caseData: CaseData;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={`${caseData.title} case study by ${siteConfig.name}.`} />
    <title>{caseData.title} — Case Study | {siteConfig.name}</title>
  </head>

  <body class="bg-black text-white">
    <main>
      <h1 class="sr-only">{caseData.title}</h1>

      <section>
        {caseData.media.map((item) => (
          <article class="w-full">
            {item.type === "video" ? (
              <iframe
                src={item.src}
                title={item.name}
                class="block aspect-video w-full border-0"
                loading="lazy"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
              ></iframe>
            ) : (
              <img
                src={item.src}
                alt={item.name}
                loading="lazy"
                class="block h-auto w-full"
              />
            )}
          </article>
        ))}
      </section>

      <div class="fixed bottom-4 left-1/2 z-10 -translate-x-1/2">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-semibold text-black shadow-lg"
        >
          <span aria-hidden="true">←</span>
          Back to Projects
        </a>
      </div>
    </main>
  </body>
</html>
