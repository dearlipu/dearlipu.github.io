---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="p-8 sm:p-10 md:px-16 lg:px-24">
      <button 
        onclick="history.back()" 
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-black group transition"
      >
        <span class="flex items-center justify-center transition group-hover:-translate-x-1">
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            width="20" 
            height="20" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="2" 
            stroke-linecap="round" 
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M5 12l14 0" />
            <path d="M5 12l4 4" />
            <path d="M5 12l4 -4" />
          </svg>
        </span>
        Back
      </button>
    </div>

    <!-- MAIN -->
    <section id="privacy" class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h1>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website.
          </p>
        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-10 shadow-sm hover:shadow-md transition">

            <!-- LETTER STYLE CONTENT -->
            <div class="space-y-6 text-sm md:text-base leading-relaxed text-gray-600">

              <p id="privacy-intro">
                This Privacy Policy outlines how your information is collected, used, and protected when you interact with this website and related services.
              </p>

              <p id="privacy-collection">
                We may collect personal information such as your name, email address, and contact details when you contact us, request services, or communicate with us. This information allows us to provide services efficiently and maintain clear communication.
              </p>

              <p id="privacy-usage">
                The information collected is used strictly for communication, project delivery, and improving service quality. We do not sell, rent, or misuse your personal data.
              </p>

              <p id="privacy-cookies">
                This website may use cookies or analytics tools to understand usage patterns and improve performance. Third-party platforms may collect data under their own policies.
              </p>

              <p id="privacy-security">
                We take reasonable steps to protect your data; however, no system can guarantee complete security against all potential risks.
              </p>

              <p id="privacy-contact">
                If you have any questions regarding this policy, you may contact us at 
                <span class="text-gray-900 font-medium">
                  {siteConfig.social.email}
                </span>.
              </p>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
