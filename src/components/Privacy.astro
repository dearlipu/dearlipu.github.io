---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- MAIN -->
    <section id="privacy" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT (same as About section) -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website and services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300">

            <!-- META -->
            <p class="text-xs text-gray-400 mb-6">
              Last updated: April 2026
            </p>

            <!-- CONTENT (About-style typography) -->
            <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

              <!-- INTRO -->
              <p class="whitespace-pre-line text-gray-700">
                This Privacy Policy outlines how we collect, use, and protect your information when you interact with our website and services. By using this website, you agree to the practices described below.
              </p>

              <!-- 1 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  1. Information We Collect
                </h2>
                <p>
                  We may collect personal information such as your name, email address, and contact details when you contact us, request services, or interact with our content. You may also provide project-related files or references for creative work.
                </p>
              </div>

              <!-- 2 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  2. How We Use Your Information
                </h2>
                <p>
                  Your information is used to communicate, deliver graphic design and video editing services, manage projects, and improve workflow efficiency. We do not sell, rent, or misuse your data.
                </p>
              </div>

              <!-- 3 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  3. Use of Client Materials
                </h2>
                <p>
                  Any files, images, or references provided by you are used strictly for project execution. We do not reuse or distribute client materials outside the agreed scope without permission.
                </p>
              </div>

              <!-- 4 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  4. Cookies & Analytics
                </h2>
                <p>
                  This website may use cookies or basic analytics tools to understand user behavior and improve performance, design, and overall user experience.
                </p>
              </div>

              <!-- 5 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  5. Third-Party Services
                </h2>
                <p>
                  We may use third-party platforms such as social media, analytics tools, or communication services. These platforms operate under their own privacy policies.
                </p>
              </div>

              <!-- 6 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  6. Data Protection
                </h2>
                <p>
                  We implement reasonable technical and organizational measures to protect your information. However, no digital system can guarantee complete security.
                </p>
              </div>

              <!-- 7 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  7. Your Rights
                </h2>
                <p>
                  You may request access, correction, or deletion of your personal information at any time by contacting us directly.
                </p>
              </div>

              <!-- 8 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  8. Contact
                </h2>
                <p>
                  For any privacy-related questions, contact:
                  <span class="text-gray-900 font-medium">
                    {siteConfig.social.email}
                  </span>
                </p>
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
