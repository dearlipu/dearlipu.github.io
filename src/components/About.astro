---
import { siteConfig } from "../config";

const aboutHighlights = [
  {
    title: "What you get",
    points: [
      "A sharper visual identity that feels premium and consistent.",
      "Clear creative that communicates fast and builds trust.",
      "Assets designed to support real business outcomes, not just aesthetics.",
    ],
  },
  {
    title: "How I work",
    points: [
      "I start by understanding your goals, audience, and positioning.",
      "I develop concepts, execute fast, and refine through focused feedback.",
      "I deliver production-ready files tailored to each platform.",
    ],
  },
];

const impactStats = [
  { value: 12, suffix: "", label: "Years of Experience" },
  { value: 270, suffix: "", label: "Completed Projects" },
  { value: 50, suffix: "+", label: "Clients Worldwide" },
];
---

<section id="about" class="px-6 py-14 sm:px-10 sm:py-16 md:px-14 lg:px-20 lg:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-4">
        <p
          class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-blue-700"
        >
          About
        </p>

        <h2 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
          Who I Am.
        </h2>
        <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

        <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
          I create strategic visuals that clarify your message, strengthen brand perception, and turn attention into action.
        </p>

        <div class="impact-metrics mt-6 rounded-2xl p-3 sm:p-4" style={`--impact-accent: ${siteConfig.accentColor};`} data-counter-root>
          <div class="grid grid-cols-3 overflow-hidden rounded-xl border border-gray-200 bg-white/80">
            {
              impactStats.map((stat, index) => (
                <article class={`impact-metric-item px-2 py-3 text-center sm:px-3 sm:py-4 ${index < impactStats.length - 1 ? "border-r border-gray-200" : ""}`}>
                  <p class="text-3xl font-extrabold leading-none sm:text-4xl">
                    <span class="impact-counter" data-counter-target={stat.value}>0</span>{stat.suffix}
                  </p>
                  <p class="mt-2 text-[11px] font-semibold leading-tight text-gray-600 sm:text-xs">{stat.label}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>

      <div class="space-y-8 lg:col-span-8">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm sm:p-7">
          <p class="text-base leading-relaxed text-gray-700 sm:text-lg md:text-xl whitespace-pre-line">
            {siteConfig.aboutMe}
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          {
            aboutHighlights.map((item) => (
              <article class="rounded-2xl border border-gray-200 bg-gray-50 p-5 sm:p-6">
                <h3 class="text-base font-semibold text-gray-900 sm:text-lg">{item.title}</h3>
                <ul class="mt-3 space-y-2">
                  {
                    item.points.map((point) => (
                      <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-600 sm:text-base">
                            <span class="service-bullet" aria-hidden="true"></span>
                            <span class="min-w-0 flex-1">{point}</span>
                      </li>
                    ))
                  }
                </ul>
              </article>
            ))
          }
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Core Capabilities</h3>
          <div class="mt-3 flex flex-wrap gap-3">
            {
              siteConfig.skills.map((skill) => (
                <span class="px-3 sm:px-4 py-1.5 sm:py-2 bg-gray-100 text-gray-800 rounded-full text-sm sm:text-base md:text-lg font-medium hover:bg-gray-200 transition-colors duration-200">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .service-bullet {
    margin-top: 0.62em;
    display: inline-block;
    height: 0.375rem;
    width: 0.375rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: #9ca3af;
  }

  .impact-metrics {
    border: 1px solid rgba(209, 213, 219, 0.8);
    background:
      radial-gradient(circle at 15% 10%, rgba(255, 255, 255, 0.96), transparent 45%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.96) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 16px 30px -24px rgba(15, 23, 42, 0.35);
  }

  .impact-metric-item {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.75), rgba(248, 250, 252, 0.9));
  }

  .impact-counter {
    color: var(--impact-accent, #2563eb);
    font-variant-numeric: tabular-nums;
    text-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
  }
</style>

<script>
  const counterRoot = document.querySelector("[data-counter-root]");

  if (counterRoot) {
    const counters = Array.from(counterRoot.querySelectorAll("[data-counter-target]"));

    const runCounters = () => {
      counters.forEach((counter, index) => {
        const target = Number(counter.getAttribute("data-counter-target") || 0);
        const duration = 1300 + index * 180;
        const start = performance.now();

        const animate = (currentTime) => {
          const progress = Math.min((currentTime - start) / duration, 1);
          const easedProgress = 1 - Math.pow(1 - progress, 3);
          counter.textContent = Math.floor(target * easedProgress).toString();

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            counter.textContent = target.toString();
          }
        };

        requestAnimationFrame(animate);
      });
    };

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            runCounters();
            obs.disconnect();
          }
        });
      },
      { threshold: 0.4 },
    );

    observer.observe(counterRoot);
  }
</script>
