---
import { siteConfig } from "../config";
import "../styles/global.css";

const faqs = [
  {
    q: "Can you match my preferred style or references?",
    a: "Yes. Share references, competitors, moodboards, or rough ideas, and I’ll align the output with your direction while improving clarity and performance.",
  },
  {
    q: "What if I’m not sure what I need yet?",
    a: "That’s common. I can help you define a clear creative direction based on your goals, audience, and platform before production starts.",
  },
  {
    q: "Do you work with creators, brands, and businesses?",
    a: "Yes. I work with solo creators, startups, and established businesses — from one-time projects to ongoing monthly support.",
  },
  {
    q: "Can you handle ongoing monthly work?",
    a: "Absolutely. Monthly support is available for recurring design, editing, and content execution with consistent quality and turnaround.",
  },
  {
    q: "How fast is your delivery?",
    a: "Delivery depends on scope. Small tasks may take 24–48 hours, while larger projects are planned with a timeline shared in advance.",
  },
  {
    q: "What happens after I submit an inquiry?",
    a: "You’ll receive a response with estimated scope, pricing, and timeline. Once approved, we move into execution with regular updates.",
  },
  {
    q: "Will I get drafts before final delivery?",
    a: "Yes. I share draft/proof stages for review so we can refine before the final files are delivered.",
  },
  {
    q: "What if I need revisions after delivery?",
    a: "Minor revisions are included. If additional work is required, I’ll share a clear add-on estimate before proceeding.",
  },
  {
    q: "Do you work with international clients?",
    a: "Yes. I work globally and manage communication online to keep collaboration smooth across time zones.",
  },
  {
    q: "What makes your service different?",
    a: "I focus on strategic visuals that not only look premium but also support real business outcomes: clarity, trust, and conversion.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>FAQs | {siteConfig.name}</title>
    <meta name="description" content="Frequently asked questions about services, workflow, delivery, and revisions." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="text-gray-800">
    <section class="px-6 py-12 sm:px-10 md:px-16 md:py-16 lg:px-20 lg:py-20 overflow-x-hidden">
      <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-4">
          <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">
            FAQ
          </p>

          <h1 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">
            Frequently asked questions
          </h1>

          <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

          <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
            Everything you need to know about my process, timelines, revisions, and collaboration model.
          </p>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/" class="faq-btn primary" style={`--accent: ${siteConfig.accentColor}`}>Back to Home</a>
            <a href="/#contact" class="faq-btn secondary">Start a Project</a>
          </div>
        </div>

        <div class="lg:col-span-8">
          <div class="faq-card">
            <div class="space-y-3">
              {
                faqs.map((item, index) => (
                  <details class="faq-item" open={index === 0}>
                    <summary>
                      <span>{item.q}</span>
                    </summary>
                    <p>{item.a}</p>
                  </details>
                ))
              }
            </div>

            <div class="mt-8 rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-600">
              Still have questions? Reach out at
              <a href={`mailto:${siteConfig.social.email}`} class="font-semibold text-gray-900 underline-offset-2 hover:underline"> {siteConfig.social.email}</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>

<style>
  .faq-card {
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(248, 250, 252, 0.92));
    padding: 1rem;
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(8px);
  }

  .faq-item {
    border-radius: 0.9rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 0.2rem 0.8rem;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.1rem;
    color: #6b7280;
    transition: transform 0.2s ease;
  }

  .faq-item[open] summary::after {
    content: "−";
    transform: rotate(180deg);
  }

  .faq-item p {
    margin: 0 0 0.9rem;
    color: #4b5563;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .faq-btn {
    border-radius: 999px;
    padding: 0.58rem 0.95rem;
    font-size: 0.84rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .faq-btn.primary {
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .faq-btn.primary:hover,
  .faq-btn.primary:focus-visible {
    transform: translateY(-1px);
    filter: brightness(0.95);
    outline: none;
  }

  .faq-btn.secondary {
    border: 1px solid #d1d5db;
    background: #fff;
    color: #111827;
  }

  .faq-btn.secondary:hover,
  .faq-btn.secondary:focus-visible {
    transform: translateY(-1px);
    border-color: #9ca3af;
    outline: none;
  }
</style>
