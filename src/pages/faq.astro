---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>FAQ</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK BUTTON -->
    <div id="backBtnWrapper"
      class="fixed top-6 right-6 z-50
             transition-all duration-300 ease-out">
    
      <button 
        onclick="history.length > 1 ? history.back() : window.location.href='/'"
        class="group flex items-center gap-2 px-4 py-2 rounded-full
               bg-white/70 backdrop-blur-md border border-gray-200
               shadow-md hover:shadow-lg
               text-sm text-gray-700 hover:text-black
               transition-all duration-300"
      >
        <span class="transition group-hover:-translate-x-1">←</span>
        Back
      </button>
    
    </div>

    <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Frequently Asked Questions.
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            Common questions about services, workflow, and project process.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300
                      w-full max-w-full">

            <div class="space-y-12 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">
            
              <!-- ITEM -->
              <div class="space-y-4">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  1. What services do you offer?
                </h2>
            
                <ul class="space-y-2 text-gray-600">
                  <li>• Graphic design (posters, banners, social media, thumbnails)</li>
                  <li>• Photo editing and retouching</li>
                  <li>• Video editing (YouTube, Instagram, cinematic)</li>
                  <li>• Motion graphics and visual content</li>
                </ul>
              </div>
            
              <!-- DIVIDER -->
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  2. How can I start a project?
                </h2>
            
                <p>
                  Contact me via website or email with your requirements. I’ll share pricing, timeline, and next steps after understanding your needs.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-4">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  3. What information do you need?
                </h2>
            
                <ul class="space-y-2">
                  <li>• Project details or idea</li>
                  <li>• Reference examples</li>
                  <li>• Required size or platform</li>
                  <li>• Deadline</li>
                </ul>
            
                <p class="text-gray-500 text-base sm:text-lg">
                  Clear input = faster and better results.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  4. How much do you charge?
                </h2>
            
                <p>
                  Pricing depends on the type of work, complexity, and time required. Custom quotes are provided for each project.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  5. Do you take advance payment?
                </h2>
            
                <p>
                  Yes, advance payment is required to confirm your booking and secure your project slot.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  6. How many revisions are included?
                </h2>
            
                <p>
                  A limited number of revisions are included. Additional revisions or major changes may be charged separately.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  7. How long does a project take?
                </h2>
            
                <p>
                  Small tasks may take 1–2 days, while larger projects depend on scope and complexity.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-4">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  8. What file formats will I receive?
                </h2>
            
                <ul class="space-y-2">
                  <li>• JPG / PNG</li>
                  <li>• MP4 / MOV</li>
                  <li>• Source files (if included)</li>
                </ul>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  9. Will I get full rights?
                </h2>
            
                <p>
                  Yes, full usage rights are transferred after complete payment. Work may still be showcased in portfolio unless agreed otherwise.
                </p>
              </div>
            
              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
            
              <!-- ITEM -->
              <div class="space-y-3">
                <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-gray-900">
                  10. Do you offer refunds?
                </h2>
            
                <p>
                  Payments are generally non-refundable once work has started. Exceptions may apply depending on the situation.
                </p>
              </div>
            
              <!-- FINAL CONTACT -->
              <div class="pt-8">
                <p class="text-gray-500 text-base sm:text-lg">
                  Have more questions?
                </p>
                <p class="text-gray-900 font-medium mt-1">
                  {siteConfig.social.email}
                </p>
              </div>
            
            </div>

          </div>

        </div>

      </div>

    </section>

      <script>
        let lastScroll = 0;
        const btn = document.getElementById("backBtnWrapper");
      
        window.addEventListener("scroll", () => {
          const currentScroll = window.scrollY;
      
          if (currentScroll > lastScroll && currentScroll > 100) {
            // hide (scroll down)
            btn.style.transform = "translateY(-40px)";
            btn.style.opacity = "0";
            btn.style.pointerEvents = "none";
          } else {
            // show (scroll up)
            btn.style.transform = "translateY(0)";
            btn.style.opacity = "1";
            btn.style.pointerEvents = "auto";
          }
      
          lastScroll = currentScroll;
        });
      </script>

  </body>
</html>
