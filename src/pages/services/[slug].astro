---
import Header from "../../components/Header.astro";import Footer from "../../components/Footer.astro";import { services } from "../../config";import "../../styles/global.css";
export function getStaticPaths(){return services.map(([slug,title,description,items])=>({params:{slug},props:{title,description,items}}));}
const { title, description, items } = Astro.props;
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><meta name="description" content={description}/><title>{title} — DearLipu Studio</title></head><body><Header/><main><section class="hero"><div class="container split"><div><p class="eyebrow">Service</p><h1>{title}</h1><p class="lead">{description}</p><div class="cta-row"><a class="btn primary" href="/contact">Start Your Project</a><a class="btn secondary" href="/#work">View Work</a></div></div><div class="hero-visual"><img src="/images/contact.webp" alt={`${title} creative mockup`}/></div></div></section><section class="section-pad alt"><div class="container"><div class="section-head"><h2>Benefits, process, gallery, pricing, and support.</h2></div><div class="process">{items.map((item,i)=><div><span>{i+1}</span><h3>{item}</h3><p>Premium execution connected to business clarity and customer trust.</p></div>)}</div></div></section><section class="final-cta"><div class="container"><h2>Ready to start {title}?</h2><p>Get a clear plan, timeline, and quote.</p><a class="btn light" href="/contact">Contact Studio</a></div></section></main><Footer/></body></html>
