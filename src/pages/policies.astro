---
import "../styles/global.css";

import Privacy from "../components/Privacy.astro";
import Refund from "../components/Refund.astro";
//import Service from "../components/Service.astro";
//import Copyright from "../components/Copyright.astro";
//import Disclaimer from "../components/Disclaimer.astro";
//import Terms from "../components/Terms.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Terms & Policies</title>

    <!-- INLINE CSS -->
    <style>
      html {
        scroll-behavior: smooth;
      }

      .nav-pill {
        padding: 6px 14px;
        font-size: 14px;
        border-radius: 999px;
        color: #555;
        background: transparent;
        transition: all 0.25s ease;
      }

      .nav-pill:hover {
        background: rgba(0,0,0,0.05);
        color: #000;
        transform: translateY(-2px);
      }

      .nav-pill.active {
        background: #f3f4f6;
        color: #111;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
      }
    </style>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="px-6 sm:px-10 md:px-16 lg:px-24 py-6">
      <button 
        onclick="history.back()" 
        class="flex items-center gap-2 text-sm text-gray-700 
               px-4 py-2 rounded-full
               bg-white/60 backdrop-blur-md border border-gray-200
               shadow-sm hover:shadow-md hover:bg-white/80
               transition duration-300 group"
      >
        <span class="transition group-hover:-translate-x-1">←</span>
        Back
      </button>
    </div>

    <!-- FLOATING NAV -->
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
      <div class="flex gap-2 sm:gap-3 px-3 py-2 sm:px-4 sm:py-3
                  bg-white/70 backdrop-blur-xl border border-gray-200
                  rounded-full shadow-lg">

        <a href="#privacy" class="nav-pill">Privacy</a>
        <!--<a href="#service" class="nav-pill">Service</a>
        <a href="#refund" class="nav-pill">Refund</a>
        <a href="#terms" class="nav-pill">Terms</a>
        <a href="#disclaimer" class="nav-pill">Disclaimer</a>
        <a href="#copyright" class="nav-pill">Copyright</a>-->
        
      </div>
    </div>

    <!-- CONTENT -->
    <main class="pb-28">

      <div id="privacy">
        <Privacy />
      </div>

      <div id="refund">
        <Refund />
      </div>

    </main>

    <!-- INLINE JS -->
    <script>
      const sections = document.querySelectorAll("section");
      const navLinks = document.querySelectorAll(".nav-pill");

      window.addEventListener("scroll", () => {
        let current = "";

        sections.forEach((section) => {
          const sectionTop = section.offsetTop - 150;
          const sectionHeight = section.clientHeight;

          if (scrollY >= sectionTop) {
            current = section.getAttribute("id");
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("active");
          if (link.getAttribute("href") === "#" + current) {
            link.classList.add("active");
          }
        });
      });
    </script>

  </body>
</html>
