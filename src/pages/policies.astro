---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Terms & Policies - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="p-8 sm:p-10 md:px-16 lg:px-24">
      <button 
        onclick="history.back()" 
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-black group"
      >
        <span class="group-hover:-translate-x-1 transition">←</span>
        Back
      </button>
    </div>

    <!-- ===================== PRIVACY ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold text-gray-900">
            Privacy Policy.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm">
            How your data is collected and protected.
          </p>
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 leading-relaxed text-gray-600 space-y-5">

            <p>
              We respect your privacy and are committed to protecting your personal information. This policy outlines how your data is collected, used, and safeguarded.
            </p>

            <p>
              <strong>Information Collection:</strong> We may collect your name, email address, and contact details when you interact with our services or reach out for work inquiries.
            </p>

            <p>
              <strong>Usage:</strong> Information is used strictly for communication, project delivery, and improving service experience. We do not sell or share your data.
            </p>

            <p>
              <strong>Security:</strong> We apply reasonable measures to protect your data, though no system can guarantee absolute security.
            </p>

          </div>
        </div>

      </div>
    </section>


    <!-- ===================== REFUND ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold text-gray-900">
            Refund Policy.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 text-gray-600 space-y-5">

            <p>
              Due to the nature of digital and creative services, refunds are limited once work has begun.
            </p>

            <p>
              <strong>No Refund After Start:</strong> Once the project has started, payments are non-refundable.
            </p>

            <p>
              <strong>Exceptions:</strong> Refunds may be considered if work has not started or in rare service failure cases.
            </p>

            <p>
              <strong>Alternative:</strong> We prioritize revisions and improvements instead of refunds.
            </p>

          </div>
        </div>

      </div>
    </section>


    <!-- ===================== SERVICE ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold">
            Service Agreement.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 text-gray-600 space-y-5">

            <p>
              By working with us, you agree to the following service terms and conditions.
            </p>

            <p>
              <strong>Scope:</strong> Work includes graphic design, video editing, and related creative services based on agreed deliverables.
            </p>

            <p>
              <strong>Revisions:</strong> Limited revisions are included depending on the selected plan.
            </p>

            <p>
              <strong>Payment:</strong> Final deliverables are shared after full payment is completed.
            </p>

            <p>
              <strong>Timeline:</strong> Delivery depends on project complexity and response time.
            </p>

          </div>
        </div>

      </div>
    </section>


    <!-- ===================== COPYRIGHT ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold">
            Copyright & Usage.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 text-gray-600 space-y-5">

            <p>
              Ownership of final work is transferred to the client only after full payment.
            </p>

            <p>
              <strong>Portfolio Rights:</strong> We reserve the right to showcase completed work.
            </p>

            <p>
              <strong>Restrictions:</strong> Raw files and unused concepts cannot be resold or redistributed.
            </p>

          </div>
        </div>

      </div>
    </section>


    <!-- ===================== DISCLAIMER ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold">
            Disclaimer.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 text-gray-600 space-y-5">

            <p>
              All services and content are provided “as is” without guarantees of specific results.
            </p>

            <p>
              We are not responsible for outcomes such as growth, engagement, or platform performance.
            </p>

          </div>
        </div>

      </div>
    </section>


    <!-- ===================== TERMS ===================== -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <div class="lg:col-span-4">
          <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold">
            Terms of Service.
          </h2>

          <div class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-8">
          <div class="bg-gray-50 border rounded-2xl p-8 md:p-10 text-gray-600 space-y-5">

            <p>
              By using this website or hiring services, you agree to these terms.
            </p>

            <p>
              Services are provided based on availability and agreement. Misuse, unauthorized redistribution, or abuse of services is not permitted.
            </p>

          </div>
        </div>

      </div>
    </section>

  </body>
</html>
