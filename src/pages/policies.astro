---
import "../styles/global.css";

import Privacy from "../components/Privacy.astro";
import Refund from "../components/Refund.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Policies</title>

    <style>
      html {
        scroll-behavior: smooth;
      }

      /* NAV */
      .nav-pill {
        padding: 6px 14px;
        font-size: 14px;
        border-radius: 999px;
        color: #555;
        transition: all 0.25s ease;
      }

      .nav-pill:hover {
        background: rgba(0,0,0,0.05);
        transform: translateY(-2px);
      }

      .nav-pill.active {
        background: rgba(0,0,0,0.06);
        color: #111;
      }

      /* FLOAT ANIMATION */
      .float-ui {
        transition: transform 0.35s ease, opacity 0.35s ease;
      }

      .hide-ui {
        transform: translateY(120%);
        opacity: 0;
      }

      /* BACK BUTTON */
      .glass-btn {
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
      }

      body {
        overflow-x: hidden;
      }
    </style>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK BUTTON (TOP RIGHT) -->
    <div id="backBtn" class="fixed top-4 right-4 sm:top-6 sm:right-6 z-50 float-ui">
      <button 
        onclick="history.back()" 
        class="glass-btn px-4 py-2 rounded-full flex items-center gap-2 text-sm text-gray-700 hover:bg-white/80 transition group"
      >
        Back
        <span class="group-hover:translate-x-1 transition">→</span>
      </button>
    </div>

    <!-- FLOAT NAV (RAISED FOR MOBILE) -->
    <div id="navBar" class="fixed bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 z-50 float-ui pointer-events-none">
      <div class="pointer-events-auto flex gap-2 px-3 py-2
                  bg-white/70 backdrop-blur-xl border border-gray-200
                  rounded-full shadow-lg">

        <a href="#privacy" class="nav-pill">Privacy</a>
        <a href="#refund" class="nav-pill">Refund</a>

      </div>
    </div>

    <!-- CONTENT -->
    <main class="pb-28">

      <div id="privacy">
        <Privacy />
      </div>

      <div id="refund">
        <Refund />
      </div>

    </main>

    <!-- SCRIPT -->
    <script>
      // ACTIVE NAV
      const sections = document.querySelectorAll("section");
      const navLinks = document.querySelectorAll(".nav-pill");

      window.addEventListener("scroll", () => {
        let current = "";

        sections.forEach((section) => {
          const top = section.offsetTop - 150;
          if (scrollY >= top) {
            current = section.getAttribute("id");
          }
        });

        navLinks.forEach(link => {
          link.classList.remove("active");
          if (link.getAttribute("href") === "#" + current) {
            link.classList.add("active");
          }
        });
      });

      // AUTO HIDE
      let lastScroll = 0;
      const nav = document.getElementById("navBar");
      const back = document.getElementById("backBtn");

      window.addEventListener("scroll", () => {
        const currentScroll = window.pageYOffset;

        if (currentScroll > lastScroll && currentScroll > 80) {
          nav.classList.add("hide-ui");
          back.classList.add("hide-ui");
        } else {
          nav.classList.remove("hide-ui");
          back.classList.remove("hide-ui");
        }

        lastScroll = currentScroll;
      });
    </script>

  </body>
</html>
