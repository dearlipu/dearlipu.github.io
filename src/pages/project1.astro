<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Featured Work</title>

  <style>
    html,body{
      height:100%;
      margin:0;
      padding:0;
      overflow-x:hidden;
      background:#000;
      font-family:-apple-system,system-ui,Segoe UI,Roboto,sans-serif;
    }

    #viewer{
      width:100vw;
      height:100vh;
      overflow:auto;
      -webkit-overflow-scrolling:touch;
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    .wrap{
      width:100%;
      margin:0;
      padding:0;
    }

    .page{
      margin:0;
      padding:0;
      line-height:0;
    }

    .page img{
      width:100vw;
      height:auto;
      margin:0;
      border:0;
      display:block;
      object-fit:cover;
      user-select:none;
    }

    .sep{
      height:0;
      margin:0;
      padding:0;
    }

    /* -------- PREMIUM SKELETON LOADER OVERLAY -------- */
    #loader{
      position:fixed;
      inset:0;
      background:radial-gradient(circle at top,#191919 0,#000 55%);
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:18px;
      z-index:9999;
      padding:20px;
      box-sizing:border-box;
      color:#fff;
      text-align:center;
    }

    .loader-title{
      font-size:18px;
      font-weight:600;
      letter-spacing:.04em;
      text-transform:uppercase;
      opacity:.85;
    }

    .loader-sub{
      font-size:13px;
      opacity:.65;
      margin-bottom:8px;
    }

    .skeleton-row{
      display:flex;
      flex-direction:column;
      gap:14px;
      width:100%;
      max-width:900px;
    }

    .skeleton-page{
      border-radius:20px;
      background:rgba(10,10,10,0.9);
      padding:16px;
      box-shadow:0 22px 60px rgba(0,0,0,0.80);
      border:1px solid rgba(255,255,255,0.04);
      overflow:hidden;
    }

    .sk-thumb{
      height:190px;
      border-radius:16px;
      margin-bottom:12px;
    }

    .sk-line{
      height:10px;
      border-radius:999px;
      margin-bottom:8px;
    }

    .sk-line:last-child{
      margin-bottom:0;
    }

    .sk-line.w1{ width:78%; }
    .sk-line.w2{ width:62%; }
    .sk-line.w3{ width:90%; }
    .sk-line.w4{ width:48%; }

    .sk-thumb,
    .sk-line{
      background-image:linear-gradient(110deg,#222 0%,#333 40%,#111 80%);
      background-size:200% 100%;
      animation:skeleton-loading 1.25s infinite linear;
    }

    @keyframes skeleton-loading{
      0%{ background-position-x:-120%; }
      100%{ background-position-x:120%; }
    }

    /* Desktop: bigger & more spread */
    @media (min-width: 900px){
      .skeleton-row{
        flex-direction:row;
      }
      .skeleton-page{
        flex:1;
      }
      .sk-thumb{
        height:min(360px,45vh);
      }
    }
  </style>
</head>

<body>

  <div id="loader"></div>

  <div id="viewer">
    <div class="wrap" id="wrap"></div>
  </div>

  <script>
  /* --------- IMAGE LOADER (optimized for webp) ----------- */
  (function(){
    const wrap   = document.getElementById('wrap');
    const loader = document.getElementById('loader');
    const folder = '/projects/';
    const base   = 'p1-';
    const tryExt = ['webp','gif']; // prefer webp first

    let idx  = 1;
    let miss = 0;

    function exists(url){
      return new Promise(res => {
        const i = new Image();
        i.onload  = () => res(true);
        i.onerror = () => res(false);
        i.src = url;
      });
    }

    function addImg(url){
      const p   = document.createElement('div');
      p.className = 'page';

      const img = document.createElement('img');
      img.src   = url;
      img.loading = 'lazy';
      img.decoding = 'async';   // hint: decode off main thread

      p.appendChild(img);
      wrap.appendChild(p);

      const sep = document.createElement('div');
      sep.className = 'sep';
      wrap.appendChild(sep);
    }

    function buildSkeleton(){
      loader.innerHTML = '';

      const title = document.createElement('div');
      title.className = 'loader-title';
      title.textContent = 'Preparing portfolio for you…';

      const sub = document.createElement('div');
      sub.className = 'loader-sub';
      sub.textContent = 'Loading high-resolution pages';

      const row = document.createElement('div');
      row.className = 'skeleton-row';

      for(let i=0;i<3;i++){
        const card = document.createElement('div');
        card.className = 'skeleton-page';
        card.innerHTML = `
          <div class="sk-thumb"></div>
          <div class="sk-line w1"></div>
          <div class="sk-line w3"></div>
          <div class="sk-line w2"></div>
          <div class="sk-line w4"></div>
        `;
        row.appendChild(card);
      }

      loader.appendChild(title);
      loader.appendChild(sub);
      loader.appendChild(row);
    }

    async function scan(){
      buildSkeleton();

      for(let n=1;n<300;n++){
        let ok = false;
        for(const ext of tryExt){
          const path = `${folder}${base}${idx}.${ext}`;
          // eslint-disable-next-line no-await-in-loop
          if(await exists(path)){
            addImg(path);
            ok = true;
            break;
          }
        }
        if(!ok){
          miss++;
          if(miss>=6) break;   // stop if several consecutive pages missing
        } else {
          miss = 0;
        }
        idx++;
      }

      loader.style.transition = 'opacity 0.3s ease';
      loader.style.opacity = '0';
      setTimeout(() => loader.remove(), 300);
    }

    scan();
  })();
  </script>

</body>
</html>
