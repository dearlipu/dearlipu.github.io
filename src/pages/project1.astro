<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Featured Work</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style>
    html,body{
      margin:0;
      padding:0;
      background:#000;
      overflow-x:hidden;
      font-family:-apple-system,system-ui,Segoe UI,Roboto,sans-serif;
    }

    #viewer{
      width:100vw;
      height:100vh;
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
      scrollbar-width:none;
    }

    #viewer::-webkit-scrollbar{
      display:none;
    }

    .wrap{
      width:100%;
    }

    .page{
      width:100%;
      line-height:0;
    }

    .page img{
      width:100vw;
      height:auto;
      display:block;
      object-fit:contain;
      background:#000;
    }

    /* REMOVE ANY POSSIBLE GAP */
    img{
      margin:0;
      padding:0;
      border:0;
      outline:none;
      vertical-align:bottom;
    }

    /* LOADER */
    #loader{
      position:fixed;
      inset:0;
      background:#ffffff;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:12px;
      z-index:9999;
      color:#111827;
    }

    .loader-title{
      font-size:16px;
      font-weight:600;
    }

    .skeleton{
      width:90%;
      max-width:400px;
    }

    .sk{
      height:120px;
      border-radius:12px;
      margin-bottom:10px;
      background:linear-gradient(110deg,#eee 0%,#f5f5f5 40%,#e5e7eb 80%);
      background-size:200% 100%;
      animation:load 1.2s infinite linear;
    }

    @keyframes load{
      0%{background-position-x:-120%}
      100%{background-position-x:120%}
    }
  </style>
</head>

<body>

<div id="loader">
  <div class="loader-title">Loading works...</div>
  <div class="skeleton">
    <div class="sk"></div>
    <div class="sk"></div>
  </div>
</div>

<div id="viewer">
  <div class="wrap" id="wrap"></div>
</div>

<script>
(function(){

  const wrap   = document.getElementById('wrap');
  const loader = document.getElementById('loader');

  const folder = '/projects/';
  const tryExt = ['webp','gif'];

  let idx  = 1;
  let miss = 0;

  function exists(url){
    return new Promise(res => {
      const i = new Image();
      i.onload  = () => res(true);
      i.onerror = () => res(false);
      i.src = url;
    });
  }

  function addImg(url){
    const p = document.createElement('div');
    p.className = 'page';

    const img = document.createElement('img');
    img.src = url;
    img.loading = 'lazy';
    img.decoding = 'async';

    p.appendChild(img);
    wrap.appendChild(p);
  }

  async function scan(){
    for(let n=1;n<300;n++){
      let found = false;

      for(const ext of tryExt){
        const path = folder + 'p1-' + idx + '.' + ext;

        if(await exists(path)){
          addImg(path);
          found = true;
          break;
        }
      }

      if(!found){
        miss++;
        if(miss >= 5) break;
      } else {
        miss = 0;
      }

      idx++;
    }

    loader.style.opacity = '0';
    setTimeout(() => loader.remove(), 300);
  }

  scan();

})();
</script>

</body>
</html>
