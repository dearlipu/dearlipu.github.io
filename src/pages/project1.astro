<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Featured Work</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <style>
    html, body {
      margin: 0;
      padding: 0;
      background: #000;
      overflow: hidden;
    }

    #app {
      position: fixed;
      inset: 0;
    }
  </style>
</head>

<body>

<div id="app"></div>

<script>
(function(){

  const root = document.getElementById('app');
  const shadow = root.attachShadow({ mode: 'open' });

  shadow.innerHTML =
    '<style>' +

    '*{margin:0;padding:0;box-sizing:border-box;}' +

    '.viewer{' +
      'position:fixed;' +
      'inset:0;' +
      'overflow-y:auto;' +
      'background:#000;' +
      '-webkit-overflow-scrolling:touch;' +
      'scrollbar-width:none;' +
    '}' +

    '.viewer::-webkit-scrollbar{display:none;}' +

    '.wrap{' +
      'display:flex;' +
      'flex-direction:column;' +
      'align-items:center;' +
      'width:100%;' +
    '}' +

    '.page{' +
      'width:100%;' +
      'min-height:100dvh;' +
      'display:flex;' +
      'align-items:center;' +
      'justify-content:center;' +
      'background:#000;' +
    '}' +

    /* 🔥 KEY FIX */
    '.page img{' +
      'max-width:100%;' +
      'max-height:100dvh;' +
      'width:auto;' +
      'height:auto;' +
      'display:block;' +
      'object-fit:contain;' +
    '}' +

    /* LOADER */
    '.loader{' +
      'position:fixed;' +
      'inset:0;' +
      'background:#fff;' +
      'display:flex;' +
      'align-items:center;' +
      'justify-content:center;' +
      'z-index:9999;' +
      'font-family:sans-serif;' +
    '}' +

    '</style>' +

    '<div class="loader" id="loader">Loading...</div>' +

    '<div class="viewer">' +
      '<div class="wrap" id="wrap"></div>' +
    '</div>';

  const wrap   = shadow.getElementById('wrap');
  const loader = shadow.getElementById('loader');

  const folder = '/projects/';
  const tryExt = ['webp','gif'];

  let idx = 1;
  let miss = 0;

  function exists(url){
    return new Promise(res => {
      const i = new Image();
      i.onload = () => res(true);
      i.onerror = () => res(false);
      i.src = url;
    });
  }

  function addImg(url){
    const p = document.createElement('div');
    p.className = 'page';

    const img = document.createElement('img');
    img.src = url;
    img.loading = 'lazy';

    p.appendChild(img);
    wrap.appendChild(p);
  }

  async function scan(){
    for(let n=1;n<300;n++){
      let found = false;

      for(let i=0;i<tryExt.length;i++){
        const ext = tryExt[i];
        const path = folder + 'p1-' + idx + '.' + ext;

        if(await exists(path)){
          addImg(path);
          found = true;
          break;
        }
      }

      if(!found){
        miss++;
        if(miss >= 5) break;
      } else {
        miss = 0;
      }

      idx++;
    }

    loader.style.opacity = '0';
    setTimeout(() => loader.remove(), 300);
  }

  scan();

})();
</script>

</body>
</html>
