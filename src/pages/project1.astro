<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Featured Work</title>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body>

<div id="app"></div>

<script>
(function(){

  const root = document.getElementById('app');
  const shadow = root.attachShadow({ mode: 'open' });

  shadow.innerHTML =
    '<style>' +

    '*{margin:0;padding:0;box-sizing:border-box;}' +

    '.viewer{' +
      'width:100vw;' +
      'height:100vh;' +
      'overflow-y:auto;' +
      'overflow-x:hidden;' +
      'background:#ffffff;' +
      '-webkit-overflow-scrolling:touch;' +
      'scrollbar-width:none;' +
    '}' +

    '.viewer::-webkit-scrollbar{display:none;}' +

    '.wrap{' +
      'display:flex;' +
      'flex-direction:column;' +
      'gap:0;' +
    '}' +

    '.page{' +
      'width:100vw;' +
      'height:100vh;' +
      'overflow:hidden;' +
      'display:flex;' +
    '}' +

    '.page img{' +
      'width:100%;' +
      'height:100%;' +
      'object-fit:cover;' +
      'object-position:center;' +
      'display:block;' +
      'border:0;' +
    '}' +

    /* LOADER */
    '.loader{' +
      'position:fixed;' +
      'inset:0;' +
      'background:#ffffff;' +
      'display:flex;' +
      'flex-direction:column;' +
      'align-items:center;' +
      'justify-content:center;' +
      'gap:12px;' +
      'z-index:9999;' +
      'font-family:-apple-system,system-ui,Segoe UI,Roboto,sans-serif;' +
    '}' +

    '.loader-title{' +
      'font-size:16px;' +
      'font-weight:600;' +
      'color:#111827;' +
    '}' +

    '.skeleton-row{' +
      'display:flex;' +
      'flex-direction:column;' +
      'gap:10px;' +
      'width:100%;' +
      'max-width:500px;' +
    '}' +

    '.skeleton-page{' +
      'border-radius:14px;' +
      'background:#f9fafb;' +
      'padding:12px;' +
      'border:1px solid #e5e7eb;' +
    '}' +

    '.sk-thumb{' +
      'height:120px;' +
      'border-radius:10px;' +
      'margin-bottom:8px;' +
    '}' +

    '.sk-line{' +
      'height:8px;' +
      'border-radius:999px;' +
      'margin-bottom:6px;' +
    '}' +

    '.sk-thumb,.sk-line{' +
      'background-image:linear-gradient(110deg,#eee 0%,#f5f5f5 40%,#e5e7eb 80%);' +
      'background-size:200% 100%;' +
      'animation:skeleton-loading 1.2s infinite linear;' +
    '}' +

    '@keyframes skeleton-loading{' +
      '0%{background-position-x:-120%;}' +
      '100%{background-position-x:120%;}' +
    '}' +

    '</style>' +

    '<div class="loader" id="loader">' +
      '<div class="loader-title">Loading works...</div>' +
      '<div class="skeleton-row">' +
        '<div class="skeleton-page">' +
          '<div class="sk-thumb"></div>' +
          '<div class="sk-line"></div>' +
          '<div class="sk-line"></div>' +
          '<div class="sk-line"></div>' +
        '</div>' +
        '<div class="skeleton-page">' +
          '<div class="sk-thumb"></div>' +
          '<div class="sk-line"></div>' +
          '<div class="sk-line"></div>' +
          '<div class="sk-line"></div>' +
        '</div>' +
      '</div>' +
    '</div>' +

    '<div class="viewer">' +
      '<div class="wrap" id="wrap"></div>' +
    '</div>';

  const wrap   = shadow.getElementById('wrap');
  const loader = shadow.getElementById('loader');

  const folder = '/projects/';
  const tryExt = ['webp','gif'];

  var idx  = 1;
  var miss = 0;

  function exists(url){
    return new Promise(function(res){
      var i = new Image();
      i.onload  = function(){ res(true); };
      i.onerror = function(){ res(false); };
      i.src = url;
    });
  }

  function addImg(url){
    var p = document.createElement('div');
    p.className = 'page';

    var img = document.createElement('img');
    img.src = url;
    img.loading = 'lazy';
    img.decoding = 'async';

    p.appendChild(img);
    wrap.appendChild(p);
  }

  async function scan(){
    for(var n=1;n<300;n++){
      var found = false;

      for(var i=0;i<tryExt.length;i++){
        var ext = tryExt[i];
        var path = folder + 'p1-' + idx + '.' + ext;

        if(await exists(path)){
          addImg(path);
          found = true;
          break;
        }
      }

      if(!found){
        miss++;
        if(miss >= 5) break;
      } else {
        miss = 0;
      }

      idx++;
    }

    loader.style.opacity = '0';
    setTimeout(function(){
      loader.remove();
    }, 300);
  }

  scan();

})();
</script>

</body>
</html>
