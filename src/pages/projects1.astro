---
/* 👉 Add your Google Drive IMAGE IDs here */
const images = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

/* Convert ID → usable image URL */
const getImage = (id) =>
  `https://lh3.googleusercontent.com/d/${id}=w1200`;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Project Gallery</title>
</head>

<body>

  <!-- 🔥 Header -->
  <div class="top">
    <h1>PROJECT GALLERY</h1>
    <p>Scroll / Drag to explore</p>
  </div>

  <!-- 🔥 Gallery -->
  <div class="gallery" id="gallery">

    {images.map((id) => (
      <div class="item">
        <img src={getImage(id)} loading="lazy" />
      </div>
    ))}

  </div>

  <!-- 🔥 Fullscreen Preview -->
  <div class="viewer" id="viewer">
    <img id="viewerImg" />
  </div>

</body>
</html>

<style>
body {
  margin: 0;
  background: #0b0b0f;
  color: white;
  font-family: sans-serif;
  overflow-x: hidden;
}

/* Header */
.top {
  padding: 20px;
  text-align: center;
}

.top h1 {
  margin: 0;
  font-size: 28px;
}

.top p {
  opacity: 0.6;
  font-size: 14px;
}

/* Gallery */
.gallery {
  column-count: 4;
  column-gap: 16px;
  padding: 20px;
  cursor: grab;
}

.item {
  break-inside: avoid;
  margin-bottom: 16px;
  border-radius: 12px;
  overflow: hidden;
}

.item img {
  width: 100%;
  display: block;
  transition: 0.4s;
}

.item img:hover {
  transform: scale(1.05);
}

/* Responsive */
@media (max-width: 1000px) {
  .gallery { column-count: 3; }
}
@media (max-width: 700px) {
  .gallery { column-count: 2; }
}
@media (max-width: 500px) {
  .gallery { column-count: 1; }
}

/* Viewer */
.viewer {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.95);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.viewer img {
  max-width: 90%;
  max-height: 90%;
  border-radius: 10px;
}
</style>

<script>
const gallery = document.getElementById("gallery");
const viewer = document.getElementById("viewer");
const viewerImg = document.getElementById("viewerImg");

/* 🔥 CLICK → OPEN FULL */
document.querySelectorAll(".item img").forEach(img => {
  img.addEventListener("click", () => {
    viewer.style.display = "flex";
    viewerImg.src = img.src;
  });
});

/* CLOSE */
viewer.addEventListener("click", () => {
  viewer.style.display = "none";
});

/* 🔥 DRAG SCROLL */
let isDown = false;
let startX, scrollLeft;

gallery.addEventListener("mousedown", (e) => {
  isDown = true;
  gallery.style.cursor = "grabbing";
  startX = e.pageX - gallery.offsetLeft;
  scrollLeft = gallery.scrollLeft;
});

gallery.addEventListener("mouseleave", () => {
  isDown = false;
  gallery.style.cursor = "grab";
});

gallery.addEventListener("mouseup", () => {
  isDown = false;
  gallery.style.cursor = "grab";
});

gallery.addEventListener("mousemove", (e) => {
  if (!isDown) return;
  e.preventDefault();
  const x = e.pageX - gallery.offsetLeft;
  const walk = (x - startX) * 2;
  gallery.scrollLeft = scrollLeft - walk;
});
</script>
