<script src="https://cdn.jsdelivr.net/npm/pixi.js@7.x/dist/pixi.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", async () => {

  // — Selectors —
  const canvas =
    document.querySelector("canvas.gallery-canvas") ||
    document.querySelector("canvas#gallery-canvas") ||
    document.querySelector("canvas");

  const wrap =
    document.querySelector(".gallery-canvas-wrap") ||
    (canvas ? canvas.parentElement : null);

  const imgEls  = Array.from(document.querySelectorAll(".gallery-img"));
  const linkEls = Array.from(document.querySelectorAll(".gallery-link"));

  console.log("[IJ] wrap?", !!wrap, "canvas?", !!canvas, "cms imgs:", imgEls.length, "cms links:", linkEls.length);

  if (!wrap)      return console.error("[IJ] No wrap found (.gallery-canvas-wrap or canvas parent)");
  if (!canvas)    return console.error("[IJ] No canvas found");
  if (!imgEls.length) return console.error("[IJ] No CMS images found (.gallery-img)");

  Object.assign(canvas.style, {
    pointerEvents: "auto",
    touchAction:   "none",
    position:      "absolute",
    inset:         "0",
    zIndex:        "2",
  });

  wrap.style.position = wrap.style.position || "relative";
  wrap.style.overflow = "hidden";

  const sourceWrap = document.querySelector(".gallery-source-wrap");
  if (sourceWrap) {
    Object.assign(sourceWrap.style, {
      position:      "absolute",
      left:          "-99999px",
      top:           "0",
      width:         "1px",
      height:        "1px",
      overflow:      "hidden",
      opacity:       "0",
      pointerEvents: "none",
    });
  }

  // — Settings —
  const GAP          = 10;
  const TILE_MIN     = 280;
  const TILE_MAX     = 800;
  const BUFFER_TILES = 0;

  const WHEEL_MULT = 1.0;
  const DRAG_MULT  = 1.0;
  const FRICTION   = 0.92;
  const MAX_VEL    = 410;
  const STOP_EPS   = 0.01;

  const CURVE_ENABLED   = true;
  const CURVE_BASE      = 30;
  const CURVE_VEL_BOOST = 1.15;
  const CURVE_POWER     = 0.95;

  const DEPTH_ENABLED = false;
  const DEPTH_MIN     = 0.84;
  const DEPTH_BOOST   = 0.06;

  const CLICK_DRAG_PX = 8;

  // — Helpers —
  const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
  const mod   = (n, m)    => ((n % m) + m) % m;

  const isBlockedByUI = (e) =>
    !!(e?.target?.closest?.('[data-no-canvas="true"]'));

  const isInsideCanvas = (x, y) => {
    const r = canvas.getBoundingClientRect();
    return x >= r.left && x <= r.right && y >= r.top && y <= r.bottom;
  };

  function computeTileSize() {
    const w = app.renderer.width / app.renderer.resolution;
    return clamp(Math.floor(w / 5.2), TILE_MIN, TILE_MAX);
  }

  function containSpriteToSquare(sp, size) {
    const scale = Math.min(size / (sp.texture.width || 1), size / (sp.texture.height || 1));
    sp.scale.set(scale);
    sp.x = (size - sp.texture.width  * scale) * 0.5;
    sp.y = (size - sp.texture.height * scale) * 0.5;
  }

  function curveY(xMid, viewW, strength) {
    if (!viewW) return 0;
    let t = (xMid / viewW) * 2 - 1;
    t = Math.pow(Math.abs(t), CURVE_POWER) * Math.sign(t);
    return Math.sin(t * Math.PI * 0.5) * strength;
  }

  function makeRng(seed = 1337) {
    let s = seed >>> 0;
    return () => { s = (1664525 * s + 1013904223) >>> 0; return s / 4294967296; };
  }

  function pickIndexAvoiding(count, forbidA, forbidB, rnd) {
    if (count <= 1) return 0;
    if (count === 2) return (forbidA === 0 || forbidB === 0) ? 1 : 0;
    for (let k = 0; k < 12; k++) {
      const cand = Math.floor(rnd() * count);
      if (cand !== forbidA && cand !== forbidB) return cand;
    }
    for (let i = 0; i < count; i++) {
      if (i !== forbidA && i !== forbidB) return i;
    }
    return 0;
  }

  // — Pixi App —
  const app = new PIXI.Application({
    view: canvas,
    resizeTo: wrap,
    backgroundAlpha: 0,
    antialias: true,
    autoDensity: true,
    resolution: window.devicePixelRatio || 1,
  });

  // — Textures —
  const srcs = imgEls.map(img => img.currentSrc || img.src).filter(Boolean);
  const textures = (await Promise.all(
    srcs.map(src =>
      PIXI.Assets.load(src).catch(err => { console.warn("[IJ] failed to load:", src, err); return null; })
    )
  )).filter(Boolean);

  if (!textures.length) return console.error("[IJ] No textures loaded.");
  if (textures.length < 3) console.warn("[IJ] < 3 textures; variety limited.");

  // — Stage & Grid —
  const tilesLayer = new PIXI.Container();
  app.stage.addChild(tilesLayer);

  let tiles = [], tileSize = 0, cell = 0;
  let cols = 0, rows = 0, gridW = 0, gridH = 0;
  let texIdxGrid = [];

  function clearTiles() {
    tilesLayer.removeChildren();
    tiles = [];
  }

  function buildGrid() {
    clearTiles();

    tileSize = computeTileSize();
    cell = tileSize + GAP;

    const res  = app.renderer.resolution;
    const w    = app.renderer.width  / res;
    const h    = app.renderer.height / res;

    cols  = Math.ceil(w / cell) + BUFFER_TILES * 2 + 1;
    rows  = Math.ceil(h / cell) + BUFFER_TILES * 2 + 1;
    gridW = cols * cell;
    gridH = rows * cell;

    texIdxGrid = Array.from({ length: rows }, () => Array(cols).fill(-1));

    const seed = (cols * 73856093) ^ (rows * 19349663) ^ (tileSize * 83492791);
    const rnd  = makeRng(seed);

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const leftIdx = c > 0 ? texIdxGrid[r][c - 1] : -1;
        const topIdx  = r > 0 ? texIdxGrid[r - 1][c] : -1;
        const idx     = pickIndexAvoiding(textures.length, leftIdx, topIdx, rnd);
        texIdxGrid[r][c] = idx;

        const tile = new PIXI.Container();

        const bg = new PIXI.Graphics();
        bg.beginFill(0x0b0b0f, 1);
        bg.drawRect(0, 0, tileSize, tileSize);
        bg.endFill();
        tile.addChild(bg);

        const img = new PIXI.Sprite(textures[idx]);
        containSpriteToSquare(img, tileSize);
        tile.addChild(img);

        tilesLayer.addChild(tile);

        tiles.push({ c, r, tile, texIndex: idx, href: linkEls[idx]?.href ?? null });
      }
    }

    console.log("[IJ] grid built:", tiles.length, "cols:", cols, "rows:", rows, "tile:", tileSize);
  }

  // — Scroll & Drag State —
  let scrollX = 0, scrollY = 0;
  let velX = 0, velY = 0;
  let dragging = false;
  let lastClientX = 0, lastClientY = 0;
  let pointerDownX = 0, pointerDownY = 0;
  let movedSinceDown = false;

  // — Input Handlers —
  function onWheel(e) {
    if (isBlockedByUI(e) || !isInsideCanvas(e.clientX ?? 0, e.clientY ?? 0)) return;
    e.preventDefault();
    velX += -(e.deltaX || 0) * 0.20 * WHEEL_MULT;
    velY += -(e.deltaY || 0) * 0.20 * WHEEL_MULT;
  }

  function onPointerDown(e) {
    const cx = e.clientX ?? 0, cy = e.clientY ?? 0;
    if (isBlockedByUI(e) || !isInsideCanvas(cx, cy)) return;
    dragging = true;
    lastClientX = pointerDownX = cx;
    lastClientY = pointerDownY = cy;
    movedSinceDown = false;
  }

  function onPointerMove(e) {
    if (!dragging) return;
    const cx = e.clientX ?? 0, cy = e.clientY ?? 0;
    const dx = cx - lastClientX, dy = cy - lastClientY;
    lastClientX = cx;
    lastClientY = cy;
    if (!movedSinceDown && Math.hypot(cx - pointerDownX, cy - pointerDownY) >= CLICK_DRAG_PX) {
      movedSinceDown = true;
    }
    velX += dx * 0.55 * DRAG_MULT;
    velY += dy * 0.55 * DRAG_MULT;
  }

  const onPointerUp = () => { dragging = false; };

  function onClick(e) {
    if (isBlockedByUI(e) || dragging || movedSinceDown) return;
    const cx = e.clientX ?? 0, cy = e.clientY ?? 0;
    if (!isInsideCanvas(cx, cy)) return;
    const rect  = canvas.getBoundingClientRect();
    const tileHit = getTileAtCanvasPoint(cx - rect.left, cy - rect.top);
    if (tileHit?.href) window.location.href = tileHit.href;
  }

  function getTileAtCanvasPoint(canvasX, canvasY) {
    for (let i = tiles.length - 1; i >= 0; i--) {
      const { tile } = tiles[i];
      const size = tileSize * (tile.scale.x || 1);
      if (canvasX >= tile.x && canvasX <= tile.x + size &&
          canvasY >= tile.y && canvasY <= tile.y + size) return tiles[i];
    }
    return null;
  }

  window.addEventListener("wheel",         onWheel,      { passive: false, capture: true });
  window.addEventListener("pointerdown",   onPointerDown,{ capture: true });
  window.addEventListener("pointermove",   onPointerMove,{ capture: true });
  window.addEventListener("pointerup",     onPointerUp,  { capture: true });
  window.addEventListener("pointercancel", onPointerUp,  { capture: true });
  window.addEventListener("click",         onClick,      { capture: true });

  // Touch fallback (passive for scroll performance)
  window.addEventListener("touchstart", (e) => {
    const t = e.touches?.[0];
    if (!t || isBlockedByUI(e) || !isInsideCanvas(t.clientX, t.clientY)) return;
    dragging = true;
    lastClientX = pointerDownX = t.clientX;
    lastClientY = pointerDownY = t.clientY;
    movedSinceDown = false;
  }, { passive: true, capture: true });

  window.addEventListener("touchmove", (e) => {
    const t = e.touches?.[0];
    if (!dragging || !t) return;
    const dx = t.clientX - lastClientX, dy = t.clientY - lastClientY;
    lastClientX = t.clientX;
    lastClientY = t.clientY;
    if (!movedSinceDown && Math.hypot(t.clientX - pointerDownX, t.clientY - pointerDownY) >= CLICK_DRAG_PX) {
      movedSinceDown = true;
    }
    velX += dx * 0.55 * DRAG_MULT;
    velY += dy * 0.55 * DRAG_MULT;
  }, { passive: true, capture: true });

  window.addEventListener("touchend", onPointerUp, { passive: true, capture: true });

  // — Layout Loop —
  let lastSX = 0, lastSY = 0;

  function layout() {
    velX = clamp(velX, -MAX_VEL, MAX_VEL);
    velY = clamp(velY, -MAX_VEL, MAX_VEL);

    scrollX += velX;
    scrollY += velY;

    velX *= FRICTION;
    velY *= FRICTION;

    if (Math.abs(velX) < STOP_EPS) velX = 0;
    if (Math.abs(velY) < STOP_EPS) velY = 0;

    const res   = app.renderer.resolution;
    const viewW = app.renderer.width / res;
    const speed = Math.hypot(scrollX - lastSX, scrollY - lastSY);
    const curveStrength = CURVE_BASE + speed * CURVE_VEL_BOOST;

    lastSX = scrollX;
    lastSY = scrollY;

    for (const t of tiles) {
      let x = mod(t.c * cell + scrollX, gridW) - cell;
      let y = mod(t.r * cell + scrollY, gridH) - cell;

      if (CURVE_ENABLED) {
        y += curveY(x + tileSize * 0.5, viewW, curveStrength);
      }

      if (DEPTH_ENABLED) {
        const n = viewW ? Math.abs(((x + tileSize * 0.5) / viewW) * 2 - 1) : 0;
        t.tile.scale.set(DEPTH_MIN + (1 - Math.min(1, n)) * DEPTH_BOOST);
      } else {
        t.tile.scale.set(1);
      }

      t.tile.x = Math.round(x);
      t.tile.y = Math.round(y);
    }
  }

  // — Init —
  let resizeTimer = null;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(buildGrid, 150);
  });

  buildGrid();
  app.ticker.add(layout);

  // Webflow layout-shift safety
  setTimeout(buildGrid, 250);
  setTimeout(buildGrid, 900);

  console.log("[IJ] ready.");
});
</script>

<style>
.cursor {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  pointer-events: none;
  width: 1em;
  height: 1em;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.85);
  transform: translate3d(-50%, -50%, 0);
  will-change: transform;
}

.cursor .cursor-paragraph {
  position: absolute;
  left: 50%;
  top: calc(100% + 10px);
  transform: translateX(-90%);
  margin: 0;
  padding: 6px 10px;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 0;
  font-size: 12px;
  line-height: 1.2;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.18s ease, transform 0.18s ease;
  will-change: opacity, transform;
}

body:has([data-cursor]:hover) .cursor .cursor-paragraph {
  opacity: 1;
  transform: translateY(-50%) translateY(0);
}

body:has(a:hover) .cursor,
body:has(button:hover) .cursor,
body:has([data-cursor]:hover) .cursor {
  width: 3em;
  height: 3em;
  background-color: rgba(255, 255, 255, 0.28);
}

body:has(a:hover) .cursor .cursor-paragraph,
body:has(button:hover) .cursor .cursor-paragraph,
body:has([data-cursor]:hover) .cursor .cursor-paragraph {
  left: calc(100% + 10px);
}

@media (hover: none) and (pointer: coarse) {
  .cursor { display: none; }
}
</style>

<script>
function initUnifiedCursor() {
  const cursor = document.querySelector(".cursor");
  if (!cursor) return;

  const label   = cursor.querySelector(".cursor-paragraph");
  const hasGSAP = typeof window.gsap !== "undefined";

  // — Smooth follow —
  if (hasGSAP) {
    gsap.set(cursor, { xPercent: -50, yPercent: -50 });
    const xTo = gsap.quickTo(cursor, "x", { duration: 0.6, ease: "power3" });
    const yTo = gsap.quickTo(cursor, "y", { duration: 0.6, ease: "power3" });
    window.addEventListener("pointermove", (e) => { xTo(e.clientX); yTo(e.clientY); updateTooltipEdge(e); }, { passive: true });
  } else {
    window.addEventListener("pointermove", (e) => {
      cursor.style.left = e.clientX + "px";
      cursor.style.top  = e.clientY + "px";
      updateTooltipEdge(e);
    }, { passive: true });
  }

  // — Tooltip text —
  let lastText = "";

  document.addEventListener("pointerover", (e) => {
    const t = e.target.closest("[data-cursor]");
    if (!t) return;
    const txt = t.getAttribute("data-cursor") || "";
    if (txt !== lastText) { label.textContent = lastText = txt; }
  }, true);

  document.addEventListener("pointerout", (e) => {
    const leaving = e.target.closest("[data-cursor]");
    if (!leaving) return;
    if (e.relatedTarget?.closest?.("[data-cursor]")) return;
    label.textContent = lastText = "";
  }, true);

  // — Edge-aware tooltip position —
  function updateTooltipEdge(e) {
    if (!label) return;
    const rect      = label.getBoundingClientRect();
    const margin    = 20;
    const nearRight  = e.clientX + rect.width  + margin > window.innerWidth;
    const nearBottom = e.clientY + rect.height + margin > window.innerHeight;

    Object.assign(label.style, {
      left:      nearRight  ? "auto"               : "calc(100% + 10px)",
      right:     nearRight  ? "calc(100% + 10px)"  : "auto",
      top:       nearBottom ? "auto"               : "50%",
      bottom:    nearBottom ? "calc(100% + 10px)"  : "auto",
      transform: "translateY(-50%)",
    });
  }
}

document.addEventListener("DOMContentLoaded", initUnifiedCursor);
</script>

<script>
{
  const wrap = document.querySelector(".page_transition_wrap");
  const rows = document.querySelectorAll(".page_transition_row");
  let isAnimating = false;

  // — Page reveal —
  window.addEventListener("load", () => {
    if (!wrap || !rows.length) return;
    gsap.set(wrap, { display: "flex" });
    gsap.set(rows, { y: "0vh" });
    gsap.to(rows, {
      y: "-100vh",
      duration: 0.9,
      ease: "expo.inOut",
      stagger: { amount: 0.25, from: "random" },
      onComplete: () => { gsap.set(wrap, { display: "none" }); isAnimating = false; },
    });
  });

  // — Link-click transition —
  document.addEventListener("DOMContentLoaded", () => {
    if (!wrap || !rows.length) return;
    document.querySelectorAll("a[href]").forEach(link => {
      link.addEventListener("click", (e) => {
        if (
          link.hostname !== window.location.hostname ||
          link.href.includes("#") ||
          link.target === "_blank" ||
          isAnimating
        ) return;

        e.preventDefault();
        isAnimating = true;
        const destination = link.href;

        document.body.classList.add("transitioning");
        gsap.set(wrap, { display: "flex" });
        gsap.set(rows, { y: "100vh" });
        gsap.to(rows, {
          y: "0vh",
          duration: 0.8,
          ease: "expo.inOut",
          stagger: { amount: 0.25, from: "random" },
        });
        setTimeout(() => { window.location.href = destination; }, 750);
      });
    });
  });

  // — Back/forward cache —
  window.addEventListener("pageshow", (e) => { if (e.persisted) window.location.reload(); });
}
</script>

<script>
gsap.registerPlugin(ScrollTrigger);

function initContentRevealScroll() {
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    gsap.set("[data-reveal-group]", { clearProps: "all", y: 0, autoAlpha: 1 });
    return;
  }

  const ctx = gsap.context(() => {
    document.querySelectorAll("[data-reveal-group]").forEach(groupEl => {
      const groupStagger = (parseFloat(groupEl.getAttribute("data-stagger")) || 100) / 1000;
      const groupDistance = groupEl.getAttribute("data-distance") || "2em";
      const triggerStart  = groupEl.getAttribute("data-start")    || "top 80%";
      const ANIM = { duration: 1.4, ease: "power4.inOut" };

      const directChildren = Array.from(groupEl.children).filter(el => el.nodeType === 1);

      // No children — animate the group itself
      if (!directChildren.length) {
        gsap.set(groupEl, { y: groupDistance, autoAlpha: 0 });
        ScrollTrigger.create({
          trigger: groupEl, start: triggerStart, once: true,
          onEnter: () => gsap.to(groupEl, { y: 0, autoAlpha: 1, ...ANIM,
            onComplete: () => gsap.set(groupEl, { clearProps: "all" }) }),
        });
        return;
      }

      // Build animation slots
      const slots = directChildren.map(child => {
        const nestedGroup =
          child.matches("[data-reveal-group-nested]")
            ? child
            : child.querySelector(":scope [data-reveal-group-nested]");

        if (nestedGroup) {
          const includeParent =
            child.getAttribute("data-ignore") === "false" ||
            nestedGroup.getAttribute("data-ignore") === "false";
          return { type: "nested", parentEl: child, nestedEl: nestedGroup, includeParent };
        }
        return { type: "item", el: child };
      });

      // Set initial hidden states
      slots.forEach(slot => {
        if (slot.type === "item") {
          const isNestedSelf = slot.el.matches("[data-reveal-group-nested]");
          const d = isNestedSelf ? groupDistance : (slot.el.getAttribute("data-distance") || groupDistance);
          gsap.set(slot.el, { y: d, autoAlpha: 0 });
        } else {
          if (slot.includeParent) gsap.set(slot.parentEl, { y: groupDistance, autoAlpha: 0 });
          const nestedD = slot.nestedEl.getAttribute("data-distance") || groupDistance;
          Array.from(slot.nestedEl.children).forEach(child => gsap.set(child, { y: nestedD, autoAlpha: 0 }));
        }
      });

      // Reveal on scroll
      ScrollTrigger.create({
        trigger: groupEl, start: triggerStart, once: true,
        onEnter: () => {
          const tl = gsap.timeline();
          slots.forEach((slot, i) => {
            const t = i * groupStagger;
            if (slot.type === "item") {
              tl.to(slot.el, { y: 0, autoAlpha: 1, ...ANIM,
                onComplete: () => gsap.set(slot.el, { clearProps: "all" }) }, t);
            } else {
              if (slot.includeParent) {
                tl.to(slot.parentEl, { y: 0, autoAlpha: 1, ...ANIM,
                  onComplete: () => gsap.set(slot.parentEl, { clearProps: "all" }) }, t);
              }
              const nestedMs      = parseFloat(slot.nestedEl.getAttribute("data-stagger"));
              const nestedStagger = isNaN(nestedMs) ? groupStagger : nestedMs / 1000;
              Array.from(slot.nestedEl.children).forEach((child, j) => {
                tl.to(child, { y: 0, autoAlpha: 1, ...ANIM,
                  onComplete: () => gsap.set(child, { clearProps: "all" }) }, t + j * nestedStagger);
              });
            }
          });
        },
      });
    });
  });

  return () => ctx.revert();
}

document.addEventListener("DOMContentLoaded", initContentRevealScroll);
</script>

<script>
function initDynamicCurrentTime() {
  const DEFAULT_TZ  = "Asia/Calcutta";
  const formatters  = new Map();

  const getFormatter = (tz) => {
    if (!formatters.has(tz)) {
      formatters.set(tz, new Intl.DateTimeFormat([], {
        timeZone:     tz,
        timeZoneName: "short",
        hour:         "2-digit",
        minute:       "2-digit",
        second:       "2-digit",
        hour12:       false,
      }));
    }
    return formatters.get(tz);
  };

  const parseTime = (str) => str.match(/(\d+):(\d+):(\d+)\s*([\w+]+)/);

  const updateTime = () => {
    const now = new Date();
    document.querySelectorAll("[data-current-time]").forEach(el => {
      const tz     = el.getAttribute("data-current-time") || DEFAULT_TZ;
      const match  = parseTime(getFormatter(tz).format(now));
      if (!match) return;

      const [, hours, minutes, seconds, timezone] = match;
      const q = (sel) => el.querySelector(sel);

      const h = q("[data-current-time-hours]");
      const m = q("[data-current-time-minutes]");
      const s = q("[data-current-time-seconds]");
      const z = q("[data-current-time-timezone]");

      if (h) h.textContent = hours;
      if (m) m.textContent = minutes;
      if (s) s.textContent = seconds;
      if (z) z.textContent = timezone;
    });
  };

  updateTime();
  setInterval(updateTime, 1000);
}

document.addEventListener("DOMContentLoaded", initDynamicCurrentTime);
</script>

<script>
function initLogoRevealLoader() {
  gsap.registerPlugin(CustomEase, SplitText);
  CustomEase.create("loader", "0.65, 0.01, 0.05, 0.99");

  const wrap = document.querySelector("[data-load-wrap]");
  if (!wrap) return;

  const container   = wrap.querySelector("[data-load-container]");
  const bg          = wrap.querySelector("[data-load-bg]");
  const progressBar = wrap.querySelector("[data-load-progress]");
  const logo        = wrap.querySelector("[data-load-logo]");
  const textEls     = [...wrap.querySelectorAll("[data-load-text]")];
  const resetEls    = [...wrap.querySelectorAll("[data-load-reset]:not([data-load-text])")];

  // Play loader once per session
  if (sessionStorage.getItem("siteLoaderPlayed") === "true") {
    gsap.set(wrap, { display: "none" });
    if (resetEls.length) gsap.set(resetEls, { autoAlpha: 1 });
    gsap.set(textEls, { autoAlpha: 1 });
    return;
  }
  sessionStorage.setItem("siteLoaderPlayed", "true");

  const tl = gsap.timeline({ defaults: { ease: "loader", duration: 3 } })
    .set(wrap, { display: "block" })
    .to(progressBar, { scaleX: 1 })
    .to(logo, { clipPath: "inset(0% 0% 0% 0%)" }, "<")
    .to(container,   { autoAlpha: 0, duration: 0.5 })
    .to(progressBar, { scaleX: 0, transformOrigin: "right center", duration: 0.5 }, "<")
    .add("hideContent", "<")
    .to(bg, { yPercent: -101, duration: 1 }, "hideContent")
    .set(wrap, { display: "none" });

  if (resetEls.length) tl.set(resetEls, { autoAlpha: 1 }, 0);

  if (textEls.length >= 2) {
    const first  = new SplitText(textEls[0], { type: "lines,chars", mask: "lines" });
    const second = new SplitText(textEls[1], { type: "lines,chars", mask: "lines" });

    gsap.set([first.chars, second.chars], { autoAlpha: 0, yPercent: 125 });
    gsap.set(textEls, { autoAlpha: 1 });

    tl.to(first.chars,  { autoAlpha: 1, yPercent: 0,    duration: 0.6, stagger: { each: 0.02 } }, 0)
      .to(first.chars,  { autoAlpha: 0, yPercent: -125, duration: 0.4, stagger: { each: 0.02 } }, ">+=0.4")
      .to(second.chars, { autoAlpha: 1, yPercent: 0,    duration: 0.6, stagger: { each: 0.02 } }, "<")
      .to(second.chars, { autoAlpha: 0, yPercent: -125, duration: 0.4, stagger: { each: 0.02 } }, "hideContent-=0.5");
  }
}

document.addEventListener("DOMContentLoaded", initLogoRevealLoader);
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  if ("ontouchstart" in window || navigator.maxTouchPoints > 0) {
    document.documentElement.classList.add("touch-device");
  }
});
</script></body></html>
