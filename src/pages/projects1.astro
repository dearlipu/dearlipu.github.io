---
import { siteConfig } from "../config";
import "../styles/global.css";

const imageIds = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

const imageUrls = imageIds.map(
  id => `https://lh3.googleusercontent.com/d/${id}=w1200`
);
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Gallery</title>

<style>

/* 🔥 KEEP YOUR THEME (NO DARK OVERRIDE) */

.gallery {
  padding: 80px 20px;
  max-width: 1400px;
  margin: auto;
}

/* HEADER */
.heading {
  font-size: 42px;
  text-align: center;
  font-weight: 600;
  color: #1f2937;
}

.subHeading {
  text-align: center;
  color: #6b7280;
  margin-top: 10px;
  margin-bottom: 60px;
}

/* 🔥 PINTEREST GRID */
.container {
  column-count: 4;
  column-gap: 18px;
}

/* CARD */
.project {
  break-inside: avoid;
  margin-bottom: 18px;
  border-radius: 16px;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 8px 25px rgba(0,0,0,0.05);
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.project:hover {
  transform: translateY(-6px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.08);
}

/* IMAGE */
.project img {
  width: 100%;
  height: auto;
  display: block;
}

/* HOVER OVERLAY */
.btn-box {
  position: absolute;
  inset: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255,255,255,0.6);
  backdrop-filter: blur(6px);
  opacity: 0;
  transition: 0.3s;
}

.project:hover .btn-box {
  opacity: 1;
}

/* BUTTON */
.btn {
  background: #2563eb;
  color: white;
  padding: 8px 18px;
  border-radius: 20px;
  font-size: 14px;
  border: none;
  cursor: pointer;
  transition: 0.2s;
}

.btn:hover {
  background: #1d4ed8;
}

/* 🔥 OVERLAY VIEW */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.overlay.active {
  display: flex;
}

.overlay img {
  max-width: 90%;
  max-height: 90%;
  border-radius: 14px;
}

.close {
  position: absolute;
  top: 25px;
  right: 35px;
  color: white;
  font-size: 20px;
  cursor: pointer;
}

/* RESPONSIVE */
@media (max-width: 1100px) {
  .container { column-count: 3; }
}
@media (max-width: 700px) {
  .container { column-count: 2; }
}
@media (max-width: 500px) {
  .container { column-count: 1; }
}

</style>
</head>

<body>

<div class="gallery">

  <h1 class="heading">Gallery</h1>
  <p class="subHeading">Visual works & creative outputs</p>

  <div class="container">

    {imageUrls.map((img) => (
      <div class="project">
        <img src={img} loading="lazy" />

        <div class="btn-box">
          <button class="btn" data-img={img}>View</button>
        </div>
      </div>
    ))}

  </div>

</div>

<!-- OVERLAY -->
<div class="overlay" id="overlay">
  <span class="close">✕</span>
  <img id="overlayImg" />
</div>

<script is:inline>
const overlay = document.getElementById("overlay");
const overlayImg = document.getElementById("overlayImg");

document.querySelectorAll(".btn").forEach(btn => {
  btn.addEventListener("click", () => {
    overlay.classList.add("active");
    overlayImg.src = btn.dataset.img;
  });
});

document.querySelector(".close").onclick = () => {
  overlay.classList.remove("active");
};

overlay.addEventListener("click", (e) => {
  if (e.target === overlay) {
    overlay.classList.remove("active");
  }
});
</script>

</body>
</html>
