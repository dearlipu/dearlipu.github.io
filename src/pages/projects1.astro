---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Social Media Content System</title>
  </head>

  <body class="bg-white text-gray-900">

    <Header />

    <main class="px-5 sm:px-8 md:px-12 lg:px-24 py-16 md:py-20 max-w-6xl mx-auto">

      <!-- HERO -->
      <section class="mb-12 md:mb-16">
        <h1 class="text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight leading-tight">
          Social Media Content System
        </h1>
        <p class="mt-4 text-base sm:text-lg text-gray-600 max-w-2xl">
          Designed a consistent content system to improve engagement and brand clarity.
        </p>
      </section>

      <!-- INFO -->
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-10 mb-14 md:mb-20 text-sm text-gray-600">
        <div>
          <p class="font-semibold text-gray-900 mb-1">Client</p>
          <p>Personal Brand</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Goal</p>
          <p>Improve consistency & engagement</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Tools</p>
          <p>Photoshop, After Effects</p>
        </div>
      </section>

      <!-- PROBLEM / SOLUTION -->
      <section class="grid md:grid-cols-2 gap-8 md:gap-12 mb-16 md:mb-24">
        <div>
          <h3 class="text-lg md:text-xl font-semibold mb-2">Problem</h3>
          <p class="text-gray-600 leading-relaxed">
            Content lacked structure and consistency.
          </p>
        </div>
        <div>
          <h3 class="text-lg md:text-xl font-semibold mb-2">Solution</h3>
          <p class="text-gray-600 leading-relaxed">
            Built a modular design system with strong visual hierarchy.
          </p>
        </div>
      </section>

      <!-- GALLERY -->
      <section class="space-y-6 md:space-y-10 mb-20 md:mb-28">

        <img src="/projects/p1-1.jpg" class="gallery big" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
          <img src="/projects/p1-2.jpg" class="gallery" />
          <video class="gallery video" muted loop playsinline>
            <source src="/projects/video.mp4" type="video/mp4" />
          </video>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6">
          <img src="/projects/p1-4.jpg" class="gallery" />
          <img src="/projects/p1-5.jpg" class="gallery" />
          <img src="/projects/p1-6.jpg" class="gallery" />
        </div>

        <img src="/projects/p1-7.jpg" class="gallery big" />

      </section>

      <!-- BEFORE AFTER -->
      <section class="mb-20 md:mb-28">
        <h3 class="text-lg md:text-xl font-semibold mb-4 md:mb-6">
          Before / After
        </h3>

        <div class="ba" id="ba">

          <div class="ba-inner">
            <img src="/projects/before.jpg" class="ba-img" />

            <div class="ba-after" id="after">
              <img src="/projects/after.jpg" class="ba-img" />
            </div>
          </div>

          <div class="ba-divider" id="divider"></div>

        </div>
      </section>

      <!-- RESULT -->
      <section>
        <h3 class="text-lg md:text-xl font-semibold mb-2">Result</h3>
        <p class="text-gray-600 max-w-2xl leading-relaxed">
          Improved clarity and consistency across content.
        </p>
      </section>

    </main>

    <Footer />

    <!-- LIGHTBOX -->
    <div id="lightbox" class="lightbox hidden">
      <img id="lightboxImg" />
    </div>

    <!-- SCRIPTS -->
    <script>
      // before after
      const container = document.getElementById("ba");
      const after = document.getElementById("after");
      const divider = document.getElementById("divider");

      let active = false;

      const move = (x) => {
        const rect = container.getBoundingClientRect();
        let pos = x - rect.left;
        pos = Math.max(0, Math.min(pos, rect.width));
        const percent = (pos / rect.width) * 100;

        after.style.width = percent + "%";
        divider.style.left = percent + "%";
      };

      container.addEventListener("mousedown", () => active = true);
      window.addEventListener("mouseup", () => active = false);
      window.addEventListener("mousemove", (e) => active && move(e.clientX));

      container.addEventListener("touchstart", () => active = true);
      window.addEventListener("touchend", () => active = false);
      window.addEventListener("touchmove", (e) => active && move(e.touches[0].clientX));

      // lightbox
      const images = document.querySelectorAll(".gallery");
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightboxImg");

      images.forEach(img => {
        img.addEventListener("click", () => {
          lightbox.classList.remove("hidden");
          lightboxImg.src = img.src;
        });
      });

      lightbox.addEventListener("click", () => {
        lightbox.classList.add("hidden");
      });

      // video hover play
      document.querySelectorAll(".video").forEach(v => {
        v.addEventListener("mouseenter", () => v.play());
        v.addEventListener("mouseleave", () => v.pause());
      });
    </script>

    <!-- STYLES -->
    <style>

      .gallery {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
        border-radius: 14px;
        transition: 0.4s ease;
        cursor: pointer;
      }

      .gallery.big {
        aspect-ratio: 16/9;
      }

      .gallery:hover {
        transform: scale(1.02);
      }

      .ba {
        position: relative;
        width: 100%;
        max-width: 900px;
        aspect-ratio: 16/9;
        overflow: hidden;
        border-radius: 14px;
      }

      .ba-inner {
        position: absolute;
        inset: 0;
      }

      .ba-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .ba-after {
        position: absolute;
        inset: 0;
        width: 50%;
        overflow: hidden;
      }

      .ba-divider {
        position: absolute;
        top: 0;
        left: 50%;
        width: 2px;
        height: 100%;
        background: white;
        transform: translateX(-50%);
      }

      .ba-divider::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: white;
        box-shadow: 0 6px 30px rgba(0,0,0,0.3);
      }

      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 999;
      }

      .lightbox img {
        max-width: 90%;
        max-height: 90%;
        border-radius: 12px;
      }

      .hidden {
        display: none;
      }

    </style>

  </body>
</html>
