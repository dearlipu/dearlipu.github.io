<style>
/* Cursor root = the DOT */
.cursor{
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  pointer-events: none;

  width: 1em;
  height: 1em;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.85);

  transform: translate3d(-50%, -50%, 0);
  will-change: transform;
}

/* Tooltip text (your existing p) */
.cursor .cursor-paragraph{
  position: absolute;
  left: 50%;
  top: calc(100% + 10px);
  transform: translateX(-90%);

  margin: 0;
  padding: 6px 10px;

  color: #ffffff;
  background: rgba(255, 255, 255, 0.25);

  border-radius: 0px;
  font-size: 12px;
  line-height: 1.2;
  white-space: nowrap;

  opacity: 0;
  transition: opacity 0.18s ease, transform 0.18s ease;
  will-change: opacity, transform;
}

/* Show tooltip only when hovering an element that has data-cursor */
body:has([data-cursor]:hover) .cursor .cursor-paragraph{
  opacity: 1;
  transform: translateY(-50%) translateY(0);
}

/* Optional: make dot a bit larger on hover */
body:has(a:hover) .cursor,
body:has(button:hover) .cursor,
body:has([data-cursor]:hover) .cursor{
  width: 3em;
  height: 3em;
  background-color: rgba(255, 255, 255, 0.28);
}

/* Keep tooltip aligned even when dot grows */
body:has(a:hover) .cursor .cursor-paragraph,
body:has(button:hover) .cursor .cursor-paragraph,
body:has([data-cursor]:hover) .cursor .cursor-paragraph{
  left: calc(100% + 10px);
}

/* Hide on touch */
@media (hover: none) and (pointer: coarse) {
  .cursor { display: none; }
}
</style>

