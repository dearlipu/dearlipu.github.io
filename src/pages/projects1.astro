---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

/* Drive IDs */
const driveIds = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

const images = driveIds.map(id => ({
  url: `https://drive.google.com/thumbnail?id=${id}&sz=w1000`,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>Social Media Content System</title>
  </head>

  <body>

    <Header />

    <main class="container">

      <!-- HERO -->
      <section class="fade">
        <h1>Social Media Content System</h1>
        <p>
          Built a scalable content system to improve brand clarity,
          engagement, and consistency.
        </p>
      </section>

      <!-- METRICS -->
      <section class="metrics fade">
        <div><h2>+65%</h2><p>Engagement</p></div>
        <div><h2>2x</h2><p>Speed</p></div>
        <div><h2>+40%</h2><p>Retention</p></div>
      </section>

      <!-- INFO -->
      <section class="value fade">
        <div><span>Client</span><p>Personal Brand</p></div>
        <div><span>Goal</span><p>Increase engagement</p></div>
        <div><span>Tools</span><p>Photoshop, AE</p></div>
      </section>

      <!-- 🔥 PINTEREST GRID -->
      <section class="gallery fade">

        {images.map((img) => (
          <div class="card">
            <img src={img.url} loading="lazy" />
          </div>
        ))}

      </section>

      <!-- BEFORE AFTER -->
      <section class="fade">
        <h3>Before / After</h3>

        <div class="ba" id="ba">

          <img src="https://drive.google.com/thumbnail?id=BEFORE_ID&sz=w1000" />

          <div class="after" id="after">
            <img src="https://drive.google.com/thumbnail?id=AFTER_ID&sz=w1000" />
          </div>

          <div class="line" id="line"></div>

        </div>
      </section>

    </main>

    <Footer />

    <!-- SCRIPT -->
    <script>
      const ba = document.getElementById("ba");
      const after = document.getElementById("after");
      const line = document.getElementById("line");

      if (ba) {
        let active = false;

        const move = x => {
          const rect = ba.getBoundingClientRect();
          let pos = x - rect.left;
          pos = Math.max(0, Math.min(pos, rect.width));
          const percent = (pos / rect.width) * 100;

          after.style.width = percent + "%";
          line.style.left = percent + "%";
        };

        ba.addEventListener("mousedown", () => active = true);
        window.addEventListener("mouseup", () => active = false);
        window.addEventListener("mousemove", e => active && move(e.clientX));

        ba.addEventListener("touchstart", () => active = true);
        window.addEventListener("touchend", () => active = false);
        window.addEventListener("touchmove", e => active && move(e.touches[0].clientX));
      }
    </script>

    <!-- STYLES -->
    <style>

      body {
        font-family: 'Josefin Sans', sans-serif;
      }

      .container {
        max-width: 1200px;
        margin: auto;
        padding: 60px 16px;
      }

      h1 {
        font-size: clamp(28px,6vw,60px);
      }

      p {
        color: #6b7280;
      }

      /* METRICS */
      .metrics {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        text-align: center;
        margin: 40px 0;
      }

      /* INFO */
      .value {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        margin-bottom: 40px;
      }

      /* 🔥 PINTEREST GRID */
      .gallery {
        column-count: 2;
        column-gap: 14px;
      }

      @media(min-width:768px){
        .gallery { column-count: 3; }
      }

      @media(min-width:1200px){
        .gallery { column-count: 4; }
      }

      .card {
        break-inside: avoid;
        margin-bottom: 14px;
        border-radius: 16px;
        overflow: hidden;
      }

      .card img {
        width: 100%;
        display: block;
        border-radius: 16px;
        transition: 0.3s;
      }

      .card img:hover {
        transform: scale(1.03);
      }

      /* BEFORE AFTER */
      .ba {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
        border-radius: 12px;
        margin-top: 20px;
      }

      .ba img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .after {
        position: absolute;
        inset: 0;
        width: 50%;
        overflow: hidden;
      }

      .line {
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 2px;
        background: white;
      }

      /* MOBILE */
      @media(max-width:600px){
        .metrics,
        .value {
          grid-template-columns: 1fr;
          gap: 20px;
        }
      }

    </style>

  </body>
</html>
