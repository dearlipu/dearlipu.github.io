---
const imageIds = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

const imageUrls = imageIds.map(
  id => `https://lh3.googleusercontent.com/d/${id}=w1200`
);
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Gallery</title>

<!-- 🔥 Font -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #0b0b0f;
  --card: #111116;
  --text: #ffffff;
  --muted: #9ca3af;
  --accent: #6366f1;
}

body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
}

/* HEADER */
.gallery {
  padding: 60px 20px;
  max-width: 1400px;
  margin: auto;
}

.heading {
  font-size: 40px;
  text-align: center;
  font-weight: 600;
}

.subHeading {
  text-align: center;
  color: var(--muted);
  margin-top: 10px;
  margin-bottom: 50px;
}

/* 🔥 PINTEREST GRID */
.container {
  column-count: 4;
  column-gap: 16px;
}

.project {
  break-inside: avoid;
  margin-bottom: 16px;
  border-radius: 14px;
  overflow: hidden;
  background: var(--card);
  position: relative;
  cursor: pointer;
  transition: transform 0.3s ease;
}

.project:hover {
  transform: translateY(-5px);
}

/* IMAGE */
.project img {
  width: 100%;
  height: auto;
  display: block;
}

/* OVERLAY BUTTON */
.btn-box {
  position: absolute;
  inset: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(0,0,0,0.4);
  opacity: 0;
  transition: 0.3s;
}

.project:hover .btn-box {
  opacity: 1;
}

.btn {
  background: white;
  color: black;
  padding: 8px 18px;
  border-radius: 20px;
  font-size: 14px;
  border: none;
  cursor: pointer;
}

/* 🔥 OVERLAY */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.overlay.active {
  display: flex;
}

.overlay img {
  max-width: 90%;
  max-height: 90%;
  border-radius: 12px;
}

.close {
  position: absolute;
  top: 25px;
  right: 35px;
  color: white;
  font-size: 18px;
  cursor: pointer;
}

/* RESPONSIVE */
@media (max-width: 1100px) {
  .container { column-count: 3; }
}
@media (max-width: 700px) {
  .container { column-count: 2; }
}
@media (max-width: 500px) {
  .container { column-count: 1; }
}
</style>
</head>

<body>

<div class="gallery">

  <h1 class="heading">Gallery</h1>
  <p class="subHeading">Visual works & creative outputs</p>

  <div class="container">

    {imageUrls.map((img) => (
      <div class="project">
        <img src={img} loading="lazy" />

        <div class="btn-box">
          <button class="btn" data-img={img}>View</button>
        </div>
      </div>
    ))}

  </div>

</div>

<!-- OVERLAY -->
<div class="overlay" id="overlay">
  <span class="close">✕</span>
  <img id="overlayImg" />
</div>

<script is:inline>
const overlay = document.getElementById("overlay");
const overlayImg = document.getElementById("overlayImg");

document.querySelectorAll(".btn").forEach(btn => {
  btn.addEventListener("click", () => {
    overlay.classList.add("active");
    overlayImg.src = btn.dataset.img;
  });
});

document.querySelector(".close").onclick = () => {
  overlay.classList.remove("active");
};

overlay.addEventListener("click", (e) => {
  if (e.target === overlay) {
    overlay.classList.remove("active");
  }
});
</script>

</body>
</html>
