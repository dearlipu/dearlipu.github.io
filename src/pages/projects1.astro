---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>Social Media Content System</title>
  </head>

  <body class="bg-white text-gray-900">

    <Header />

    <main class="px-5 md:px-12 lg:px-20 py-16 max-w-7xl mx-auto">

      <!-- HERO -->
      <section class="mb-12">
        <h1 class="text-3xl md:text-6xl font-bold">
          Social Media Content System
        </h1>
        <p class="mt-4 text-gray-600 max-w-xl">
          A complete visual system designed for consistency, clarity and engagement.
        </p>
      </section>

      <!-- FILTER -->
      <div class="flex gap-3 overflow-x-auto pb-4 mb-10">

        <button class="filter active" data-filter="all">All</button>
        <button class="filter" data-filter="design">Design</button>
        <button class="filter" data-filter="branding">Branding</button>
        <button class="filter" data-filter="video">Video</button>

      </div>

      <!-- MASONRY GRID -->
      <div id="grid" class="grid">

        <!-- ITEM -->
        <div class="item design">
          <img src="/projects/p1-1.jpg" />
          <div class="overlay">Social Post</div>
        </div>

        <div class="item branding">
          <img src="/projects/p1-2.jpg" />
          <div class="overlay">Brand Layout</div>
        </div>

        <div class="item video">
          <video muted loop playsinline>
            <source src="/projects/video.mp4" type="video/mp4" />
          </video>
          <div class="overlay">Video Edit</div>
        </div>

        <div class="item design">
          <img src="/projects/p1-3.jpg" />
          <div class="overlay">Typography</div>
        </div>

        <div class="item design">
          <img src="/projects/p1-4.jpg" />
          <div class="overlay">Creative Layout</div>
        </div>

        <div class="item branding">
          <img src="/projects/p1-5.jpg" />
          <div class="overlay">Brand System</div>
        </div>

        <div class="item design">
          <img src="/projects/p1-6.jpg" />
          <div class="overlay">Visual Design</div>
        </div>

      </div>

      <!-- BEFORE AFTER -->
      <section class="mt-24">
        <h3 class="text-xl font-semibold mb-6">Before / After</h3>

        <div class="ba" id="ba">

          <img src="/projects/before.jpg" class="ba-img" />

          <div class="ba-after" id="after">
            <img src="/projects/after.jpg" class="ba-img" />
          </div>

          <div class="ba-divider" id="divider"></div>

        </div>

      </section>

    </main>

    <Footer />

    <!-- LIGHTBOX -->
    <div id="lightbox" class="lightbox hidden">
      <img id="lightboxImg" />
    </div>

    <!-- SCRIPT -->
    <script>

      // FILTER
      const filters = document.querySelectorAll(".filter");
      const items = document.querySelectorAll(".item");

      filters.forEach(btn => {
        btn.addEventListener("click", () => {
          document.querySelector(".filter.active").classList.remove("active");
          btn.classList.add("active");

          const filter = btn.dataset.filter;

          items.forEach(item => {
            item.style.display =
              filter === "all" || item.classList.contains(filter)
                ? "block"
                : "none";
          });
        });
      });

      // LIGHTBOX
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightboxImg");

      document.querySelectorAll(".item img").forEach(img => {
        img.addEventListener("click", () => {
          lightbox.classList.remove("hidden");
          lightboxImg.src = img.src;
        });
      });

      lightbox.addEventListener("click", () => {
        lightbox.classList.add("hidden");
      });

      // VIDEO HOVER
      document.querySelectorAll("video").forEach(v => {
        v.addEventListener("mouseenter", () => v.play());
        v.addEventListener("mouseleave", () => v.pause());
      });

      // BEFORE AFTER FIX
      const container = document.getElementById("ba");
      const after = document.getElementById("after");
      const divider = document.getElementById("divider");

      let active = false;

      const move = (x) => {
        const rect = container.getBoundingClientRect();
        let pos = x - rect.left;
        pos = Math.max(0, Math.min(pos, rect.width));
        const percent = (pos / rect.width) * 100;

        after.style.width = percent + "%";
        divider.style.left = percent + "%";
      };

      container.addEventListener("mousedown", () => active = true);
      window.addEventListener("mouseup", () => active = false);
      window.addEventListener("mousemove", e => active && move(e.clientX));

      container.addEventListener("touchstart", () => active = true);
      window.addEventListener("touchend", () => active = false);
      window.addEventListener("touchmove", e => active && move(e.touches[0].clientX));

    </script>

    <!-- STYLES -->
    <style>

      /* FILTER */
      .filter {
        padding: 8px 16px;
        border-radius: 999px;
        background: #f3f4f6;
        font-size: 14px;
        white-space: nowrap;
      }

      .filter.active {
        background: #111827;
        color: white;
      }

      /* GRID */
      .grid {
        column-count: 1;
        column-gap: 16px;
      }

      @media (min-width: 640px) {
        .grid { column-count: 2; }
      }

      @media (min-width: 1024px) {
        .grid { column-count: 3; }
      }

      .item {
        break-inside: avoid;
        margin-bottom: 16px;
        position: relative;
        cursor: pointer;
      }

      .item img,
      .item video {
        width: 100%;
        border-radius: 14px;
        display: block;
      }

      /* HOVER */
      .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.5);
        color: white;
        display: flex;
        align-items: end;
        padding: 16px;
        opacity: 0;
        transition: 0.3s;
        border-radius: 14px;
      }

      .item:hover .overlay {
        opacity: 1;
      }

      /* LIGHTBOX */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
      }

      .lightbox img {
        max-width: 90%;
        max-height: 90%;
      }

      .hidden { display: none; }

      /* BEFORE AFTER */
      .ba {
        position: relative;
        max-width: 900px;
        aspect-ratio: 16/9;
        overflow: hidden;
        border-radius: 14px;
      }

      .ba-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .ba-after {
        position: absolute;
        inset: 0;
        width: 50%;
        overflow: hidden;
      }

      .ba-divider {
        position: absolute;
        left: 50%;
        top: 0;
        width: 2px;
        height: 100%;
        background: white;
        transform: translateX(-50%);
      }

      .ba-divider::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 30px;
        height: 30px;
        background: white;
        border-radius: 50%;
        transform: translate(-50%, -50%);
      }

    </style>

  </body>
</html>
