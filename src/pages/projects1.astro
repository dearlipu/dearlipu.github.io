---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Social Media Content System</title>
  </head>

  <body>
    <Header />

    <main class="px-6 md:px-12 lg:px-24 py-16 max-w-6xl mx-auto">

      <!-- HERO -->
      <section class="mb-12">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900">
          Social Media Content System
        </h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl">
          Designed a consistent content system to improve engagement and brand clarity across social media.
        </p>
      </section>

      <!-- INFO ROW -->
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16 text-sm text-gray-600">
        <div>
          <p class="font-semibold text-gray-900">Client</p>
          <p>Personal Brand</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900">Goal</p>
          <p>Improve consistency & engagement</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900">Tools</p>
          <p>Photoshop, After Effects</p>
        </div>
      </section>

      <!-- PROBLEM / SOLUTION -->
      <section class="grid md:grid-cols-2 gap-10 mb-16">
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Problem</h3>
          <p class="text-gray-600">
            Content lacked structure and consistency, making the brand feel unprofessional.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Solution</h3>
          <p class="text-gray-600">
            Built a modular design system with reusable layouts, consistent typography, and strong visual hierarchy.
          </p>
        </div>
      </section>

      <!-- GALLERY -->
      <section class="space-y-6 mb-20">

        <!-- BIG -->
        <img src="/projects/p1-1.jpg" class="w-full rounded-xl shadow-md" />

        <!-- 2 GRID -->
        <div class="grid md:grid-cols-2 gap-6">
          <img src="/projects/p1-2.jpg" class="rounded-xl" />
          <img src="/projects/p1-3.jpg" class="rounded-xl" />
        </div>

        <!-- 3 GRID -->
        <div class="grid md:grid-cols-3 gap-6">
          <img src="/projects/p1-4.jpg" class="rounded-xl" />
          <img src="/projects/p1-5.jpg" class="rounded-xl" />
          <img src="/projects/p1-6.jpg" class="rounded-xl" />
        </div>

        <!-- BIG -->
        <img src="/projects/p1-7.jpg" class="w-full rounded-xl shadow-md" />

      </section>

      <!-- BEFORE AFTER SLIDER -->
      <section class="mb-20">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">Before / After</h3>

        <div class="relative w-full max-w-3xl">

          <img src="/projects/before.jpg" class="w-full rounded-xl" />

          <div class="absolute inset-0 overflow-hidden" id="afterContainer">
            <img src="/projects/after.jpg" class="w-full rounded-xl" />
          </div>

          <input
            type="range"
            min="0"
            max="100"
            value="50"
            class="absolute bottom-4 left-1/2 -translate-x-1/2 w-2/3"
            id="slider"
          />

        </div>
      </section>

      <!-- RESULT -->
      <section>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Result</h3>
        <p class="text-gray-600 max-w-2xl">
          Delivered a scalable content system that improves clarity, speed, and brand consistency.
        </p>
      </section>

    </main>

    <Footer />

    <script>
      const slider = document.getElementById("slider");
      const after = document.getElementById("afterContainer");

      slider.addEventListener("input", (e) => {
        const val = e.target.value;
        after.style.width = val + "%";
      });
    </script>

  </body>
</html>
