---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>Social Media Content System</title>
  </head>

  <body>

    <div id="page">

      <Header />

      <main class="container">

        <!-- HERO -->
        <section class="hero fade">
          <h1>Social Media Content System</h1>
          <p>
            Built a scalable content system to improve brand clarity,
            engagement, and consistency across social media.
          </p>
        </section>

        <!-- VALUE STRIP (CLIENT FOCUSED) -->
        <section class="value fade">
          <div>
            <span>Client</span>
            <p>Personal Brand</p>
          </div>
          <div>
            <span>Goal</span>
            <p>Increase engagement</p>
          </div>
          <div>
            <span>Impact</span>
            <p>Stronger brand consistency</p>
          </div>
        </section>

        <!-- PROBLEM / SOLUTION -->
        <section class="ps fade">
          <div>
            <h3>Problem</h3>
            <p>
              Content lacked structure, making posts inconsistent and
              reducing audience trust.
            </p>
          </div>
          <div>
            <h3>Solution</h3>
            <p>
              Created a modular visual system with reusable layouts,
              strong hierarchy, and clear branding.
            </p>
          </div>
        </section>

        <!-- GALLERY -->
        <section class="grid fade">

          <img src="/projects/p1-1.jpg" class="item big" />

          <img src="/projects/p1-2.jpg" class="item" />

          <video class="item video" muted loop playsinline>
            <source src="/projects/video.mp4" type="video/mp4" />
          </video>

          <img src="/projects/p1-3.jpg" class="item" />
          <img src="/projects/p1-4.jpg" class="item" />
          <img src="/projects/p1-5.jpg" class="item" />

          <img src="/projects/p1-6.jpg" class="item big" />

        </section>

        <!-- BEFORE AFTER -->
        <section class="fade">
          <h3>Before / After</h3>

          <div class="ba" id="ba">

            <img src="/projects/before.jpg" class="ba-img" />

            <div class="ba-after" id="after">
              <img src="/projects/after.jpg" class="ba-img" />
            </div>

            <div class="ba-divider" id="divider"></div>

          </div>
        </section>

        <!-- RESULT (VERY IMPORTANT FOR CLIENTS) -->
        <section class="result fade">
          <h3>Result</h3>
          <p>
            Delivered a system that improved consistency, reduced design time,
            and created a more professional brand presence.
          </p>
        </section>

      </main>

      <Footer />

    </div>

    <!-- LIGHTBOX -->
    <div id="lightbox" class="lightbox hidden">
      <img id="lightboxImg" />
    </div>

    <!-- SCRIPT -->
    <script>

      // PAGE TRANSITION
      window.addEventListener("load", () => {
        document.getElementById("page").classList.add("show");
      });

      // SCROLL ANIMATION
      const fades = document.querySelectorAll(".fade");

      const observer = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("show");
          }
        });
      }, { threshold: 0.2 });

      fades.forEach(el => observer.observe(el));

      // LIGHTBOX
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightboxImg");

      document.querySelectorAll(".item").forEach(el => {
        if (el.tagName === "IMG") {
          el.addEventListener("click", () => {
            lightbox.classList.remove("hidden");
            lightboxImg.src = el.src;
          });
        }
      });

      lightbox.onclick = () => lightbox.classList.add("hidden");

      // VIDEO HOVER
      document.querySelectorAll(".video").forEach(v => {
        v.addEventListener("mouseenter", () => v.play());
        v.addEventListener("mouseleave", () => v.pause());
      });

      // BEFORE AFTER
      const container = document.getElementById("ba");
      const after = document.getElementById("after");
      const divider = document.getElementById("divider");

      let active = false;

      const move = x => {
        const rect = container.getBoundingClientRect();
        let pos = x - rect.left;
        pos = Math.max(0, Math.min(pos, rect.width));
        const percent = (pos / rect.width) * 100;

        after.style.width = percent + "%";
        divider.style.left = percent + "%";
      };

      container.addEventListener("mousedown", () => active = true);
      window.addEventListener("mouseup", () => active = false);
      window.addEventListener("mousemove", e => active && move(e.clientX));

      container.addEventListener("touchstart", () => active = true);
      window.addEventListener("touchend", () => active = false);
      window.addEventListener("touchmove", e => active && move(e.touches[0].clientX));

    </script>

    <!-- STYLES -->
    <style>

      body {
        font-family: 'Josefin Sans', sans-serif;
        background: #fff;
      }

      #page {
        opacity: 0;
        transform: translateY(10px);
        transition: 0.6s ease;
      }

      #page.show {
        opacity: 1;
        transform: none;
      }

      .container {
        max-width: 1100px;
        margin: auto;
        padding: 60px 20px;
      }

      h1 {
        font-size: clamp(32px, 6vw, 64px);
        font-weight: 700;
      }

      h3 {
        font-size: 20px;
        margin-bottom: 10px;
      }

      p {
        color: #6b7280;
        line-height: 1.6;
      }

      /* VALUE */
      .value {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin: 40px 0;
      }

      .value span {
        font-size: 12px;
        color: gray;
      }

      /* PROBLEM SOLUTION */
      .ps {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
        margin-bottom: 60px;
      }

      @media(min-width:768px){
        .ps {
          grid-template-columns: 1fr 1fr;
        }
      }

      /* GRID */
      .grid {
        column-count: 1;
        gap: 16px;
      }

      @media(min-width:768px){
        .grid { column-count: 2; }
      }

      @media(min-width:1024px){
        .grid { column-count: 3; }
      }

      .item {
        width: 100%;
        margin-bottom: 16px;
        border-radius: 12px;
        display: block;
        cursor: pointer;
      }

      .big {
        width: 100%;
      }

      /* FADE */
      .fade {
        opacity: 0;
        transform: translateY(30px);
        transition: 0.6s ease;
      }

      .fade.show {
        opacity: 1;
        transform: none;
      }

      /* LIGHTBOX */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
      }

      .lightbox img {
        max-width: 90%;
        max-height: 90%;
      }

      .hidden { display:none; }

      /* BEFORE AFTER */
      .ba {
        position: relative;
        max-width: 900px;
        aspect-ratio: 16/9;
        overflow: hidden;
        border-radius: 12px;
      }

      .ba-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .ba-after {
        position: absolute;
        inset: 0;
        width: 50%;
        overflow: hidden;
      }

      .ba-divider {
        position: absolute;
        left: 50%;
        top: 0;
        width: 2px;
        height: 100%;
        background: white;
      }

      .ba-divider::after {
        content:"";
        position:absolute;
        top:50%;
        left:50%;
        width:28px;
        height:28px;
        background:white;
        border-radius:50%;
        transform:translate(-50%,-50%);
      }

      /* MOBILE FIX */
      @media(max-width:600px){
        .value {
          grid-template-columns: 1fr;
        }
      }

    </style>

  </body>
</html>
