<script>
(() => {
  console.log("✅ gallery script loaded");

  const wrap =
    document.querySelector(".gallery-source-wrap") ||
    document.querySelector("[data-gallery-source]") ||
    document.body;

  console.log("✅ wrap found?", !!wrap, wrap);

  const imgs = Array.from(document.images);
  console.log("🧾 total <img> on page:", imgs.length);

  // Try the intended scope first
  const scoped = Array.from(wrap.querySelectorAll("img"));
  console.log("🖼️ imgs inside wrap:", scoped.length);

  // Print first 5 srcs so we know we’re targeting the right ones
  console.log("🔎 sample srcs:", scoped.slice(0,5).map(i => i.currentSrc || i.src));

})();
