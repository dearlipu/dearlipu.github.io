---
const images = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

const getImage = (id) =>
  `https://lh3.googleusercontent.com/d/${id}=w1200`;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Gallery</title>

  <style>
    body {
      margin: 0;
      background: #0b0b0f;
      overflow: hidden;
    }

    canvas {
      position: fixed;
      inset: 0;
    }

    .top {
      position: fixed;
      top: 20px;
      left: 20px;
      z-index: 10;
      color: white;
      font-family: sans-serif;
    }
  </style>
</head>

<body>

<div class="top">
  <h2>PROJECT</h2>
  <p>Drag / Scroll</p>
</div>

<canvas id="canvas"></canvas>

<script src="https://cdn.jsdelivr.net/npm/pixi.js@7.x/dist/pixi.min.js"></script>

<script>
const images = JSON.parse(`${JSON.stringify(images.map(id => getImage(id)))}`);

const app = new PIXI.Application({
  view: document.getElementById("canvas"),
  resizeTo: window,
  backgroundAlpha: 0
});

let textures = [];
let tiles = [];

let scrollX = 0;
let scrollY = 0;
let velX = 0;
let velY = 0;

const GAP = 20;
let tileSize = 300;
let cols, rows;

async function loadTextures() {
  textures = await Promise.all(
    images.map(src => PIXI.Assets.load(src))
  );
  buildGrid();
}

function buildGrid() {
  cols = Math.ceil(window.innerWidth / tileSize) + 2;
  rows = Math.ceil(window.innerHeight / tileSize) + 2;

  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {

      const tex = textures[Math.floor(Math.random() * textures.length)];

      const sprite = new PIXI.Sprite(tex);
      sprite.width = tileSize - GAP;
      sprite.height = tileSize - GAP;

      sprite.x = x * tileSize;
      sprite.y = y * tileSize;

      app.stage.addChild(sprite);

      tiles.push({ sprite, x, y });
    }
  }
}

function update() {

  scrollX += velX;
  scrollY += velY;

  velX *= 0.92;
  velY *= 0.92;

  const gridW = cols * tileSize;
  const gridH = rows * tileSize;

  tiles.forEach(t => {
    let x = (t.x * tileSize + scrollX) % gridW;
    let y = (t.y * tileSize + scrollY) % gridH;

    if (x < 0) x += gridW;
    if (y < 0) y += gridH;

    t.sprite.x = x;
    t.sprite.y = y;
  });
}

app.ticker.add(update);

/* DRAG */
let isDown = false;
let lastX, lastY;

window.addEventListener("pointerdown", e => {
  isDown = true;
  lastX = e.clientX;
  lastY = e.clientY;
});

window.addEventListener("pointerup", () => isDown = false);

window.addEventListener("pointermove", e => {
  if (!isDown) return;

  let dx = e.clientX - lastX;
  let dy = e.clientY - lastY;

  velX += dx * 0.5;
  velY += dy * 0.5;

  lastX = e.clientX;
  lastY = e.clientY;
});

/* SCROLL */
window.addEventListener("wheel", e => {
  velX += -e.deltaX * 0.2;
  velY += -e.deltaY * 0.2;
});

loadTextures();
</script>

</body>
</html>
