---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Social Media Content System</title>
  </head>

  <body>
    <Header />

    <main class="px-6 md:px-12 lg:px-24 py-16 max-w-6xl mx-auto">

      <!-- HERO -->
      <section class="mb-14">
        <h1 class="text-4xl md:text-6xl font-bold text-gray-900 tracking-tight">
          Social Media Content System
        </h1>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl">
          Designed a consistent content system to improve engagement and brand clarity across social media.
        </p>
      </section>

      <!-- INFO -->
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-16 text-sm text-gray-600">
        <div>
          <p class="font-semibold text-gray-900 mb-1">Client</p>
          <p>Personal Brand</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Goal</p>
          <p>Improve consistency & engagement</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Tools</p>
          <p>Photoshop, After Effects</p>
        </div>
      </section>

      <!-- PROBLEM / SOLUTION -->
      <section class="grid md:grid-cols-2 gap-12 mb-20">
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Problem</h3>
          <p class="text-gray-600 leading-relaxed">
            Content lacked structure and consistency, making the brand feel unprofessional.
          </p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Solution</h3>
          <p class="text-gray-600 leading-relaxed">
            Built a modular design system with reusable layouts, consistent typography, and strong visual hierarchy.
          </p>
        </div>
      </section>

      <!-- GALLERY -->
      <section class="space-y-8 mb-24">

        <!-- BIG -->
        <img src="/projects/p1-1.jpg" class="gallery-img big" />

        <!-- 2 GRID -->
        <div class="grid md:grid-cols-2 gap-6">
          <img src="/projects/p1-2.jpg" class="gallery-img" />
          <img src="/projects/p1-3.jpg" class="gallery-img" />
        </div>

        <!-- 3 GRID -->
        <div class="grid md:grid-cols-3 gap-6">
          <img src="/projects/p1-4.jpg" class="gallery-img" />
          <img src="/projects/p1-5.jpg" class="gallery-img" />
          <img src="/projects/p1-6.jpg" class="gallery-img" />
        </div>

        <!-- BIG -->
        <img src="/projects/p1-7.jpg" class="gallery-img big" />

      </section>

      <!-- BEFORE AFTER -->
      <section class="mb-24">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">Before / After</h3>

        <div class="ba-container" id="baContainer">

          <img src="/projects/before.jpg" class="ba-img" />

          <div class="ba-after" id="baAfter">
            <img src="/projects/after.jpg" class="ba-img" />
          </div>

          <!-- HANDLE -->
          <div class="ba-handle" id="baHandle"></div>

        </div>
      </section>

      <!-- RESULT -->
      <section>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Result</h3>
        <p class="text-gray-600 max-w-2xl leading-relaxed">
          Delivered a scalable content system that improves clarity, speed, and brand consistency.
        </p>
      </section>

    </main>

    <Footer />

    <script>
      const container = document.getElementById("baContainer");
      const after = document.getElementById("baAfter");
      const handle = document.getElementById("baHandle");

      let isDragging = false;

      const move = (x) => {
        const rect = container.getBoundingClientRect();
        let pos = x - rect.left;
        pos = Math.max(0, Math.min(pos, rect.width));
        const percent = (pos / rect.width) * 100;

        after.style.width = percent + "%";
        handle.style.left = percent + "%";
      };

      container.addEventListener("mousedown", () => isDragging = true);
      window.addEventListener("mouseup", () => isDragging = false);
      window.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        move(e.clientX);
      });

      // touch
      container.addEventListener("touchstart", () => isDragging = true);
      window.addEventListener("touchend", () => isDragging = false);
      window.addEventListener("touchmove", (e) => {
        if (!isDragging) return;
        move(e.touches[0].clientX);
      });
    </script>

    <style>
      /* IMAGE SYSTEM */
      .gallery-img {
        width: 100%;
        height: 280px;
        object-fit: cover;
        border-radius: 16px;
        transition: all 0.4s ease;
      }

      .gallery-img.big {
        height: 420px;
      }

      .gallery-img:hover {
        transform: scale(1.02);
      }

      /* BEFORE AFTER */
      .ba-container {
        position: relative;
        max-width: 800px;
        border-radius: 16px;
        overflow: hidden;
        cursor: ew-resize;
      }

      .ba-img {
        width: 100%;
        height: 420px;
        object-fit: cover;
        display: block;
      }

      .ba-after {
        position: absolute;
        top: 0;
        left: 0;
        width: 50%;
        overflow: hidden;
      }

      .ba-handle {
        position: absolute;
        top: 0;
        left: 50%;
        width: 2px;
        height: 100%;
        background: white;
        box-shadow: 0 0 0 4px rgba(255,255,255,0.2);
        transform: translateX(-50%);
      }

      .ba-handle::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: white;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
      }
    </style>

  </body>
</html>
