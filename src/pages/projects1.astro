---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

/* 🔥 Only add Drive FILE IDs here */
const driveIds = [
  "11ED5yQTazPPWzzlU5rlYMHDzqELyl9QP",
  "1yxGFHBfkSOYnKY0Z4Mk-EwFKADJ0Vt91",
  "1YhRzX0KQ8IHWO-L8Lpcj26uqSkEVQ2GZ",
  "1t0_rJeF8pwhGJKmwG7FCaA6DK2afPGaj",
  "1cjX3CVhxVoEZGQuSFFSoJvFgj0gCqgCx",
  "1G5HafXFH4whR-Nf_03jhrcXfEhJLhphk"
];

const images = driveIds.map(id => ({
  url: `https://lh3.googleusercontent.com/d/${id}=w1000`,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>Social Media Content System</title>
  </head>

  <body>

    <div id="page">

      <Header />

      <main class="container">

        <!-- HERO -->
        <section class="fade">
          <h1>Social Media Content System</h1>
          <p>
            Built a scalable content system to improve brand clarity,
            engagement, and consistency.
          </p>
        </section>

        <!-- METRICS -->
        <section class="metrics fade">
          <div>
            <h2>+65%</h2>
            <p>Engagement Increase</p>
          </div>
          <div>
            <h2>2x</h2>
            <p>Content Speed</p>
          </div>
          <div>
            <h2>+40%</h2>
            <p>Audience Retention</p>
          </div>
        </section>

        <!-- VALUE -->
        <section class="value fade">
          <div>
            <span>Client</span>
            <p>Personal Brand</p>
          </div>
          <div>
            <span>Goal</span>
            <p>Increase engagement</p>
          </div>
          <div>
            <span>Tools</span>
            <p>Photoshop, After Effects</p>
          </div>
        </section>

        <!-- GALLERY (Pinterest Style) -->
        <section class="grid fade">

          {images.map((img) => (
            <img
              src={img.url}
              loading="lazy"
              class="item lazy"
            />
          ))}

        </section>

        <!-- BEFORE AFTER -->
        <section class="fade">
          <h3>Before / After</h3>

          <div class="ba" id="ba">
            <img src="https://drive.google.com/uc?export=view&id=BEFORE_ID" class="ba-img" />

            <div class="ba-after" id="after">
              <img src="https://drive.google.com/uc?export=view&id=AFTER_ID" class="ba-img" />
            </div>

            <div class="ba-divider" id="divider"></div>
          </div>
        </section>

        <!-- CTA -->
        <section class="cta fade">
          <h2>Want similar results?</h2>
          <p>I help brands build high-performing visual systems.</p>

          <div class="cta-btns">
            <a href="https://wa.me/your-number">Chat on WhatsApp</a>
            <a href="/#contact">Start Project</a>
          </div>
        </section>

      </main>

      <Footer />

    </div>

    <!-- LIGHTBOX -->
    <div id="lightbox" class="lightbox hidden">
      <img id="lightboxImg" />
    </div>

    <!-- SCRIPT -->
    <script>
      window.addEventListener("DOMContentLoaded", () => {

        // page animation
        document.getElementById("page")?.classList.add("show");

        // fade on scroll
        const fades = document.querySelectorAll(".fade");

        const observer = new IntersectionObserver(entries => {
          entries.forEach(e => {
            if (e.isIntersecting) e.target.classList.add("show");
          });
        });

        fades.forEach(el => observer.observe(el));

        // lightbox
        const lightbox = document.getElementById("lightbox");
        const lightboxImg = document.getElementById("lightboxImg");

        document.querySelectorAll(".item").forEach(img => {
          img.addEventListener("click", () => {
            lightbox.classList.remove("hidden");
            lightboxImg.src = img.src;
          });
        });

        lightbox.onclick = () => lightbox.classList.add("hidden");

        // blur load effect
        const lazyImages = document.querySelectorAll(".lazy");

        const imgObserver = new IntersectionObserver(entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const img = entry.target;

              const temp = new Image();
              temp.src = img.src;

              temp.onload = () => {
                img.classList.add("loaded");
              };

              imgObserver.unobserve(img);
            }
          });
        });

        lazyImages.forEach(img => imgObserver.observe(img));

        // before after
        const container = document.getElementById("ba");
        const after = document.getElementById("after");
        const divider = document.getElementById("divider");

        if (container && after && divider) {
          let active = false;

          const move = x => {
            const rect = container.getBoundingClientRect();
            let pos = x - rect.left;
            pos = Math.max(0, Math.min(pos, rect.width));
            const percent = (pos / rect.width) * 100;

            after.style.width = percent + "%";
            divider.style.left = percent + "%";
          };

          container.addEventListener("mousedown", () => active = true);
          window.addEventListener("mouseup", () => active = false);
          window.addEventListener("mousemove", e => active && move(e.clientX));

          container.addEventListener("touchstart", () => active = true);
          window.addEventListener("touchend", () => active = false);
          window.addEventListener("touchmove", e => active && move(e.touches[0].clientX));
        }

      });
    </script>

    <!-- STYLES -->
    <style>

      body {
        font-family: 'Josefin Sans', sans-serif;
      }

      #page {
        opacity: 0;
        transform: translateY(10px);
        transition: 0.6s ease;
      }

      #page.show {
        opacity: 1;
        transform: none;
      }

      .container {
        max-width: 1200px;
        margin: auto;
        padding: 60px 16px;
      }

      h1 { font-size: clamp(28px,6vw,60px); }
      h2 { font-size: 26px; }
      h3 { font-size: 20px; }

      p { color: #6b7280; }

      /* METRICS */
      .metrics {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        text-align: center;
        margin: 40px 0;
      }

      /* VALUE */
      .value {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin: 40px 0;
      }

      /* PINTEREST GRID */
      .grid {
        column-count: 2;
        column-gap: 12px;
      }

      @media(min-width:768px){
        .grid { column-count: 3; }
      }

      @media(min-width:1200px){
        .grid { column-count: 4; }
      }

      .item {
        width: 100%;
        margin-bottom: 12px;
        border-radius: 16px;
        display: block;
        break-inside: avoid;
        cursor: pointer;
        transition: 0.3s;
      }

      .item:hover {
        transform: scale(1.03);
      }

      /* BLUR LOAD */
      .lazy {
        filter: blur(12px);
        transform: scale(1.05);
        transition: 0.5s;
      }

      .lazy.loaded {
        filter: blur(0);
        transform: scale(1);
      }

      /* CTA */
      .cta {
        text-align: center;
        margin-top: 80px;
      }

      .cta-btns {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 20px;
        flex-wrap: wrap;
      }

      .cta a {
        padding: 12px 20px;
        border-radius: 999px;
        background: black;
        color: white;
        text-decoration: none;
      }

      /* LIGHTBOX */
      .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .lightbox img {
        max-width: 90%;
      }

      .hidden { display:none; }

      /* BEFORE AFTER */
      .ba {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
        border-radius: 12px;
        margin-top: 20px;
      }

      .ba-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .ba-after {
        position: absolute;
        inset: 0;
        width: 50%;
        overflow: hidden;
      }

      .ba-divider {
        position: absolute;
        left: 50%;
        width: 2px;
        height: 100%;
        background: white;
      }

      /* MOBILE */
      @media(max-width:600px){
        .metrics,
        .value {
          grid-template-columns: 1fr;
          gap: 20px;
        }
      }

      /* FADE */
      .fade {
        opacity: 0;
        transform: translateY(20px);
        transition: 0.6s;
      }

      .fade.show {
        opacity: 1;
        transform: none;
      }

    </style>

  </body>
</html>
