---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Coming Soon</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>

    <div class="wrapper">

      <!-- Glow -->
      <div class="bg-glow"></div>

      <!-- Content -->
      <div class="content">

        <h1 class="title-main">Coming Soon</h1>

        <p class="subtitle">
          I’m working on something new — crafted with detail, clarity, and purpose.
        </p>

        <div class="actions">
          <a href="/" class="btn-primary">Go Home</a>
          <a href={`mailto:${siteConfig.social.email}`} class="btn-secondary">
            Contact Me
          </a>
        </div>

      </div>

    </div>

  </body>
</html>

<style>

/* GLOBAL */
body {
  margin: 0;
  font-family: 'Josefin Sans', sans-serif;
  background: #f9fafb;
  overflow-x: hidden;
}

/* WRAPPER (same as 404) */
.wrapper {
  position: relative;
  min-height: 100vh;
  padding: 20px;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* GLOW */
.bg-glow {
  position: absolute;
  width: 700px;
  height: 700px;
  background: radial-gradient(circle, rgba(29,78,216,0.12), transparent 70%);
  filter: blur(90px);
  animation: floatGlow 10s ease-in-out infinite;
}

/* CONTENT */
.content {
  position: relative;
  text-align: center;
  width: 100%;
  max-width: 420px;
  padding: 10px;
  animation: fadeUp 0.5s ease;
}

/* TITLE (same scaling system) */
.title-main {
  font-size: clamp(42px, 8vw, 64px);
  font-weight: 600;
  color: #111827;
  letter-spacing: -1px;
  margin: 0;
}

/* SUBTITLE */
.subtitle {
  margin-top: 12px;
  color: #6b7280;
  font-size: 15px;
  line-height: 1.6;
}

/* BUTTONS */
.actions {
  margin-top: 24px;
  display: flex;
  justify-content: center;
  gap: 12px;
}

.btn-primary {
  background: #101828;
  color: white;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background: var(--accent, #1d4ed8);
}

.btn-secondary {
  border: 1px solid #e5e7eb;
  color: #374151;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-secondary:hover {
  background: #f3f4f6;
}

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes floatGlow {
  0% { transform: translate(0,0); }
  50% { transform: translate(40px,-20px); }
  100% { transform: translate(0,0); }
}

/* MOBILE */
@media (max-width: 640px) {

  .wrapper {
    padding: 16px;
  }

  .bg-glow {
    width: 450px;
    height: 450px;
    filter: blur(70px);
  }

  .content {
    max-width: 100%;
    padding: 0 10px;
  }

  .title-main {
    font-size: 42px;
  }

  .subtitle {
    font-size: 16px;
    line-height: 1.6;
  }

  .actions {
    flex-direction: column;
    gap: 14px;
    margin-top: 28px;
  }

  .btn-primary,
  .btn-secondary {
    width: 100%;
    padding: 16px;
    font-size: 16px;
    border-radius: 10px;
  }
}

</style>
