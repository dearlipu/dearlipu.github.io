---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Coming Soon</title>

    <!-- Same font as your site -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  </head>

  <body>

    <div class="wrapper">

      <!-- Glow background -->
      <div class="bg-glow"></div>

      <!-- Content -->
      <div class="content">

        <h1 class="title">Coming Soon</h1>

        <p class="subtitle">
          I’m working on something new — crafted with detail, clarity, and purpose.
        </p>

        <div class="actions">
          <a href="/" class="btn-primary">Go Home</a>

          <a href={`mailto:${siteConfig.social.email}`} class="btn-secondary">
            Contact Me
          </a>
        </div>

      </div>

    </div>

  </body>
</html>

<style>

/* GLOBAL */
body {
  margin: 0;
  font-family: 'Josefin Sans', sans-serif;
  background: #f9fafb;
  overflow: hidden;
}

/* WRAPPER */
.wrapper {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* SOFT GLOW BACKGROUND */
.bg-glow {
  position: absolute;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(29,78,216,0.15), transparent 70%);
  filter: blur(80px);
  animation: floatGlow 8s ease-in-out infinite;
}

/* CONTENT */
.content {
  position: relative;
  text-align: center;
  max-width: 500px;
  padding: 20px;
  animation: fadeUp 0.6s ease;
}

/* TITLE */
.title {
  font-size: 48px;
  font-weight: 600;
  color: #111827;
  letter-spacing: -0.02em;
}

/* SUBTITLE */
.subtitle {
  margin-top: 12px;
  color: #6b7280;
  font-size: 15px;
  line-height: 1.6;
}

/* BUTTONS */
.actions {
  margin-top: 24px;
  display: flex;
  justify-content: center;
  gap: 12px;
}

.btn-primary {
  background: #101828;
  color: white;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background: var(--accent, #1d4ed8);
}

.btn-secondary {
  border: 1px solid #e5e7eb;
  color: #374151;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-secondary:hover {
  background: #f3f4f6;
}

/* ANIMATIONS */

/* fade + slight move */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* floating glow */
@keyframes floatGlow {
  0% { transform: translate(0, 0); }
  50% { transform: translate(30px, -20px); }
  100% { transform: translate(0, 0); }
}

/* RESPONSIVE */
@media (max-width: 640px) {
  .title {
    font-size: 36px;
  }
}

</style>
