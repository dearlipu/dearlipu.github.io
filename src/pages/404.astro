---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Page Not Found</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>

    <div class="wrapper">

      <div class="bg-glow"></div>

      <div class="content">

        <h1 class="code">404</h1>

        <h2 class="title">Page not found</h2>

        <p class="subtitle">
          The page you’re looking for doesn’t exist or has been moved.
        </p>

        <div class="actions">
          <a href="/" class="btn-primary">Go Home</a>
          <a href="/#contact" class="btn-secondary">Start a Project</a>
        </div>

      </div>

    </div>

  </body>
</html>

<style>

/* GLOBAL */
body {
  margin: 0;
  font-family: 'Josefin Sans', sans-serif;
  background: #f9fafb;
  overflow-x: hidden;
}

/* WRAPPER */
.wrapper {
  position: relative;
  min-height: 100vh;
  padding: 20px;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* GLOW */
.bg-glow {
  position: absolute;
  width: 700px;
  height: 700px;
  background: radial-gradient(circle, rgba(29,78,216,0.12), transparent 70%);
  filter: blur(90px);
  animation: floatGlow 10s ease-in-out infinite;
}

/* CONTENT */
.content {
  position: relative;
  text-align: center;
  width: 100%;
  max-width: 420px;
  padding: 10px;
}

/* TEXT */
.code {
  font-size: clamp(90px, 12vw, 140px);
  font-weight: 700;
  color: #111827;
  letter-spacing: -4px;
}

.title {
  font-size: 28px;
  font-weight: 600;
  margin-top: 10px;
  color: #111827;
}

.subtitle {
  margin-top: 8px;
  color: #6b7280;
  font-size: 15px;
}

/* BUTTONS */
.actions {
  margin-top: 24px;
  display: flex;
  justify-content: center;
  gap: 12px;
}

.btn-primary {
  background: #101828;
  color: white;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
}

.btn-secondary {
  border: 1px solid #e5e7eb;
  color: #374151;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
}

/* ANIMATION */
@keyframes floatGlow {
  0% { transform: translate(0,0); }
  50% { transform: translate(40px,-20px); }
  100% { transform: translate(0,0); }
}

/* ================= MOBILE ================= */
@media (max-width: 640px) {

  .wrapper {
    padding: 16px;
  }

  .content {
    max-width: 100%;
    padding: 0 10px;
  }

  .code {
    font-size: 120px;
  }

  .title {
    font-size: 26px;
  }

  .subtitle {
    font-size: 16px;
    line-height: 1.6;
  }

  .actions {
    flex-direction: column;
    gap: 14px;
    margin-top: 28px;
  }

  .btn-primary,
  .btn-secondary {
    width: 100%;
    padding: 16px;
    font-size: 16px;
    border-radius: 10px;
  }

  .bg-glow {
    width: 500px;
    height: 500px;
    filter: blur(70px);
  }
}
</style>
