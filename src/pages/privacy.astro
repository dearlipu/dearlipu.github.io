---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="p-8 sm:p-10 md:px-16 lg:px-24">
      <button 
        onclick="history.back()" 
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-black group"
      >
        <span class="group-hover:-translate-x-1 transition">←</span>
        Back
      </button>
    </div>

    <!-- MAIN -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h1>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website.
          </p>
        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 space-y-6">

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              1. Information We Collect
            </h2>
            <p class="text-sm text-gray-600">
              We may collect personal details such as your name, email address, and contact information when you reach out or use our services.
            </p>
          </div>

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              2. How We Use Information
            </h2>
            <p class="text-sm text-gray-600">
              Your information is used to communicate, deliver services, improve workflows, and provide a better experience. We do not sell your data.
            </p>
          </div>

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              3. Cookies
            </h2>
            <p class="text-sm text-gray-600">
              We may use cookies or analytics tools to improve performance.
            </p>
          </div>

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              4. Third-Party Services
            </h2>
            <p class="text-sm text-gray-600">
              External platforms may collect data under their own policies.
            </p>
          </div>

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              5. Data Protection
            </h2>
            <p class="text-sm text-gray-600">
              We apply reasonable security measures, though absolute protection cannot be guaranteed.
            </p>
          </div>

          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              6. Contact
            </h2>
            <p class="text-sm text-gray-600">
              {siteConfig.social.email}
            </p>
          </div>

        </div>

      </div>

    </section>

  </body>
</html>
