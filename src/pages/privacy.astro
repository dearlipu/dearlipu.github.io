---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Privacy Policy</title>
  </head>

  <body class="bg-white text-gray-800 font-[Josefin_Sans]">

    <!-- MAIN -->
    <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website and services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300">

            <p class="text-xs text-gray-400 mb-6">
              Last updated: April 2026
            </p>

            <div class="space-y-8 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">
            
              <p>
                Saurav Panda ("I," "we," "our," or "us") respects your privacy and is committed to protecting your personal information. This policy outlines what we collect, how we use it, and your rights when you use this website or interact with our services.
              </p>
            
              <p>
                When you visit this website or contact us, we may collect personal information you provide, such as your name, email address, project details, and any other information shared through forms, messages, or direct communication.
              </p>
            
              <p>
                We may also collect basic usage data such as your IP address, browser type, pages visited, and time spent on the site. Cookies and similar technologies may be used to improve your experience and understand how the site is used.
              </p>
            
              <p>
                This information is used to respond to inquiries, deliver services, improve the website, communicate updates when relevant, and ensure smooth operation of the platform.
              </p>
            
              <p>
                We do not sell or rent your personal information. Your data may be shared with trusted third-party providers (such as hosting or communication services) only when necessary to operate this website and deliver services.
              </p>
            
              <p>
                We may also disclose information if required by law or to protect our rights, users, or services.
              </p>
            
              <p>
                You have the right to access, update, or request deletion of your personal data where applicable. You may also opt out of any communication at any time.
              </p>
            
              <p>
                While reasonable steps are taken to protect your data, no method of transmission over the internet is completely secure. By using this website, you acknowledge these inherent risks.
              </p>
            
              <p>
                This website may contain links to external sites. We are not responsible for the content or privacy practices of those websites.
              </p>
            
              <p>
                This policy may be updated from time to time. Continued use of the website indicates acceptance of any updates.
              </p>
            
              <!-- CONTACT -->
              <div class="pt-6">
                <p class="text-gray-500 text-base sm:text-lg">
                  For any privacy-related questions:
                </p>
            
                <p class="text-gray-900 font-medium mt-1">
                  {siteConfig.social.email}
                </p>
              </div>
            
            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
