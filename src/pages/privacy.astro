---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT (your site font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Privacy Policy</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- MAIN -->
    <section id="privacy" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website and services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300
                      w-full max-w-full">

            <!-- META -->
            <p class="text-xs text-gray-400 mb-6">
              Last updated: April 2026
            </p>

            <!-- CONTENT -->
            <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">
            
              <p class="whitespace-pre-line text-gray-700">
                Welcome to my website. Your privacy is important, and this Privacy Policy explains how I collect, use, and protect your information when you visit or interact with this site.
              </p>
            
              <!-- 1 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  1. Information I Collect
                </h2>
            
                <p class="mb-4">
                  I may collect the following types of information:
                </p>
            
                <p class="font-medium text-gray-900">a. Personal Information</p>
                <ul class="list-disc ml-6 mt-2 space-y-1">
                  <li>Your name</li>
                  <li>Email address</li>
                  <li>Any message or project details you provide</li>
                </ul>
            
                <p class="font-medium text-gray-900 mt-4">b. Non-Personal Information</p>
                <ul class="list-disc ml-6 mt-2 space-y-1">
                  <li>Browser type</li>
                  <li>Device information</li>
                  <li>Pages visited</li>
                  <li>General location (non-precise)</li>
                </ul>
              </div>
            
              <!-- 2 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  2. How Your Information Is Used
                </h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Responding to inquiries or project requests</li>
                  <li>Communicating about services</li>
                  <li>Improving website performance and user experience</li>
                </ul>
            
                <p class="mt-4 font-medium text-gray-900">
                  I do not sell, rent, or trade your personal information.
                </p>
              </div>
            
              <!-- 3 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  3. Third-Party Services
                </h2>
                <p class="mb-3">
                  This website may use third-party services such as:
                </p>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Website hosting providers</li>
                  <li>Email services</li>
                  <li>Analytics tools</li>
                </ul>
              </div>
            
              <!-- 4 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  4. Data Protection
                </h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Protection from unauthorized access</li>
                  <li>Prevention of misuse</li>
                  <li>Limiting unauthorized disclosure</li>
                </ul>
            
                <p class="mt-3">
                  However, no method of transmission over the internet is 100% secure.
                </p>
              </div>
            
              <!-- 5 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  5. Your Rights
                </h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Request access to your personal data</li>
                  <li>Request correction or deletion</li>
                  <li>Withdraw communication at any time</li>
                </ul>
              </div>
            
              <!-- 6 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  6. Cookies
                </h2>
                <p>
                  This website may use basic cookies to improve performance and user experience. You can disable cookies through your browser settings.
                </p>
              </div>
            
              <!-- 7 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  7. External Links
                </h2>
                <p>
                  This website may contain links to external sites. I am not responsible for their privacy practices.
                </p>
              </div>
            
              <!-- 8 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  8. Changes to This Policy
                </h2>
                <p>
                  This policy may be updated from time to time. Updates will be posted on this page.
                </p>
              </div>
            
              <!-- 9 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  9. Contact
                </h2>
                <p>
                  Email: <span class="text-gray-900 font-medium">{siteConfig.social.email}</span>
                </p>
              </div>
            
              <!-- 10 -->
              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  10. Consent
                </h2>
                <p>
                  By using this website, you agree to this Privacy Policy.
                </p>
              </div>
            
            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
