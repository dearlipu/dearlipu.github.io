---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT (your site font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Privacy Policy</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- MAIN -->
    <section id="privacy" class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website and services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300
                      w-full max-w-full">

            <!-- META -->
            <p class="text-xs text-gray-400 mb-6">
              Last updated: April 2026
            </p>

            <!-- CONTENT -->
            <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

              <p class="whitespace-pre-line text-gray-700">
                This Privacy Policy outlines how we collect, use, and protect your information when you interact with our website and services. By using this website, you agree to the practices described below.
              </p>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  1. Information We Collect
                </h2>
                <p>
                  We may collect personal information such as your name, email address, and contact details when you contact us, request services, or interact with our content.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  2. How We Use Your Information
                </h2>
                <p>
                  Your information is used to communicate, deliver services, and manage projects efficiently.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  3. Use of Client Materials
                </h2>
                <p>
                  Any files or references provided are used only for project execution and are not reused without permission.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  4. Cookies & Analytics
                </h2>
                <p>
                  We may use cookies or analytics tools to improve performance and user experience.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  5. Third-Party Services
                </h2>
                <p>
                  Third-party platforms may operate under their own policies.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  6. Data Protection
                </h2>
                <p>
                  We apply reasonable safeguards, but complete protection cannot be guaranteed.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  7. Your Rights
                </h2>
                <p>
                  You may request access or deletion of your data anytime.
                </p>
              </div>

              <div class="border-t border-gray-200 pt-6">
                <h2 class="text-base sm:text-lg md:text-xl font-semibold text-gray-900 mb-2">
                  8. Contact
                </h2>
                <p>
                  {siteConfig.social.email}
                </p>
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
