---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Privacy Policy</title>
  </head>

  <body class="bg-white text-gray-800 font-[Josefin_Sans]">

    <!-- BACK BUTTON -->
    <div class="fixed top-6 right-6 z-50">
      <button 
        onclick="history.length > 1 ? history.back() : window.location.href='/'"
        class="group flex items-center gap-2 px-4 py-2 rounded-full
               bg-white/70 backdrop-blur-md border border-gray-200
               shadow-md hover:shadow-lg
               text-sm text-gray-700 hover:text-black
               transition-all duration-300"
      >
        <span class="transition group-hover:-translate-x-1">←</span>
        Back
      </button>
    </div>

    <!-- MAIN -->
    <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website and services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300">

            <p class="text-xs text-gray-400 mb-6">
              Last updated: April 2026
            </p>

            <div class="space-y-12 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

              <!-- INTRO -->
              <p class="text-gray-700">
                Your privacy matters. This page explains how your information is collected, used, and protected when you interact with this website.
              </p>

              <!-- 1 -->
              <div class="space-y-4">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  1. Information I Collect
                </h2>

                <div>
                  <p class="font-medium text-gray-900">Personal Information</p>
                  <ul class="mt-2 space-y-2">
                    <li>• Name</li>
                    <li>• Email address</li>
                    <li>• Project details you provide</li>
                  </ul>
                </div>

                <div>
                  <p class="font-medium text-gray-900">Non-Personal Information</p>
                  <ul class="mt-2 space-y-2">
                    <li>• Browser and device data</li>
                    <li>• Pages visited</li>
                    <li>• General location</li>
                  </ul>
                </div>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 2 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  2. How Information Is Used
                </h2>

                <ul class="space-y-2">
                  <li>• Respond to inquiries</li>
                  <li>• Deliver services</li>
                  <li>• Improve user experience</li>
                </ul>

                <p class="text-gray-500">
                  Your data is never sold or shared for marketing.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 3 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  3. Third-Party Services
                </h2>

                <p>External tools may be used for:</p>

                <ul class="space-y-2">
                  <li>• Hosting</li>
                  <li>• Email communication</li>
                  <li>• Analytics</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 4 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  4. Data Protection
                </h2>

                <ul class="space-y-2">
                  <li>• Protection from unauthorized access</li>
                  <li>• Prevention of misuse</li>
                  <li>• Limited data exposure</li>
                </ul>

                <p class="text-gray-500">
                  Absolute security cannot be guaranteed online.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 5 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  5. Your Rights
                </h2>

                <ul class="space-y-2">
                  <li>• Access your data</li>
                  <li>• Request corrections</li>
                  <li>• Request deletion</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 6 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  6. Cookies
                </h2>

                <p>
                  Cookies may be used to improve performance and usability. You can disable them in browser settings.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 7 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  7. External Links
                </h2>

                <p>
                  I am not responsible for privacy practices of external websites.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 8 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  8. Updates
                </h2>

                <p>
                  This policy may be updated periodically. Changes will be reflected here.
                </p>
              </div>

              <!-- CONTACT -->
              <div class="pt-8">
                <p class="text-gray-500 text-base sm:text-lg">
                  Questions?
                </p>
                <p class="text-gray-900 font-medium mt-1">
                  {siteConfig.social.email}
                </p>
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
