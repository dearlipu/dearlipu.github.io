---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- HERO / TOP -->
    <section class="relative overflow-hidden px-6 sm:px-10 md:px-16 lg:px-24 pt-10 pb-16">

      <!-- BACK BUTTON -->
      <div class="mb-10">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-black group">
          <span class="group-hover:-translate-x-1 transition">←</span>
          Back
        </a>
      </div>

      <!-- TITLE -->
      <div class="max-w-4xl">

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 leading-tight">
          Privacy Policy
        </h1>

        <div
          class="w-[90px] h-[5px] mt-4 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        />

        <p class="mt-6 text-lg text-gray-600 max-w-2xl leading-relaxed">
          We respect your privacy. This page explains how your information is collected, used, and protected when you interact with our website and services.
        </p>

      </div>

      <!-- subtle background -->
      <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full opacity-10 blur-3xl"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

    </section>


    <!-- CONTENT -->
    <section class="px-6 sm:px-10 md:px-16 lg:px-24 pb-24">

      <div class="max-w-4xl mx-auto space-y-6">

        <!-- CARD -->
        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">01</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                Information We Collect
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                We may collect basic personal information such as your name, email address, and contact details when you reach out or request services. This helps us communicate effectively and deliver work accurately.
              </p>
            </div>
          </div>

        </div>

        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">02</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                How We Use Your Information
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                Your information is used to respond to inquiries, deliver services, improve workflows, and maintain communication. We do not sell, rent, or misuse your data.
              </p>
            </div>
          </div>

        </div>

        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">03</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                Cookies & Tracking
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                We may use cookies or analytics tools to understand usage patterns and improve performance. These tools help us make better design and experience decisions.
              </p>
            </div>
          </div>

        </div>

        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">04</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                Third-Party Services
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                We may use external tools such as social media platforms or analytics services. These platforms operate under their own policies, and we recommend reviewing them separately.
              </p>
            </div>
          </div>

        </div>

        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">05</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                Data Protection
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                We implement reasonable safeguards to protect your information. However, no digital system is completely secure, and absolute protection cannot be guaranteed.
              </p>
            </div>
          </div>

        </div>

        <div class="group bg-white border border-gray-200 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-lg transition-all duration-300">

          <div class="flex items-start gap-4">
            <span class="text-sm font-semibold text-gray-400">06</span>

            <div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2">
                Contact
              </h2>
              <p class="text-gray-600 leading-relaxed text-sm">
                For any privacy-related queries, you can contact us at:
                <span class="text-gray-900 font-medium"> {siteConfig.social.email}</span>
              </p>
            </div>
          </div>

        </div>

      </div>

    </section>

  </body>
</html>
