---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="p-6 md:p-8">
      <a href="/" class="flex items-center gap-2 text-sm text-gray-600 hover:text-black group">
        <span class="group-hover:-translate-x-1 transition">←</span>
        Back
      </a>
    </div>

    <!-- MAIN SECTION (same as your site layout) -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

        <!-- LEFT TITLE (same style as About / Projects) -->
        <div class="lg:col-span-4">

          <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h1>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
            How your data is handled, stored, and protected when using this website and services.
          </p>

        </div>


        <!-- RIGHT CONTENT -->
        <div class="lg:col-span-8 space-y-6">

          <!-- CARD -->
          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              1. Information We Collect
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              We may collect personal information such as your name, email address, and contact details when you reach out, request services, or interact with this website.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              2. How We Use Your Information
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              Your information is used to communicate, deliver services, improve workflows, and provide a better overall experience. We do not sell or misuse your data.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              3. Cookies & Tracking
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              This website may use cookies or basic analytics tools to understand usage patterns and improve performance.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              4. Third-Party Tools
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              We may use third-party platforms such as social media or analytics tools. These services operate under their own privacy policies.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              5. Data Protection
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              We implement reasonable security measures to protect your information, though no system can guarantee absolute security.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h2 class="text-lg font-semibold text-gray-900 mb-2">
              6. Contact
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed">
              For any privacy-related questions, contact:  
              <span class="text-gray-900 font-medium">
                {siteConfig.social.email}
              </span>
            </p>
          </div>

        </div>

      </div>

    </section>

  </body>
</html>
