---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK BUTTON -->
    <div class="p-6">
      <a href="/" class="flex items-center gap-2 text-sm text-gray-600 hover:text-black">
        ← Back
      </a>
    </div>

    <!-- CONTENT -->
    <section class="max-w-4xl mx-auto px-6 pb-16">

      <h1 class="text-3xl md:text-5xl font-bold text-gray-900">
        Privacy Policy
      </h1>

      <div class="w-[75px] h-[5px] mt-3 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <p class="mt-6 text-gray-600">
        This Privacy Policy explains how we collect, use, and protect your information when you use this website.
      </p>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-gray-600">

        <div>
          <h2 class="text-lg font-semibold text-gray-900">1. Information We Collect</h2>
          <p>
            We may collect basic information such as your name, email address, or contact details when you contact us or use our services.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">2. How We Use Information</h2>
          <p>
            Your information is used to respond to inquiries, provide services, improve user experience, and communicate updates.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">3. Cookies</h2>
          <p>
            This website may use cookies to improve performance and user experience.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">4. Third-Party Services</h2>
          <p>
            We may use third-party tools (like analytics or social media platforms) that may collect data according to their policies.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">5. Data Protection</h2>
          <p>
            We take reasonable steps to protect your information but cannot guarantee absolute security.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">6. Contact</h2>
          <p>
            If you have any questions, contact us at {siteConfig.social.email}.
          </p>
        </div>

      </div>

    </section>

  </body>
</html>
