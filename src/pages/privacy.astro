---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Privacy Policy - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK -->
    <div class="p-8 sm:p-10 md:px-16 lg:px-24">
      <button 
        onclick="history.back()" 
        class="flex items-center gap-2 text-sm text-gray-600 hover:text-black group"
      >
        <span class="group-hover:-translate-x-1 transition">←</span>
        Back
      </button>
    </div>

    <!-- MAIN -->
    <section class="p-8 sm:p-12 md:p-16 lg:p-24 pt-0">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">
          <h1 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Privacy Policy.
          </h1>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />

          <p class="text-gray-500 mt-5 text-sm max-w-sm leading-relaxed">
            How your data is collected, used, and protected when you use this website.
          </p>
        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8">
        
          <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 md:p-10 
                      shadow-sm hover:shadow-md transition">
        
            <div class="space-y-6 text-sm md:text-base leading-relaxed text-gray-600">
        
              <p>
                This Privacy Policy explains how your information is collected, used, and protected when you use this website and related services.
              </p>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  1. Information We Collect
                </h2>
                <p>
                  We may collect personal information such as your name, email address, and contact details when you reach out or use our services. This helps us communicate effectively and deliver work accurately.
                </p>
              </div>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  2. How We Use Information
                </h2>
                <p>
                  Your information is used to communicate, deliver services, improve workflows, and provide a better experience. We do not sell, rent, or misuse your data.
                </p>
              </div>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  3. Cookies
                </h2>
                <p>
                  We may use cookies or basic analytics tools to understand usage patterns and improve performance. These tools help enhance usability and design decisions.
                </p>
              </div>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  4. Third-Party Services
                </h2>
                <p>
                  We may use external platforms such as social media or analytics services. These platforms operate under their own privacy policies, which we encourage you to review.
                </p>
              </div>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  5. Data Protection
                </h2>
                <p>
                  We implement reasonable safeguards to protect your information. However, no digital system can guarantee complete security, and absolute protection cannot be ensured.
                </p>
              </div>
        
              <div>
                <h2 class="text-base md:text-lg font-semibold text-gray-900 mb-2">
                  6. Contact
                </h2>
                <p>
                  If you have any questions regarding this policy, you can contact us at:
                  <span class="text-gray-900 font-medium">
                    {siteConfig.social.email}
                  </span>
                </p>
              </div>
        
            </div>
        
          </div>
        
        </div>


      </div>

    </section>

  </body>
</html>
