---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Terms & Conditions</title>
  </head>

  <body class="bg-white text-gray-800">

    <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20 overflow-x-hidden">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Terms & Conditions
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            Terms for using this website and working with services.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300
                      w-full max-w-full">

            <p class="text-xs text-gray-400 mb-6">
              Effective Date: April 2026
            </p>

            <div class="space-y-10 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

              <p class="text-gray-700">
                By accessing this website or working with me, you agree to the following terms.
              </p>

              <!-- 1 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">1. Services</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Graphic design</li>
                  <li>Photo editing and retouching</li>
                  <li>Video editing and motion graphics</li>
                  <li>Social media and digital content design</li>
                </ul>
                <p class="mt-3">All services are customized based on client requirements.</p>
              </div>

              <!-- 2 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">2. Project Agreement</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Scope, pricing, and timeline will be agreed before starting</li>
                  <li>Work begins only after confirmation</li>
                </ul>
              </div>

              <!-- 3 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">3. Payments</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Advance payment may be required</li>
                  <li>Final payment before delivery</li>
                  <li>Payments are non-refundable unless agreed</li>
                </ul>
              </div>

              <!-- 4 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">4. Revisions</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Limited revisions included</li>
                  <li>Extra revisions may be charged</li>
                  <li>Major changes = new project</li>
                </ul>
              </div>

              <!-- 5 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">5. Delivery</h2>
                <p>
                  Timelines are estimates. Delays due to client response are not my responsibility.
                </p>
              </div>

              <!-- 6 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">6. Client Responsibilities</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>Provide clear instructions</li>
                  <li>Respond on time</li>
                  <li>Ensure rights to provided content</li>
                </ul>
              </div>

              <!-- 7 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">7. Intellectual Property</h2>
                <p>
                  Rights transfer after full payment. I may showcase work unless agreed otherwise.
                </p>
              </div>

              <!-- 8 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">8. Prohibited Use</h2>
                <ul class="list-disc ml-6 space-y-1">
                  <li>No illegal use</li>
                  <li>No claiming work before rights transfer</li>
                </ul>
              </div>

              <!-- 9 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">9. Limitation of Liability</h2>
                <p>
                  I am not responsible for indirect or business losses.
                </p>
              </div>

              <!-- 10 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">10. Termination</h2>
                <p>
                  Projects may be canceled if terms are violated or payments are not met.
                </p>
              </div>

              <!-- 11 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">11. Changes to Terms</h2>
                <p>
                  Terms may be updated anytime. Continued use means acceptance.
                </p>
              </div>

              <!-- 12 -->
              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">12. Contact</h2>
                <p>{siteConfig.social.email}</p>
              </div>

              <!-- DISCLAIMER SECTION -->
              <div class="border-t pt-10">
                <h2 class="text-xl font-bold text-gray-900 mb-4">
                  Disclaimer
                </h2>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">1. General Information</h2>
                <p>Content is for informational and portfolio purposes only.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">2. No Guarantees</h2>
                <p>Results may vary. No guarantees on performance or outcomes.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">3. Third-Party Content</h2>
                <p>Some work may include client or third-party materials.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">4. External Links</h2>
                <p>I am not responsible for external websites.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">5. Professional Relationship</h2>
                <p>No client relationship exists without agreement.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">6. Errors and Updates</h2>
                <p>Content may change without notice.</p>
              </div>

              <div class="border-t pt-6">
                <h2 class="font-semibold text-gray-900 mb-2">7. Contact</h2>
                <p>{siteConfig.social.email}</p>
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
