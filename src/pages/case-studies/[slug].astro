---
import Header from "../../components/Header.astro";import Footer from "../../components/Footer.astro";import { projects } from "../../config";import "../../styles/global.css";
export function getStaticPaths(){return projects.map((project)=>({params:{slug:project.slug},props:{project}}));}
const { project } = Astro.props;
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><meta name="description" content={project.description}/><title>{project.name} Case Study — DearLipu Studio</title></head><body><Header/><main><section class="hero"><div class="container"><p class="eyebrow">Case Study • {project.industry}</p><h1>{project.name}</h1><p class="lead">{project.description}</p><div class="hero-visual"><img src={project.image} alt={`${project.name} hero banner`}/></div></div></section><section class="section-pad alt"><div class="container process">{["Problem","Goal","Research","Sketches","Wireframes","Design Process","Before / After","Results","Technologies","Lessons Learned"].map((s,i)=><div><span>{i+1}</span><h3>{s}</h3><p>{i===7?project.result:"A focused phase designed to improve clarity, trust, and conversion."}</p></div>)}</div></section><section class="final-cta"><div class="container"><h2>Want results like {project.result}?</h2><p>Let’s shape your next launch into a premium digital experience.</p><a class="btn light" href="/contact">Start Your Project</a></div></section></main><Footer/></body></html>
