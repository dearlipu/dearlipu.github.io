---
import { siteConfig } from "../config";
import "../styles/global.css";

const termsSections = [
  {
    title: "Acceptance of Terms",
    body: "By using this website or purchasing services, you agree to these terms. If you do not agree, please do not use the website or services.",
  },
  {
    title: "Scope of Work",
    body: "Each project is delivered based on mutually agreed scope, timeline, and pricing. New requests outside scope may require additional fees or timeline updates.",
  },
  {
    title: "Payments",
    body: "A deposit may be required to reserve your project slot. Final files are delivered after full payment unless otherwise agreed in writing.",
  },
  {
    title: "Revisions",
    body: "Minor revisions are included based on the selected service. Major direction changes or additional tasks may be billed separately.",
  },
  {
    title: "Client Responsibilities",
    body: "You are responsible for providing clear brief details, timely feedback, and legally owned/licensed assets required for your project.",
  },
  {
    title: "Intellectual Property",
    body: "Website content remains my intellectual property. Project usage rights transfer according to the agreed terms once payment is complete.",
  },
  {
    title: "Liability",
    body: "Services are provided in good faith and to professional standards, but no guaranteed business outcome is implied. Liability is limited to the value of services paid.",
  },
  {
    title: "Updates",
    body: "These terms may be updated periodically. Continued use of the website or services indicates acceptance of any revised terms.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Terms of Service | {siteConfig.name}</title>
    <meta name="description" content="Terms and conditions for using this website and creative services." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="text-gray-800">
    <section class="px-6 py-12 sm:px-10 md:px-16 md:py-16 lg:px-20 lg:py-20 overflow-x-hidden">
      <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-4">
          <p class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Legal</p>

          <h1 class="mt-4 text-3xl font-bold leading-tight text-gray-900 sm:text-4xl md:text-5xl">Terms of Service</h1>

          <div class="mt-3 h-1.5 w-20 rounded-full" style={`background-color: ${siteConfig.accentColor}`}></div>

          <p class="mt-5 max-w-sm text-sm leading-relaxed text-gray-600 sm:text-base">
            Key terms that define project expectations, payment, revisions, and responsibilities.
          </p>

          <p class="mt-6 text-xs uppercase tracking-[0.14em] text-gray-500">Last updated: April 2026</p>
        </div>

        <div class="lg:col-span-8">
          <div class="legal-card">
            <div class="space-y-3">
              {
                termsSections.map((item) => (
                  <article class="legal-block">
                    <h2>{item.title}</h2>
                    <p>{item.body}</p>
                  </article>
                ))
              }
            </div>

            <div class="mt-8 rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-600">
              Questions about these terms?
              <a href={`mailto:${siteConfig.social.email}`} class="font-semibold text-gray-900 underline-offset-2 hover:underline"> {siteConfig.social.email}</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </body>
</html>

<style>
  .legal-card {
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.93), rgba(248, 250, 252, 0.92));
    padding: 1rem;
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(8px);
  }

  .legal-block {
    border-radius: 0.9rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 0.9rem;
  }

  .legal-block h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
  }

  .legal-block p {
    margin: 0.45rem 0 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #4b5563;
  }
</style>
