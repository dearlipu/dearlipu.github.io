---
import { siteConfig } from "../config";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Terms of Service - {siteConfig.name}</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- BACK BUTTON -->
    <div class="p-6">
      <a href="/" class="flex items-center gap-2 text-sm text-gray-600 hover:text-black">
        ← Back
      </a>
    </div>

    <section class="max-w-4xl mx-auto px-6 pb-16">

      <h1 class="text-3xl md:text-5xl font-bold text-gray-900">
        Terms of Service
      </h1>

      <div class="w-[75px] h-[5px] mt-3 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>

      <div class="mt-10 space-y-8 text-sm leading-relaxed text-gray-600">

        <div>
          <h2 class="text-lg font-semibold text-gray-900">1. Services</h2>
          <p>
            We provide design, video, and digital services. Scope and pricing may vary depending on the project.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">2. Payments</h2>
          <p>
            All payments must be completed before final delivery unless agreed otherwise.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">3. Revisions</h2>
          <p>
            Revision limits depend on the selected plan or agreement.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">4. Ownership</h2>
          <p>
            Final designs are transferred after full payment. We may showcase work in our portfolio.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">5. Liability</h2>
          <p>
            We are not responsible for any losses resulting from the use of our services.
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-gray-900">6. Changes</h2>
          <p>
            These terms may be updated at any time.
          </p>
        </div>

      </div>

    </section>

  </body>
</html>
