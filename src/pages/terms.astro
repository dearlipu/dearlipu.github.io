---
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- FONT -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>Terms & Conditions</title>
  </head>

  <body class="bg-white text-gray-800">

    <!-- MAIN -->
    <section class="px-6 sm:px-10 md:px-16 lg:px-24 py-12 md:py-16 lg:py-20">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-20 items-start">

        <!-- LEFT -->
        <div class="lg:col-span-4">

          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
            Terms of Service.
          </h2>

          <div
            class="w-[75px] h-[5px] mt-2 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>

          <p class="text-gray-500 mt-5 text-sm sm:text-base max-w-sm leading-relaxed">
            Rules, agreements, and responsibilities when using services or working together.
          </p>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-8 w-full min-w-0">

          <div class="bg-gray-50 border border-gray-200 rounded-2xl 
                      p-6 sm:p-8 md:p-10 lg:p-12
                      shadow-sm hover:shadow-lg transition duration-300">

            <div class="space-y-12 text-lg sm:text-xl md:text-xl leading-relaxed text-gray-600">

              <!-- INTRO -->
              <p class="text-gray-700">
                By accessing this website or working with me, you agree to the following terms and conditions.
              </p>

              <!-- 1 -->
              <div class="space-y-4">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  1. Services
                </h2>
                <ul class="space-y-2">
                  <li>• Graphic design</li>
                  <li>• Photo editing and retouching</li>
                  <li>• Video editing and motion graphics</li>
                  <li>• Social media and digital content</li>
                </ul>
                <p class="text-gray-500 text-base sm:text-lg">
                  All services are customized based on client requirements.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 2 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  2. Project Agreement
                </h2>
                <ul class="space-y-2">
                  <li>• Scope, pricing, and timeline are discussed before starting</li>
                  <li>• Work begins only after mutual confirmation</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 3 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  3. Payments
                </h2>
                <ul class="space-y-2">
                  <li>• Advance payment may be required</li>
                  <li>• Final payment before delivery</li>
                  <li>• Payments are non-refundable unless agreed</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 4 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  4. Revisions
                </h2>
                <ul class="space-y-2">
                  <li>• Limited revisions included</li>
                  <li>• Extra revisions may be charged</li>
                  <li>• Major changes treated as new work</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 5 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  5. Delivery
                </h2>
                <p>
                  Timelines are estimates and may vary. Delays due to client response or missing materials are not my responsibility.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 6 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  6. Client Responsibilities
                </h2>
                <ul class="space-y-2">
                  <li>• Provide clear instructions</li>
                  <li>• Share required materials</li>
                  <li>• Ensure rights to provided content</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 7 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  7. Intellectual Property
                </h2>
                <ul class="space-y-2">
                  <li>• Rights transferred after full payment</li>
                  <li>• Work may be showcased in portfolio</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 8 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  8. Prohibited Use
                </h2>
                <ul class="space-y-2">
                  <li>• Illegal or harmful usage is not allowed</li>
                  <li>• Cannot claim work before rights transfer</li>
                </ul>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 9 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  9. Limitation of Liability
                </h2>
                <p>
                  I am not responsible for indirect or business losses resulting from use of delivered work.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 10 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  10. Termination
                </h2>
                <p>
                  Projects may be cancelled if terms are violated or payments are not completed.
                </p>
              </div>

              <div class="h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

              <!-- 11 -->
              <div class="space-y-3">
                <h2 class="text-xl md:text-2xl font-semibold text-gray-900">
                  11. Changes to Terms
                </h2>
                <p>
                  Terms may be updated anytime. Continued use means acceptance of updated terms.
                </p>
              </div>

              <!-- CONTACT -->
              <div class="pt-8">
                <p class="text-gray-500 text-base sm:text-lg">
                  Questions or concerns?
                </p>
              
                <p class="text-gray-900 font-medium mt-1">
                  {siteConfig.social.email}
                </p>

              </div>

              <!-- CTA -->
              <div class="pt-10 mt-10 border-t border-gray-200">
              
                <p class="text-gray-500 text-base sm:text-lg">
                  Ready to start your project?
                </p>
              
                <div class="mt-4 flex flex-wrap gap-3">
              
                  <a 
                    href="/#contact"
                    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                           text-white text-sm sm:text-base font-medium
                           transition-all duration-300 hover:scale-[1.03]"
                    style={`background-color: ${siteConfig.accentColor}`}
                  >
                    Share your project details
                  </a>
              
                </div>
              
              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

  </body>
</html>
